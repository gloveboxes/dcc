; dccrtl.mac - minimal CP/M-80 runtime for dcc
;
; M80/L80 Z80 assembly.
;
;        org     100h

        extrn   _main
        extrn   __hstart   ; heap start
        extrn   __bssb     ; bss begin
        extrn   __bsse     ; bss end
        extrn   __stack_size ; bytes reserved above heap for C stack
        public  __brk
        public  __hlimit   ; heap limit
        public  start

HDRSIZE          equ     2

        cseg
start:
        call    __build_argv

        ; Initialize heap allocator.
        ; __hlimit = initial SP - __stack_size
        ld      hl,0
        add     hl,sp
        ld      de,__stack_size
        or      a
        sbc     hl,de
        ld      (__hlimit),hl
        ; __brk = __hbase = __hstart (label at end of user module)
        ld      hl,__hstart
        ld      (__hbase),hl
        ld      (__brk),hl

        ; Zero BSS (C89: uninitialized globals must be zero at startup)
        ld      hl,__bsse
        ld      de,__bssb
        or      a
        sbc     hl,de           ; HL = __bsse - __bssb = BSS length
        ld      b,h
        ld      c,l
        ld      a,b
        or      c
        jr      z,bss_done
        ld      hl,__bssb
        ld      (hl),0
        ld      d,h
        ld      e,l
        inc     de
        dec     bc
        ld      a,b
        or      c
        jr      z,bss_done
        ldir
bss_done:

        ld      hl,argv
        push    hl              ; argv
        ld      hl,(__argc)
        push    hl              ; argc
        call    _main
        call    __cpm_set_retcode
        jp      0000h


; ------------------------------------------------------------
; CP/M command-tail argc/argv builder
; ------------------------------------------------------------
; CP/M command tail:
;   0080h = length
;   0081h = text
;
; Builds:
;   argc = 1 + whitespace-delimited command-tail args
;   argv[0] = ""
;   argv[1..] = pointers into __argbuf

        public  __build_argv

__build_argv:
        ld      hl,argv0
        ld      (argv),hl
        ld      hl,1
        ld      (__argc),hl

        ld      a,(80h)
        or      a
        ret     z

        ld      b,a
        ld      hl,81h
        ld      de,__argbuf

ba_copy:
        ld      a,b
        or      a
        jr      z,ba_done_copy
        ld      a,(hl)
        cp      0dh
        jr      z,ba_done_copy
        ld      (de),a
        inc     hl
        inc     de
        dec     b
        jr      ba_copy

ba_done_copy:
        xor     a
        ld      (de),a

        ld      hl,__argbuf
        ld      de,argv+2
        ld      c,1

ba_skip_spaces:
        ld      a,(hl)
        or      a
        jr      z,ba_finish
        cp      ' '
        jr      nz,ba_arg_start
        inc     hl
        jr      ba_skip_spaces

ba_arg_start:
        ld      a,l
        ld      (de),a
        inc     de
        ld      a,h
        ld      (de),a
        inc     de
        inc     c

ba_scan_arg:
        ld      a,(hl)
        or      a
        jr      z,ba_finish
        cp      ' '
        jr      z,ba_end_arg
        inc     hl
        jr      ba_scan_arg

ba_end_arg:
        xor     a
        ld      (hl),a
        inc     hl
        jr      ba_skip_spaces

ba_finish:
        ld      h,0
        ld      l,c
        ld      (__argc),hl
        ret

__argc:
        dw      0

argv0:
        db      0

argv:
        ds      34

__argbuf:
        ds      128

; __conout: output char in E to console with LF->CR/LF translation.
; Preserves all registers except F.
__conout:
        ld      a,e
        cp      0ah             ; LF?
        jr      nz,__conout_raw
        push    de
        ld      e,0dh           ; emit CR first
        ld      c,2
        call    5
        pop     de              ; restore original E (=0Ah)
__conout_raw:
        ld      c,2
        call    5
        ret

        public  _putchar
_putchar:
        push    ix
        ld      ix,0
        add     ix,sp
        ld      e,(ix+4)
        call    __conout
        ld      h,0
        ld      l,e
        pop     ix
        ret

        public  _fputc
_fputc:
        push    ix
        ld      ix,0
        add     ix,sp

        ; int fputc(int c, FILE *fp)
        ; fp values 0/1/2 are stdin/stdout/stderr pseudo FILEs in this RTL.
        ld      a,(ix+6)        ; low byte of fp/fd
        cp      1
        jr      z,fputc_con
        cp      2
        jr      z,fputc_con

        ; file path: store char in a one-byte buffer and call _write(fp,&ch,1)
        ld      a,(ix+4)
        ld      (__fputc_ch),a

        ld      hl,1
        push    hl              ; count
        ld      hl,__fputc_ch
        push    hl              ; buf
        ld      l,(ix+6)
        ld      h,(ix+7)
        push    hl              ; fp
        call    _write

        ; clean 3 args while preserving _write return in HL
        ex      de,hl
        ld      hl,6
        add     hl,sp
        ld      sp,hl
        ex      de,hl

        ; success iff _write returned 1 byte
        ld      a,h
        or      a
        jr      nz,fputc_bad
        ld      a,l
        cp      1
        jr      nz,fputc_bad

        ld      h,0
        ld      l,(ix+4)        ; return written character
        pop     ix
        ret

fputc_con:
        ld      e,(ix+4)
        call    __conout
        ld      h,0
        ld      l,(ix+4)
        pop     ix
        ret

fputc_bad:
        ld      hl,0ffffh       ; EOF
        pop     ix
        ret

__fputc_ch:
        db      0

        public  _clearerr
_clearerr:
        ; void clearerr(FILE *fp)
        ; This simple RTL keeps no per-FILE error/eof flags.
        ld      hl,0
        ret

        public  _setbuf
_setbuf:
        ; void setbuf(FILE *fp, char *buf)
        ; Unbuffered/stubbed: all current I/O goes through direct CP/M calls.
        ld      hl,0
        ret

        public  _strerror
_strerror:
        ; char *strerror(int errnum)
        ; Minimal fallback for programs that only need a printable message.
        ld      hl,__strerror_msg
        ret

__strerror_msg:
        db      'Error',0


        public  _putc
_putc:
        ; int putc(int c, FILE *fp) -- same calling convention as fputc
        jp      _fputc

        public  _getc
_getc:
        ; int getc(FILE *fp)
        push    ix
        ld      ix,0
        add     ix,sp

        ld      hl,1
        push    hl              ; count
        ld      hl,__getc_ch
        push    hl              ; buf
        ld      l,(ix+4)
        ld      h,(ix+5)
        push    hl              ; fp/fd
        call    _read
        ex      de,hl
        ld      hl,6
        add     hl,sp
        ld      sp,hl
        ex      de,hl

        ; success iff _read returned 1
        ld      a,h
        or      a
        jr      nz,getc_bad
        ld      a,l
        cp      1
        jr      nz,getc_bad

        ld      h,0
        ld      a,(__getc_ch)
        ld      l,a
        pop     ix
        ret

getc_bad:
        ld      hl,0ffffh       ; EOF
        pop     ix
        ret

__getc_ch:
        db      0

        public  _remove
_remove:
        ; int remove(const char *path)
        jp      _unlink

        public  _getchar
_getchar:
        ld      c,1
        call    5
        ld      h,0
        ld      l,a
        ret



; bdos(fn, dearg)
; Call CP/M BDOS directly.
;
; C prototype:
;     extern int bdos(int fn, int dearg);
;
; Arguments:
;     fn    -> BDOS function number, placed in C
;     dearg -> 16-bit argument pointer/value, placed in DE
;
; Return:
;     low-byte BDOS result A, returned as int in HL.
;     This matches CP/M 2.2 BDOS functions that return a byte value.
;     Functions whose useful result is written through DE, such as FCB/DMA
;     operations, should read that memory after the call.
        public  _bdos
_bdos:
        push    ix
        ld      ix,0
        add     ix,sp
        ld      c,(ix+4)        ; function number
        ld      e,(ix+6)        ; DE argument
        ld      d,(ix+7)
        call    5
        ld      l,a
        ld      h,0
        pop     ix
        ret


        public  _strlen
_strlen:
        push    ix
        ld      ix,0
        add     ix,sp
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      de,0
sl1:
        ld      a,(hl)
        or      a
        jr      z,sl2
        inc     hl
        inc     de
        jr      sl1
sl2:
        ex      de,hl
        pop     ix
        ret

        public  _strcpy
_strcpy:
        push    ix
        ld      ix,0
        add     ix,sp
        ld      e,(ix+4)
        ld      d,(ix+5)
        ld      l,(ix+6)
        ld      h,(ix+7)
        push    de
sc1:
        ld      a,(hl)
        ld      (de),a
        inc     hl
        inc     de
        or      a
        jr      nz,sc1
        pop     hl
        pop     ix
        ret

        public  _strcmp
_strcmp:
        push    ix
        ld      ix,0
        add     ix,sp
        ld      e,(ix+4)
        ld      d,(ix+5)
        ld      l,(ix+6)
        ld      h,(ix+7)
sp1:
        ld      a,(de)
        cp      (hl)
        jr      nz,sp2
        or      a
        jr      z,sp3
        inc     de
        inc     hl
        jr      sp1
sp2:
        ld      c,a
        ld      a,(hl)
        ld      b,a
        ld      a,c
        sub     b
        ld      l,a
        ld      h,0
        jr      nc,sp4
        ld      h,0ffh
sp4:
        pop     ix
        ret

sp3:
        ld      hl,0
        pop     ix
        ret

        public  _strrchr
_strrchr:
        ; char *strrchr(const char *s, int c)
        push    ix
        ld      ix,0
        add     ix,sp
        ld      l,(ix+4)
        ld      h,(ix+5)        ; HL = scan pointer
        ld      c,(ix+6)        ; C = target char
        ld      de,0            ; DE = last match / NULL
src_loop:
        ld      a,(hl)
        cp      c
        jr      nz,src_no_match
        ld      e,l
        ld      d,h
src_no_match:
        ld      a,(hl)
        or      a
        jr      z,src_done
        inc     hl
        jr      src_loop
src_done:
        ex      de,hl           ; return last match
        pop     ix
        ret

        public  _memcmp
_memcmp:
        ; int memcmp(const void *s1, const void *s2, size_t n)
        push    ix
        ld      ix,0
        add     ix,sp
        ld      l,(ix+4)
        ld      h,(ix+5)        ; HL = s1
        ld      e,(ix+6)
        ld      d,(ix+7)        ; DE = s2
        ld      c,(ix+8)
        ld      b,(ix+9)        ; BC = n
mcmp_loop:
        ld      a,b
        or      c
        jr      z,mcmp_eq
        ld      a,(de)
        push    bc
        ld      b,a             ; B = *s2
        ld      a,(hl)          ; A = *s1
        cp      b
        jr      nz,mcmp_diff
        pop     bc
        inc     hl
        inc     de
        dec     bc
        jr      mcmp_loop
mcmp_diff:
        ; A still has s1 byte, B has s2 byte. Return signed byte difference.
        sub     b
        ld      l,a
        ld      h,0
        jr      nc,mcmp_diff_done
        ld      h,0ffh
mcmp_diff_done:
        pop     bc
        pop     ix
        ret
mcmp_eq:
        ld      hl,0
        pop     ix
        ret

        public  _memmove
_memmove:
        ; void *memmove(void *dst, const void *src, size_t n)
        push    ix
        ld      ix,0
        add     ix,sp

        ; if n == 0, done
        ld      c,(ix+8)
        ld      b,(ix+9)
        ld      a,b
        or      c
        jr      z,mmv_ret_dst

        ; if dst == src, done
        ld      a,(ix+4)
        cp      (ix+6)
        jr      nz,mmv_cmp
        ld      a,(ix+5)
        cp      (ix+7)
        jr      z,mmv_ret_dst

mmv_cmp:
        ; Compare dst - src unsigned. If dst < src, copy forward.
        ld      l,(ix+4)
        ld      h,(ix+5)        ; HL = dst
        ld      e,(ix+6)
        ld      d,(ix+7)        ; DE = src
        or      a
        sbc     hl,de
        jr      c,mmv_do_forward

        ; Backward copy: HL = src+n, DE = dst+n, BC = n.
        ld      l,(ix+6)
        ld      h,(ix+7)        ; HL = src
        ld      c,(ix+8)
        ld      b,(ix+9)
        add     hl,bc           ; HL = src+n
        ld      e,(ix+4)
        ld      d,(ix+5)        ; DE = dst
        ex      de,hl           ; HL = dst, DE = src+n
        add     hl,bc           ; HL = dst+n
        ex      de,hl           ; HL = src+n, DE = dst+n
mmv_back_loop:
        ld      a,b
        or      c
        jr      z,mmv_ret_dst
        dec     hl
        dec     de
        ld      a,(hl)
        ld      (de),a
        dec     bc
        jr      mmv_back_loop

mmv_do_forward:
        ; Forward copy: HL = src, DE = dst, BC = n.
        ld      l,(ix+6)
        ld      h,(ix+7)
        ld      e,(ix+4)
        ld      d,(ix+5)
        ld      c,(ix+8)
        ld      b,(ix+9)
        ldir

mmv_ret_dst:
        ld      l,(ix+4)
        ld      h,(ix+5)
        pop     ix
        ret

        public  _strncat
_strncat:
        ; char *strncat(char *dst, const char *src, size_t n)
        push    ix
        ld      ix,0
        add     ix,sp
        ld      e,(ix+4)
        ld      d,(ix+5)        ; DE = dst
        ld      l,(ix+6)
        ld      h,(ix+7)        ; HL = src
        ld      c,(ix+8)
        ld      b,(ix+9)        ; BC = n
        push    de              ; return dst

        ; find terminating NUL in dst, leaving DE at append position
snc_find_end:
        ld      a,(de)
        or      a
        jr      z,snc_copy
        inc     de
        jr      snc_find_end

snc_copy:
        ld      a,b
        or      c
        jr      z,snc_term
        ld      a,(hl)
        or      a
        jr      z,snc_term
        ld      (de),a
        inc     hl
        inc     de
        dec     bc
        jr      snc_copy

snc_term:
        xor     a
        ld      (de),a
        pop     hl              ; return dst
        pop     ix
        ret

        public  _memcpy
_memcpy:
        push    ix
        ld      ix,0
        add     ix,sp
        ld      e,(ix+4)
        ld      d,(ix+5)
        ld      l,(ix+6)
        ld      h,(ix+7)
        ld      c,(ix+8)
        ld      b,(ix+9)
        push    de
mc1:
        ld      a,b
        or      c
        jr      z,mc2
        ld      a,(hl)
        ld      (de),a
        inc     hl
        inc     de
        dec     bc
        jr      mc1
mc2:
        pop     hl
        pop     ix
        ret

        public  _memset
_memset:
        ; void *memset(void *dest, int c, int count)
        ; Uses Z80 LDIR block-fill: write first byte, then LDIR propagates it.
        push    ix
        ld      ix,0
        add     ix,sp
        ld      l,(ix+4)
        ld      h,(ix+5)        ; HL = dest
        ld      c,(ix+8)
        ld      b,(ix+9)        ; BC = count
        push    hl              ; save dest for return value
        ld      a,b
        or      c
        jr      z,ms_done       ; count == 0, nothing to do
        ld      a,(ix+6)        ; fill byte
        ld      (hl),a          ; write first byte
        dec     bc
        ld      a,b
        or      c
        jr      z,ms_done       ; count was 1, done
        ld      d,h
        ld      e,l
        inc     de              ; DE = dest+1, HL = dest (contains fill byte)
        ldir                    ; copy (HL)->(DE) BC times, each step propagates fill
ms_done:
        pop     hl              ; HL = dest (return value)
        ld      sp,ix
        pop     ix
        ret


; Indirect call helper.
; Input HL = target address. Returns whatever callee returns in HL.
        public  __call_hl
__call_hl:
        jp      (hl)

        public  __mulu
__mulu:
        push    bc
        push    af
        ld      b,16
        ld      c,l
        ld      a,h
        ld      hl,0
mu1:
        srl     a
        rr      c
        jr      nc,mu2
        add     hl,de
mu2:
        ex      de,hl
        add     hl,hl
        ex      de,hl
        djnz    mu1
        pop     af
        pop     bc
        ret

        public  __divmodu_slow
__divmodu_slow:
        push    bc
        push    af
        ld      a,d
        or      e
        jr      nz,dms0
        ld      d,h
        ld      e,l
        ld      hl,0ffffh
        jr      dms_done
dms0:
        ld      bc,0
        push    de
        ex      de,hl
dms1:
        pop     hl
        push    hl
        ld      a,e
        sub     l
        ld      a,d
        sbc     a,h
        jr      c,dms2
        ld      a,e
        sub     l
        ld      e,a
        ld      a,d
        sbc     a,h
        ld      d,a
        inc     bc
        jr      dms1
dms2:
        pop     hl
        ld      h,b
        ld      l,c
dms_done:
        pop     af
        pop     bc
        ret

        public  __divu
__divu:
        ; Faster cache-aware unsigned divide.
        ; Input:  HL = dividend, DE = divisor
        ; Output: HL = quotient
        ;
        ; Fast hit path compares the live operands directly against the
        ; cached operands.  This avoids storing scratch operands on every
        ; div/mod pair hit.
        ld      a,(__dmval)
        or      a
        jr      z,du_miss_save

        push    hl              ; save dividend
        or      a
        ld      hl,(__dmc_rhs)
        sbc     hl,de
        jr      nz,du_rhs_bad

        pop     hl              ; restore dividend
        push    de              ; save divisor
        push    hl              ; save original dividend so miss has correct HL
        ld      de,(__dmc_lhs)
        or      a
        sbc     hl,de           ; compare only; result discarded on both paths
        pop     hl              ; restore original dividend (hit or miss)
        pop     de              ; restore divisor
        jr      nz,du_miss_save

        ld      hl,(__dmquot)
        ret

du_rhs_bad:
        pop     hl              ; restore dividend

du_miss_save:
        ld      (__dmc_lhs),hl
        ex      de,hl
        ld      (__dmc_rhs),hl
        ex      de,hl

        call    __divmodu_slow        ; HL = quotient, DE = remainder

        ld      (__dmquot),hl
        ex      de,hl
        ld      (__dmrem),hl
        ld      a,1
        ld      (__dmval),a
        ld      hl,(__dmquot)
        ret

        public  __modu
__modu:
        ; Cache-aware unsigned modulo.  Same cache as __divu, so x%n then x/n
        ; (or x/n then x%n) with identical operands calls __divmodu_slow once.
        ; Input:  HL = dividend, DE = divisor
        ; Output: HL = remainder
        ld      a,(__dmval)
        or      a
        jr      z,dm_miss       ; cache empty
        push    de              ; [SP: divisor]
        push    hl              ; [SP: dividend, divisor]
        ; Check rhs (divisor)
        or      a
        ld      hl,(__dmc_rhs)
        sbc     hl,de
        jr      nz,dm_both_pop  ; rhs mismatch
        ; rhs matches â€” check lhs (dividend)
        pop     hl              ; restore dividend  [SP: divisor]
        push    hl              ; re-save           [SP: dividend, divisor]
        ld      de,(__dmc_lhs)
        or      a
        sbc     hl,de           ; HL = dividend - cached_lhs (HL corrupted)
        jr      nz,dm_both_pop  ; lhs mismatch
        ; cache hit
        pop     hl              ; discard saved dividend [SP: divisor]
        pop     de              ; restore divisor
        ld      hl,(__dmrem)
        ret
dm_both_pop:
        pop     hl              ; restore dividend
        pop     de              ; restore divisor
dm_miss:
        ld      (__dmc_lhs),hl
        ex      de,hl
        ld      (__dmc_rhs),hl
        ex      de,hl
        call    __divmodu_slow  ; HL = quotient, DE = remainder
        ld      (__dmquot),hl
        ex      de,hl
        ld      (__dmrem),hl    ; HL = remainder
        ld      a,1
        ld      (__dmval),a
        ret


; Signed 16-bit division/modulo wrappers.
; Input:  HL = signed dividend, DE = signed divisor
; Output: HL = quotient (__divs) or remainder (__mods)
; Semantics: quotient truncates toward zero; remainder has dividend sign.
        public  __divs
__divs:
        ; Fast path: if both operands are non-negative, signed division is
        ; identical to unsigned division.  This avoids the sign-wrapper
        ; overhead in hot loops such as e.c where int values stay >= 0.
        ld      a,h
        or      d
        jp      p,__divu
        push    bc
        ld      b,0             ; bit0: quotient negative?
        ld      a,h
        or      a
        jp      p,__ds_lpos
        ld      a,b
        xor     1
        ld      b,a
        xor     a
        sub     l
        ld      l,a
        ld      a,0
        sbc     a,h
        ld      h,a
__ds_lpos:
        ld      a,d
        or      a
        jp      p,__ds_rpos
        ld      a,b
        xor     1
        ld      b,a
        ex      de,hl
        xor     a
        sub     l
        ld      l,a
        ld      a,0
        sbc     a,h
        ld      h,a
        ex      de,hl
__ds_rpos:
        call    __divu
        ld      a,b
        or      a
        jp      z,__ds_done
        xor     a
        sub     l
        ld      l,a
        ld      a,0
        sbc     a,h
        ld      h,a
__ds_done:
        pop     bc
        ret

        public  __mods
__mods:
        ; Fast path: if both operands are non-negative, signed modulo is
        ; identical to unsigned modulo.  Jump directly so cache pairing with
        ; __divu/__modu still works.
        ld      a,h
        or      d
        jp      p,__modu
        push    bc
        ld      b,0             ; bit0: remainder negative? dividend sign only
        ld      a,h
        or      a
        jp      p,__ms_lpos
        ld      b,1
        xor     a
        sub     l
        ld      l,a
        ld      a,0
        sbc     a,h
        ld      h,a
__ms_lpos:
        ld      a,d
        or      a
        jp      p,__ms_rpos
        ex      de,hl
        xor     a
        sub     l
        ld      l,a
        ld      a,0
        sbc     a,h
        ld      h,a
        ex      de,hl
__ms_rpos:
        call    __modu
        ld      a,b
        or      a
        jp      z,__ms_done
        xor     a
        sub     l
        ld      l,a
        ld      a,0
        sbc     a,h
        ld      h,a
__ms_done:
        pop     bc
        ret

        public  _printf
_printf:
        push    ix
        ld      ix,0
        add     ix,sp
        push    bc
        push    de
        ld      hl,0
        ld      (pf_sink),hl            ; console mode
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      de,6
        ld      bc,0
        call    __pf_run
        ld      h,b
        ld      l,c
        pop     de
        pop     bc
        pop     ix
        ret

; __pf_run: shared printf body.
; IN:  HL=fmt, DE=vararg offset from IX, BC=0, pf_sink set.
; IX must point to the caller's stack frame throughout.
; OUT: BC = character count.
__pf_run:
pf_loop:
        ld      a,(hl)
        or      a
        jp      z,pf_done
        inc     hl
        cp      '%'
        jp      z,pf_percent
        call    pf_emit_a
        jp      pf_loop

pf_percent:
        xor     a
        ld      (pf_width),a
        ld      (pf_prec),a

pf_pct_next:
        ld      a,(hl)
        or      a
        jp      z,pf_done
        inc     hl

        cp      '%'
        jp      z,pf_emit_and_loop

        cp      '.'
        jp      z,pf_pct_dot

        ; C99 size_t length modifier.  In dcc, size_t is 16-bit, so
        ; %zu/%zd/%zi/%zx/%zX use the ordinary 16-bit integer handlers.
        cp      'z'
        jp      z,pf_pct_z

        ; Decimal field width: %2d / %3u / %8s etc.
        cp      '0'
        jp      c,pf_pct_done_width
        cp      '9'+1
        jp      nc,pf_pct_done_width

        sub     '0'
        ld      (pf_digit),a
        push    de              ; DE is the vararg byte offset; preserve it.
        ld      a,(pf_width)
        add     a,a             ; 2*w
        ld      e,a
        add     a,a             ; 4*w
        add     a,a             ; 8*w
        add     a,e             ; 10*w
        ld      e,a
        ld      a,(pf_digit)
        add     a,e
        ld      (pf_width),a
        pop     de
        jp      pf_pct_next

pf_pct_dot:
        ; Parse digits after '.' into pf_prec (e.g. %.4d → prec=4).
        ; '.' was already consumed by inc hl in pf_pct_next.
pf_pct_prec_loop:
        ld      a,(hl)
        or      a
        jp      z,pf_done
        cp      '0'
        jp      c,pf_pct_prec_done
        cp      '9'+1
        jp      nc,pf_pct_prec_done
        inc     hl
        sub     '0'
        ld      (pf_digit),a
        push    de
        ld      a,(pf_prec)
        add     a,a             ; 2*p
        ld      e,a
        add     a,a             ; 4*p
        add     a,a             ; 8*p
        add     a,e             ; 10*p
        ld      e,a
        ld      a,(pf_digit)
        add     a,e
        ld      (pf_prec),a
        pop     de
        jr      pf_pct_prec_loop
pf_pct_prec_done:
        ; A = format specifier char, HL points to it (not yet consumed)
        inc     hl
        jp      pf_pct_done_width

pf_pct_z:
        ld      a,(hl)
        or      a
        jp      z,pf_done
        inc     hl
        ; fall through into dispatch with A = conversion char after 'z'

pf_pct_done_width:
        cp      'c'
        jp      z,pf_c
        cp      's'
        jp      z,pf_s
        cp      'u'
        jp      z,pf_u
        cp      'd'
        jp      z,pf_d
        cp      'i'
        jp      z,pf_d
        cp      'x'
        jp      z,pf_x
        cp      'X'
        jp      z,pf_x
        cp      'l'
        jp      z,pf_l

pf_emit_and_loop:
        call    pf_emit_a
        jp      pf_loop

pf_arg_hl:
        push    ix
        pop     hl
        add     hl,de
        ld      a,(hl)
        inc     hl
        ld      h,(hl)
        ld      l,a
        inc     de
        inc     de
        ret

; Emit (pf_width - A) spaces, if positive.  A is content length.
pf_pad_a:
        push    af
        ld      a,(pf_width)
        ld      e,a
        pop     af
        ld      d,a
        ld      a,e
        sub     d
        ret     c
        ret     z
        ld      d,a
pf_pad_loop:
        ld      a,' '
        call    pf_emit_a
        dec     d
        jr      nz,pf_pad_loop
        ret

pf_c:
        push    hl
        call    pf_arg_hl
        push    de
        ld      a,1
        call    pf_pad_a
        ld      a,l
        call    pf_emit_a
        pop     de
        pop     hl
        jp      pf_loop

pf_s:
        push    hl
        call    pf_arg_hl
        push    de
        push    hl
        call    pf_strlen_hl       ; A = strlen(HL), HL preserved by stack below
        call    pf_pad_a
        pop     hl
pf_s_loop:
        ld      a,(hl)
        or      a
        jr      z,pf_s_done
        inc     hl
        call    pf_emit_a
        jr      pf_s_loop
pf_s_done:
        pop     de
        pop     hl
        jp      pf_loop

pf_u:
        push    hl
        call    pf_arg_hl
        push    de
        push    hl
        call    pf_count_u_digits  ; A = digit count, HL destroyed
        call    pf_pad_a
        pop     hl
        call    pf_print_u
        pop     de
        pop     hl
        jp      pf_loop

pf_d:
        push    hl
        call    pf_arg_hl
        push    de

        ; Compute display width first: digit count (saved) plus sign if negative.
        push    hl
        bit     7,h
        jr      z,pf_d_count_pos
        xor     a
        sub     l
        ld      l,a
        ld      a,0
        sbc     a,h
        ld      h,a
        call    pf_count_u_digits
        ld      (pf_digit),a    ; save digit count of |value|
        inc     a               ; +1 for '-'
        jr      pf_d_count_done
pf_d_count_pos:
        call    pf_count_u_digits
        ld      (pf_digit),a    ; save digit count
pf_d_count_done:
        call    pf_pad_a
        pop     hl

        ; Print sign and negate if negative
        bit     7,h
        jr      z,pf_d_pos
        ld      a,'-'
        call    pf_emit_a
        xor     a
        sub     l
        ld      l,a
        ld      a,0
        sbc     a,h
        ld      h,a
pf_d_pos:
        ; Zero-fill for precision: print (prec - digit_count) leading zeros
        ld      a,(pf_prec)
        or      a
        jr      z,pf_d_print    ; prec=0: no zero-fill
        ld      d,a             ; D = prec (DE preserved across pf_emit_a)
        ld      a,(pf_digit)
        sub     d               ; A = digit_count - prec
        jr      nc,pf_d_print   ; digit_count >= prec: no fill
        neg                     ; A = prec - digit_count (zeros needed)
        ld      d,a
pf_d_zero_loop:
        ld      a,'0'
        call    pf_emit_a       ; push de/pop de preserves D
        dec     d
        jr      nz,pf_d_zero_loop
pf_d_print:
        call    pf_print_u
        pop     de
        pop     hl
        jp      pf_loop

pf_x:
        push    hl
        call    pf_arg_hl
        push    de
        ld      a,4
        call    pf_pad_a
        call    pf_print_x
        pop     de
        pop     hl
        jp      pf_loop

pf_l:
        ; 'l' length modifier: read next char for ld/lu/lx/ls
        ld      a,(hl)
        inc     hl
        cp      'd'
        jp      z,pf_ld
        cp      'u'
        jp      z,pf_lu
        cp      'x'
        jp      z,pf_lx
        cp      's'
        jp      z,pf_ls
        call    pf_emit_a
        jp      pf_loop

pf_ls:
        ; wchar_t * string.  DCC wchar_t is 16-bit for L"..." literals.
        ; Print the low byte as ASCII and ignore the high byte.
        push    hl
        call    pf_arg_hl
        push    de
        push    hl
        call    pf_wstrlen_hl      ; A = wide string length, HL preserved by stack
        call    pf_pad_a
        pop     hl
pf_ls_loop:
        ld      a,(hl)
        inc     hl
        ld      e,a                ; save low byte
        ld      a,(hl)
        inc     hl                 ; skip high byte
        or      e
        jr      z,pf_ls_done
        ld      a,e
        call    pf_emit_a
        jr      pf_ls_loop
pf_ls_done:
        pop     de
        pop     hl
        jp      pf_loop

pf_wstrlen_hl:
        push    hl
        ld      c,0
pf_wstrlen_loop:
        ld      a,(hl)
        inc     hl
        ld      e,a
        ld      a,(hl)
        inc     hl
        or      e
        jr      z,pf_wstrlen_done
        inc     c
        jr      pf_wstrlen_loop
pf_wstrlen_done:
        ld      a,c
        pop     hl
        ret

pf_ld:
        ; Signed 32-bit decimal
        push    hl
        call    pf_arg_dehl     ; loads __pf32_l/__pf32_h, advances DE by 4
        push    de
        ld      hl,(__pf32_h)
        bit     7,h
        jr      z,pf_ld_pos
        ; Negative: negate, then print with '-'
        call    pf_neg32
        call    pf_count_u32_digits
        inc     a               ; +1 for '-'
        call    pf_pad_a
        ld      a,'-'
        call    pf_emit_a
        jr      pf_ld_print
pf_ld_pos:
        call    pf_count_u32_digits
        call    pf_pad_a
pf_ld_print:
        call    pf_print_u32
        pop     de
        pop     hl
        jp      pf_loop

pf_lu:
        ; Unsigned 32-bit decimal
        push    hl
        call    pf_arg_dehl
        push    de
        call    pf_count_u32_digits
        call    pf_pad_a
        call    pf_print_u32
        pop     de
        pop     hl
        jp      pf_loop

pf_lx:
        ; Unsigned 32-bit hex (%lx): 8 hex digits, high word first
        push    hl
        call    pf_arg_dehl     ; loads __pf32_l/__pf32_h, advances DE by 4
        push    de
        ld      hl,(__pf32_h)
        call    pf_print_x      ; high word (4 hex digits)
        ld      hl,(__pf32_l)
        call    pf_print_x      ; low word (4 hex digits)
        pop     de
        pop     hl
        jp      pf_loop

pf_done:
        ret                     ; count in BC; caller cleans up

pf_emit_a:
        push    hl
        push    de
        push    bc
        ld      e,a
        ld      hl,(pf_sink)
        ld      a,h
        or      l
        jr      z,pfe_con       ; pf_sink=0 → console
pfe_buf:
        ld      hl,(pf_bufptr)
        ld      (hl),e
        inc     hl
        ld      (pf_bufptr),hl
        pop     bc
        pop     de
        pop     hl
        inc     bc
        ret
pfe_con:
        call    __conout
        pop     bc
        pop     de
        pop     hl
        inc     bc
        ret

pf_strlen_hl:
        push    hl
        push    bc
        ld      bc,0
pfsl1:
        ld      a,(hl)
        or      a
        jr      z,pfsl2
        inc     hl
        inc     bc
        jr      pfsl1
pfsl2:
        ld      a,c              ; low byte is enough for current tests
        pop     bc
        pop     hl
        ret

pf_count_u_digits:
        push    bc
        ld      bc,0
        ld      a,h
        or      l
        jr      nz,pfcud1
        ld      a,1
        pop     bc
        ret
pfcud1:
        inc     c
        ld      de,10
        call    __divmodu_slow   ; HL = quotient, DE = remainder
        ld      a,h
        or      l
        jr      nz,pfcud1
        ld      a,c
        pop     bc
        ret

pf_print_u:
        push    ix
        ld      ix,pf_decbuf+6
        ld      (ix+0),0
        ld      a,h
        or      l
        jr      nz,pfu1
        ld      a,'0'
        call    pf_emit_a
        pop     ix
        ret
pfu1:
        dec     ix
        ld      de,10
        call    __divmodu_slow
        ld      a,e
        add     a,'0'
        ld      (ix+0),a
        ld      a,h
        or      l
        jr      nz,pfu1
pfu2:
        ld      a,(ix+0)
        or      a
        jr      z,pfu3
        call    pf_emit_a
        inc     ix
        jr      pfu2
pfu3:
        pop     ix
        ret

pf_print_x:
        ld      a,h
        call    pf_hex_byte
        ld      a,l
        call    pf_hex_byte
        ret
pf_hex_byte:
        push    af
        rrca
        rrca
        rrca
        rrca
        call    pf_hex_nib
        pop     af
pf_hex_nib:
        and     0fh
        add     a,'0'
        cp      '9'+1
        jr      c,pfh1
        add     a,7
pfh1:
        call    pf_emit_a
        ret

pf_width:
        db      0
pf_digit:
        db      0
pf_prec:
        db      0

pf_decbuf:
        ds      7

pf_decbuf32:
        ds      11

; pf_arg_dehl: read 4-byte vararg into __pf32_l/__pf32_h, advance DE by 4
pf_arg_dehl:
        push    de              ; save vararg offset
        push    ix
        pop     hl              ; HL = IX (frame base)
        add     hl,de           ; HL = IX + DE
        ld      a,(hl)
        inc     hl
        ld      b,(hl)          ; B:A = low word bytes (A=low, B=high)
        inc     hl
        ld      c,(hl)
        inc     hl
        ld      e,(hl)          ; E:C = high word bytes (C=low, E=high)
        ld      l,a
        ld      h,b
        ld      (__pf32_l),hl
        ld      l,c
        ld      h,e
        ld      (__pf32_h),hl
        pop     de              ; restore vararg offset
        inc     de
        inc     de
        inc     de
        inc     de
        ret

; pf_neg32: negate __pf32_l/__pf32_h (two's complement)
pf_neg32:
        ld      de,(__pf32_l)
        ld      hl,0
        or      a
        sbc     hl,de
        ld      (__pf32_l),hl
        ld      de,(__pf32_h)
        ld      hl,0
        sbc     hl,de
        ld      (__pf32_h),hl
        ret

; pf_divu32_10: divide __pf32_l/__pf32_h by 10
; Output: __pf32_l/__pf32_h = quotient, A = remainder (0-9)
pf_divu32_10:
        push    bc
        push    de
        push    hl
        ld      hl,0
        ld      (__pf32_rem_l),hl
        ld      (__pf32_rem_h),hl
        ld      (__pf32_quo_l),hl
        ld      (__pf32_quo_h),hl
        ld      b,32
pf32d_loop:
        ; Shift {rem:pf32} left 1 (64-bit)
        ld      hl,(__pf32_l)
        or      a
        add     hl,hl
        ld      (__pf32_l),hl
        ld      hl,(__pf32_h)
        adc     hl,hl
        ld      (__pf32_h),hl
        ld      hl,(__pf32_rem_l)
        adc     hl,hl
        ld      (__pf32_rem_l),hl
        ld      hl,(__pf32_rem_h)
        adc     hl,hl
        ld      (__pf32_rem_h),hl
        ; rem < 20, so rem_h = 0; compare rem_l with 10
        ld      hl,(__pf32_rem_l)
        ld      a,l
        cp      10
        jr      c,pf32d_no_sub
        ; rem >= 10
        sub     10
        ld      l,a
        ld      h,0
        ld      (__pf32_rem_l),hl
        ; quotient <<= 1, set bit 0
        ld      hl,(__pf32_quo_l)
        or      a
        add     hl,hl
        inc     l
        ld      (__pf32_quo_l),hl
        ld      hl,(__pf32_quo_h)
        adc     hl,hl
        ld      (__pf32_quo_h),hl
        jr      pf32d_next
pf32d_no_sub:
        ld      hl,(__pf32_quo_l)
        or      a
        add     hl,hl
        ld      (__pf32_quo_l),hl
        ld      hl,(__pf32_quo_h)
        adc     hl,hl
        ld      (__pf32_quo_h),hl
pf32d_next:
        djnz    pf32d_loop
        ld      hl,(__pf32_quo_l)
        ld      (__pf32_l),hl
        ld      hl,(__pf32_quo_h)
        ld      (__pf32_h),hl
        ld      hl,(__pf32_rem_l)
        ld      a,l             ; remainder 0-9
        pop     hl
        pop     de
        pop     bc
        ret

; pf_count_u32_digits: count decimal digits of __pf32_l/__pf32_h; A = count
pf_count_u32_digits:
        push    bc
        push    de
        push    hl
        ld      hl,(__pf32_h)
        ld      a,h
        or      l
        ld      hl,(__pf32_l)
        or      h
        or      l
        jr      nz,pfcud32_start
        ld      a,1
        pop     hl
        pop     de
        pop     bc
        ret
pfcud32_start:
        ; Save __pf32
        ld      (__pf32_save_l),hl
        ld      hl,(__pf32_h)
        ld      (__pf32_save_h),hl
        ld      c,0
pfcud32_loop:
        inc     c
        call    pf_divu32_10
        ld      hl,(__pf32_h)
        ld      a,h
        or      l
        ld      hl,(__pf32_l)
        or      h
        or      l
        jr      nz,pfcud32_loop
        ld      a,c
        ; Restore __pf32
        ld      hl,(__pf32_save_l)
        ld      (__pf32_l),hl
        ld      hl,(__pf32_save_h)
        ld      (__pf32_h),hl
        pop     hl
        pop     de
        pop     bc
        ret

; pf_print_u32: print __pf32_l/__pf32_h as unsigned decimal
pf_print_u32:
        push    ix
        ld      ix,pf_decbuf32+10
        ld      (ix+0),0        ; null terminator
        ld      hl,(__pf32_h)
        ld      a,h
        or      l
        ld      hl,(__pf32_l)
        or      h
        or      l
        jr      nz,pfu32_start
        ld      a,'0'
        call    pf_emit_a
        pop     ix
        ret
pfu32_start:
        dec     ix
        call    pf_divu32_10    ; A = remainder digit
        add     a,'0'
        ld      (ix+0),a
        ld      hl,(__pf32_h)
        ld      a,h
        or      l
        ld      hl,(__pf32_l)
        or      h
        or      l
        jr      nz,pfu32_start
pfu32_emit:
        ld      a,(ix+0)
        or      a
        jr      z,pfu32_done
        call    pf_emit_a
        inc     ix
        jr      pfu32_emit
pfu32_done:
        pop     ix
        ret

__pf32_l:       dw      0
__pf32_h:       dw      0
__pf32_rem_l:   dw      0
__pf32_rem_h:   dw      0
__pf32_quo_l:   dw      0
__pf32_quo_h:   dw      0
__pf32_save_l:  dw      0
__pf32_save_h:  dw      0


; ---- float-enabled printf (-ffloatio) ------------------------------
        public  _pffio
_pffio:
        push    ix
        ld      ix,0
        add     ix,sp
        push    bc
        push    de
        ld      hl,0
        ld      (pf_sink),hl            ; console mode
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      de,6
        ld      bc,0
        call    __qf_run
        ld      h,b
        ld      l,c
        pop     de
        pop     bc
        pop     ix
        ret

; __qf_run: shared printf body.
; IN:  HL=fmt, DE=vararg offset from IX, BC=0, pf_sink set.
; IX must point to the caller's stack frame throughout.
; OUT: BC = character count.
__qf_run:
qf_loop:
        ld      a,(hl)
        or      a
        jp      z,qf_done
        inc     hl
        cp      '%'
        jp      z,qf_percent
        call    qf_emit_a
        jp      qf_loop

qf_percent:
        xor     a
        ld      (qf_width),a
        ld      (qf_prec),a

qf_pct_next:
        ld      a,(hl)
        or      a
        jp      z,qf_done
        inc     hl

        cp      '%'
        jp      z,qf_emit_and_loop

        cp      '.'
        jp      z,qf_pct_dot

        ; C99 size_t length modifier.  In dcc, size_t is 16-bit, so
        ; %zu/%zd/%zi/%zx/%zX use the ordinary 16-bit integer handlers.
        cp      'z'
        jp      z,qf_pct_z

        ; Decimal field width: %2d / %3u / %8s etc.
        cp      '0'
        jp      c,qf_pct_done_width
        cp      '9'+1
        jp      nc,qf_pct_done_width

        sub     '0'
        ld      (qf_digit),a
        push    de              ; DE is the vararg byte offset; preserve it.
        ld      a,(qf_width)
        add     a,a             ; 2*w
        ld      e,a
        add     a,a             ; 4*w
        add     a,a             ; 8*w
        add     a,e             ; 10*w
        ld      e,a
        ld      a,(qf_digit)
        add     a,e
        ld      (qf_width),a
        pop     de
        jp      qf_pct_next

qf_pct_dot:
        ; Parse digits after '.' into qf_prec (e.g. %.4d → prec=4).
        ; '.' was already consumed by inc hl in qf_pct_next.
qf_pct_prec_loop:
        ld      a,(hl)
        or      a
        jp      z,qf_done
        cp      '0'
        jp      c,qf_pct_prec_done
        cp      '9'+1
        jp      nc,qf_pct_prec_done
        inc     hl
        sub     '0'
        ld      (qf_digit),a
        push    de
        ld      a,(qf_prec)
        add     a,a             ; 2*p
        ld      e,a
        add     a,a             ; 4*p
        add     a,a             ; 8*p
        add     a,e             ; 10*p
        ld      e,a
        ld      a,(qf_digit)
        add     a,e
        ld      (qf_prec),a
        pop     de
        jr      qf_pct_prec_loop
qf_pct_prec_done:
        ; A = format specifier char, HL points to it (not yet consumed)
        inc     hl
        jp      qf_pct_done_width

qf_pct_z:
        ld      a,(hl)
        or      a
        jp      z,qf_done
        inc     hl
        ; fall through into dispatch with A = conversion char after 'z'

qf_pct_done_width:
        cp      'c'
        jp      z,qf_c
        cp      's'
        jp      z,qf_s
        cp      'u'
        jp      z,qf_u
        cp      'd'
        jp      z,qf_d
        cp      'i'
        jp      z,qf_d
        cp      'x'
        jp      z,qf_x
        cp      'X'
        jp      z,qf_x
        cp      'f'
        jp      z,qf_f
        cp      'l'
        jp      z,qf_l

qf_emit_and_loop:
        call    qf_emit_a
        jp      qf_loop

qf_arg_hl:
        push    ix
        pop     hl
        add     hl,de
        ld      a,(hl)
        inc     hl
        ld      h,(hl)
        ld      l,a
        inc     de
        inc     de
        ret

; Emit (qf_width - A) spaces, if positive.  A is content length.
qf_pad_a:
        push    af
        ld      a,(qf_width)
        ld      e,a
        pop     af
        ld      d,a
        ld      a,e
        sub     d
        ret     c
        ret     z
        ld      d,a
qf_pad_loop:
        ld      a,' '
        call    qf_emit_a
        dec     d
        jr      nz,qf_pad_loop
        ret

qf_c:
        push    hl
        call    qf_arg_hl
        push    de
        ld      a,1
        call    qf_pad_a
        ld      a,l
        call    qf_emit_a
        pop     de
        pop     hl
        jp      qf_loop

qf_s:
        push    hl
        call    qf_arg_hl
        push    de
        push    hl
        call    qf_strlen_hl       ; A = strlen(HL), HL preserved by stack below
        call    qf_pad_a
        pop     hl
qf_s_loop:
        ld      a,(hl)
        or      a
        jr      z,qf_s_done
        inc     hl
        call    qf_emit_a
        jr      qf_s_loop
qf_s_done:
        pop     de
        pop     hl
        jp      qf_loop

qf_u:
        push    hl
        call    qf_arg_hl
        push    de
        push    hl
        call    qf_count_u_digits  ; A = digit count, HL destroyed
        call    qf_pad_a
        pop     hl
        call    qf_print_u
        pop     de
        pop     hl
        jp      qf_loop

qf_d:
        push    hl
        call    qf_arg_hl
        push    de

        ; Compute display width first: digit count (saved) plus sign if negative.
        push    hl
        bit     7,h
        jr      z,qf_d_count_pos
        xor     a
        sub     l
        ld      l,a
        ld      a,0
        sbc     a,h
        ld      h,a
        call    qf_count_u_digits
        ld      (qf_digit),a    ; save digit count of |value|
        inc     a               ; +1 for '-'
        jr      qf_d_count_done
qf_d_count_pos:
        call    qf_count_u_digits
        ld      (qf_digit),a    ; save digit count
qf_d_count_done:
        call    qf_pad_a
        pop     hl

        ; Print sign and negate if negative
        bit     7,h
        jr      z,qf_d_pos
        ld      a,'-'
        call    qf_emit_a
        xor     a
        sub     l
        ld      l,a
        ld      a,0
        sbc     a,h
        ld      h,a
qf_d_pos:
        ; Zero-fill for precision: print (prec - digit_count) leading zeros
        ld      a,(qf_prec)
        or      a
        jr      z,qf_d_print    ; prec=0: no zero-fill
        ld      d,a             ; D = prec (DE preserved across qf_emit_a)
        ld      a,(qf_digit)
        sub     d               ; A = digit_count - prec
        jr      nc,qf_d_print   ; digit_count >= prec: no fill
        neg                     ; A = prec - digit_count (zeros needed)
        ld      d,a
qf_d_zero_loop:
        ld      a,'0'
        call    qf_emit_a       ; push de/pop de preserves D
        dec     d
        jr      nz,qf_d_zero_loop
qf_d_print:
        call    qf_print_u
        pop     de
        pop     hl
        jp      qf_loop

qf_x:
        push    hl
        call    qf_arg_hl
        push    de
        ld      a,4
        call    qf_pad_a
        call    qf_print_x
        pop     de
        pop     hl
        jp      qf_loop


qf_f:
        ; Single-precision float formatter for -ffloatio.
        ; Reads one 4-byte float vararg into __qf32_l/__qf32_h.
        ; Prints fixed 6 digits after the decimal point.
        push    hl
        call    qf_arg_dehl
        push    de

        ld      hl,(__qf32_l)
        ld      (qf_fl),hl
        ld      hl,(__qf32_h)
        ld      (qf_fh),hl

        ; Sign and absolute value.
        bit     7,h
        jp      z,qf_f_absdone
        ld      a,'-'
        call    qf_emit_a
        ld      hl,(__qf32_h)
        res     7,h
        ld      (__qf32_h),hl
        ld      (qf_fh),hl
qf_f_absdone:
        ld      hl,(__qf32_l)
        ld      (qf_fl),hl

        ; Decide printed precision early.  Existing qf semantics use
        ; qf_prec == 0 as the default precision of 6.
        ld      a,(qf_prec)
        or      a
        jp      nz,qf_f_prec_known
        ld      a,6
qf_f_prec_known:
        ld      (qf_fcnt),a

        ; Round before splitting integer/fractional parts.  The digit
        ; loop below truncates each decimal digit, so add 0.5*10^-prec
        ; to the absolute value first.  This also carries correctly for
        ; values such as 0.9999996 -> 1.000000.
        cp      10
        jp      nc,qf_f_rounded     ; no table entry for larger precisions
        add     a,a                 ; offset = precision * 4
        add     a,a
        ld      e,a
        ld      d,0
        ld      hl,qf_rndtab
        add     hl,de
        ld      e,(hl)
        inc     hl
        ld      d,(hl)
        inc     hl
        ld      (qf_tl),de
        ld      e,(hl)
        inc     hl
        ld      d,(hl)
        ld      (qf_th),de

        ld      hl,(qf_fl)
        ld      de,(qf_fh)
        push    de
        push    hl
        ld      hl,(qf_tl)
        ld      de,(qf_th)
        push    de
        push    hl
        call    __fadd
        pop     bc
        pop     bc
        pop     bc
        pop     bc
        ld      (qf_fl),hl
        ld      (qf_fh),de
qf_f_rounded:

        ; Integer part = (unsigned long)abs(f).
        ; The old path used __ffi/qf_print_u, so %f could not print an
        ; integer part above 65535 and produced values like 65535.//////.
        ld      hl,(qf_fl)
        ld      de,(qf_fh)
        call    __fful

        ; Save integer part both for printing and later subtraction.
        ld      (__qf32_l),hl
        ld      (__qf32_h),de
        ld      (qf_tl),hl
        ld      (qf_th),de

        call    qf_print_u32

        ld      a,'.'
        call    qf_emit_a

        ; qf_print_u32 destroys __qf32_l/__qf32_h, so use saved copy.
        ld      hl,(qf_tl)
        ld      de,(qf_th)
        call    __fulf
        ld      (qf_tl),hl
        ld      (qf_th),de
        ld      hl,(qf_fl)
        ld      de,(qf_fh)
        push    de
        push    hl
        ld      hl,(qf_tl)
        ld      de,(qf_th)
        push    de
        push    hl
        call    __fsub
        pop     bc
        pop     bc
        pop     bc
        pop     bc
        ld      (qf_fl),hl
        ld      (qf_fh),de

qf_f_digloop:
        ld      a,(qf_fcnt)
        or      a
        jp      z,qf_f_done

        ; frac *= 10.0f
        ld      hl,(qf_fl)
        ld      de,(qf_fh)
        push    de
        push    hl
        ld      hl,0
        ld      de,16672        ; 10.0f = 0x41200000
        push    de
        push    hl
        call    __fmul
        pop     bc
        pop     bc
        pop     bc
        pop     bc
        ld      (qf_fl),hl
        ld      (qf_fh),de

        ; digit = (int)frac
        call    __ffi
        ld      (qf_iw),hl
        ld      a,l
        add     a,'0'
        call    qf_emit_a

        ; frac -= (float)digit
        ld      hl,(qf_iw)
        call    __fif
        ld      (qf_tl),hl
        ld      (qf_th),de
        ld      hl,(qf_fl)
        ld      de,(qf_fh)
        push    de
        push    hl
        ld      hl,(qf_tl)
        ld      de,(qf_th)
        push    de
        push    hl
        call    __fsub
        pop     bc
        pop     bc
        pop     bc
        pop     bc
        ld      (qf_fl),hl
        ld      (qf_fh),de

        ld      a,(qf_fcnt)
        dec     a
        ld      (qf_fcnt),a
        jp      qf_f_digloop
qf_f_done:
        pop     de
        pop     hl
        jp      qf_loop

qf_fl:      dw 0
qf_fh:      dw 0
qf_tl:      dw 0
qf_th:      dw 0
qf_iw:      dw 0
qf_fcnt:    db 0

qf_rndtab:
        dw      00000H,03F00H        ; 0.5e-0
        dw      0CCCDH,03D4CH        ; 0.5e-1
        dw      0D70AH,03BA3H        ; 0.5e-2
        dw      0126FH,03A03H        ; 0.5e-3
        dw      0B717H,03851H        ; 0.5e-4
        dw      0C5ACH,036A7H        ; 0.5e-5
        dw      037BDH,03506H        ; 0.5e-6
        dw      0BF95H,03356H        ; 0.5e-7
        dw      0CC77H,031ABH        ; 0.5e-8
        dw      0705FH,03009H        ; 0.5e-9

qf_l:
        ; 'l' length modifier: read next char for ld/lu/lx/ls
        ld      a,(hl)
        inc     hl
        cp      'd'
        jp      z,qf_ld
        cp      'u'
        jp      z,qf_lu
        cp      'x'
        jp      z,qf_lx
        cp      's'
        jp      z,qf_ls
        call    qf_emit_a
        jp      qf_loop

qf_ls:
        ; wchar_t * string.  DCC wchar_t is 16-bit for L"..." literals.
        ; Print the low byte as ASCII and ignore the high byte.
        push    hl
        call    qf_arg_hl
        push    de
        push    hl
        call    qf_wstrlen_hl      ; A = wide string length, HL preserved by stack
        call    qf_pad_a
        pop     hl
qf_ls_loop:
        ld      a,(hl)
        inc     hl
        ld      e,a                ; save low byte
        ld      a,(hl)
        inc     hl                 ; skip high byte
        or      e
        jr      z,qf_ls_done
        ld      a,e
        call    qf_emit_a
        jr      qf_ls_loop
qf_ls_done:
        pop     de
        pop     hl
        jp      qf_loop

qf_wstrlen_hl:
        push    hl
        ld      c,0
qf_wstrlen_loop:
        ld      a,(hl)
        inc     hl
        ld      e,a
        ld      a,(hl)
        inc     hl
        or      e
        jr      z,qf_wstrlen_done
        inc     c
        jr      qf_wstrlen_loop
qf_wstrlen_done:
        ld      a,c
        pop     hl
        ret

qf_ld:
        ; Signed 32-bit decimal
        push    hl
        call    qf_arg_dehl     ; loads __qf32_l/__qf32_h, advances DE by 4
        push    de
        ld      hl,(__qf32_h)
        bit     7,h
        jr      z,qf_ld_pos
        ; Negative: negate, then print with '-'
        call    qf_neg32
        call    qf_count_u32_digits
        inc     a               ; +1 for '-'
        call    qf_pad_a
        ld      a,'-'
        call    qf_emit_a
        jr      qf_ld_print
qf_ld_pos:
        call    qf_count_u32_digits
        call    qf_pad_a
qf_ld_print:
        call    qf_print_u32
        pop     de
        pop     hl
        jp      qf_loop

qf_lu:
        ; Unsigned 32-bit decimal
        push    hl
        call    qf_arg_dehl
        push    de
        call    qf_count_u32_digits
        call    qf_pad_a
        call    qf_print_u32
        pop     de
        pop     hl
        jp      qf_loop

qf_lx:
        ; Unsigned 32-bit hex (%lx): 8 hex digits, high word first
        push    hl
        call    qf_arg_dehl     ; loads __qf32_l/__qf32_h, advances DE by 4
        push    de
        ld      hl,(__qf32_h)
        call    qf_print_x      ; high word (4 hex digits)
        ld      hl,(__qf32_l)
        call    qf_print_x      ; low word (4 hex digits)
        pop     de
        pop     hl
        jp      qf_loop

qf_done:
        ret                     ; count in BC; caller cleans up

qf_emit_a:
        push    hl
        push    de
        push    bc
        ld      e,a
        ld      hl,(pf_sink)
        ld      a,h
        or      l
        jr      z,qfe_con       ; pf_sink=0 → console
qfe_buf:
        ld      hl,(pf_bufptr)
        ld      (hl),e
        inc     hl
        ld      (pf_bufptr),hl
        pop     bc
        pop     de
        pop     hl
        inc     bc
        ret
qfe_con:
        call    __conout
        pop     bc
        pop     de
        pop     hl
        inc     bc
        ret

qf_strlen_hl:
        push    hl
        push    bc
        ld      bc,0
qfsl1:
        ld      a,(hl)
        or      a
        jr      z,qfsl2
        inc     hl
        inc     bc
        jr      qfsl1
qfsl2:
        ld      a,c              ; low byte is enough for current tests
        pop     bc
        pop     hl
        ret

qf_count_u_digits:
        push    bc
        ld      bc,0
        ld      a,h
        or      l
        jr      nz,qfcud1
        ld      a,1
        pop     bc
        ret
qfcud1:
        inc     c
        ld      de,10
        call    __divmodu_slow   ; HL = quotient, DE = remainder
        ld      a,h
        or      l
        jr      nz,qfcud1
        ld      a,c
        pop     bc
        ret

qf_print_u:
        push    ix
        ld      ix,qf_decbuf+6
        ld      (ix+0),0
        ld      a,h
        or      l
        jr      nz,qfu1
        ld      a,'0'
        call    qf_emit_a
        pop     ix
        ret
qfu1:
        dec     ix
        ld      de,10
        call    __divmodu_slow
        ld      a,e
        add     a,'0'
        ld      (ix+0),a
        ld      a,h
        or      l
        jr      nz,qfu1
qfu2:
        ld      a,(ix+0)
        or      a
        jr      z,qfu3
        call    qf_emit_a
        inc     ix
        jr      qfu2
qfu3:
        pop     ix
        ret

qf_print_x:
        ld      a,h
        call    qf_hex_byte
        ld      a,l
        call    qf_hex_byte
        ret
qf_hex_byte:
        push    af
        rrca
        rrca
        rrca
        rrca
        call    qf_hex_nib
        pop     af
qf_hex_nib:
        and     0fh
        add     a,'0'
        cp      '9'+1
        jr      c,qfh1
        add     a,7
qfh1:
        call    qf_emit_a
        ret

qf_width:
        db      0
qf_digit:
        db      0
qf_prec:
        db      0

qf_decbuf:
        ds      7

qf_decbuf32:
        ds      11

; qf_arg_dehl: read 4-byte vararg into __qf32_l/__qf32_h, advance DE by 4
qf_arg_dehl:
        push    de              ; save vararg offset
        push    ix
        pop     hl              ; HL = IX (frame base)
        add     hl,de           ; HL = IX + DE
        ld      a,(hl)
        inc     hl
        ld      b,(hl)          ; B:A = low word bytes (A=low, B=high)
        inc     hl
        ld      c,(hl)
        inc     hl
        ld      e,(hl)          ; E:C = high word bytes (C=low, E=high)
        ld      l,a
        ld      h,b
        ld      (__qf32_l),hl
        ld      l,c
        ld      h,e
        ld      (__qf32_h),hl
        pop     de              ; restore vararg offset
        inc     de
        inc     de
        inc     de
        inc     de
        ret

; qf_neg32: negate __qf32_l/__qf32_h (two's complement)
qf_neg32:
        ld      de,(__qf32_l)
        ld      hl,0
        or      a
        sbc     hl,de
        ld      (__qf32_l),hl
        ld      de,(__qf32_h)
        ld      hl,0
        sbc     hl,de
        ld      (__qf32_h),hl
        ret

; qf_divu32_10: divide __qf32_l/__qf32_h by 10
; Output: __qf32_l/__qf32_h = quotient, A = remainder (0-9)
qf_divu32_10:
        push    bc
        push    de
        push    hl
        ld      hl,0
        ld      (__qf32_rem_l),hl
        ld      (__qf32_rem_h),hl
        ld      (__qf32_quo_l),hl
        ld      (__qf32_quo_h),hl
        ld      b,32
qf32d_loop:
        ; Shift {rem:qf32} left 1 (64-bit)
        ld      hl,(__qf32_l)
        or      a
        add     hl,hl
        ld      (__qf32_l),hl
        ld      hl,(__qf32_h)
        adc     hl,hl
        ld      (__qf32_h),hl
        ld      hl,(__qf32_rem_l)
        adc     hl,hl
        ld      (__qf32_rem_l),hl
        ld      hl,(__qf32_rem_h)
        adc     hl,hl
        ld      (__qf32_rem_h),hl
        ; rem < 20, so rem_h = 0; compare rem_l with 10
        ld      hl,(__qf32_rem_l)
        ld      a,l
        cp      10
        jr      c,qf32d_no_sub
        ; rem >= 10
        sub     10
        ld      l,a
        ld      h,0
        ld      (__qf32_rem_l),hl
        ; quotient <<= 1, set bit 0
        ld      hl,(__qf32_quo_l)
        or      a
        add     hl,hl
        inc     l
        ld      (__qf32_quo_l),hl
        ld      hl,(__qf32_quo_h)
        adc     hl,hl
        ld      (__qf32_quo_h),hl
        jr      qf32d_next
qf32d_no_sub:
        ld      hl,(__qf32_quo_l)
        or      a
        add     hl,hl
        ld      (__qf32_quo_l),hl
        ld      hl,(__qf32_quo_h)
        adc     hl,hl
        ld      (__qf32_quo_h),hl
qf32d_next:
        djnz    qf32d_loop
        ld      hl,(__qf32_quo_l)
        ld      (__qf32_l),hl
        ld      hl,(__qf32_quo_h)
        ld      (__qf32_h),hl
        ld      hl,(__qf32_rem_l)
        ld      a,l             ; remainder 0-9
        pop     hl
        pop     de
        pop     bc
        ret

; qf_count_u32_digits: count decimal digits of __qf32_l/__qf32_h; A = count
qf_count_u32_digits:
        push    bc
        push    de
        push    hl
        ld      hl,(__qf32_h)
        ld      a,h
        or      l
        ld      hl,(__qf32_l)
        or      h
        or      l
        jr      nz,qfcud32_start
        ld      a,1
        pop     hl
        pop     de
        pop     bc
        ret
qfcud32_start:
        ; Save __qf32
        ld      (__qf32_save_l),hl
        ld      hl,(__qf32_h)
        ld      (__qf32_save_h),hl
        ld      c,0
qfcud32_loop:
        inc     c
        call    qf_divu32_10
        ld      hl,(__qf32_h)
        ld      a,h
        or      l
        ld      hl,(__qf32_l)
        or      h
        or      l
        jr      nz,qfcud32_loop
        ld      a,c
        ; Restore __qf32
        ld      hl,(__qf32_save_l)
        ld      (__qf32_l),hl
        ld      hl,(__qf32_save_h)
        ld      (__qf32_h),hl
        pop     hl
        pop     de
        pop     bc
        ret

; qf_print_u32: print __qf32_l/__qf32_h as unsigned decimal
qf_print_u32:
        push    ix
        ld      ix,qf_decbuf32+10
        ld      (ix+0),0        ; null terminator
        ld      hl,(__qf32_h)
        ld      a,h
        or      l
        ld      hl,(__qf32_l)
        or      h
        or      l
        jr      nz,qfu32_start
        ld      a,'0'
        call    qf_emit_a
        pop     ix
        ret
qfu32_start:
        dec     ix
        call    qf_divu32_10    ; A = remainder digit
        add     a,'0'
        ld      (ix+0),a
        ld      hl,(__qf32_h)
        ld      a,h
        or      l
        ld      hl,(__qf32_l)
        or      h
        or      l
        jr      nz,qfu32_start
qfu32_emit:
        ld      a,(ix+0)
        or      a
        jr      z,qfu32_done
        call    qf_emit_a
        inc     ix
        jr      qfu32_emit
qfu32_done:
        pop     ix
        ret

__qf32_l:       dw      0
__qf32_h:       dw      0
__qf32_rem_l:   dw      0
__qf32_rem_h:   dw      0
__qf32_quo_l:   dw      0
__qf32_quo_h:   dw      0
__qf32_save_l:  dw      0
__qf32_save_h:  dw      0

        public  _exit
_exit:
        push    ix
        ld      ix,0
        add     ix,sp
        ld      l,(ix+4)
        ld      h,(ix+5)
        pop     ix
        call    __cpm_set_retcode
        jp      0000h

; ------------------------------------------------------------
; CP/M 3 program return code support.
;
; CP/M 3 / CP/M Plus BDOS function 108 (P_CODE):
;     C  = 6Ch
;     DE = program return code to set
;     DE = FFFFh means get current code, so avoid using FFFFh as a
;          set value.  For exit(-1), use 00FFh, matching the common
;          8-bit process-status convention.
;
; CP/M 2.2 safely ignores unsupported BDOS functions, and emulators can
; intercept this call directly, so no version check is needed.
; ------------------------------------------------------------
__cpm_set_retcode:
        ; input: HL = C int status / main return value

        ; If status is FFFFh, remap to 00FFh.  DE=FFFFh is the
        ; P_CODE "get" sentinel, not a settable return code.
        ld      a,h
        and     l
        inc     a
        jr      nz,csr_not_minus1
        ld      hl,00ffh
csr_not_minus1:

        ex      de,hl           ; DE = status
        ld      c,6ch           ; P_CODE: get/set program return code
        call    5
        ret

        public  _atoi
_atoi:
        push    ix
        ld      ix,0
        add     ix,sp
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      de,0
        ld      b,0
at_ws:
        ld      a,(hl)
        cp      ' '
        jr      z,at_ws_inc
        cp      9
        jr      nz,at_sign
at_ws_inc:
        inc     hl
        jr      at_ws
at_sign:
        cp      '-'
        jr      nz,at_digits
        ld      b,1
        inc     hl
at_digits:
        ld      a,(hl)
        cp      '0'
        jr      c,at_done_abs
        cp      '9'+1
        jr      nc,at_done_abs
        sub     '0'
        push    hl
        push    af
        ex      de,hl
        ld      de,10
        call    __mulu
        ex      de,hl
        pop     af
        ld      l,a
        ld      h,0
        add     hl,de
        ex      de,hl
        pop     hl
        inc     hl
        jr      at_digits
at_done_abs:
        ex      de,hl
        ld      a,b
        or      a
        jr      z,at_done
        xor     a
        sub     l
        ld      l,a
        ld      a,0
        sbc     a,h
        ld      h,a
at_done:
        pop     ix
        ret

        public  _fflush
_fflush:
        ld      hl,0
        ret

        public  _stdout
_stdout:
        dw      1               ; fd 1 = console output



        public  _stderr
_stderr:
        dw      2               ; fd 2 = console output

        public  _stdin
_stdin:
        dw      0

        public  _open
        public  _read
        public  _write
        public  _close
        public  _unlink
        public  _lseek
        public  _fsync
        public  _fdatasync
        public  _errno

FIRSTFD  equ     3
NFILES   equ     4
MAXFD    equ     7
FCBSIZE  equ     36

; ------------------------------------------------------------
; Minimal CP/M byte-stream file I/O.
;
; fd 0 = stdin, fd 1 = stdout, fd 2 = stderr.
; real files are fd 3..6.
;
; One shared 128-byte DMA buffer. 32-bit current offsets, but lseek returns low 16 bits.
; ------------------------------------------------------------

_open:
        push    ix
        ld      ix,0
        add     ix,sp

        ld      hl,__fduse
        ld      b,NFILES
        xor     a
opfind:
        ld      e,a
        ld      a,(hl)
        or      a
        jr      z,opslot
        inc     hl
        ld      a,e
        inc     a
        djnz    opfind
        call    __ioerr
        ld      hl,0ffffh
        pop     ix
        ret

opslot:
        ld      a,e
        ld      (__slot),a
        ld      (hl),1

        call    __offp
        xor     a
        ld      (hl),a
        inc     hl
        ld      (hl),a
        inc     hl
        ld      (hl),a
        inc     hl
        ld      (hl),a

        ld      a,(__slot)
        call    __fcbp
        push    hl
        ex      de,hl
        ld      b,FCBSIZE
        xor     a
opclr:
        ld      (de),a
        inc     de
        djnz    opclr

        pop     de
        push    de
        ld      l,(ix+4)
        ld      h,(ix+5)
        call    __mkfcb
        pop     de

        ; Create/truncate only if O_CREAT or O_TRUNC is set.
        ; Test uses:
        ;   O_CREAT = 0100 octal = 0040h
        ;   O_TRUNC = 01000 octal = 0200h
        ;   O_RDWR  = 2, which must NOT truncate.
        ld      a,(ix+6)
        and     40h             ; O_CREAT low byte
        jr      nz,opmake
        ld      a,(ix+7)
        and     2               ; O_TRUNC high byte
        jr      nz,opmake

        ld      c,15            ; open existing
        call    5
        cp      0ffh
        jr      z,opfail
        jr      opok

opmake:
        push    de
        ld      c,19            ; delete old, ignore status
        call    5
        pop     de
        ld      c,22            ; make new
        call    5
        cp      0ffh
        jr      z,opfail

opok:
        ld      a,(__slot)
        add     a,FIRSTFD
        ld      h,0
        ld      l,a
        pop     ix
        ret

opfail:
        ld      a,(__slot)
        call    __usep
        ld      (hl),0
        call    __ioerr
        ld      hl,0ffffh
        pop     ix
        ret

_close:
        push    ix
        ld      ix,0
        add     ix,sp
        ld      a,(ix+4)
        cp      FIRSTFD
        jr      c,clok
        cp      MAXFD
        jr      nc,clbad
        sub     FIRSTFD
        ld      (__slot),a
        call    __fcbp
        ex      de,hl
        ld      c,16            ; close file
        call    5
        ld      a,(__slot)
        call    __usep
        ld      (hl),0
clok:
        ld      hl,0
        pop     ix
        ret
clbad:
        call    __ioerr
        ld      hl,0ffffh
        pop     ix
        ret

; ---- _unlink(path) -> 0 on success, -1 on failure ----
; Erases a CP/M file using BDOS fn 19.
; path @ IX+4/5.
_unlink:
        push    ix
        ld      ix,0
        add     ix,sp

        ; Zero the scratch FCB (drive + 8-char name + 3-char ext = 12 bytes)
        ld      hl,__ulfcb
        ld      b,12
        xor     a
ulclr:
        ld      (hl),a
        inc     hl
        djnz    ulclr

        ; Build FCB from path string
        ld      l,(ix+4)
        ld      h,(ix+5)        ; HL = path
        ld      de,__ulfcb      ; DE = scratch FCB
        call    __mkfcb

        ; BDOS fn 19: erase file (DE = FCB)
        ld      de,__ulfcb
        ld      c,19
        call    5

        ; A = 0ffh on failure, 0..3 (directory code) on success
        cp      0ffh
        jr      z,ul_fail
        ld      hl,0
        pop     ix
        ret
ul_fail:
        call    __ioerr
        ld      hl,0ffffh
        pop     ix
        ret

_read:
        push    ix
        ld      ix,0
        add     ix,sp

        ld      a,(ix+4)
        or      a
        jr      nz,rdfile
        ; stdin: return one blocking char if count > 0.
        ld      a,(ix+8)
        or      (ix+9)
        jr      z,rdzero
        ld      c,6
        ld      e,0ffh
        call    5
        ld      l,(ix+6)
        ld      h,(ix+7)
        ld      (hl),a
        ld      hl,1
        pop     ix
        ret
rdzero:
        ld      hl,0
        pop     ix
        ret

rdfile:
        call    __chkfd
        jr      c,rdbad
        ld      l,(ix+6)
        ld      h,(ix+7)
        ld      (__rwbuf),hl
        ld      l,(ix+8)
        ld      h,(ix+9)
        ld      (__rwrem),hl
        ld      hl,0
        ld      (__rwcnt),hl

rdloop:
        ld      hl,(__rwrem)
        ld      a,h
        or      l
        jr      z,rddone
        call    __setrr
        ld      de,__dma
        ld      c,26            ; set DMA
        call    5
        ld      a,(__slot)
        call    __fcbp
        ex      de,hl
        ld      c,33            ; random read
        call    5
        or      a
        jr      nz,rddone       ; EOF/error returns short count

        call    __chunk
        ; copy __chunk bytes from __dma+remainder to user buffer
        ld      a,(__remdr)
        ld      h,0
        ld      l,a
        ld      de,__dma
        add     hl,de           ; HL = source
        ld      de,(__rwbuf)    ; DE = dest
        ld      a,(__chnk)
        ld      c,a
        ld      b,0
        ldir
        call    __advio
        jr      rdloop

rddone:
        ld      hl,(__rwcnt)
        pop     ix
        ret
rdbad:
        call    __ioerr
        ld      hl,0ffffh
        pop     ix
        ret

_write:
        push    ix
        ld      ix,0
        add     ix,sp

        ld      a,(ix+4)
        cp      1
        jp      z,wrcon
        cp      2
        jp      z,wrcon
        call    __chkfd
        jp      c,wrbad
        ld      l,(ix+6)
        ld      h,(ix+7)
        ld      (__rwbuf),hl
        ld      l,(ix+8)
        ld      h,(ix+9)
        ld      (__rwrem),hl
        ld      hl,0
        ld      (__rwcnt),hl

wrloop:
        ld      hl,(__rwrem)
        ld      a,h
        or      l
        jr      z,wrdone
        call    __setrr
        call    __chunk

        ; For partial records, read old data first. If it fails,
        ; zero-fill the shared DMA buffer.
        ld      a,(__remdr)
        or      a
        jr      nz,wrrd
        ld      a,(__chnk)
        cp      128
        jr      z,wrcopy
wrrd:
        ld      de,__dma
        ld      c,26
        call    5
        ld      a,(__slot)
        call    __fcbp
        ex      de,hl
        ld      c,33
        call    5
        or      a
        jr      z,wrcopy
        call    __zerdm

wrcopy:
        ; copy __chunk bytes from user buffer to __dma+remainder
        ld      hl,(__rwbuf)    ; source
        ld      a,(__remdr)
        ld      d,0
        ld      e,a
        push    hl
        ld      hl,__dma
        add     hl,de
        ex      de,hl           ; DE = dest
        pop     hl              ; HL = source
        ld      a,(__chnk)
        ld      c,a
        ld      b,0
        ldir

        ld      de,__dma
        ld      c,26
        call    5
        ld      a,(__slot)
        call    __fcbp
        ex      de,hl
        ld      c,34            ; random write
        call    5
        or      a
        jr      nz,wrbad
        call    __advio
        jr      wrloop

wrdone:
        ld      hl,(__rwcnt)
        pop     ix
        ret

wrcon:
        ld      hl,(__rwcnt)
        ; initialize console write vars
        ld      l,(ix+6)
        ld      h,(ix+7)
        ld      (__rwbuf),hl
        ld      l,(ix+8)
        ld      h,(ix+9)
        ld      (__rwrem),hl
        ld      hl,0
        ld      (__rwcnt),hl
wcloop:
        ld      hl,(__rwrem)
        ld      a,h
        or      l
        jr      z,wrdone
        ld      hl,(__rwbuf)
        ld      e,(hl)
        call    __conout
        ; advance buf/cnt/rem by 1 without updating fdoff (no __offp call)
        ld      hl,(__rwbuf)
        inc     hl
        ld      (__rwbuf),hl
        ld      hl,(__rwcnt)
        inc     hl
        ld      (__rwcnt),hl
        ld      hl,(__rwrem)
        dec     hl
        ld      (__rwrem),hl
        jr      wcloop

wrbad:
        call    __ioerr
        ld      hl,0ffffh
        pop     ix
        ret

_lseek:
        push    ix
        ld      ix,0
        add     ix,sp
        call    __chkfd
        jp      c,lsbad

        ; long lseek(int fd, long offset, int whence)
        ; ix+4/5   fd
        ; ix+6..9  offset, low word then high word
        ; ix+10/11 whence
        ld      a,(ix+10)
        or      a
        jr      z,lsset
        cp      1
        jr      z,lscur
        cp      2
        jr      z,lsend
        jp      lsbad

lsset:
        ; Set current offset from full 32-bit argument.
        call    __offp
        ld      a,(ix+6)
        ld      (hl),a
        inc     hl
        ld      a,(ix+7)
        ld      (hl),a
        inc     hl
        ld      a,(ix+8)
        ld      (hl),a
        inc     hl
        ld      a,(ix+9)
        ld      (hl),a
        jr      lsret

lscur:
        ; Add full 32-bit delta to current offset.
        call    __offp
        ld      a,(hl)
        add     a,(ix+6)
        ld      (hl),a
        inc     hl
        ld      a,(hl)
        adc     a,(ix+7)
        ld      (hl),a
        inc     hl
        ld      a,(hl)
        adc     a,(ix+8)
        ld      (hl),a
        inc     hl
        ld      a,(hl)
        adc     a,(ix+9)
        ld      (hl),a
        jr      lsret

lsret:
        ; Return full 32-bit offset in DE:HL.
        call    __offp
        ld      e,(hl)          ; byte 0
        inc     hl
        ld      d,(hl)          ; byte 1
        inc     hl
        push    de              ; low word
        ld      e,(hl)          ; byte 2
        inc     hl
        ld      d,(hl)          ; byte 3
        pop     hl              ; HL = low word, DE = high word
        pop     ix
        ret

lsend:
        ; SEEK_END: use BDOS fn 35 to get size in 128-byte records,
        ; then convert to byte offset and add full 32-bit delta.
        ld      a,(__slot)
        call    __fcbp
        ex      de,hl
        ld      c,35
        call    5

        ld      a,(__slot)
        call    __fcbp
        ld      de,33
        add     hl,de
        ld      c,(hl)
        inc     hl
        ld      b,(hl)          ; BC = 16-bit record count

        ; BC * 128 -> A:HL, where A is byte 2 and byte 3 is zero.
        ld      l,c
        ld      h,b
        xor     a
        add     hl,hl
        rla
        add     hl,hl
        rla
        add     hl,hl
        rla
        add     hl,hl
        rla
        add     hl,hl
        rla
        add     hl,hl
        rla
        add     hl,hl
        rla

        ; Add offset low word.
        ld      e,(ix+6)
        ld      d,(ix+7)
        add     hl,de

        ; Add offset high bytes plus carry from low word.
        ld      e,a
        ld      a,e
        adc     a,(ix+8)
        ld      b,a             ; result byte 2

        ld      a,0
        adc     a,(ix+9)
        ld      c,a             ; result byte 3

        push    bc
        push    hl

        call    __offp

        pop     de              ; low word
        ld      (hl),e
        inc     hl
        ld      (hl),d
        inc     hl
        pop     bc
        ld      (hl),b
        inc     hl
        ld      (hl),c
        jr      lsret

lsbad:
        call    __ioerr
        ld      hl,0ffffh
        ld      de,0ffffh
        pop     ix
        ret


_fsync:
_fdatasync:
        ld      hl,0
        ret

; Validate fd in A or (ix+4). Sets __slot. Carry set on error.
__chkfd:
        ld      a,(ix+4)
        cp      FIRSTFD
        jr      c,cfbad
        cp      MAXFD
        jr      nc,cfbad
        sub     FIRSTFD
        ld      (__slot),a
        call    __usep
        ld      a,(hl)
        or      a
        jr      z,cfbad
        or      a               ; clear carry
        ret
cfbad:
        scf
        ret

; A = slot 0..3, returns HL = fd_used slot
__usep:
        ld      h,0
        ld      l,a
        ld      de,__fduse
        add     hl,de
        ret

; __slot -> HL = 32-bit offset dword
__offp:
        ld      a,(__slot)
        ld      h,0
        ld      l,a
        add     hl,hl
        add     hl,hl           ; *4 bytes per offset
        ld      de,__fdoff
        add     hl,de
        ret

; A = slot 0..3, returns HL = FCB
__fcbp:
        ld      h,0
        ld      l,a
        add     hl,hl           ; *2
        add     hl,hl           ; *4
        ld      d,h
        ld      e,l
        add     hl,hl           ; *8
        add     hl,hl           ; *16
        add     hl,hl           ; *32
        add     hl,de           ; *36
        ld      de,__fcbs
        add     hl,de
        ret

; Set FCB random record from 32-bit byte offset.
; record = offset >> 7. remainder = offset & 127.
__setrr:
        call    __offp
        ld      e,(hl)          ; offset byte 0
        inc     hl
        ld      d,(hl)          ; offset byte 1
        inc     hl
        ld      b,(hl)          ; offset byte 2
        inc     hl
        ld      c,(hl)          ; offset byte 3

        ld      a,e
        and     7fh
        ld      (__remdr),a

        ; r0 = (byte0 >> 7) | (byte1 << 1)
        ld      a,e
        rlca
        and     1
        ld      l,a
        ld      a,d
        add     a,a
        or      l
        ld      l,a             ; L = r0

        ; r1 = (byte1 >> 7) | (byte2 << 1)
        ld      a,d
        rlca
        and     1
        ld      h,a
        ld      a,b
        add     a,a
        or      h
        ld      h,a             ; H = r1

        ; r2 = (byte2 >> 7) | (byte3 << 1)
        ld      a,b
        rlca
        and     1
        ld      e,a
        ld      a,c
        add     a,a
        or      e
        ld      e,a             ; E = r2

        push    hl              ; save r0/r1
        push    de              ; save r2 in E
        ld      a,(__slot)
        call    __fcbp
        ld      de,33
        add     hl,de
        pop     de
        pop     bc              ; C = r0, B = r1
        ld      (hl),c
        inc     hl
        ld      (hl),b
        inc     hl
        ld      (hl),e
        ret
; Compute chunk = min(remaining, bytes-left-in-current-CP/M-record), stores __chnk.
; Each CP/M BDOS record is 128 bytes, so we cap at 128 bytes per call.
; The important rule is that when remaining is less than 128, __chnk must
; be remaining, even at a record boundary.
__chunk:
        ; e = min(remaining, 128)
        ld      hl,(__rwrem)
        ld      a,h
        or      a
        jr      nz,ch_more128
        ld      a,l
        cp      129
        jr      nc,ch_more128
        ld      e,a             ; remaining is 1..128
        jr      ch_have_count

ch_more128:
        ld      e,128

ch_have_count:
        ; room = 128 - remainder.  If remainder is 0, room is 128,
        ; so the 128-byte cap already fits.
        ld      a,(__remdr)
        or      a
        jr      z,ch_store
        ld      c,a
        ld      a,128
        sub     c               ; room is 1..127
        cp      e
        jr      nc,ch_store
        ld      e,a

ch_store:
        ld      a,e
        ld      (__chnk),a
        ret

__advio:
        ld      a,(__chnk)
        ld      e,a
        ld      d,0
        ld      hl,(__rwbuf)
        add     hl,de
        ld      (__rwbuf),hl
        ld      hl,(__rwcnt)
        add     hl,de
        ld      (__rwcnt),hl
        ld      hl,(__rwrem)
        or      a
        sbc     hl,de
        ld      (__rwrem),hl
        call    __offp
        ; __offp clobbers DE, so reload the chunk before updating offset.
        ld      a,(__chnk)
        ld      e,a
        ld      d,0
        ld      a,(hl)
        add     a,e
        ld      (hl),a
        inc     hl
        ld      a,(hl)
        adc     a,d
        ld      (hl),a
        inc     hl
        ld      a,(hl)
        adc     a,0
        ld      (hl),a
        inc     hl
        ld      a,(hl)
        adc     a,0
        ld      (hl),a
        ret

__zerdm:
        ld      hl,__dma
        ld      b,128
        ld      a,1ah           ; Ctrl-Z: CP/M text-file EOF sentinel
zdm1:
        ld      (hl),a
        inc     hl
        djnz    zdm1
        ret

; HL = filename string, DE = FCB address.
__mkfcb:
        ld      (__mffcb),de
        push    hl
        ex      de,hl
        xor     a
        ld      (hl),a          ; default drive
        inc     hl
        ld      b,11
mfspc:
        ld      (hl),' '
        inc     hl
        djnz    mfspc
        pop     hl

        ld      de,(__mffcb)
        inc     de              ; name field
        ld      b,8
mfnam:
        ld      a,(hl)
        or      a
        ret     z
        cp      '.'
        jr      z,mfdot
        call    __upa
        ld      (de),a
        inc     de
        inc     hl
        djnz    mfnam
mfskp:
        ld      a,(hl)
        or      a
        ret     z
        cp      '.'
        jr      z,mfdot
        inc     hl
        jr      mfskp
mfdot:
        inc     hl
        push    hl
        ld      hl,(__mffcb)
        ld      de,9
        add     hl,de
        ex      de,hl           ; DE = extension field
        pop     hl
        ld      b,3
mfext:
        ld      a,(hl)
        or      a
        ret     z
        call    __upa
        ld      (de),a
        inc     de
        inc     hl
        djnz    mfext
        ret

__upa:
        cp      'a'
        ret     c
        cp      'z'+1
        ret     nc
        sub     20h
        ret

__ioerr:
        ld      hl,22
        ld      (_errno),hl
        ret


        public  _srand
_srand:
        push    ix
        ld      ix,0
        add     ix,sp

        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      (__rand_state),hl

        pop     ix
        ret

        public  _rand
_rand:
        ; Deterministic 16-bit xorshift generator.
        ; Avoids the very weak low bits of the old state = state * 5 + 1 LCG.
        ; Return value is in the usual C rand() range 0..32767.
        ;
        ; x ^= x << 7
        ; x ^= x >> 9
        ; x ^= x << 8
        ld      hl,(__rand_state)

        ; de = x, hl = x << 7
        push    hl
        add     hl,hl
        add     hl,hl
        add     hl,hl
        add     hl,hl
        add     hl,hl
        add     hl,hl
        add     hl,hl
        pop     de
        ld      a,l
        xor     e
        ld      l,a
        ld      a,h
        xor     d
        ld      h,a

        ; de = x, hl = x >> 9
        push    hl
        ld      l,h
        ld      h,0
        srl     l
        pop     de
        ld      a,l
        xor     e
        ld      l,a
        ld      a,h
        xor     d
        ld      h,a

        ; de = x, hl = x << 8
        push    hl
        ld      h,l
        ld      l,0
        pop     de
        ld      a,l
        xor     e
        ld      l,a
        ld      a,h
        xor     d
        ld      h,a

        ; xorshift has a zero lock-up state.  The default seed is non-zero,
        ; but recover defensively if memory was clobbered.
        ld      a,h
        or      l
        jp      nz,__rand_store
        inc     hl

__rand_store:
        ld      (__rand_state),hl
        res     7,h
        ret

__rand_state:
        dw      1

_errno:
        dw      0
__slot:
        db      0
__chnk:
        db      0
__remdr:
        db      0
__rwbuf:
        dw      0
__rwrem:
        dw      0
__rwcnt:
        dw      0
__mffcb:
        dw      0
__ulfcb:
        ds      12              ; scratch FCB for _unlink

__dmval:
        db      0
__dmc_lhs:
        dw      0
__dmc_rhs:
        dw      0
__dmquot:
        dw      0
__dmrem:
        dw      0

__fduse:
        ds      4
__fdoff:
        ds      16
__fcbs:
        ds      144
__dma:
        ds      128



; ============================================================
; 32-bit long arithmetic runtime routines
; Calling convention: caller pushes LHS (push de; push hl),
;   then RHS (push de; push hl), then calls.  After push ix;
;   ld ix,0; add ix,sp: IX+4=RHS_L, IX+6=RHS_H,
;   IX+8=LHS_L, IX+10=LHS_H.  Returns DE:HL (DE=high,
;   HL=low).  Caller cleans 8 bytes of args after return.
; ============================================================

        public  __lmul
__lmul:
        push    ix
        ld      ix,0
        add     ix,sp
        ld      a,(ix+8)
        ld      l,a
        ld      a,(ix+9)
        ld      h,a
        ld      (__lm_lhs_l),hl
        ld      a,(ix+10)
        ld      l,a
        ld      a,(ix+11)
        ld      h,a
        ld      (__lm_lhs_h),hl
        ld      a,(ix+4)
        ld      l,a
        ld      a,(ix+5)
        ld      h,a
        ld      (__lm_rhs_l),hl
        ld      a,(ix+6)
        ld      l,a
        ld      a,(ix+7)
        ld      h,a
        ld      (__lm_rhs_h),hl
        ld      hl,0
        ld      (__lm_res_l),hl
        ld      (__lm_res_h),hl
        ; Fast path: select iteration count based on operand width.
        ; Both high words = 0 (16-bit): 16 iterations suffice.
        ; Both low words also have high byte = 0 (8-bit): 8 iterations suffice.
        ld      hl,(__lm_lhs_h)
        ld      a,h
        or      l
        jp      nz,lmul_full32
        ld      hl,(__lm_rhs_h)
        ld      a,h
        or      l
        jp      nz,lmul_full32
        ; Both operands fit in 16 bits.  Check if both fit in 8 bits.
        ld      hl,(__lm_lhs_l)
        ld      a,h             ; high byte of lhs low word
        or      a
        jp      nz,lmul_16bit
        ld      hl,(__lm_rhs_l)
        ld      a,h             ; high byte of rhs low word
        or      a
        jp      nz,lmul_16bit
        ld      b,8             ; both 8-bit: 8 iterations suffice
        jp      lmul_loop
lmul_16bit:
        ld      b,16
        jp      lmul_loop
lmul_full32:
        ld      b,32
lmul_loop:
        push    bc
        ld      hl,(__lm_rhs_l)
        ld      a,l
        and     1
        jr      z,lmul_no_add
        ld      hl,(__lm_res_l)
        ld      de,(__lm_lhs_l)
        or      a
        add     hl,de
        ld      (__lm_res_l),hl
        ld      hl,(__lm_res_h)
        ld      de,(__lm_lhs_h)
        adc     hl,de
        ld      (__lm_res_h),hl
lmul_no_add:
        ; LHS <<= 1
        ld      hl,(__lm_lhs_l)
        or      a
        add     hl,hl
        ld      (__lm_lhs_l),hl
        ld      hl,(__lm_lhs_h)
        adc     hl,hl
        ld      (__lm_lhs_h),hl
        ; RHS >>= 1 (logical)
        ld      hl,(__lm_rhs_h)
        or      a
        srl     h
        rr      l
        ld      (__lm_rhs_h),hl
        ld      de,(__lm_rhs_l)
        rr      d
        rr      e
        ld      (__lm_rhs_l),de
        pop     bc
        djnz    lmul_loop
        ld      hl,(__lm_res_l)
        ld      de,(__lm_res_h)
        ld      sp,ix
        pop     ix
        ret

; __ldivu: unsigned 32-bit divide.  Returns DE:HL = LHS / RHS.
        public  __ldu
__ldu:
        push    ix
        ld      ix,0
        add     ix,sp
        ld      a,(ix+4)
        ld      l,a
        ld      a,(ix+5)
        ld      h,a
        ld      (__ldv_dvs_l),hl
        ld      a,(ix+6)
        ld      l,a
        ld      a,(ix+7)
        ld      h,a
        ld      (__ldv_dvs_h),hl
        ld      a,(ix+8)
        ld      l,a
        ld      a,(ix+9)
        ld      h,a
        ld      (__ldv_dvd_l),hl
        ld      a,(ix+10)
        ld      l,a
        ld      a,(ix+11)
        ld      h,a
        ld      (__ldv_dvd_h),hl
        ld      hl,0
        ld      (__ldv_rem_l),hl
        ld      (__ldv_rem_h),hl
        ld      (__ldv_quo_l),hl
        ld      (__ldv_quo_h),hl
        ld      b,32
ldivu_loop:
        push    bc
        ; Shift {rem:dvd} left 1 (64-bit)
        ld      hl,(__ldv_dvd_l)
        or      a
        add     hl,hl
        ld      (__ldv_dvd_l),hl
        ld      hl,(__ldv_dvd_h)
        adc     hl,hl
        ld      (__ldv_dvd_h),hl
        ld      hl,(__ldv_rem_l)
        adc     hl,hl
        ld      (__ldv_rem_l),hl
        ld      hl,(__ldv_rem_h)
        adc     hl,hl
        ld      (__ldv_rem_h),hl
        ; Compare rem with dvs (32-bit)
        ld      hl,(__ldv_rem_l)
        ld      de,(__ldv_dvs_l)
        or      a
        sbc     hl,de
        ex      de,hl           ; DE = rem_l - dvs_l (tentative)
        ld      hl,(__ldv_rem_h)
        ld      bc,(__ldv_dvs_h)
        sbc     hl,bc           ; HL = rem_h - dvs_h - borrow
        jr      c,ldivu_no_sub
        ; rem >= dvs: store rem - dvs, set quotient bit
        ld      (__ldv_rem_h),hl
        ex      de,hl
        ld      (__ldv_rem_l),hl
        ld      hl,(__ldv_quo_l)
        or      a
        add     hl,hl
        inc     l
        ld      (__ldv_quo_l),hl
        ld      hl,(__ldv_quo_h)
        adc     hl,hl
        ld      (__ldv_quo_h),hl
        jr      ldivu_next
ldivu_no_sub:
        ld      hl,(__ldv_quo_l)
        or      a
        add     hl,hl
        ld      (__ldv_quo_l),hl
        ld      hl,(__ldv_quo_h)
        adc     hl,hl
        ld      (__ldv_quo_h),hl
ldivu_next:
        pop     bc
        djnz    ldivu_loop
        ld      hl,(__ldv_quo_l)
        ld      de,(__ldv_quo_h)
        ld      sp,ix
        pop     ix
        ret

; __lmodu: unsigned 32-bit modulo.  Returns DE:HL = LHS % RHS.
        public  __lmu
__lmu:
        push    ix
        ld      ix,0
        add     ix,sp
        ld      a,(ix+4)
        ld      l,a
        ld      a,(ix+5)
        ld      h,a
        ld      (__ldv_dvs_l),hl
        ld      a,(ix+6)
        ld      l,a
        ld      a,(ix+7)
        ld      h,a
        ld      (__ldv_dvs_h),hl
        ld      a,(ix+8)
        ld      l,a
        ld      a,(ix+9)
        ld      h,a
        ld      (__ldv_dvd_l),hl
        ld      a,(ix+10)
        ld      l,a
        ld      a,(ix+11)
        ld      h,a
        ld      (__ldv_dvd_h),hl
        ld      hl,0
        ld      (__ldv_rem_l),hl
        ld      (__ldv_rem_h),hl
        ; Fast path: divisor fits in 16 bits → use compact register-based algorithm.
        ; Keep DE = divisor and HL = 16-bit running remainder throughout.
        ; Process the 32-bit dividend MSB-first, 8 bits per call to lmodu_byte.
        ld      hl,(__ldv_dvs_h)
        ld      a,h
        or      l
        jp      z,lmodu_dvs16
        ld      b,32
lmodu_loop:
        push    bc
        ld      hl,(__ldv_dvd_l)
        or      a
        add     hl,hl
        ld      (__ldv_dvd_l),hl
        ld      hl,(__ldv_dvd_h)
        adc     hl,hl
        ld      (__ldv_dvd_h),hl
        ld      hl,(__ldv_rem_l)
        adc     hl,hl
        ld      (__ldv_rem_l),hl
        ld      hl,(__ldv_rem_h)
        adc     hl,hl
        ld      (__ldv_rem_h),hl
        ld      hl,(__ldv_rem_l)
        ld      de,(__ldv_dvs_l)
        or      a
        sbc     hl,de
        ex      de,hl
        ld      hl,(__ldv_rem_h)
        ld      bc,(__ldv_dvs_h)
        sbc     hl,bc
        jr      c,lmodu_no_sub
        ld      (__ldv_rem_h),hl
        ex      de,hl
        ld      (__ldv_rem_l),hl
lmodu_no_sub:
        pop     bc
        djnz    lmodu_loop
        ld      hl,(__ldv_rem_l)
        ld      de,(__ldv_rem_h)
        ld      sp,ix
        pop     ix
        ret

lmodu_dvs16:
        ; Divisor is 16-bit (in __ldv_dvs_l).  Process the 32-bit dividend
        ; byte-by-byte MSB-first, accumulating a 16-bit remainder in HL.
        ; Result fits in HL since remainder < 16-bit divisor.
        ; Use conditional call (call nz) to skip zero bytes cheaply.
        ld      de,(__ldv_dvs_l)        ; DE = divisor (stays in register)
        ld      hl,0                    ; HL = partial remainder
        ld      a,(__ldv_dvd_h+1)       ; byte 3 (MSB)
        or      a
        call    nz,lmodu_byte           ; skip entirely if byte = 0
        ld      a,(__ldv_dvd_h)         ; byte 2
        or      a
        call    nz,lmodu_byte           ; skip if byte 2 = 0
        ld      a,(__ldv_dvd_l+1)       ; byte 1
        call    lmodu_byte
        ld      a,(__ldv_dvd_l)         ; byte 0 (LSB)
        call    lmodu_byte
        ; HL = remainder; DE high word = 0 (remainder < 16-bit divisor)
        ld      de,0
        ld      sp,ix
        pop     ix
        ret

lmodu_byte:
        ; Process 8 bits of A (MSB-first) into 16-bit remainder HL.
        ; DE = divisor (constant).  Clobbers A, B.
        ;
        ; When adc hl,hl overflows (carry set), true_shifted > 65535 >= DE so
        ; we must subtract.  (HL_wrapped - DE) wraps to true_shifted - DE which
        ; is the correct new remainder; skip the restore.
        ld      b,8
lmodu_bit:
        rlca                            ; rotate A left: MSB → carry (next dividend bit)
        adc     hl,hl                   ; HL = (HL<<1) | bit; carry = 16-bit overflow
        jr      c,lmodu_ovf             ; overflow: true_shifted > 65535 >= DE; always sub
        or      a                       ; clear carry (no overflow)
        sbc     hl,de                   ; try HL -= divisor
        jr      nc,lmodu_bit_ok         ; HL >= divisor: keep
        add     hl,de                   ; restore: HL was < divisor
        jr      lmodu_bit_ok
lmodu_ovf:
        or      a                       ; clear carry
        sbc     hl,de                   ; HL_wrapped - DE = correct new remainder
lmodu_bit_ok:
        djnz    lmodu_bit
        ret

; __ldivs: signed 32-bit divide.  Returns DE:HL = LHS / RHS.
        public  __lds
__lds:
        push    ix
        ld      ix,0
        add     ix,sp
        ; Load args and make positive, track sign
        ld      a,(ix+8)
        ld      l,a
        ld      a,(ix+9)
        ld      h,a
        ld      (__ldv_dvd_l),hl
        ld      a,(ix+10)
        ld      l,a
        ld      a,(ix+11)
        ld      h,a
        ld      (__ldv_dvd_h),hl
        ld      a,(ix+4)
        ld      l,a
        ld      a,(ix+5)
        ld      h,a
        ld      (__ldv_dvs_l),hl
        ld      a,(ix+6)
        ld      l,a
        ld      a,(ix+7)
        ld      h,a
        ld      (__ldv_dvs_h),hl
        ; sign = sign(dvd) XOR sign(dvs)
        ld      a,(ix+11)       ; high byte of LHS_H
        xor     (ix+7)          ; XOR with high byte of RHS_H
        ld      (__ldv_sign),a  ; bit7 = result sign
        ; If dvd negative: negate it
        ld      a,(ix+11)
        bit     7,a
        jr      z,ldivs_dvd_pos
        ld      de,(__ldv_dvd_l)
        ld      hl,0
        or      a
        sbc     hl,de
        ld      (__ldv_dvd_l),hl
        ld      de,(__ldv_dvd_h)
        ld      hl,0
        sbc     hl,de
        ld      (__ldv_dvd_h),hl
ldivs_dvd_pos:
        ; If dvs negative: negate it
        ld      a,(ix+7)
        bit     7,a
        jr      z,ldivs_dvs_pos
        ld      de,(__ldv_dvs_l)
        ld      hl,0
        or      a
        sbc     hl,de
        ld      (__ldv_dvs_l),hl
        ld      de,(__ldv_dvs_h)
        ld      hl,0
        sbc     hl,de
        ld      (__ldv_dvs_h),hl
ldivs_dvs_pos:
        ; Now do unsigned division using the scratch vars
        ld      hl,0
        ld      (__ldv_rem_l),hl
        ld      (__ldv_rem_h),hl
        ld      (__ldv_quo_l),hl
        ld      (__ldv_quo_h),hl
        ld      b,32
ldivs_loop:
        push    bc
        ld      hl,(__ldv_dvd_l)
        or      a
        add     hl,hl
        ld      (__ldv_dvd_l),hl
        ld      hl,(__ldv_dvd_h)
        adc     hl,hl
        ld      (__ldv_dvd_h),hl
        ld      hl,(__ldv_rem_l)
        adc     hl,hl
        ld      (__ldv_rem_l),hl
        ld      hl,(__ldv_rem_h)
        adc     hl,hl
        ld      (__ldv_rem_h),hl
        ld      hl,(__ldv_rem_l)
        ld      de,(__ldv_dvs_l)
        or      a
        sbc     hl,de
        ex      de,hl
        ld      hl,(__ldv_rem_h)
        ld      bc,(__ldv_dvs_h)
        sbc     hl,bc
        jr      c,ldivs_no_sub
        ld      (__ldv_rem_h),hl
        ex      de,hl
        ld      (__ldv_rem_l),hl
        ld      hl,(__ldv_quo_l)
        or      a
        add     hl,hl
        inc     l
        ld      (__ldv_quo_l),hl
        ld      hl,(__ldv_quo_h)
        adc     hl,hl
        ld      (__ldv_quo_h),hl
        jr      ldivs_next
ldivs_no_sub:
        ld      hl,(__ldv_quo_l)
        or      a
        add     hl,hl
        ld      (__ldv_quo_l),hl
        ld      hl,(__ldv_quo_h)
        adc     hl,hl
        ld      (__ldv_quo_h),hl
ldivs_next:
        pop     bc
        djnz    ldivs_loop
        ; Apply sign to quotient
        ld      a,(__ldv_sign)
        bit     7,a
        jr      z,ldivs_pos_result
        ld      de,(__ldv_quo_l)
        ld      hl,0
        or      a
        sbc     hl,de
        ld      (__ldv_quo_l),hl
        ld      de,(__ldv_quo_h)
        ld      hl,0
        sbc     hl,de
        ld      (__ldv_quo_h),hl
ldivs_pos_result:
        ld      hl,(__ldv_quo_l)
        ld      de,(__ldv_quo_h)
        ld      sp,ix
        pop     ix
        ret

; __lmods: signed 32-bit modulo.  Returns DE:HL = LHS % RHS.
        public  __lms
__lms:
        push    ix
        ld      ix,0
        add     ix,sp
        ld      a,(ix+8)
        ld      l,a
        ld      a,(ix+9)
        ld      h,a
        ld      (__ldv_dvd_l),hl
        ld      a,(ix+10)
        ld      l,a
        ld      a,(ix+11)
        ld      h,a
        ld      (__ldv_dvd_h),hl
        ld      a,(ix+4)
        ld      l,a
        ld      a,(ix+5)
        ld      h,a
        ld      (__ldv_dvs_l),hl
        ld      a,(ix+6)
        ld      l,a
        ld      a,(ix+7)
        ld      h,a
        ld      (__ldv_dvs_h),hl
        ; sign of result = sign of dividend
        ld      a,(ix+11)
        ld      (__ldv_sign),a
        ; If dvd negative: negate
        bit     7,a
        jr      z,lmods_dvd_pos
        ld      de,(__ldv_dvd_l)
        ld      hl,0
        or      a
        sbc     hl,de
        ld      (__ldv_dvd_l),hl
        ld      de,(__ldv_dvd_h)
        ld      hl,0
        sbc     hl,de
        ld      (__ldv_dvd_h),hl
lmods_dvd_pos:
        ; If dvs negative: negate
        ld      a,(ix+7)
        bit     7,a
        jr      z,lmods_dvs_pos
        ld      de,(__ldv_dvs_l)
        ld      hl,0
        or      a
        sbc     hl,de
        ld      (__ldv_dvs_l),hl
        ld      de,(__ldv_dvs_h)
        ld      hl,0
        sbc     hl,de
        ld      (__ldv_dvs_h),hl
lmods_dvs_pos:
        ld      hl,0
        ld      (__ldv_rem_l),hl
        ld      (__ldv_rem_h),hl
        ld      b,32
lmods_loop:
        push    bc
        ld      hl,(__ldv_dvd_l)
        or      a
        add     hl,hl
        ld      (__ldv_dvd_l),hl
        ld      hl,(__ldv_dvd_h)
        adc     hl,hl
        ld      (__ldv_dvd_h),hl
        ld      hl,(__ldv_rem_l)
        adc     hl,hl
        ld      (__ldv_rem_l),hl
        ld      hl,(__ldv_rem_h)
        adc     hl,hl
        ld      (__ldv_rem_h),hl
        ld      hl,(__ldv_rem_l)
        ld      de,(__ldv_dvs_l)
        or      a
        sbc     hl,de
        ex      de,hl
        ld      hl,(__ldv_rem_h)
        ld      bc,(__ldv_dvs_h)
        sbc     hl,bc
        jr      c,lmods_no_sub
        ld      (__ldv_rem_h),hl
        ex      de,hl
        ld      (__ldv_rem_l),hl
lmods_no_sub:
        pop     bc
        djnz    lmods_loop
        ; Apply sign to remainder
        ld      a,(__ldv_sign)
        bit     7,a
        jr      z,lmods_pos_result
        ld      de,(__ldv_rem_l)
        ld      hl,0
        or      a
        sbc     hl,de
        ld      (__ldv_rem_l),hl
        ld      de,(__ldv_rem_h)
        ld      hl,0
        sbc     hl,de
        ld      (__ldv_rem_h),hl
lmods_pos_result:
        ld      hl,(__ldv_rem_l)
        ld      de,(__ldv_rem_h)
        ld      sp,ix
        pop     ix
        ret

; ---- 32-bit comparison functions ----
; Each returns HL=1 (true) or HL=0 (false).
; Caller cleanup (HL only): ex de,hl; ld hl,8; add hl,sp; ld sp,hl; ex de,hl

; Macro-like helper: load LHS_L into HL, RHS_L into DE, then
; load LHS_H into HL, RHS_H into DE after sbc.
; LHS at IX+8/10, RHS at IX+4/6.

        public  __ltu
__ltu:
        push    ix
        ld      ix,0
        add     ix,sp
        ld      a,(ix+8)
        ld      l,a
        ld      a,(ix+9)
        ld      h,a
        ld      a,(ix+4)
        ld      e,a
        ld      a,(ix+5)
        ld      d,a
        or      a
        sbc     hl,de
        ld      a,(ix+10)
        ld      l,a
        ld      a,(ix+11)
        ld      h,a
        ld      a,(ix+6)
        ld      e,a
        ld      a,(ix+7)
        ld      d,a
        sbc     hl,de
        ld      hl,0
        jr      nc,ltu_done
        inc     l
ltu_done:
        ld      sp,ix
        pop     ix
        ret

        public  __leu
__leu:
        ; LHS <= RHS  <==>  NOT (LHS > RHS)  <==>  NOT (RHS < LHS)
        push    ix
        ld      ix,0
        add     ix,sp
        ld      a,(ix+4)
        ld      l,a
        ld      a,(ix+5)
        ld      h,a
        ld      a,(ix+8)
        ld      e,a
        ld      a,(ix+9)
        ld      d,a
        or      a
        sbc     hl,de
        ld      a,(ix+6)
        ld      l,a
        ld      a,(ix+7)
        ld      h,a
        ld      a,(ix+10)
        ld      e,a
        ld      a,(ix+11)
        ld      d,a
        sbc     hl,de
        ; carry set iff RHS < LHS, i.e. LHS > RHS
        ld      hl,1
        jr      nc,leu_done ; RHS >= LHS, so LHS <= RHS: return 1
        ld      l,0
leu_done:
        ld      sp,ix
        pop     ix
        ret

        public  __lgu
__lgu:
        ; LHS > RHS  <==>  RHS < LHS
        push    ix
        ld      ix,0
        add     ix,sp
        ld      a,(ix+4)
        ld      l,a
        ld      a,(ix+5)
        ld      h,a
        ld      a,(ix+8)
        ld      e,a
        ld      a,(ix+9)
        ld      d,a
        or      a
        sbc     hl,de
        ld      a,(ix+6)
        ld      l,a
        ld      a,(ix+7)
        ld      h,a
        ld      a,(ix+10)
        ld      e,a
        ld      a,(ix+11)
        ld      d,a
        sbc     hl,de
        ld      hl,0
        jr      nc,gtu_done
        inc     l
gtu_done:
        ld      sp,ix
        pop     ix
        ret

        public  __lku
__lku:
        ; LHS >= RHS  <==>  NOT (LHS < RHS)
        push    ix
        ld      ix,0
        add     ix,sp
        ld      a,(ix+8)
        ld      l,a
        ld      a,(ix+9)
        ld      h,a
        ld      a,(ix+4)
        ld      e,a
        ld      a,(ix+5)
        ld      d,a
        or      a
        sbc     hl,de
        ld      a,(ix+10)
        ld      l,a
        ld      a,(ix+11)
        ld      h,a
        ld      a,(ix+6)
        ld      e,a
        ld      a,(ix+7)
        ld      d,a
        sbc     hl,de
        ld      hl,1
        jr      nc,geu_done
        ld      l,0
geu_done:
        ld      sp,ix
        pop     ix
        ret

; Signed comparisons: same as unsigned but check sign bits differently.
; For signed 32-bit a < b:
;   if sign(a) != sign(b): a < b iff a is negative
;   else: a - b has borrow (same as unsigned)
; Implemented as: (a - b) has "signed overflow" indicated by
;   (result sign != expected sign), or equivalently check
;   carry XOR overflow. Simpler: use sbc and check signed flags.
; Actually on Z80 for signed compare: after sbc hl,de on high word,
;   the S and P/V flags together indicate signed overflow.
;   Signed less-than: S xor P/V (i.e. jp m after XOR check).
;   But after 32-bit subtraction we only have the high-word flags.
;   The flags from the high-word sbc are sufficient for signed compare.

        public  __lts
__lts:
        push    ix
        ld      ix,0
        add     ix,sp
        ld      a,(ix+8)
        ld      l,a
        ld      a,(ix+9)
        ld      h,a
        ld      a,(ix+4)
        ld      e,a
        ld      a,(ix+5)
        ld      d,a
        or      a
        sbc     hl,de
        ld      a,(ix+10)
        ld      l,a
        ld      a,(ix+11)
        ld      h,a
        ld      a,(ix+6)
        ld      e,a
        ld      a,(ix+7)
        ld      d,a
        sbc     hl,de
        ; Signed less-than: S xor P/V
        ; jp pe = jump if parity/overflow set; jp m = jump if sign (negative)
        ld      hl,0
        jp      pe,lts_ov  ; overflow set
        jp      m,lts_true ; no overflow, negative â†’ LHS < RHS
        jr      lts_done
lts_ov:
        jp      p,lts_true ; overflow + positive â†’ LHS < RHS
        jr      lts_done
lts_true:
        inc     l
lts_done:
        ld      sp,ix
        pop     ix
        ret

        public  __lks
__lks:
        ; LHS >= RHS: NOT (LHS < RHS)
        push    ix
        ld      ix,0
        add     ix,sp
        ld      a,(ix+8)
        ld      l,a
        ld      a,(ix+9)
        ld      h,a
        ld      a,(ix+4)
        ld      e,a
        ld      a,(ix+5)
        ld      d,a
        or      a
        sbc     hl,de
        ld      a,(ix+10)
        ld      l,a
        ld      a,(ix+11)
        ld      h,a
        ld      a,(ix+6)
        ld      e,a
        ld      a,(ix+7)
        ld      d,a
        sbc     hl,de
        ld      hl,1
        jp      pe,ges_ov
        jp      m,ges_false
        jr      ges_done
ges_ov:
        jp      p,ges_false
        jr      ges_done
ges_false:
        ld      l,0
ges_done:
        ld      sp,ix
        pop     ix
        ret

        public  __lgs
__lgs:
        ; LHS > RHS: RHS < LHS (swap operands, do signed-lt)
        push    ix
        ld      ix,0
        add     ix,sp
        ld      a,(ix+4)
        ld      l,a
        ld      a,(ix+5)
        ld      h,a
        ld      a,(ix+8)
        ld      e,a
        ld      a,(ix+9)
        ld      d,a
        or      a
        sbc     hl,de
        ld      a,(ix+6)
        ld      l,a
        ld      a,(ix+7)
        ld      h,a
        ld      a,(ix+10)
        ld      e,a
        ld      a,(ix+11)
        ld      d,a
        sbc     hl,de
        ld      hl,0
        jp      pe,gts_ov
        jp      m,gts_true
        jr      gts_done
gts_ov:
        jp      p,gts_true
        jr      gts_done
gts_true:
        inc     l
gts_done:
        ld      sp,ix
        pop     ix
        ret

        public  __les
__les:
        ; LHS <= RHS: NOT (RHS < LHS)
        push    ix
        ld      ix,0
        add     ix,sp
        ld      a,(ix+4)
        ld      l,a
        ld      a,(ix+5)
        ld      h,a
        ld      a,(ix+8)
        ld      e,a
        ld      a,(ix+9)
        ld      d,a
        or      a
        sbc     hl,de
        ld      a,(ix+6)
        ld      l,a
        ld      a,(ix+7)
        ld      h,a
        ld      a,(ix+10)
        ld      e,a
        ld      a,(ix+11)
        ld      d,a
        sbc     hl,de
        ld      hl,1
        jp      pe,les_ov
        jp      m,les_false
        jr      les_done
les_ov:
        jp      p,les_false
        jr      les_done
les_false:
        ld      l,0
les_done:
        ld      sp,ix
        pop     ix
        ret

; ============================================================
; Heap allocator: first-fit, 2-byte block headers.
;
; Header word layout:
;   bit 15 = 1: block is free; bit 15 = 0: block is in use
;   bits 14-0 = user data size in bytes
;
; __hbase / __brk / __hlimit are set by start:.
; ============================================================

        public  _malloc
_malloc:
        push    ix
        ld      ix,0
        add     ix,sp
        ld      l,(ix+4)
        ld      h,(ix+5)        ; HL = requested size
        call    __malloc_hl
        pop     ix
        ret

        public  _calloc
_calloc:
        push    ix
        ld      ix,0
        add     ix,sp
        ld      l,(ix+4)
        ld      h,(ix+5)        ; HL = nmemb
        ld      e,(ix+6)
        ld      d,(ix+7)        ; DE = size
        call    __mulu          ; HL = nmemb * size
        call    __malloc_hl     ; HL = ptr or 0; __ml_need = total size
        push    hl              ; save ptr for return
        ld      a,h
        or      l
        jr      z,ca_done       ; NULL: skip zero fill
        ; Zero fill __ml_need bytes starting at HL
        ld      de,(__ml_need)
        ld      b,d
        ld      c,e             ; BC = count
        ld      a,b
        or      c
        jr      z,ca_done       ; nothing to zero
        xor     a
        ld      (hl),a          ; write first zero
        dec     bc
        ld      a,b
        or      c
        jr      z,ca_done       ; count was 1
        ld      d,h
        ld      e,l
        inc     de              ; DE = ptr+1
        ldir                    ; fill remaining bytes
ca_done:
        pop     hl              ; return ptr (or 0)
        pop     ix
        ret

        public  _free
_free:
        push    ix
        ld      ix,0
        add     ix,sp
        ld      l,(ix+4)
        ld      h,(ix+5)        ; HL = ptr
        ld      a,h
        or      l
        jr      z,fr_done       ; NULL: do nothing
        dec     hl              ; HL = &header[1] (high byte, holds free bit)
        ld      a,(hl)
        or      80h             ; set bit 7 = free flag
        ld      (hl),a
fr_done:
        pop     ix
        ret

; Internal: HL = requested size (0 treated as 1). Returns HL = ptr or 0.
; Corrupts AF, BC, DE, HL. Does not use/save IX.
__malloc_hl:
        ld      a,h
        or      l
        jr      nz,mh_sz_ok
        ld      l,1             ; size 0 -> 1
mh_sz_ok:
        ld      (__ml_need),hl

        ; Walk free list from __hbase to __brk
        ld      hl,(__hbase)
        ld      (__ml_p),hl

mh_walk:
        ; Stop if walk pointer has reached (or passed) __brk
        ld      hl,(__brk)
        ld      de,(__ml_p)
        or      a
        sbc     hl,de           ; HL = brk - p; carry if p > brk
        jp      z,mh_extend
        jp      c,mh_extend

        ; Read 2-byte header at __ml_p
        ld      hl,(__ml_p)
        ld      e,(hl)
        inc     hl
        ld      d,(hl)          ; DE = header: D=high (bit7=free), E=low

        ; Dispatch on free flag
        bit     7,d
        jr      z,mh_used

        ; --- Free block ---
        ; User size = DE & 0x7FFF
        ld      a,d
        and     7fh
        ld      d,a             ; DE = user_size
        ld      (__ml_usiz),de  ; save in case block is too small

        ; Compare user_size (DE) >= need (HL = __ml_need)
        ld      hl,(__ml_need)
        ex      de,hl           ; HL = user_size, DE = need
        or      a
        sbc     hl,de           ; HL = user_size - need; carry if too small
        jr      c,mh_skip_free

        ; Block fits. HL = remainder = user_size - need, DE = need.
        ; Split if remainder >= HDRSIZE+1 (= 3)
        ld      a,h
        or      a
        jr      nz,mh_split     ; high byte != 0 -> remainder >= 256 -> always split
        ld      a,l
        cp      HDRSIZE+1
        jr      nc,mh_split

        ; No split: use whole block. Restore user_size = need + remainder.
        ex      de,hl           ; HL = need, DE = remainder
        add     hl,de           ; HL = user_size
        ; Write used header (bit15=0) at __ml_p
        ld      de,(__ml_p)
        ld      a,l
        ld      (de),a
        inc     de
        ld      a,h
        and     7fh             ; clear free bit
        ld      (de),a
        ; Return __ml_p + HDRSIZE
        ld      hl,(__ml_p)
        ld      de,HDRSIZE
        add     hl,de
        ret

mh_split:
        ; HL = remainder, DE = need.
        ; Write used header at __ml_p: size=need, bit15=0
        ld      bc,(__ml_p)
        ld      a,e
        ld      (bc),a          ; header low = need_lo
        inc     bc
        ld      a,d
        and     7fh
        ld      (bc),a          ; header high = need_hi (bit15=0)
        ; Compute new free block address = __ml_p + HDRSIZE + need
        push    hl              ; save remainder
        ld      hl,(__ml_p)
        ld      de,HDRSIZE
        add     hl,de
        ld      de,(__ml_need)
        add     hl,de           ; HL = new free block address
        pop     de              ; DE = remainder
        ; New block user_size = remainder - HDRSIZE
        ld      a,e
        sub     HDRSIZE
        ld      e,a
        ld      a,d
        sbc     a,0
        ld      d,a             ; DE = new_user_size
        ; Write free header at HL
        ld      (hl),e
        inc     hl
        ld      a,d
        or      80h             ; set free bit
        ld      (hl),a
        ; Return __ml_p + HDRSIZE
        ld      hl,(__ml_p)
        ld      de,HDRSIZE
        add     hl,de
        ret

mh_skip_free:
        ; Free but too small: advance by HDRSIZE + user_size
        ld      hl,(__ml_p)
        ld      de,(__ml_usiz)
        ld      bc,HDRSIZE
        add     hl,bc
        add     hl,de
        ld      (__ml_p),hl
        jp      mh_walk

mh_used:
        ; Used block. bit15=0 so DE = user_size directly.
        ld      hl,(__ml_p)
        ld      bc,HDRSIZE
        add     hl,bc
        add     hl,de
        ld      (__ml_p),hl
        jp      mh_walk

mh_extend:
        ; No free block found. Extend heap upward.
        ; Check: brk + HDRSIZE + need <= heap_limit
        ld      hl,(__brk)
        ld      (__ml_p),hl     ; save old brk (reuse __ml_p)
        ld      de,(__ml_need)
        add     hl,de
        ld      de,HDRSIZE
        add     hl,de           ; HL = brk + need + HDRSIZE
        ld      de,(__hlimit)
        inc     de              ; allow == heap_limit (> not >=)
        or      a
        sbc     hl,de           ; carry if brk+need+HDRSIZE < heap_limit+1 (fits)
        jr      nc,mh_oom       ; no carry: out of memory

        ; Write used header at old brk
        ld      hl,(__ml_p)     ; HL = old brk
        ld      de,(__ml_need)
        ld      (hl),e
        inc     hl
        ld      a,d
        and     7fh
        ld      (hl),a
        ; Advance brk: new_brk = old_brk + HDRSIZE + need
        ld      hl,(__ml_p)
        ld      de,HDRSIZE
        add     hl,de
        ld      de,(__ml_need)
        add     hl,de
        ld      (__brk),hl
        ; Return old_brk + HDRSIZE
        ld      hl,(__ml_p)
        ld      de,HDRSIZE
        add     hl,de
        ret

        nop
        nop
        nop
        nop
        nop
mh_oom:
        ld      hl,0
        ret

; Heap state
__hbase:    dw      0
__brk:          dw      0
__hlimit:   dw      0

; Allocator temporaries
__ml_need:      dw      0
__ml_p:         dw      0
__ml_usiz:      dw      0

; ---- scratch data for long arithmetic ----
__lm_lhs_l:     dw      0
__lm_lhs_h:     dw      0
__lm_rhs_l:     dw      0
__lm_rhs_h:     dw      0
__lm_res_l:     dw      0
__lm_res_h:     dw      0

__ldv_dvs_l:    dw      0
__ldv_dvs_h:    dw      0
__ldv_dvd_l:    dw      0
__ldv_dvd_h:    dw      0
__ldv_rem_l:    dw      0
__ldv_rem_h:    dw      0
__ldv_quo_l:    dw      0
__ldv_quo_h:    dw      0
__ldv_sign:     db      0

; ============================================================
; Character classification and conversion
; ============================================================

; ---- _toupper(int c) ----
; Returns c converted to upper-case if 'a'<=c<='z', else c unchanged.
; Arg: c @ IX+4/5.  Return: HL = result.
        public  _toupper
_toupper:
        push    ix
        ld      ix,0
        add     ix,sp
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      a,l
        cp      'a'             ; c < 'a' -> leave as-is
        jr      c,toup_done
        cp      'z'+1           ; c > 'z' -> leave as-is
        jr      nc,toup_done
        sub     20h             ; lowercase -> uppercase
        ld      l,a
        ld      h,0
toup_done:
        pop     ix
        ret

; ---- _isspace(int c) ----
; Returns HL=1 if c is a whitespace character, HL=0 otherwise.
; Recognises: SP HT LF VT FF CR.
        public  _isspace
_isspace:
        push    ix
        ld      ix,0
        add     ix,sp
        ld      a,(ix+4)
        cp      ' '
        jr      z,issp_yes
        cp      09h             ; HT
        jr      z,issp_yes
        cp      0ah             ; LF
        jr      z,issp_yes
        cp      0bh             ; VT
        jr      z,issp_yes
        cp      0ch             ; FF
        jr      z,issp_yes
        cp      0dh             ; CR
        jr      z,issp_yes
        ld      hl,0
        pop     ix
        ret
issp_yes:
        ld      hl,1
        pop     ix
        ret

; ---- _isdigit(int c) ----
; Returns HL=1 if '0'<=c<='9', HL=0 otherwise.
        public  _isdigit
_isdigit:
        push    ix
        ld      ix,0
        add     ix,sp
        ld      a,(ix+4)
        cp      '0'
        jr      c,isdig_no
        cp      '9'+1
        jr      nc,isdig_no
        ld      hl,1
        pop     ix
        ret
isdig_no:
        ld      hl,0
        pop     ix
        ret

; ---- _fgets(char *buf, int size, FILE *fp) ----
; fp < 3 (stdin/stdout/stderr) → read from console via BDOS fn 1.
; fp >= 3 (real file) → read char-by-char using _read.
; Returns HL = buf on success, HL = 0 at EOF or if size <= 0.
; Args: buf @ IX+4/5,  size @ IX+6/7,  fp @ IX+8/9.
        public  _fgets
_fgets:
        push    ix
        ld      ix,0
        add     ix,sp

        ; if size <= 0 return NULL immediately
        ld      l,(ix+6)
        ld      h,(ix+7)
        ld      a,h
        or      l
        jp      z,fgets_null

        ; dispatch on fp: < 3 → console, >= 3 → file
        ld      a,(ix+8)
        cp      FIRSTFD
        jp      c,fgets_con

        ; ---- File path ----
        ; Check EOF flag for this slot
        sub     FIRSTFD                 ; A = slot
        ld      h,0
        ld      l,a
        ld      de,__fdeof
        add     hl,de
        ld      a,(hl)
        or      a
        jp      nz,fgets_null           ; already at EOF

        ; Set up: rem = size-1, ptr = buf, start = buf
        ld      l,(ix+6)
        ld      h,(ix+7)
        dec     hl
        ld      (__fgets_rem),hl
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      (__fgets_ptr),hl
        ld      (__fgets_start),hl

fgf_loop:
        ld      hl,(__fgets_rem)
        ld      a,h
        or      l
        jp      z,fgets_term            ; buffer full

        ; _read(fp, &__fgets_ch, 1)
        ld      hl,1
        push    hl                      ; count=1
        ld      hl,__fgets_ch
        push    hl                      ; buf
        ld      l,(ix+8)
        ld      h,(ix+9)
        push    hl                      ; fp
        call    _read
        ex      de,hl                   ; DE = bytes read
        ld      hl,6
        add     hl,sp
        ld      sp,hl                   ; clean 3 args
        ex      de,hl                   ; HL = bytes read

        ld      a,h
        or      l
        jr      z,fgf_eof               ; read 0 bytes → EOF

        ld      a,(__fgets_ch)
        cp      1ah                     ; Ctrl-Z = CP/M EOF marker
        jr      z,fgf_eof

        ; store char
        ld      hl,(__fgets_ptr)
        ld      (hl),a
        inc     hl
        ld      (__fgets_ptr),hl
        ld      hl,(__fgets_rem)
        dec     hl
        ld      (__fgets_rem),hl
        cp      0ah                     ; LF → end of line
        jr      z,fgets_term
        jr      fgf_loop

fgf_eof:
        ; set EOF flag for this slot
        ld      a,(ix+8)
        sub     FIRSTFD
        ld      h,0
        ld      l,a
        ld      de,__fdeof
        add     hl,de
        ld      (hl),1
        ; if no chars were stored → return NULL
        ld      hl,(__fgets_ptr)
        ld      de,(__fgets_start)
        or      a
        sbc     hl,de
        jp      z,fgets_null            ; ptr == start → nothing read
        ; else: NUL-terminate and return buf
        jr      fgets_term

        ; ---- Console path ----
fgets_con:
        ; HL still = size (loaded at top); compute rem = size-1
        ld      l,(ix+6)
        ld      h,(ix+7)
        dec     hl
        ld      (__fgets_rem),hl
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      (__fgets_ptr),hl

fgets_loop:
        ld      hl,(__fgets_rem)
        ld      a,h
        or      l
        jr      z,fgets_term

        ld      c,1
        call    5                       ; BDOS fn 1: console input → A

        cp      1ah                     ; Ctrl-Z → EOF
        jr      z,fgets_term

        cp      0dh                     ; CR → translate to LF, end line
        jr      nz,fgets_store
        ld      e,0ah
        ld      c,2
        call    5                       ; echo LF
        ld      a,0ah

fgets_store:
        ld      b,a
        ld      hl,(__fgets_ptr)
        ld      (hl),b
        inc     hl
        ld      (__fgets_ptr),hl
        ld      hl,(__fgets_rem)
        dec     hl
        ld      (__fgets_rem),hl
        ld      a,b
        cp      0ah
        jr      z,fgets_term
        jr      fgets_loop

fgets_term:
        ld      hl,(__fgets_ptr)
        ld      (hl),0
        ld      l,(ix+4)
        ld      h,(ix+5)
        pop     ix
        ret

fgets_null:
        ld      hl,0
        pop     ix
        ret

__fgets_ptr:    dw      0
__fgets_rem:    dw      0
__fgets_ch:     db      0
__fgets_start:  dw      0

; ============================================================
; printf/sprintf/fprintf shared data
; ============================================================
pf_sink:        dw      0       ; 0=console, 0FFFFh=buffer
pf_bufptr:      dw      0       ; write pointer for sprintf/fprintf
__pf_cnt:       dw      0       ; char count saved by fprintf
__pf_fbuf:      ds      256     ; static buffer for fprintf

; ============================================================
; _sprintf(buf, fmt, ...)
; IX+4=buf, IX+6=fmt, IX+8=first vararg
; ============================================================
        public  _sprintf
_sprintf:
        push    ix
        ld      ix,0
        add     ix,sp
        push    bc
        push    de
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      (pf_bufptr),hl          ; pf_bufptr = buf
        ld      hl,0FFFFh
        ld      (pf_sink),hl            ; buffer mode
        ld      l,(ix+6)
        ld      h,(ix+7)                ; HL = fmt (second arg)
        ld      de,8                    ; first vararg at IX+8
        ld      bc,0
        call    __pf_run                ; IX = _sprintf's frame; varargs at IX+8+
        ld      hl,(pf_bufptr)
        ld      (hl),0                  ; NUL-terminate
        ld      h,b
        ld      l,c                     ; return count
        pop     de
        pop     bc
        pop     ix
        ret

; ============================================================
; _fprintf(fp, fmt, ...)
; IX+4=fp, IX+6=fmt, IX+8=first vararg
; Formats into __pf_fbuf, then writes to fp via _write.
; ============================================================
        public  _fprintf
_fprintf:
        push    ix
        ld      ix,0
        add     ix,sp
        push    bc
        push    de
        ld      hl,__pf_fbuf
        ld      (pf_bufptr),hl          ; output to static buffer
        ld      hl,0FFFFh
        ld      (pf_sink),hl            ; buffer mode
        ld      l,(ix+6)
        ld      h,(ix+7)                ; HL = fmt
        ld      de,8                    ; first vararg at IX+8
        ld      bc,0
        call    __pf_run                ; IX = _fprintf's frame
        ld      h,b
        ld      l,c
        ld      (__pf_cnt),hl           ; save count
        ld      hl,(pf_bufptr)
        ld      (hl),0                  ; NUL-terminate
        ; _write(fp, __pf_fbuf, count)
        ld      hl,(__pf_cnt)
        push    hl                      ; count
        ld      hl,__pf_fbuf
        push    hl                      ; buf
        ld      l,(ix+4)
        ld      h,(ix+5)
        push    hl                      ; fp
        call    _write
        ex      de,hl
        ld      hl,6
        add     hl,sp
        ld      sp,hl                   ; clean 3 args
        ld      hl,(__pf_cnt)           ; return char count
        pop     de
        pop     bc
        pop     ix
        ret

; ============================================================
; _puts(str)  –  write str + '\n' to stdout.
; ============================================================
        public  _puts
_puts:
        push    ix
        ld      ix,0
        add     ix,sp
        ld      l,(ix+4)
        ld      h,(ix+5)                ; str
puts_loop:
        ld      a,(hl)
        or      a
        jr      z,puts_nl
        ld      e,a
        call    __conout
        inc     hl
        jr      puts_loop
puts_nl:
        ld      e,0ah
        call    __conout                ; '\n' (with CR+LF translation)
        ld      hl,0
        pop     ix
        ret

; ============================================================
; _fopen(path, mode)
; path @ IX+4/5, mode @ IX+6/7
; Returns HL = FILE* (fd 3..6) or HL = 0 on failure.
; ============================================================
        public  _fopen
_fopen:
        push    ix
        ld      ix,0
        add     ix,sp
        ld      l,(ix+6)
        ld      h,(ix+7)
        ld      a,(hl)                  ; first char of mode
        ld      hl,0
        cp      'r'
        jr      z,fo_doit               ; flags=0: open existing
        ld      hl,0240h
        cp      'w'
        jr      z,fo_doit               ; flags=O_CREAT|O_TRUNC
        ld      hl,0040h                ; "a" or other: O_CREAT only
fo_doit:
        push    hl                      ; flags (second arg to _open)
        ld      l,(ix+4)
        ld      h,(ix+5)
        push    hl                      ; path (first arg)
        call    _open
        pop     de
        pop     de                      ; clean 4 bytes
        ld      a,h
        cp      0FFh
        jr      z,fo_fail               ; _open returned -1
        ; Clear EOF and error flags for the new slot
        push    hl                      ; save fd
        ld      a,l
        sub     FIRSTFD
        ld      e,a
        ld      d,0
        ld      hl,__fdeof
        add     hl,de
        xor     a
        ld      (hl),a
        ld      hl,__fderr
        add     hl,de
        ld      (hl),a
        ; Initialize file position to zero for this slot
        ld      hl,__fdoff
        add     hl,de           ; HL = __fdoff + slot
        add     hl,de           ; HL = __fdoff + slot*2
        add     hl,de           ; HL = __fdoff + slot*3
        add     hl,de           ; HL = __fdoff + slot*4
        xor     a               ; A already 0 but be explicit
        ld      (hl),a
        inc     hl
        ld      (hl),a
        inc     hl
        ld      (hl),a
        inc     hl
        ld      (hl),a
        pop     hl                      ; restore fd = FILE*
        pop     ix
        ret
fo_fail:
        ld      hl,0
        pop     ix
        ret

; ============================================================
; _fclose(fp)
; ============================================================
        public  _fclose
_fclose:
        push    ix
        ld      ix,0
        add     ix,sp
        ld      l,(ix+4)
        ld      h,(ix+5)
        push    hl                      ; fp
        call    _close
        pop     de                      ; clean 2 bytes
        pop     ix
        ret                             ; HL = 0 (ok) or -1 (error)

; ============================================================
; _fputs(str, fp)
; fp < 3 → console output;  fp >= 3 → _write to file.
; ============================================================
        public  _fputs
_fputs:
        push    ix
        ld      ix,0
        add     ix,sp
        ld      a,(ix+6)                ; fp (low byte)
        cp      FIRSTFD
        jr      nc,fputs_file
        ; console path
        ld      l,(ix+4)
        ld      h,(ix+5)
fputs_con:
        ld      a,(hl)
        or      a
        jr      z,fputs_con_done
        ld      e,a
        call    __conout
        inc     hl
        jr      fputs_con
fputs_con_done:
        ld      hl,0
        pop     ix
        ret
fputs_file:
        ; compute strlen(str)
        ld      l,(ix+4)
        ld      h,(ix+5)
        push    hl
        ld      bc,0
fputs_sl:
        ld      a,(hl)
        or      a
        jr      z,fputs_sl_done
        inc     hl
        inc     bc
        jr      fputs_sl
fputs_sl_done:
        pop     hl                      ; str
        ; _write(fp, str, len)
        push    bc                      ; len
        push    hl                      ; str
        ld      l,(ix+6)
        ld      h,(ix+7)
        push    hl                      ; fp
        call    _write
        ex      de,hl
        ld      hl,6
        add     hl,sp
        ld      sp,hl
        ex      de,hl                   ; HL = _write return value
        pop     ix
        ret

; ============================================================
; _fread(buf, size, count, fp)
; IX+4=buf, IX+6=size, IX+8=count, IX+10=fp
; Returns HL = number of items read.
; ============================================================
        public  _fread
_fread:
        push    ix
        ld      ix,0
        add     ix,sp
        ; nbytes = size * count
        ld      l,(ix+6)
        ld      h,(ix+7)                ; HL = size
        ld      e,(ix+8)
        ld      d,(ix+9)                ; DE = count
        call    __mulu                  ; HL = size * count
        ld      (__frw_nb),hl
        ; _read(fp, buf, nbytes)
        push    hl                      ; nbytes
        ld      l,(ix+4)
        ld      h,(ix+5)
        push    hl                      ; buf
        ld      l,(ix+10)
        ld      h,(ix+11)
        push    hl                      ; fp
        call    _read
        ex      de,hl
        ld      hl,6
        add     hl,sp
        ld      sp,hl
        ex      de,hl                   ; HL = bytes_read
        ; if bytes_read < nbytes → set EOF
        push    hl
        ld      de,(__frw_nb)
        or      a
        sbc     hl,de
        jr      nc,frd_neof
        ld      a,(ix+10)
        sub     FIRSTFD
        jr      c,frd_neof
        ld      h,0
        ld      l,a
        ld      de,__fdeof
        add     hl,de
        ld      (hl),1
frd_neof:
        pop     hl                      ; bytes_read
        ; return bytes_read / size
        ld      e,(ix+6)
        ld      d,(ix+7)
        call    __divu                  ; HL = items read
        pop     ix
        ret

__frw_nb:       dw      0

; ============================================================
; _fwrite(buf, size, count, fp)
; IX+4=buf, IX+6=size, IX+8=count, IX+10=fp
; Returns HL = number of items written.
; ============================================================
        public  _fwrite
_fwrite:
        push    ix
        ld      ix,0
        add     ix,sp
        ; nbytes = size * count
        ld      l,(ix+6)
        ld      h,(ix+7)
        ld      e,(ix+8)
        ld      d,(ix+9)
        call    __mulu
        ; _write(fp, buf, nbytes)
        push    hl                      ; nbytes
        ld      l,(ix+4)
        ld      h,(ix+5)
        push    hl                      ; buf
        ld      l,(ix+10)
        ld      h,(ix+11)
        push    hl                      ; fp
        call    _write
        ex      de,hl
        ld      hl,6
        add     hl,sp
        ld      sp,hl
        ex      de,hl                   ; HL = bytes_written
        ; return bytes_written / size
        ld      e,(ix+6)
        ld      d,(ix+7)
        call    __divu
        pop     ix
        ret

; ============================================================
; _fseek(fp, offset, whence)  →  delegates to _lseek; clears EOF.
; ============================================================
        public  _fseek
_fseek:
        push    ix
        ld      ix,0
        add     ix,sp

        ; int fseek(FILE *fp, long offset, int whence)
        ; ix+4/5   fp/fd
        ; ix+6..9  offset, low word then high word
        ; ix+10/11 whence
        ;
        ; Call long lseek(int fd, long offset, int whence).
        ld      l,(ix+10)
        ld      h,(ix+11)
        push    hl                      ; whence

        ld      l,(ix+8)
        ld      h,(ix+9)
        push    hl                      ; offset high word

        ld      l,(ix+6)
        ld      h,(ix+7)
        push    hl                      ; offset low word

        ld      l,(ix+4)
        ld      h,(ix+5)
        push    hl                      ; fp/fd

        call    _lseek

        ; Pop 8 bytes of arguments.
        push    de
        push    hl
        ld      hl,8
        add     hl,sp
        ld      sp,hl
        pop     hl
        pop     de

        ; lseek failure is -1L == DE:HL all ones.
        ld      a,h
        cp      0ffh
        jr      nz,fseek_ok_clear
        ld      a,l
        cp      0ffh
        jr      nz,fseek_ok_clear
        ld      a,d
        cp      0ffh
        jr      nz,fseek_ok_clear
        ld      a,e
        cp      0ffh
        jr      nz,fseek_ok_clear
        jr      fseek_bad

fseek_ok_clear:
        ; clear EOF flag
        ld      a,(ix+4)
        sub     FIRSTFD
        jr      c,fseek_ok
        ld      h,0
        ld      l,a
        ld      de,__fdeof
        add     hl,de
        ld      (hl),0
fseek_ok:
        ld      hl,0
        pop     ix
        ret
fseek_bad:
        ld      hl,0FFFFh
        pop     ix
        ret


; ============================================================
; _ftell(fp)  →  returns current file position (low 16 bits).
; ============================================================
        public  _ftell
_ftell:
        push    ix
        ld      ix,0
        add     ix,sp
        ld      a,(ix+4)
        sub     FIRSTFD
        jr      c,ftell_bad
        cp      NFILES
        jr      nc,ftell_bad
        ld      (__slot),a
        call    __offp                  ; HL → 32-bit offset table entry
        ld      e,(hl)
        inc     hl
        ld      d,(hl)                  ; DE = low 16 bits of file position
        inc     hl
        ld      a,(hl)
        inc     hl
        ld      h,(hl)
        ld      l,a                     ; HL = high 16 bits of file position
        ex      de,hl                   ; HL = low 16 bits, DE = high 16 bits
        pop     ix
        ret
ftell_bad:
        ld      hl,0FFFFh
        ld      de,0FFFFh
        pop     ix
        ret

; ============================================================
; _rewind(fp)  →  seek to 0, clear EOF.
; ============================================================
        public  _rewind
_rewind:
        push    ix
        ld      ix,0
        add     ix,sp
        ld      hl,0
        push    hl                      ; whence=0
        push    hl                      ; offset=0
        ld      l,(ix+4)
        ld      h,(ix+5)
        push    hl                      ; fp
        call    _lseek
        ex      de,hl
        ld      hl,6
        add     hl,sp
        ld      sp,hl
        ; clear EOF flag
        ld      a,(ix+4)
        sub     FIRSTFD
        jr      c,rewind_ret
        ld      h,0
        ld      l,a
        ld      de,__fdeof
        add     hl,de
        ld      (hl),0
rewind_ret:
        ld      hl,0
        pop     ix
        ret

; ============================================================
; _feof(fp)  →  returns HL=1 if EOF, HL=0 otherwise.
; ============================================================
        public  _feof
_feof:
        push    ix
        ld      ix,0
        add     ix,sp
        ld      a,(ix+4)
        sub     FIRSTFD
        jr      c,feof_no
        cp      NFILES
        jr      nc,feof_no
        ld      h,0
        ld      l,a
        ld      de,__fdeof
        add     hl,de
        ld      a,(hl)
        ld      l,a
        ld      h,0
        pop     ix
        ret
feof_no:
        ld      hl,0
        pop     ix
        ret

; ============================================================
; _ferror(fp)  →  returns HL=1 if error, HL=0 otherwise.
; ============================================================
        public  _ferror
_ferror:
        push    ix
        ld      ix,0
        add     ix,sp
        ld      a,(ix+4)
        sub     FIRSTFD
        jr      c,ferr_no
        cp      NFILES
        jr      nc,ferr_no
        ld      h,0
        ld      l,a
        ld      de,__fderr
        add     hl,de
        ld      a,(hl)
        ld      l,a
        ld      h,0
        pop     ix
        ret
ferr_no:
        ld      hl,0
        pop     ix
        ret

; ============================================================
; _scanf, _sscanf, _fscanf  –  stubs (return 0).
; ============================================================
        public  _scanf
        public  _sscanf
        public  _fscanf
_scanf:
_sscanf:
_fscanf:
        ld      hl,0
        ret

; ============================================================
; Additional data
; ============================================================
__fdeof:        ds      4       ; EOF flag per slot (index = fd - FIRSTFD)
__fderr:        ds      4       ; error flag per slot

; ============================================================
; setjmp / longjmp  (C89)
;
; jmp_buf layout (stored at the address passed as first arg):
;   [0,1] = saved return address (where setjmp "returns" to)
;   [2,3] = saved SP  (= IX+4 at time of setjmp call, i.e. the SP
;            after ret from setjmp, pointing at the env argument)
;   [4,5] = saved IX  (caller's frame pointer)
;   [6,7] = padding
;
; Z80/dcc calling convention at entry to _setjmp:
;   (IX+0,1) = old IX pushed by prologue
;   (IX+2,3) = return address
;   (IX+4,5) = env pointer (first argument = &jmp_buf)
; ============================================================

        public  _setjmp
_setjmp:
        push    ix
        ld      ix,0
        add     ix,sp
        ; HL = env pointer (jmp_buf address)
        ld      l,(ix+4)
        ld      h,(ix+5)

        ; env[0,1] = return address
        ld      a,(ix+2)
        ld      (hl),a
        inc     hl
        ld      a,(ix+3)
        ld      (hl),a
        inc     hl

        ; env[2,3] = saved SP = IX + 4
        ;   (after ret from _setjmp, SP will point to env arg slot = IX+4)
        push    ix
        pop     de              ; DE = current IX value
        ld      a,e
        add     a,4
        ld      (hl),a
        inc     hl
        ld      a,d
        adc     a,0
        ld      (hl),a
        inc     hl

        ; env[4,5] = saved IX (caller's frame pointer = old IX at (IX+0,1))
        ld      a,(ix+0)
        ld      (hl),a
        inc     hl
        ld      a,(ix+1)
        ld      (hl),a

        ; return 0
        ld      hl,0
        ld      sp,ix
        pop     ix
        ret

; ============================================================
        public  _longjmp
_longjmp:
        push    ix
        ld      ix,0
        add     ix,sp
        ; (IX+4,5) = env pointer
        ; (IX+6,7) = val (must not be 0; if 0 return 1 per C standard)

        ; Get return value, ensure != 0
        ld      l,(ix+6)
        ld      h,(ix+7)
        ld      a,h
        or      l
        jr      nz,lj_nonzero
        ld      hl,1
lj_nonzero:
        ld      (lj_val),hl

        ; Load env pointer
        ld      l,(ix+4)
        ld      h,(ix+5)

        ; Read env[0,1] = saved return address
        ld      a,(hl)
        ld      (lj_retaddr),a
        inc     hl
        ld      a,(hl)
        ld      (lj_retaddr+1),a
        inc     hl

        ; Read env[2,3] = saved SP
        ld      a,(hl)
        ld      (lj_sp),a
        inc     hl
        ld      a,(hl)
        ld      (lj_sp+1),a
        inc     hl

        ; Read env[4,5] = saved IX
        ld      a,(hl)
        ld      (lj_ix),a
        inc     hl
        ld      a,(hl)
        ld      (lj_ix+1),a

        ; Restore SP (points to env arg slot in original setjmp call frame)
        ld      hl,(lj_sp)
        ld      sp,hl

        ; Restore IX (caller's frame pointer)
        ld      hl,(lj_ix)
        push    hl
        pop     ix

        ; Push return address so RET jumps to setjmp call site
        ld      hl,(lj_retaddr)
        push    hl

        ; Load return value into HL
        ld      hl,(lj_val)

        ; Jump to setjmp call site — HL is the return value
        ret

lj_val:         dw      0
lj_retaddr:     dw      0
lj_sp:          dw      0
lj_ix:          dw      0



; ============================================================
; Minimal CP/M dirent API
;
; Supports:
;   DIR *opendir(const char *path);     ; macro -> dopn
;   struct dirent *readdir(DIR *dirp);  ; macro -> drd
;   int closedir(DIR *dirp);         ; macro -> dcls
;   void perror(const char *s);
;
; This is intentionally small and CP/M-2.2-oriented.  opendir("."),
; opendir("*.*"), and opendir("A:") enumerate all files on the selected
; drive.  Other path strings are accepted but treated as wildcard scans;
; CP/M has no hierarchical directories.
; ============================================================
        public  _dopn
_dopn:
        push    ix
        ld      ix,0
        add     ix,sp

        ; Clear FCB.
        ld      hl,__drfcb
        ld      de,__drfcb+1
        ld      bc,35
        ld      (hl),0
        ldir

        ; Optional drive letter: "A:" -> 1, "B:" -> 2, ...
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      a,(hl)
        or      a
        jr      z,__drod0
        inc     hl
        ld      b,(hl)
        dec     hl
        ld      a,b
        cp      ':'
        jr      nz,__drod0
        ld      a,(hl)
        cp      'a'
        jr      c,__drod1
        cp      'z'+1
        jr      nc,__drod1
        sub     20h
__drod1:
        cp      'A'
        jr      c,__drod0
        cp      'Z'+1
        jr      nc,__drod0
        sub     'A'-1
        ld      (__drfcb),a
__drod0:

        ; Wildcard name/ext: ???????????
        ld      hl,__drfcb+1
        ld      b,11
__drofq:
        ld      (hl),'?'
        inc     hl
        djnz    __drofq

        ; Set DMA buffer.
        ld      c,26
        ld      de,__drdma
        call    5

        ; Find first.
        ld      c,17
        ld      de,__drfcb
        call    5
        cp      0ffh
        jr      nz,__droky
        ld      hl,0
        pop     ix
        ret

__droky:
        ld      (__dridx),a
        xor     a
        ld      (__drdn),a
        inc     a
        ld      (__drhav),a
        ld      hl,__dirob
        pop     ix
        ret

        public  _drd
_drd:
        push    ix
        ld      ix,0
        add     ix,sp

        ; NULL DIR* or done -> NULL.
        ld      a,(ix+4)
        or      (ix+5)
        jr      z,__drnul
        ld      a,(__drdn)
        or      a
        jr      nz,__drnul

        ; If opendir already has a current result, consume it; otherwise
        ; ask BDOS for the next result.
        ld      a,(__drhav)
        or      a
        jr      nz,__drcur

        ld      c,18
        ld      de,__drfcb
        call    5
        cp      0ffh
        jr      nz,__drnxt
        ld      (__drdn),a
__drnul:
        ld      hl,0
        pop     ix
        ret

__drnxt:
        ld      (__dridx),a
__drcur:
        xor     a
        ld      (__drhav),a

        ; HL = __drdma + result_index * 32
        ld      a,(__dridx)
        add     a,a
        add     a,a
        add     a,a
        add     a,a
        add     a,a
        ld      e,a
        ld      d,0
        ld      hl,__drdma
        add     hl,de
        inc     hl              ; skip user byte; now at 8-byte name
        ld      de,__drent

        ; Copy base name, trimming spaces/high attribute bits.
        ld      b,8
__drnam:
        ld      a,(hl)
        and     7fh
        cp      ' '
        jr      z,__drnsp
        ld      (de),a
        inc     de
__drnsp:
        inc     hl
        djnz    __drnam

        ; Extension: if first ext char is non-space, add '.' and copy the
        ; non-space extension chars.
        ld      a,(hl)
        and     7fh
        cp      ' '
        jr      z,__drter
        ld      a,'.'
        ld      (de),a
        inc     de
        ld      b,3
__drext:
        ld      a,(hl)
        and     7fh
        cp      ' '
        jr      z,__dresp
        ld      (de),a
        inc     de
__dresp:
        inc     hl
        djnz    __drext

__drter:
        xor     a
        ld      (de),a
        ld      hl,__drent
        pop     ix
        ret

        public  _dcls
_dcls:
        ld      a,1
        ld      (__drdn),a
        ld      hl,0
        ret

        public  _perror
_perror:
        push    ix
        ld      ix,0
        add     ix,sp
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      a,h
        or      l
        jr      z,__prmsg
__prlp:
        ld      a,(hl)
        or      a
        jr      z,__prcol
        ld      e,a
        call    __conout
        inc     hl
        jr      __prlp
__prcol:
        ld      e,':'
        call    __conout
        ld      e,' '
        call    __conout
__prmsg:
        ld      hl,__prtxt
__prlp2:
        ld      a,(hl)
        or      a
        jr      z,__prend
        ld      e,a
        call    __conout
        inc     hl
        jr      __prlp2
__prend:
        ld      hl,0
        pop     ix
        ret

__prtxt:        db      'error',0ah,0

; Opaque DIR object, FCB, DMA buffer, and one static dirent.  This API is
; deliberately non-reentrant, matching the tiny CP/M runtime style.
__dirob:        db      0
__dridx:        db      0
__drhav:        db      0
__drdn:         db      1
__drfcb:        ds      36
__drdma:        ds      128
__drent:        ds      13



; ---------------------------------------------------------------------------
; IEEE-754 single precision float core, phase 1.
;
; ABI convention for opaque float values matches dcc's existing 32-bit value
; convention: DE:HL holds the raw IEEE bits, with HL = low word and DE = high
; word.  In memory this is little-endian: byte0, byte1, byte2, byte3.
;
; These helpers intentionally do not implement arithmetic yet.  They provide
; classification/sign primitives and real IEEE-aware equality/inequality that
; later arithmetic/conversion routines can build on.  Kept as separate PUBLIC
; blocks so dccrtlstrip can remove them when no float operation references them.
; ---------------------------------------------------------------------------

        public  __fzro
__fzro:
        ; input DE:HL raw float. return HL=1 if +/-0.0, else 0.
        ld      a,d
        and     7fh
        or      e
        or      h
        or      l
        jp      z,__fzr1
        ld      hl,0
        ret
__fzr1:
        ld      hl,1
        ret

        public  __fnan
__fnan:
        ; input DE:HL raw float. return HL=1 if NaN, else 0.
        ld      a,d
        and     7fh
        cp      7fh
        jp      nz,__fnn0
        ld      a,e
        and     80h
        jp      z,__fnn0
        ld      a,e
        and     7fh
        or      h
        or      l
        jp      z,__fnn0
        ld      hl,1
        ret
__fnn0:
        ld      hl,0
        ret

        public  __finf
__finf:
        ; input DE:HL raw float. return HL=1 if +/-Inf, else 0.
        ld      a,d
        and     7fh
        cp      7fh
        jp      nz,__fif0
        ld      a,e
        and     80h
        jp      z,__fif0
        ld      a,e
        and     7fh
        or      h
        or      l
        jp      nz,__fif0
        ld      hl,1
        ret
__fif0:
        ld      hl,0
        ret

        public  __fabs
__fabs:
        ; input/output DE:HL raw float. clear sign bit.
        ld      a,d
        and     7fh
        ld      d,a
        ret

        public  __fchs
__fchs:
        ; input/output DE:HL raw float. toggle sign bit.
        ld      a,d
        xor     80h
        ld      d,a
        ret

        public  __fsgn
__fsgn:
        ; input DE:HL raw float. return HL=1 if sign bit set, else 0.
        bit     7,d
        jp      nz,__fsg1
        ld      hl,0
        ret
__fsg1:
        ld      hl,1
        ret

        public  __feq
__feq:
        ; int __feq(float a, float b)
        ; IEEE-aware equality for phase 1: NaN compares false, +0 == -0.
        push    ix
        ld      ix,0
        add     ix,sp

        ; if a is NaN, false
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      e,(ix+6)
        ld      d,(ix+7)
        call    __fnan
        ld      a,h
        or      l
        jp      nz,__feq0

        ; if b is NaN, false
        ld      l,(ix+8)
        ld      h,(ix+9)
        ld      e,(ix+10)
        ld      d,(ix+11)
        call    __fnan
        ld      a,h
        or      l
        jp      nz,__feq0

        ; if a is zero, true only when b is also zero
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      e,(ix+6)
        ld      d,(ix+7)
        call    __fzro
        ld      a,h
        or      l
        jp      z,__feq_cmp
        ld      l,(ix+8)
        ld      h,(ix+9)
        ld      e,(ix+10)
        ld      d,(ix+11)
        call    __fzro
        ld      a,h
        or      l
        jp      nz,__feq1
        jp      __feq0

__feq_cmp:
        ; raw bit compare for all non-zero, non-NaN values
        ld      a,(ix+4)
        cp      (ix+8)
        jp      nz,__feq0
        ld      a,(ix+5)
        cp      (ix+9)
        jp      nz,__feq0
        ld      a,(ix+6)
        cp      (ix+10)
        jp      nz,__feq0
        ld      a,(ix+7)
        cp      (ix+11)
        jp      nz,__feq0
__feq1:
        ld      hl,1
        ld      sp,ix
        pop     ix
        ret
__feq0:
        ld      hl,0
        ld      sp,ix
        pop     ix
        ret

        public  __fneq
__fneq:
        ; int __fneq(float a, float b) -- logical inverse of __feq.
        push    ix
        ld      ix,0
        add     ix,sp

        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      e,(ix+6)
        ld      d,(ix+7)
        call    __fnan
        ld      a,h
        or      l
        jp      nz,__fnq1

        ld      l,(ix+8)
        ld      h,(ix+9)
        ld      e,(ix+10)
        ld      d,(ix+11)
        call    __fnan
        ld      a,h
        or      l
        jp      nz,__fnq1

        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      e,(ix+6)
        ld      d,(ix+7)
        call    __fzro
        ld      a,h
        or      l
        jp      z,__fnq_cmp
        ld      l,(ix+8)
        ld      h,(ix+9)
        ld      e,(ix+10)
        ld      d,(ix+11)
        call    __fzro
        ld      a,h
        or      l
        jp      nz,__fnq0
        jp      __fnq1

__fnq_cmp:
        ld      a,(ix+4)
        cp      (ix+8)
        jp      nz,__fnq1
        ld      a,(ix+5)
        cp      (ix+9)
        jp      nz,__fnq1
        ld      a,(ix+6)
        cp      (ix+10)
        jp      nz,__fnq1
        ld      a,(ix+7)
        cp      (ix+11)
        jp      nz,__fnq1
__fnq0:
        ld      hl,0
        ld      sp,ix
        pop     ix
        ret
__fnq1:
        ld      hl,1
        ld      sp,ix
        pop     ix
        ret


; ---------------------------------------------------------------------------
; IEEE-754 single precision ordered comparisons, phase 2.
;
; C-style ordered comparisons return false when either operand is NaN.
; +0.0 and -0.0 compare equal.  For all other values, comparison is done by
; sign first, then raw IEEE magnitude ordering.  This is enough for correct
; < <= > >= without doing any arithmetic.
;
; Calling convention: first arg at IX+4..IX+7, second arg at IX+8..IX+11.
; Return HL=1 for true, HL=0 for false.
; ---------------------------------------------------------------------------

        public  __flt
__flt:
        ; int __flt(float a, float b) -- a < b
        push    ix
        ld      ix,0
        add     ix,sp

        ; Fast path: both positive non-NaN. For positive IEEE singles (sign=0,
        ; exp<255), raw byte ordering matches numeric ordering, so skip NaN/zero
        ; checks and compare directly.
        ld      a,(ix+7)
        ld      b,a
        ld      a,(ix+11)
        or      b               ; both sign bits must be 0
        and     80h
        jp      nz,__flt_slow
        ld      a,(ix+7)
        and     7fh
        cp      7fh
        jp      z,__flt_slow    ; a: D&7F==7F => might be NaN/Inf
        ld      a,(ix+11)
        and     7fh
        cp      7fh
        jp      z,__flt_slow    ; b: D&7F==7F => might be NaN/Inf
        ld      a,(ix+7)
        cp      (ix+11)
        jp      c,__flt1
        jp      nz,__flt0
        ld      a,(ix+6)
        cp      (ix+10)
        jp      c,__flt1
        jp      nz,__flt0
        ld      a,(ix+5)
        cp      (ix+9)
        jp      c,__flt1
        jp      nz,__flt0
        ld      a,(ix+4)
        cp      (ix+8)
        jp      c,__flt1
        jp      __flt0

__flt_slow:
        ; NaN => false
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      e,(ix+6)
        ld      d,(ix+7)
        call    __fnan
        ld      a,h
        or      l
        jp      nz,__flt0
        ld      l,(ix+8)
        ld      h,(ix+9)
        ld      e,(ix+10)
        ld      d,(ix+11)
        call    __fnan
        ld      a,h
        or      l
        jp      nz,__flt0

        ; both zero => false
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      e,(ix+6)
        ld      d,(ix+7)
        call    __fzro
        push    hl
        ld      l,(ix+8)
        ld      h,(ix+9)
        ld      e,(ix+10)
        ld      d,(ix+11)
        call    __fzro
        pop     de
        ld      a,d
        or      e
        jp      z,__flt_sign
        ld      a,h
        or      l
        jp      nz,__flt0

__flt_sign:
        ; different signs: negative < positive
        ld      a,(ix+7)
        xor     (ix+11)
        and     80h
        jp      z,__flt_same
        ld      a,(ix+7)
        bit     7,a
        jp      nz,__flt1
        jp      __flt0

__flt_same:
        ld      a,(ix+7)
        bit     7,a
        jp      nz,__flt_neg
        ; positive: raw a < raw b
        call    __frlt
        jp      __flt_ret
__flt_neg:
        ; negative: raw a > raw b
        call    __frgt
__flt_ret:
        ld      sp,ix
        pop     ix
        ret
__flt1:
        ld      hl,1
        ld      sp,ix
        pop     ix
        ret
__flt0:
        ld      hl,0
        ld      sp,ix
        pop     ix
        ret

        public  __fgt
__fgt:
        ; int __fgt(float a, float b) -- a > b == b < a
        push    ix
        ld      ix,0
        add     ix,sp

        ; Fast path: both positive non-NaN -- a > b iff b_raw < a_raw.
        ld      a,(ix+7)
        ld      b,a
        ld      a,(ix+11)
        or      b
        and     80h
        jp      nz,__fgt_slow
        ld      a,(ix+7)
        and     7fh
        cp      7fh
        jp      z,__fgt_slow
        ld      a,(ix+11)
        and     7fh
        cp      7fh
        jp      z,__fgt_slow
        ld      a,(ix+11)       ; compare b vs a (b < a means a > b)
        cp      (ix+7)
        jp      c,__fgt1
        jp      nz,__fgt0
        ld      a,(ix+10)
        cp      (ix+6)
        jp      c,__fgt1
        jp      nz,__fgt0
        ld      a,(ix+9)
        cp      (ix+5)
        jp      c,__fgt1
        jp      nz,__fgt0
        ld      a,(ix+8)
        cp      (ix+4)
        jp      c,__fgt1
        jp      __fgt0

__fgt_slow:
        ; NaN => false
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      e,(ix+6)
        ld      d,(ix+7)
        call    __fnan
        ld      a,h
        or      l
        jp      nz,__fgt0
        ld      l,(ix+8)
        ld      h,(ix+9)
        ld      e,(ix+10)
        ld      d,(ix+11)
        call    __fnan
        ld      a,h
        or      l
        jp      nz,__fgt0

        ; both zero => false
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      e,(ix+6)
        ld      d,(ix+7)
        call    __fzro
        push    hl
        ld      l,(ix+8)
        ld      h,(ix+9)
        ld      e,(ix+10)
        ld      d,(ix+11)
        call    __fzro
        pop     de
        ld      a,d
        or      e
        jp      z,__fgt_sign
        ld      a,h
        or      l
        jp      nz,__fgt0

__fgt_sign:
        ld      a,(ix+7)
        xor     (ix+11)
        and     80h
        jp      z,__fgt_same
        ld      a,(ix+7)
        bit     7,a
        jp      nz,__fgt0
        jp      __fgt1

__fgt_same:
        ld      a,(ix+7)
        bit     7,a
        jp      nz,__fgt_neg
        ; positive: raw a > raw b
        call    __frgt
        jp      __fgt_ret
__fgt_neg:
        ; negative: raw a < raw b
        call    __frlt
__fgt_ret:
        ld      sp,ix
        pop     ix
        ret
__fgt1:
        ld      hl,1
        ld      sp,ix
        pop     ix
        ret
__fgt0:
        ld      hl,0
        ld      sp,ix
        pop     ix
        ret

        public  __fle
__fle:
        ; int __fle(float a, float b) -- a <= b, false if unordered.
        push    ix
        ld      ix,0
        add     ix,sp

        ; Fast path: both positive non-NaN -- a <= b iff a_raw <= b_raw.
        ld      a,(ix+7)
        ld      b,a
        ld      a,(ix+11)
        or      b
        and     80h
        jp      nz,__fle_slow
        ld      a,(ix+7)
        and     7fh
        cp      7fh
        jp      z,__fle_slow
        ld      a,(ix+11)
        and     7fh
        cp      7fh
        jp      z,__fle_slow
        ld      a,(ix+7)
        cp      (ix+11)
        jp      c,__fle1
        jp      nz,__fle0
        ld      a,(ix+6)
        cp      (ix+10)
        jp      c,__fle1
        jp      nz,__fle0
        ld      a,(ix+5)
        cp      (ix+9)
        jp      c,__fle1
        jp      nz,__fle0
        ld      a,(ix+4)
        cp      (ix+8)
        jp      c,__fle1
        jp      nz,__fle0
        jp      __fle1          ; equal => a <= b

__fle_slow:
        ; NaN => false
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      e,(ix+6)
        ld      d,(ix+7)
        call    __fnan
        ld      a,h
        or      l
        jp      nz,__fle0
        ld      l,(ix+8)
        ld      h,(ix+9)
        ld      e,(ix+10)
        ld      d,(ix+11)
        call    __fnan
        ld      a,h
        or      l
        jp      nz,__fle0

        ; equality, including +/-0, is true
        push    ix
        pop     hl
        ld      de,4
        add     hl,de
        ; Reuse raw compare directly; both-zero is also handled here below.
        ld      a,(ix+4)
        cp      (ix+8)
        jp      nz,__fle_lt
        ld      a,(ix+5)
        cp      (ix+9)
        jp      nz,__fle_lt
        ld      a,(ix+6)
        cp      (ix+10)
        jp      nz,__fle_lt
        ld      a,(ix+7)
        cp      (ix+11)
        jp      z,__fle1

        ; raw differs; +/-0 still equal
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      e,(ix+6)
        ld      d,(ix+7)
        call    __fzro
        push    hl
        ld      l,(ix+8)
        ld      h,(ix+9)
        ld      e,(ix+10)
        ld      d,(ix+11)
        call    __fzro
        pop     de
        ld      a,d
        or      e
        jp      z,__fle_lt
        ld      a,h
        or      l
        jp      nz,__fle1

__fle_lt:
        ; otherwise same as a < b
        ld      a,(ix+7)
        xor     (ix+11)
        and     80h
        jp      z,__fle_same
        ld      a,(ix+7)
        bit     7,a
        jp      nz,__fle1
        jp      __fle0
__fle_same:
        ld      a,(ix+7)
        bit     7,a
        jp      nz,__fle_neg
        call    __frlt
        jp      __fle_ret
__fle_neg:
        call    __frgt
__fle_ret:
        ld      sp,ix
        pop     ix
        ret
__fle1:
        ld      hl,1
        ld      sp,ix
        pop     ix
        ret
__fle0:
        ld      hl,0
        ld      sp,ix
        pop     ix
        ret

        public  __fge
__fge:
        ; int __fge(float a, float b) -- a >= b, false if unordered.
        push    ix
        ld      ix,0
        add     ix,sp

        ; Fast path: both positive non-NaN -- a >= b iff a_raw >= b_raw.
        ld      a,(ix+7)
        ld      b,a
        ld      a,(ix+11)
        or      b
        and     80h
        jp      nz,__fge_slow
        ld      a,(ix+7)
        and     7fh
        cp      7fh
        jp      z,__fge_slow
        ld      a,(ix+11)
        and     7fh
        cp      7fh
        jp      z,__fge_slow
        ld      a,(ix+7)
        cp      (ix+11)
        jp      c,__fge0        ; a_byte < b_byte => a < b
        jp      nz,__fge1       ; a_byte > b_byte => a > b
        ld      a,(ix+6)
        cp      (ix+10)
        jp      c,__fge0
        jp      nz,__fge1
        ld      a,(ix+5)
        cp      (ix+9)
        jp      c,__fge0
        jp      nz,__fge1
        ld      a,(ix+4)
        cp      (ix+8)
        jp      c,__fge0
        jp      __fge1          ; equal or a_byte >= b_byte => a >= b

__fge_slow:
        ; NaN => false
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      e,(ix+6)
        ld      d,(ix+7)
        call    __fnan
        ld      a,h
        or      l
        jp      nz,__fge0
        ld      l,(ix+8)
        ld      h,(ix+9)
        ld      e,(ix+10)
        ld      d,(ix+11)
        call    __fnan
        ld      a,h
        or      l
        jp      nz,__fge0

        ; equality, including +/-0, is true
        ld      a,(ix+4)
        cp      (ix+8)
        jp      nz,__fge_gt
        ld      a,(ix+5)
        cp      (ix+9)
        jp      nz,__fge_gt
        ld      a,(ix+6)
        cp      (ix+10)
        jp      nz,__fge_gt
        ld      a,(ix+7)
        cp      (ix+11)
        jp      z,__fge1

        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      e,(ix+6)
        ld      d,(ix+7)
        call    __fzro
        push    hl
        ld      l,(ix+8)
        ld      h,(ix+9)
        ld      e,(ix+10)
        ld      d,(ix+11)
        call    __fzro
        pop     de
        ld      a,d
        or      e
        jp      z,__fge_gt
        ld      a,h
        or      l
        jp      nz,__fge1

__fge_gt:
        ; otherwise same as a > b
        ld      a,(ix+7)
        xor     (ix+11)
        and     80h
        jp      z,__fge_same
        ld      a,(ix+7)
        bit     7,a
        jp      nz,__fge0
        jp      __fge1
__fge_same:
        ld      a,(ix+7)
        bit     7,a
        jp      nz,__fge_neg
        call    __frgt
        jp      __fge_ret
__fge_neg:
        call    __frlt
__fge_ret:
        ld      sp,ix
        pop     ix
        ret
__fge1:
        ld      hl,1
        ld      sp,ix
        pop     ix
        ret
__fge0:
        ld      hl,0
        ld      sp,ix
        pop     ix
        ret

; Raw unsigned compare helpers for the two stack operands.
; __frlt returns a_raw < b_raw.  __frgt returns a_raw > b_raw.
; These helpers assume IX points at the current comparison frame.

__frlt:
        ld      a,(ix+7)
        cp      (ix+11)
        jp      c,__frt1
        jp      nz,__frt0
        ld      a,(ix+6)
        cp      (ix+10)
        jp      c,__frt1
        jp      nz,__frt0
        ld      a,(ix+5)
        cp      (ix+9)
        jp      c,__frt1
        jp      nz,__frt0
        ld      a,(ix+4)
        cp      (ix+8)
        jp      c,__frt1
        jp      __frt0

__frgt:
        ld      a,(ix+11)
        cp      (ix+7)
        jp      c,__frt1
        jp      nz,__frt0
        ld      a,(ix+10)
        cp      (ix+6)
        jp      c,__frt1
        jp      nz,__frt0
        ld      a,(ix+9)
        cp      (ix+5)
        jp      c,__frt1
        jp      nz,__frt0
        ld      a,(ix+8)
        cp      (ix+4)
        jp      c,__frt1
        jp      __frt0

__frt1:
        ld      hl,1
        ret
__frt0:
        ld      hl,0
        ret


; ---- IEEE single / integer conversion helpers ---------------------------
; Calling convention: float values are returned/passed in DE:HL, with HL
; holding the low 16 bits and DE holding the high 16 bits of the IEEE word.
;
; __fuf: unsigned 16-bit HL -> float DE:HL
; __fif: signed   16-bit HL -> float DE:HL
; __ffu: float DE:HL -> unsigned 16-bit HL, trunc toward zero
; __ffi: float DE:HL -> signed   16-bit HL, trunc toward zero

        public  __fuf
__fuf:
        ld      a,h
        or      l
        jp      nz,FUFNZ
        ld      de,0
        ret
FUFNZ:
        ld      b,142          ; exponent for bit 15
FUFN1:
        bit     7,h
        jp      nz,FUFND
        add     hl,hl
        dec     b
        jp      FUFN1
FUFND:
        ld      c,h            ; C = normalized high byte
        ld      a,l
        ld      h,a            ; HL low word = (norm_low << 8)
        ld      l,0
        ld      a,b
        ld      d,a
        srl     d              ; D = exponent >> 1
        and     1
        rrca                    ; A = exponent low bit in bit 7
        and     80h
        ld      e,a
        ld      a,c
        and     7fh            ; mantissa bits 22..16
        or      e
        ld      e,a
        ret

        public  __fif
__fif:
        bit     7,h
        jp      nz,FIFNG
        jp      __fuf
FIFNG:
        ld      a,h
        cpl
        ld      h,a
        ld      a,l
        cpl
        ld      l,a
        inc     hl
        call    __fuf
        ld      a,d
        or      80h
        ld      d,a
        ret

        public  __ffu
__ffu:
        ; Get unbiased exponent from high word DE.  Sign is ignored here.
        ld      a,d
        and     7fh
        add     a,a
        ld      c,a
        ld      a,e
        rlca
        and     1
        or      c              ; A = exponent
        cp      127
        jp      nc,FFU_GE1
        ld      hl,0
        ret
FFU_GE1:
        cp      143
        jp      c,FFU_OK
        ld      hl,0ffffh      ; saturate overflow/inf/nan-ish cases
        ret
FFU_OK:
        ld      c,a
        ld      a,142
        sub     c
        ld      b,a            ; B = right shift count
        ld      c,h            ; save mantissa bits 15..8 source
        ld      a,e
        and     7fh
        or      80h
        ld      h,a
        ld      l,c            ; HL = normalized 1.x as 16-bit
        inc     b
FFUS1:
        dec     b
        jp      z,FFUDN
        srl     h
        rr      l
        jp      FFUS1
FFUDN:
        ret

        public  __ffi
__ffi:
        ld      a,d
        and     80h
        push    af
        res     7,d
        call    __ffu
        pop     af
        or      a
        ret     z
        ld      a,h
        cpl
        ld      h,a
        ld      a,l
        cpl
        ld      l,a
        inc     hl
        ret



; ---- IEEE single add/sub helpers ----------------------------------------
; Calling convention: caller pushes left float then right float as
;   push de / push hl for each.  At entry:
;     IX+4..7   = right operand low..high
;     IX+8..11  = left  operand low..high
; Return DE:HL = left +/- right.  This is a compact phase-1 IEEE add/sub:
; normalized finite numbers and signed zero are handled; NaN/Inf handling is
; conservative and returns the left operand for those uncommon bootstrap cases.

        public  __fadd
__fadd:
        push    ix
        ld      ix,0
        add     ix,sp
        xor     a
        ld      (FSUB),a
        jp      FADD0

        public  __fsub
__fsub:
        push    ix
        ld      ix,0
        add     ix,sp
        ld      a,1
        ld      (FSUB),a
FADD0:
        ; unpack left operand into A* scratch
        ld      l,(ix+8)
        ld      h,(ix+9)
        ld      e,(ix+10)
        ld      d,(ix+11)
        call    FUNA
        ; unpack right operand into B* scratch
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      e,(ix+6)
        ld      d,(ix+7)
        call    FUNB
        ld      a,(FSUB)
        or      a
        jp      z,FANOS
        ld      a,(BSGN)
        xor     80h             ; flip IEEE sign bit, not bit 0
        ld      (BSGN),a
FANOS:
        ; zero shortcuts
        ld      a,(AEXP)
        or      a
        jp      nz,FABNZ
        ld      a,(AM2)
        or      a
        jp      nz,FABNZ
        ld      a,(AM1)
        or      a
        jp      nz,FABNZ
        ld      a,(AM0)
        or      a
        jp      nz,FABNZ
        call    FPB
        jp      FARET
FABNZ:
        ld      a,(BEXP)
        or      a
        jp      nz,FALGN
        ld      a,(BM2)
        or      a
        jp      nz,FALGN
        ld      a,(BM1)
        or      a
        jp      nz,FALGN
        ld      a,(BM0)
        or      a
        jp      nz,FALGN
        call    FPA
        jp      FARET

FALGN:
        ; align exponents: compute diff once, shift in a djnz loop, early-exit if diff>=24.
        ld      a,(AEXP)
        ld      b,a             ; B = AEXP
        ld      a,(BEXP)        ; A = BEXP
        sub     b               ; A = BEXP - AEXP (signed)
        jp      z,FASGN         ; equal exponents: nothing to align
        jp      c,FALGN_AGT     ; carry: BEXP < AEXP, A has larger exponent

        ; BEXP > AEXP: shift A mantissa right by (BEXP-AEXP), then set AEXP=BEXP
        cp      24
        jp      nc,FALGN_AABS   ; diff >= 24: A's contribution rounds to zero
        ld      b,a             ; B = shift count
FALGN_ASHR:
        call    FSRA
        djnz    FALGN_ASHR
        ld      a,(BEXP)
        ld      (AEXP),a        ; align AEXP up to BEXP
        jp      FASGN

FALGN_AGT:
        ; AEXP > BEXP: A = BEXP-AEXP is negative, negate to get AEXP-BEXP
        neg                     ; A = AEXP - BEXP (positive)
        cp      24
        jp      nc,FALGN_BABS   ; diff >= 24: B's contribution rounds to zero
        ld      b,a             ; B = shift count
FALGN_BSHR:
        call    FSRB
        djnz    FALGN_BSHR
        jp      FASGN

FALGN_AABS:
        ; A is negligible relative to B: zero A's mantissa, set AEXP=BEXP
        xor     a
        ld      (AM0),a
        ld      (AM1),a
        ld      (AM2),a
        ld      a,(BEXP)
        ld      (AEXP),a
        jp      FASGN

FALGN_BABS:
        ; B is negligible relative to A: zero B's mantissa
        xor     a
        ld      (BM0),a
        ld      (BM1),a
        ld      (BM2),a
        jp      FASGN

FASGN:
        ld      a,(ASGN)
        ld      b,a
        ld      a,(BSGN)
        cp      b
        jp      nz,FSUBM
        ; same sign: mantissa A += B
        ld      a,(AM0)
        ld      b,a
        ld      a,(BM0)
        add     a,b
        ld      (AM0),a
        ld      a,(AM1)
        ld      b,a
        ld      a,(BM1)
        adc     a,b
        ld      (AM1),a
        ld      a,(AM2)
        ld      b,a
        ld      a,(BM2)
        adc     a,b
        ld      (AM2),a
        jp      nc,FNORM
        ; carry out of bit 23: shift right and set hidden bit
        call    FSRA
        ld      a,(AM2)
        or      80h
        ld      (AM2),a
        ld      a,(AEXP)
        inc     a
        ld      (AEXP),a
        jp      FPACK

FSUBM:
        ; different signs: subtract smaller magnitude from larger.
        call    FCMPM
        jp      z,FZERO
        jp      nc,FASUB          ; A >= B
        ; B > A: A = B - A, sign = B sign
        ld      a,(BM0)
        ld      b,a
        ld      a,(AM0)
        ld      c,a
        ld      a,b
        sub     c
        ld      (AM0),a
        ld      a,(BM1)
        ld      b,a
        ld      a,(AM1)
        ld      c,a
        ld      a,b
        sbc     a,c
        ld      (AM1),a
        ld      a,(BM2)
        ld      b,a
        ld      a,(AM2)
        ld      c,a
        ld      a,b
        sbc     a,c
        ld      (AM2),a
        ld      a,(BSGN)
        ld      (ASGN),a
        jp      FNORM
FASUB:
        ld      a,(AM0)
        ld      b,a
        ld      a,(BM0)
        ld      c,a
        ld      a,b
        sub     c
        ld      (AM0),a
        ld      a,(AM1)
        ld      b,a
        ld      a,(BM1)
        ld      c,a
        ld      a,b
        sbc     a,c
        ld      (AM1),a
        ld      a,(AM2)
        ld      b,a
        ld      a,(BM2)
        ld      c,a
        ld      a,b
        sbc     a,c
        ld      (AM2),a

FNORM:
        ; if mantissa became zero, return +0.
        ld      a,(AM2)
        or      a
        jp      nz,FNL1
        ld      a,(AM1)
        or      a
        jp      nz,FNL0
        ld      a,(AM0)
        or      a
        jp      z,FZERO
FNL0:
        ; shift left until high byte non-zero or exponent reaches zero
        call    FSLA
        ld      a,(AEXP)
        dec     a
        ld      (AEXP),a
        jp      z,FPACK
        jp      FNORM
FNL1:
        ; Reload AM2 on each pass.  After decrementing AEXP, A no longer
        ; contains the mantissa high byte.
        ld      a,(AM2)
        bit     7,a
        jp      nz,FPACK
        call    FSLA
        ld      a,(AEXP)
        dec     a
        ld      (AEXP),a
        jp      nz,FNL1

FPACK:
        call    FPA
FARET:
        ld      sp,ix
        pop     ix
        ret
FZERO:
        ld      hl,0
        ld      de,0
        jp      FARET

; unpack DE:HL to A scratch
FUNA:
        ld      a,d
        and     80h
        ld      (ASGN),a
        ld      a,d
        and     7fh
        add     a,a
        ld      b,a
        ld      a,e
        rlca
        and     1
        or      b
        ld      (AEXP),a
        ld      a,e
        and     7fh
        ld      b,a
        ld      a,(AEXP)
        or      a
        jp      z,FUNAZ
        ld      a,b
        or      80h
        ld      b,a
FUNAZ:
        ld      a,b
        ld      (AM2),a
        ld      a,h
        ld      (AM1),a
        ld      a,l
        ld      (AM0),a
        ret
; unpack DE:HL to B scratch
FUNB:
        ld      a,d
        and     80h
        ld      (BSGN),a
        ld      a,d
        and     7fh
        add     a,a
        ld      b,a
        ld      a,e
        rlca
        and     1
        or      b
        ld      (BEXP),a
        ld      a,e
        and     7fh
        ld      b,a
        ld      a,(BEXP)
        or      a
        jp      z,FUNBZ
        ld      a,b
        or      80h
        ld      b,a
FUNBZ:
        ld      a,b
        ld      (BM2),a
        ld      a,h
        ld      (BM1),a
        ld      a,l
        ld      (BM0),a
        ret

; pack A scratch to DE:HL
FPA:
        ld      a,(AEXP)
        or      a
        jp      z,FPAZ
        ld      b,a
        srl     a
        ld      d,a
        ld      a,(ASGN)
        or      d
        ld      d,a
        ld      a,b
        and     1
        rrca
        and     80h
        ld      b,a
        ld      a,(AM2)
        and     7fh
        or      b
        ld      e,a
        ld      a,(AM1)
        ld      h,a
        ld      a,(AM0)
        ld      l,a
        ret
FPAZ:
        ld      hl,0
        ld      de,0
        ret
FPB:
        ld      a,(BEXP)
        ld      (AEXP),a
        ld      a,(BSGN)
        ld      (ASGN),a
        ld      a,(BM2)
        ld      (AM2),a
        ld      a,(BM1)
        ld      (AM1),a
        ld      a,(BM0)
        ld      (AM0),a
        jp      FPA

FSRA:
        ld      a,(AM2)
        srl     a
        ld      (AM2),a
        ld      a,(AM1)
        rr      a
        ld      (AM1),a
        ld      a,(AM0)
        rr      a
        ld      (AM0),a
        ret
FSRB:
        ld      a,(BM2)
        srl     a
        ld      (BM2),a
        ld      a,(BM1)
        rr      a
        ld      (BM1),a
        ld      a,(BM0)
        rr      a
        ld      (BM0),a
        ret
FSLA:
        ld      a,(AM0)
        add     a,a
        ld      (AM0),a
        ld      a,(AM1)
        rla
        ld      (AM1),a
        ld      a,(AM2)
        rla
        ld      (AM2),a
        ret

; compare A mantissa with B mantissa. Carry set if A < B, Z if equal.
FCMPM:
        ld      a,(AM2)
        ld      b,a
        ld      a,(BM2)
        cp      b
        jp      c,FCAGT
        jp      nz,FCALT
        ld      a,(AM1)
        ld      b,a
        ld      a,(BM1)
        cp      b
        jp      c,FCAGT
        jp      nz,FCALT
        ld      a,(AM0)
        ld      b,a
        ld      a,(BM0)
        cp      b
        jp      c,FCAGT
        jp      nz,FCALT
        xor     a              ; A == B: clear carry, set Z
        ret
FCAGT:
        or      1              ; A > B: clear carry, force Z clear
        ret
FCALT:
        or      1              ; A < B: force Z clear before setting carry
        scf
        ret



        public  __fmul
__fmul:
        push    ix
        ld      ix,0
        add     ix,sp

        ; unpack left operand into A scratch
        ld      l,(ix+8)
        ld      h,(ix+9)
        ld      e,(ix+10)
        ld      d,(ix+11)
        call    FUNA
        ; unpack right operand into B scratch
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      e,(ix+6)
        ld      d,(ix+7)
        call    FUNB

        ; zero/subnormal shortcut: this phase treats exponent-zero values as 0.
        ld      a,(AEXP)
        or      a
        jp      z,FMZERO
        ld      a,(BEXP)
        or      a
        jp      z,FMZERO

        ; sign = ASGN xor BSGN
        ld      a,(ASGN)
        ld      b,a
        ld      a,(BSGN)
        xor     b
        and     80h
        ld      (ASGN),a

        ; exponent = AEXP + BEXP - 127
        ld      a,(AEXP)
        ld      l,a
        ld      h,0
        ld      a,(BEXP)
        ld      e,a
        ld      d,0
        add     hl,de
        ld      de,127
        or      a
        sbc     hl,de
        bit     7,h
        jp      nz,FMZERO
        ld      a,h
        or      a
        jp      nz,FMINF
        ld      a,l
        cp      255
        jp      nc,FMINF
        ld      (AEXP),a

        ; P = 0.
        xor     a
        ld      (FP0),a
        ld      (FP1),a
        ld      (FP2),a
        ld      (FP3),a
        ld      (FP4),a
        ld      (FP5),a

        ; Choose the multiplier Q to avoid guaranteed zero low-byte
        ; iterations.  Product is commutative, so this is exact.
        ;
        ; Prefer a 16-bit byte skip if either mantissa has two zero low bytes;
        ; otherwise use an 8-bit byte skip if either mantissa has one zero low
        ; byte.  This keeps full 24-bit mantissas and only avoids iterations
        ; where Q's low byte would force no add.
        ld      a,(AM0)
        or      a
        jp      nz,FMCHECK_B
        ld      a,(AM1)
        or      a
        jp      z,FMSET_BA_8    ; A has 16 low zero bits
        jp      FMCHECK_B2_FOR_8

FMCHECK_B:
        ld      a,(BM0)
        or      a
        jp      nz,FMSET_AB_24
        ld      a,(BM1)
        or      a
        jp      z,FMSET_AB_8    ; B has 16 low zero bits
        jp      FMSET_AB_16     ; B has 8 low zero bits

FMCHECK_B2_FOR_8:
        ; A has 8 low zero bits.  If B has 16, prefer that; otherwise use A.
        ld      a,(BM0)
        or      a
        jp      nz,FMSET_BA_16
        ld      a,(BM1)
        or      a
        jp      z,FMSET_AB_8
        jp      FMSET_BA_16

FMSET_BA_16:
        ; A has 8 low zero bits: M = B mantissa << 8, Q = A >> 8.
        xor     a
        ld      (FM0),a
        ld      a,(BM0)
        ld      (FM1),a
        ld      a,(BM1)
        ld      (FM2),a
        ld      a,(BM2)
        ld      (FM3),a
        xor     a
        ld      (FM4),a
        ld      (FM5),a
        ld      h,0
        ld      a,(AM2)
        ld      l,a
        ld      a,(AM1)
        ld      e,a
        ld      b,16
        jp      FMLP

FMSET_BA_8:
        ; A has 16 low zero bits: M = B mantissa << 16, Q = A >> 16.
        xor     a
        ld      (FM0),a
        ld      (FM1),a
        ld      a,(BM0)
        ld      (FM2),a
        ld      a,(BM1)
        ld      (FM3),a
        ld      a,(BM2)
        ld      (FM4),a
        xor     a
        ld      (FM5),a
        ld      h,0
        ld      l,0
        ld      a,(AM2)
        ld      e,a
        ld      b,8
        jp      FMLP

FMSET_AB_16:
        ; B has 8 low zero bits: M = A mantissa << 8, Q = B >> 8.
        xor     a
        ld      (FM0),a
        ld      a,(AM0)
        ld      (FM1),a
        ld      a,(AM1)
        ld      (FM2),a
        ld      a,(AM2)
        ld      (FM3),a
        xor     a
        ld      (FM4),a
        ld      (FM5),a
        ld      h,0
        ld      a,(BM2)
        ld      l,a
        ld      a,(BM1)
        ld      e,a
        ld      b,16
        jp      FMLP

FMSET_AB_8:
        ; B has 16 low zero bits: M = A mantissa << 16, Q = B >> 16.
        xor     a
        ld      (FM0),a
        ld      (FM1),a
        ld      a,(AM0)
        ld      (FM2),a
        ld      a,(AM1)
        ld      (FM3),a
        ld      a,(AM2)
        ld      (FM4),a
        xor     a
        ld      (FM5),a
        ld      h,0
        ld      l,0
        ld      a,(BM2)
        ld      e,a
        ld      b,8
        jp      FMLP

FMSET_AB_24:
        ; General path: M = A mantissa, Q = B mantissa.
        ld      a,(AM0)
        ld      (FM0),a
        ld      a,(AM1)
        ld      (FM1),a
        ld      a,(AM2)
        ld      (FM2),a
        xor     a
        ld      (FM3),a
        ld      (FM4),a
        ld      (FM5),a
        ld      a,(BM2)
        ld      h,a
        ld      a,(BM1)
        ld      l,a
        ld      a,(BM0)
        ld      e,a
        ld      b,24

FMLP:
        ld      a,e             ; FQ0 in register E
        and     1
        jp      z,FMNA
        ; P += M
        ld      a,(FP0)
        ld      c,a
        ld      a,(FM0)
        add     a,c
        ld      (FP0),a
        ld      a,(FP1)
        ld      c,a
        ld      a,(FM1)
        adc     a,c
        ld      (FP1),a
        ld      a,(FP2)
        ld      c,a
        ld      a,(FM2)
        adc     a,c
        ld      (FP2),a
        ld      a,(FP3)
        ld      c,a
        ld      a,(FM3)
        adc     a,c
        ld      (FP3),a
        ld      a,(FP4)
        ld      c,a
        ld      a,(FM4)
        adc     a,c
        ld      (FP4),a
        ld      a,(FP5)
        ld      c,a
        ld      a,(FM5)
        adc     a,c
        ld      (FP5),a
FMNA:
        ; M <<= 1
        ld      a,(FM0)
        add     a,a
        ld      (FM0),a
        ld      a,(FM1)
        rla
        ld      (FM1),a
        ld      a,(FM2)
        rla
        ld      (FM2),a
        ld      a,(FM3)
        rla
        ld      (FM3),a
        ld      a,(FM4)
        rla
        ld      (FM4),a
        ld      a,(FM5)
        rla
        ld      (FM5),a
        ; Q >>= 1 (registers only: H=FQ2, L=FQ1, E=FQ0)
        srl     h
        rr      l
        rr      e
        dec     b
        jp      nz,FMLP

        ; If product bit 47 is set, mantissa = product >> 24 and exponent++.
        ld      a,(FP5)
        bit     7,a
        jp      z,FMNOC
        ld      a,(AEXP)
        inc     a
        cp      255
        jp      nc,FMINF
        ld      (AEXP),a
        ld      a,(FP3)
        ld      (AM0),a
        ld      a,(FP4)
        ld      (AM1),a
        ld      a,(FP5)
        ld      (AM2),a
        jp      FMPAK

FMNOC:
        ; Mantissa = product >> 23.  Shift P5:P4:P3:P2 right by 7.
        ld      b,7
FMSR7:
        ld      a,(FP5)
        srl     a
        ld      (FP5),a
        ld      a,(FP4)
        rr      a
        ld      (FP4),a
        ld      a,(FP3)
        rr      a
        ld      (FP3),a
        ld      a,(FP2)
        rr      a
        ld      (FP2),a
        djnz    FMSR7
        ld      a,(FP2)
        ld      (AM0),a
        ld      a,(FP3)
        ld      (AM1),a
        ld      a,(FP4)
        ld      (AM2),a

FMPAK:
        call    FPA
        ld      sp,ix
        pop     ix
        ret
FMZERO:
        ld      hl,0
        ld      de,0
        ld      sp,ix
        pop     ix
        ret
FMINF:
        ld      hl,0
        ld      de,7f80h
        ld      a,(ASGN)
        or      d
        ld      d,a
        ld      sp,ix
        pop     ix
        ret


        public  __fdiv
__fdiv:
        push    ix
        ld      ix,0
        add     ix,sp

        ; unpack left operand into A scratch
        ld      l,(ix+8)
        ld      h,(ix+9)
        ld      e,(ix+10)
        ld      d,(ix+11)
        call    FUNA
        ; unpack right operand into B scratch
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      e,(ix+6)
        ld      d,(ix+7)
        call    FUNB

        ; sign = ASGN xor BSGN
        ld      a,(ASGN)
        ld      c,a
        ld      a,(BSGN)
        xor     c
        and     80h
        ld      (ASGN),a

        ; 0 / anything = 0.  This phase treats subnormals as zero.
        ld      a,(AEXP)
        or      a
        jp      z,FDZRO

        ; divide by zero => signed infinity
        ld      a,(BEXP)
        or      a
        jp      z,FDINF

        ; exponent = AEXP - BEXP + 127
        ld      a,(AEXP)
        ld      l,a
        ld      h,0
        ld      a,(BEXP)
        ld      e,a
        ld      d,0
        or      a
        sbc     hl,de
        ld      de,127
        add     hl,de
        bit     7,h
        jp      nz,FDZRO
        ld      a,h
        or      a
        jp      nz,FDINF
        ld      a,l
        or      a
        jp      z,FDZRO
        cp      255
        jp      nc,FDINF
        ld      (AEXP),a

        ; R = A mantissa, Q = 0.  Compute 24-bit Q ~= A/B scaled by 2^23.
        ld      a,(AM0)
        ld      (FP0),a
        ld      a,(AM1)
        ld      (FP1),a
        ld      a,(AM2)
        ld      (FP2),a
        xor     a
        ld      (FP3),a
        ld      (FQ0),a
        ld      (FQ1),a
        ld      (FQ2),a

        ; Load divisor mantissa into registers for the 24-iteration loop.
        ; H=BM2, L=BM1, D=BM0 are constant throughout; C=0 for FP3 borrow.
        ; B=BM2 survives from FUNB; BM0/BM1 must reload from memory because
        ; the exponent computation above clobbers H, L, D, and E.
        ld      h,b             ; H = BM2  (B preserved through exponent computation)
        ld      a,(BM1)
        ld      l,a             ; L = BM1
        ld      a,(BM0)
        ld      d,a             ; D = BM0
        ld      c,0

        ld      b,24
FDLUP:
        ; Q <<= 1
        ld      a,(FQ0)
        add     a,a
        ld      (FQ0),a
        ld      a,(FQ1)
        rla
        ld      (FQ1),a
        ld      a,(FQ2)
        rla
        ld      (FQ2),a

        ; if R >= B then R -= B and set low bit of Q.
        ; R is kept as a 25-bit value in FP3:FP2:FP1:FP0.
        ; BM (divisor mantissa) is in H:L:D; C=0 supplies the zero borrow operand.
        ld      a,(FP3)
        or      a
        jp      nz,FDSUB        ; FP3 != 0: R > B (B has no byte here)
        ld      a,(FP2)
        cp      h               ; FP2 - BM2; carry if FP2 < BM2
        jp      c,FDNSB         ; R < B
        jp      nz,FDSUB        ; R > B
        ld      a,(FP1)
        cp      l               ; FP1 - BM1
        jp      c,FDNSB
        jp      nz,FDSUB
        ld      a,(FP0)
        cp      d               ; FP0 - BM0; carry if FP0 < BM0
        jp      c,FDNSB         ; R < B; fall through if R >= B
FDSUB:
        ld      a,(FP0)
        sub     d               ; FP0 - BM0 (no borrow input)
        ld      (FP0),a
        ld      a,(FP1)
        sbc     a,l             ; FP1 - BM1 - borrow
        ld      (FP1),a
        ld      a,(FP2)
        sbc     a,h             ; FP2 - BM2 - borrow
        ld      (FP2),a
        ld      a,(FP3)
        sbc     a,c             ; FP3 - 0 - borrow (C=0)
        ld      (FP3),a
        ld      a,(FQ0)
        or      1
        ld      (FQ0),a
FDNSB:
        ; R <<= 1
        ld      a,(FP0)
        add     a,a
        ld      (FP0),a
        ld      a,(FP1)
        rla
        ld      (FP1),a
        ld      a,(FP2)
        rla
        ld      (FP2),a
        ld      a,(FP3)
        rla
        ld      (FP3),a

        dec     b
        jp      nz,FDLUP

        ; Round division result.  At this point FP3:FP2:FP1:FP0 holds
        ; 2*remainder from the final quotient step.  If that value is at
        ; least the divisor mantissa, round the 24-bit quotient up.  This is
        ; round-half-up rather than full round-to-nearest-even, but it fixes
        ; the dominant truncation error without changing the ABI or helper
        ; calling convention.
        ld      a,(FP3)
        or      a
        jp      nz,FDRUP
        ld      a,(FP2)
        ld      c,a
        ld      a,(BM2)
        cp      c
        jp      c,FDRUP
        jp      nz,FDRNO
        ld      a,(FP1)
        ld      c,a
        ld      a,(BM1)
        cp      c
        jp      c,FDRUP
        jp      nz,FDRNO
        ld      a,(FP0)
        ld      c,a
        ld      a,(BM0)
        cp      c
        jp      c,FDRUP
        jp      nz,FDRNO
FDRUP:
        ld      a,(FQ0)
        inc     a
        ld      (FQ0),a
        jp      nz,FDRNO
        ld      a,(FQ1)
        inc     a
        ld      (FQ1),a
        jp      nz,FDRNO
        ld      a,(FQ2)
        inc     a
        ld      (FQ2),a
        jp      nz,FDRNO
        ; Quotient overflowed from 0ffffffh to 1000000h.  Renormalize to
        ; 800000h and bump exponent.
        ld      a,80h
        ld      (FQ2),a
        xor     a
        ld      (FQ1),a
        ld      (FQ0),a
        ld      a,(AEXP)
        inc     a
        cp      255
        jp      nc,FDINF
        ld      (AEXP),a
FDRNO:

        ; Q is the mantissa candidate. Normalize left if the hidden bit is clear.
        ld      a,(FQ0)
        ld      (AM0),a
        ld      a,(FQ1)
        ld      (AM1),a
        ld      a,(FQ2)
        ld      (AM2),a
FDNOR:
        ld      a,(AM2)
        bit     7,a
        jp      nz,FDPAK
        call    FSLA
        ld      a,(AEXP)
        dec     a
        ld      (AEXP),a
        jp      z,FDZRO
        jp      FDNOR

FDPAK:
        call    FPA
        ld      sp,ix
        pop     ix
        ret
FDZRO:
        ld      hl,0
        ld      de,0
        ld      sp,ix
        pop     ix
        ret
FDINF:
        ld      hl,0
        ld      de,7f80h
        ld      a,(ASGN)
        or      d
        ld      d,a
        ld      sp,ix
        pop     ix
        ret

FSUB:   db      0
ASGN:   db      0
AEXP:   db      0
AM0:    db      0
AM1:    db      0
AM2:    db      0
BSGN:   db      0
BEXP:   db      0
BM0:    db      0
BM1:    db      0
BM2:    db      0
FP0:    db      0
FP1:    db      0
FP2:    db      0
FP3:    db      0
FP4:    db      0
FP5:    db      0
FM0:    db      0
FM1:    db      0
FM2:    db      0
FM3:    db      0
FM4:    db      0
FM5:    db      0
FQ0:    db      0
FQ1:    db      0
FQ2:    db      0


; ---------------------------------------------------------------------------
; C89-ish single-precision math helpers.  These are intentionally separate
; PUBLIC blocks so dccrtlstrip can remove them unless the app references them.
;
; ABI: float arguments are 4 bytes on stack, low word then high word.
;      return float in DE:HL.
; These helpers reuse the existing IEEE single core/arithmetic helpers.

        public  _fabsf
_fabsf:
        push    ix
        ld      ix,0
        add     ix,sp
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      e,(ix+6)
        ld      d,(ix+7)
        call    __fabs
        ld      sp,ix
        pop     ix
        ret

        public  _floorf
_floorf:
        push    ix
        ld      ix,0
        add     ix,sp
        ld      hl,-8
        add     hl,sp
        ld      sp,hl

        ; l = (long)x
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      e,(ix+6)
        ld      d,(ix+7)
        call    __ffl
        ld      (ix-4),l
        ld      (ix-3),h
        ld      (ix-2),e
        ld      (ix-1),d

        ; y = (float)l
        ld      l,(ix-4)
        ld      h,(ix-3)
        ld      e,(ix-2)
        ld      d,(ix-1)
        call    __flf
        ld      (ix-8),l
        ld      (ix-7),h
        ld      (ix-6),e
        ld      (ix-5),d

        ; if (x < y) l--, y = (float)l.
        ; Do the adjustment in integer space.  This avoids depending on
        ; opposite-sign __fsub edge cases while preserving floor semantics
        ; for negative non-integral values.
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      e,(ix+6)
        ld      d,(ix+7)
        push    de
        push    hl
        ld      l,(ix-8)
        ld      h,(ix-7)
        ld      e,(ix-6)
        ld      d,(ix-5)
        push    de
        push    hl
        call    __fgt             ; y > x
        pop     bc
        pop     bc
        pop     bc
        pop     bc
        ld      a,h
        or      l
        jp      z,FMFRET

        ld      l,(ix-4)
        ld      h,(ix-3)
        ld      e,(ix-2)
        ld      d,(ix-1)
        dec     hl
        ld      a,l
        cp      0ffh
        jp      nz,FMFDEC
        ld      a,h
        cp      0ffh
        jp      nz,FMFDEC
        dec     de
FMFDEC:
        call    __flf
        ld      (ix-8),l
        ld      (ix-7),h
        ld      (ix-6),e
        ld      (ix-5),d
FMFRET:
        ld      l,(ix-8)
        ld      h,(ix-7)
        ld      e,(ix-6)
        ld      d,(ix-5)
        ld      sp,ix
        pop     ix
        ret

        public  _ceilf
_ceilf:
        push    ix
        ld      ix,0
        add     ix,sp
        ld      hl,-8
        add     hl,sp
        ld      sp,hl

        ; l = (long)x
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      e,(ix+6)
        ld      d,(ix+7)
        call    __ffl
        ld      (ix-4),l
        ld      (ix-3),h
        ld      (ix-2),e
        ld      (ix-1),d

        ; y = (float)l
        ld      l,(ix-4)
        ld      h,(ix-3)
        ld      e,(ix-2)
        ld      d,(ix-1)
        call    __flf
        ld      (ix-8),l
        ld      (ix-7),h
        ld      (ix-6),e
        ld      (ix-5),d

        ; if (x > y) l++, y = (float)l.
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      e,(ix+6)
        ld      d,(ix+7)
        push    de
        push    hl
        ld      l,(ix-8)
        ld      h,(ix-7)
        ld      e,(ix-6)
        ld      d,(ix-5)
        push    de
        push    hl
        call    __flt             ; y < x
        pop     bc
        pop     bc
        pop     bc
        pop     bc
        ld      a,h
        or      l
        jp      z,FMCRET

        ld      l,(ix-4)
        ld      h,(ix-3)
        ld      e,(ix-2)
        ld      d,(ix-1)
        inc     hl
        ld      a,h
        or      l
        jp      nz,FMCCNV
        inc     de
FMCCNV:
        call    __flf
        ld      (ix-8),l
        ld      (ix-7),h
        ld      (ix-6),e
        ld      (ix-5),d
FMCRET:
        ld      l,(ix-8)
        ld      h,(ix-7)
        ld      e,(ix-6)
        ld      d,(ix-5)
        ld      sp,ix
        pop     ix
        ret

        public  _sqrtf
_sqrtf:
        push    ix
        ld      ix,0
        add     ix,sp
        ld      hl,-10
        add     hl,sp
        ld      sp,hl

        ; if (x <= 0.0f) return 0.0f;
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      e,(ix+6)
        ld      d,(ix+7)
        push    de
        push    hl
        ld      hl,0
        ld      de,0
        push    de
        push    hl
        call    __fge             ; generated convention for x <= 0.0f
        pop     bc
        pop     bc
        pop     bc
        pop     bc
        ld      a,h
        or      l
        jp      z,FMSPOS
        ld      hl,0
        ld      de,0
        jp      FMSRET

FMSPOS:
        ; g = x
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      e,(ix+6)
        ld      d,(ix+7)
        ld      (ix-4),l
        ld      (ix-3),h
        ld      (ix-2),e
        ld      (ix-1),d
        ld      hl,0              ; i = 0
        ld      (ix-6),l
        ld      (ix-5),h
FMSLP:
        ld      l,(ix-6)
        ld      h,(ix-5)
        push    hl
        ld      hl,8
        ex      de,hl
        pop     hl
        ld      a,h
        xor     80h
        ld      h,a
        ld      a,d
        xor     80h
        ld      d,a
        or      a
        sbc     hl,de
        jp      nc,FMSDONE

        ; g = (g + x / g) * 0.5f
        ld      l,(ix-4)
        ld      h,(ix-3)
        ld      e,(ix-2)
        ld      d,(ix-1)
        push    de
        push    hl
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      e,(ix+6)
        ld      d,(ix+7)
        push    de
        push    hl
        ld      l,(ix-4)
        ld      h,(ix-3)
        ld      e,(ix-2)
        ld      d,(ix-1)
        push    de
        push    hl
        call    __fdiv
        pop     bc
        pop     bc
        pop     bc
        pop     bc
        push    de
        push    hl
        call    __fadd
        pop     bc
        pop     bc
        pop     bc
        pop     bc
        push    de
        push    hl
        ld      hl,0
        ld      de,16128          ; 0.5f = 3f000000, high word 3f00h
        push    de
        push    hl
        call    __fmul
        pop     bc
        pop     bc
        pop     bc
        pop     bc
        ld      (ix-4),l
        ld      (ix-3),h
        ld      (ix-2),e
        ld      (ix-1),d

        inc     (ix-6)
        jp      nz,FMSLP
        inc     (ix-5)
        jp      FMSLP

FMSDONE:
        ; One final correction: the simple division/multiply helpers truncate,
        ; so Newton iteration can settle one representable value below the
        ; correctly rounded answer for perfect squares such as 9.0f.  If
        ; g*g < x, advance positive g by one IEEE single-precision bit.
        ld      l,(ix-4)
        ld      h,(ix-3)
        ld      e,(ix-2)
        ld      d,(ix-1)
        push    de
        push    hl
        push    de
        push    hl
        call    __fmul
        pop     bc
        pop     bc
        pop     bc
        pop     bc
        ; Save product, then call __flt(product, x).  The C calling
        ; convention pushes arguments right-to-left, so push x first.
        ld      (ix-10),l
        ld      (ix-9),h
        ld      (ix-8),e
        ld      (ix-7),d
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      e,(ix+6)
        ld      d,(ix+7)
        push    de
        push    hl
        ld      l,(ix-10)
        ld      h,(ix-9)
        ld      e,(ix-8)
        ld      d,(ix-7)
        push    de
        push    hl
        call    __flt             ; g*g < x ?
        pop     bc
        pop     bc
        pop     bc
        pop     bc
        ld      a,h
        or      l
        jp      z,FMSLD
        ld      l,(ix-4)
        ld      h,(ix-3)
        ld      e,(ix-2)
        ld      d,(ix-1)
        inc     hl
        ld      a,h
        or      l
        jp      nz,FMSST
        inc     de
FMSST:
        ld      (ix-4),l
        ld      (ix-3),h
        ld      (ix-2),e
        ld      (ix-1),d
FMSLD:
        ld      l,(ix-4)
        ld      h,(ix-3)
        ld      e,(ix-2)
        ld      d,(ix-1)
FMSRET:
        ld      sp,ix
        pop     ix
        ret

; ---- IEEE single <-> 32-bit long conversion helpers ---------------------
; Float calling convention: DE:HL holds the 32-bit IEEE single value.
; Long calling convention:  DE:HL holds a 32-bit integer value.
;
; __flf   signed   long  DE:HL -> float DE:HL
; __fulf  unsigned long  DE:HL -> float DE:HL
; __ffl   float DE:HL -> signed   long DE:HL, trunc toward zero
; __fful  float DE:HL -> unsigned long DE:HL, trunc toward zero


        public  __fscale_pow2
__fscale_pow2:
        ; Scale float DE:HL by 2^B.
        ; Input:  DE:HL = IEEE single raw bits, B = signed exponent delta.
        ; Output: DE:HL = scaled float.
        ;
        ; Fast/correct for normalized finite results.  Preserves NaN/Inf and
        ; signed zero.  Overflow becomes signed infinity.  Underflow currently
        ; becomes signed zero, matching the rest of this compact RTL's
        ; tendency to treat subnormal arithmetic as zero outside nextafterf.
        ;
        ; This is intended for compiler-generated x*2^k and x/2^k paths such
        ; as num /= 16.0f and f = 16.0f * f.

        ; exp = ((D & 7f) << 1) | (E >> 7)
        ld      a,d
        and     7fh
        add     a,a
        ld      c,a
        ld      a,e
        rlca
        and     1
        or      c              ; A = biased exponent

        ; zero/subnormal: preserve signed zero / treat subnormal as zero.
        or      a
        jp      z,FSCL_RET

        ; NaN/Inf: preserve input.
        cp      255
        jp      z,FSCL_RET

        ; A = exponent, B = signed delta.  Compute signed 16-bit A+B in HL.
        ld      l,a
        ld      h,0
        bit     7,b
        jp      z,FSCL_POS
        ld      a,b
        ld      e,a
        ld      d,0ffh
        jp      FSCL_ADD
FSCL_POS:
        ld      e,b
        ld      d,0
FSCL_ADD:
        add     hl,de

        ; new exponent <= 0 => signed zero.
        bit     7,h
        jp      nz,FSCL_ZERO
        ld      a,h
        or      a
        jp      nz,FSCL_INF
        ld      a,l
        or      a
        jp      z,FSCL_ZERO

        ; new exponent >= 255 => signed infinity.
        cp      255
        jp      nc,FSCL_INF

        ; Install new biased exponent A into D/E, preserving sign and mantissa.
        ld      c,a            ; C = new exponent
        srl     a              ; A = exp >> 1
        ld      b,a
        ld      a,d
        and     80h            ; sign bit
        or      b
        ld      d,a
        ld      a,c
        and     1
        rrca                   ; exp low bit -> bit 7
        ld      b,a
        ld      a,e
        and     7fh            ; preserve mantissa high 7 bits
        or      b
        ld      e,a
        ret

FSCL_ZERO:
        ld      a,d
        and     80h
        ld      d,a
        ld      e,0
        ld      h,0
        ld      l,0
        ret

FSCL_INF:
        ld      a,d
        and     80h
        or      7fh
        ld      d,a
        ld      e,80h
        ld      h,0
        ld      l,0
FSCL_RET:
        ret


        public  __fulf
__fulf:
        ld      a,d
        or      e
        or      h
        or      l
        jp      nz,FUL1
        ld      de,0
        ret
FUL1:
        ld      b,158          ; exponent for bit 31
FUL2:
        bit     7,d
        jp      nz,FUL3
        add     hl,hl
        rl      e
        rl      d
        dec     b
        jp      FUL2
FUL3:
        ld      a,e
        ld      (FULM),a       ; mantissa bits 23..16
        ld      a,h
        ld      (FULL),a       ; mantissa bits 15..8
        ld      c,d            ; normalized top byte, bit 7 hidden
        ld      a,b
        ld      d,a
        srl     d              ; D = exponent >> 1, sign clear
        and     1
        rrca
        and     80h
        ld      e,a
        ld      a,c
        and     7fh            ; mantissa bits 22..16
        or      e
        ld      e,a
        ld      a,(FULM)
        ld      h,a
        ld      a,(FULL)
        ld      l,a
        ret
FULM:   db      0
FULL:   db      0

        public  __flf
__flf:
        bit     7,d
        jp      nz,FLFN
        jp      __fulf
FLFN:
        ld      a,l
        cpl
        ld      l,a
        ld      a,h
        cpl
        ld      h,a
        ld      a,e
        cpl
        ld      e,a
        ld      a,d
        cpl
        ld      d,a
        inc     l
        jp      nz,FLF1
        inc     h
        jp      nz,FLF1
        inc     e
        jp      nz,FLF1
        inc     d
FLF1:
        call    __fulf
        ld      a,d
        or      80h
        ld      d,a
        ret

        public  __fful
__fful:
        ld      a,d
        and     7fh
        add     a,a
        ld      b,a
        ld      a,e
        rlca
        and     1
        or      b              ; A = biased exponent
        cp      127
        jp      nc,FFUL1
        ld      de,0
        ld      hl,0
        ret
FFUL1:
        cp      159
        jp      c,FFUL2
        ld      de,0ffffh
        ld      hl,0ffffh
        ret
FFUL2:
        ld      c,a            ; C = exponent
        ld      a,e
        and     7fh
        or      80h
        ld      e,a            ; DEHL = 00:mantissa24
        ld      d,0
        ; H and L are already mantissa low bytes from input float.
        ld      a,c
        cp      150
        jp      z,FFULD
        jp      c,FFURS
        sub     150
        ld      b,a
FFULS:
        add     hl,hl
        rl      e
        rl      d
        dec     b
        jp      nz,FFULS
        jp      FFULD
FFURS:
        ld      a,150
        sub     c
        ld      b,a
FFUR1:
        srl     d
        rr      e
        rr      h
        rr      l
        dec     b
        jp      nz,FFUR1
FFULD:
        ret

        public  __ffl
__ffl:
        ld      a,d
        and     80h
        push    af
        res     7,d
        call    __fful
        pop     af
        or      a
        ret     z
        ld      a,l
        cpl
        ld      l,a
        ld      a,h
        cpl
        ld      h,a
        ld      a,e
        cpl
        ld      e,a
        ld      a,d
        cpl
        ld      d,a
        inc     l
        ret     nz
        inc     h
        ret     nz
        inc     e
        ret     nz
        inc     d
        ret


; ---------------------------------------------------------------------------
; nextafter / nextafterf -- single-precision implementation for dcc.
;
; dcc currently has only 32-bit float arithmetic, so both nextafter and
; nextafterf use float ABI: nextafter(float x, float y) returns the adjacent
; IEEE-754 single value after x in the direction of y.
;
; Args: x at IX+4..IX+7, y at IX+8..IX+11. Return DE:HL.
; ---------------------------------------------------------------------------

        public  _nextafterf
_nextafterf:
        push    ix
        ld      ix,0
        add     ix,sp

        ; Fast path for nextafterf(x, FLT_MAX).  eps() uses exactly this form:
        ;     nextafterf(f, FLT_MAX) - f
        ; For finite/non-NaN x, moving toward +FLT_MAX is just an IEEE raw
        ; bit step: positive values increment, negative values decrement,
        ; zero returns the smallest positive subnormal.  Fall back to the
        ; general path for every other 'toward' value.
        ld      l,(ix+8)
        ld      h,(ix+9)
        ld      e,(ix+10)
        ld      d,(ix+11)
        ld      a,l
        cp      0ffh
        jp      nz,NXGEN
        ld      a,h
        cp      0ffh
        jp      nz,NXGEN
        ld      a,e
        cp      07fh
        jp      nz,NXGEN
        ld      a,d
        cp      07fh
        jp      nz,NXGEN

        ; x is NaN => return x
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      e,(ix+6)
        ld      d,(ix+7)
        call    __fnan
        ld      a,h
        or      l
        jp      nz,NXRET_X

        ; x == FLT_MAX => return y/x unchanged
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      e,(ix+6)
        ld      d,(ix+7)
        ld      a,l
        cp      0ffh
        jp      nz,NXFMAX_NE
        ld      a,h
        cp      0ffh
        jp      nz,NXFMAX_NE
        ld      a,e
        cp      07fh
        jp      nz,NXFMAX_NE
        ld      a,d
        cp      07fh
        jp      z,NXRET
NXFMAX_NE:

        ; x == +/-0 => smallest positive subnormal
        ld      a,d
        and     7fh
        or      e
        or      h
        or      l
        jp      nz,NXFMAX_NZ
        ld      hl,1
        ld      de,0
        jp      NXRET
NXFMAX_NZ:
        ; For negative x, move toward +FLT_MAX by decrementing raw bits.
        bit     7,d
        jp      nz,NXDEC
        jp      NXINC

NXGEN:
        ; if x is NaN, return x
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      e,(ix+6)
        ld      d,(ix+7)
        call    __fnan
        ld      a,h
        or      l
        jp      nz,NXRET_X

        ; if y is NaN, return y
        ld      l,(ix+8)
        ld      h,(ix+9)
        ld      e,(ix+10)
        ld      d,(ix+11)
        call    __fnan
        ld      a,h
        or      l
        jp      nz,NXRET_Y

        ; if x == y, return y
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      e,(ix+6)
        ld      d,(ix+7)
        push    de
        push    hl
        ld      l,(ix+8)
        ld      h,(ix+9)
        ld      e,(ix+10)
        ld      d,(ix+11)
        push    de
        push    hl
        call    __feq
        pop     bc
        pop     bc
        pop     bc
        pop     bc
        ld      a,h
        or      l
        jp      nz,NXRET_Y

        ; if x == 0, return the smallest subnormal with y's sign
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      e,(ix+6)
        ld      d,(ix+7)
        call    __fzro
        ld      a,h
        or      l
        jp      nz,NXZERO

        ; lt = x < y
        ; __flt follows the normal dcc call ABI: the first argument must be
        ; the last value pushed, so push y first, then x.
        ld      l,(ix+8)
        ld      h,(ix+9)
        ld      e,(ix+10)
        ld      d,(ix+11)
        push    de
        push    hl
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      e,(ix+6)
        ld      d,(ix+7)
        push    de
        push    hl
        call    __flt
        pop     bc
        pop     bc
        pop     bc
        pop     bc
        ld      a,h
        or      l
        ld      (NXLT),a

        ; Load raw x.
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      e,(ix+6)
        ld      d,(ix+7)

        ; For positive x, x<y means increment raw bits; otherwise decrement.
        ; For negative x, x<y means decrement raw bits; otherwise increment.
        ld      a,d
        and     80h
        jp      nz,NXNEG
NXPOS:
        ld      a,(NXLT)
        or      a
        jp      nz,NXINC
        jp      NXDEC
NXNEG:
        ld      a,(NXLT)
        or      a
        jp      nz,NXDEC
        jp      NXINC

NXZERO:
        ld      hl,1
        ld      de,0
        ld      a,(ix+11)
        and     80h
        jp      z,NXRET
        ld      d,80h
        jp      NXRET

NXRET_X:
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      e,(ix+6)
        ld      d,(ix+7)
        jp      NXRET
NXRET_Y:
        ld      l,(ix+8)
        ld      h,(ix+9)
        ld      e,(ix+10)
        ld      d,(ix+11)
        jp      NXRET

NXINC:
        inc     l
        jp      nz,NXRET
        inc     h
        jp      nz,NXRET
        inc     e
        jp      nz,NXRET
        inc     d
        jp      NXRET

NXDEC:
        ld      a,l
        or      a
        jp      nz,NXDL
        ld      l,0ffh
        ld      a,h
        or      a
        jp      nz,NXDH
        ld      h,0ffh
        ld      a,e
        or      a
        jp      nz,NXDE
        ld      e,0ffh
        dec     d
        jp      NXRET
NXDE:
        dec     e
        jp      NXRET
NXDH:
        dec     h
        jp      NXRET
NXDL:
        dec     l

NXRET:
        ld      sp,ix
        pop     ix
        ret

NXLT:   db      0

        end     start
