; dccrtl.mac - minimal CP/M-80 runtime for dcc
;
; M80/L80 Z80 assembly.
;
;        org     100h

        extrn   _main
        extrn   __hstart   ; heap start
        extrn   __bssb     ; bss begin
        extrn   __bsse     ; bss end
        extrn   __stack_size ; bytes reserved above heap for C stack
        public  __brk
        public  __hlimit   ; heap limit
        public  start

HDRSIZE          equ     3

; errno values used by the CP/M file layer.  Keep these in sync with errno.h.
ENOENT   equ     2
EIO      equ     5
EBADF    equ     9
EINVAL   equ     22
EMFILE   equ     24
ENOSPC   equ     28

        cseg
; Heap state used by start/free/malloc.  Keep this in the always-kept
; startup block so allocator code itself is not pulled in just because
; start initializes __brk/__hlimit.
__hbase:        dw      0
__brk:          dw      0
__hlimit:       dw      0

start:
        call    __build_argv

        ; Initialize heap allocator.
        ; __hlimit = initial SP - __stack_size
        ld      hl,0
        add     hl,sp
        ld      de,__stack_size
        or      a
        sbc     hl,de
        ld      (__hlimit),hl
        ; __brk = __hbase = __hstart (label at end of user module)
        ld      hl,__hstart
        ld      (__hbase),hl
        ld      (__brk),hl

        ; Zero BSS (C89: uninitialized globals must be zero at startup)
        ld      hl,__bsse
        ld      de,__bssb
        or      a
        sbc     hl,de           ; HL = __bsse - __bssb = BSS length
        ld      b,h
        ld      c,l
        ld      a,b
        or      c
        jr      z,bss_done
        ld      hl,__bssb
        ld      (hl),0
        ld      d,h
        ld      e,l
        inc     de
        dec     bc
        ld      a,b
        or      c
        jr      z,bss_done
        ldir
bss_done:

        ld      hl,argv
        push    hl              ; argv
        ld      hl,(__argc)
        push    hl              ; argc
        call    _main
        call    __cpm_set_retcode
        jp      0000h


; ------------------------------------------------------------
; CP/M command-tail argc/argv builder
; ------------------------------------------------------------
; CP/M command tail:
;   0080h = length
;   0081h = text
;
; Builds:
;   argc = 1 + whitespace-delimited command-tail args
;   argv[0] = ""
;   argv[1..] = pointers into __argbuf

        public  __build_argv

__build_argv:
        ld      hl,argv0
        ld      (argv),hl
        ld      hl,1
        ld      (__argc),hl

        ld      a,(80h)
        or      a
        ret     z

        ld      b,a
        ld      hl,81h
        ld      de,__argbuf

ba_copy:
        ld      a,b
        or      a
        jr      z,ba_done_copy
        ld      a,(hl)
        cp      0dh
        jr      z,ba_done_copy
        ld      (de),a
        inc     hl
        inc     de
        dec     b
        jr      ba_copy

ba_done_copy:
        xor     a
        ld      (de),a

        ld      hl,__argbuf
        ld      de,argv+2
        ld      c,1

ba_skip_spaces:
        ld      a,(hl)
        or      a
        jr      z,ba_finish
        cp      ' '
        jr      nz,ba_arg_start
        inc     hl
        jr      ba_skip_spaces

ba_arg_start:
        ld      a,l
        ld      (de),a
        inc     de
        ld      a,h
        ld      (de),a
        inc     de
        inc     c

ba_scan_arg:
        ld      a,(hl)
        or      a
        jr      z,ba_finish
        cp      ' '
        jr      z,ba_end_arg
        inc     hl
        jr      ba_scan_arg

ba_end_arg:
        xor     a
        ld      (hl),a
        inc     hl
        jr      ba_skip_spaces

ba_finish:
        ld      h,0
        ld      l,c
        ld      (__argc),hl
        ret

__argc:
        dw      0

argv0:
        db      0

argv:
        ds      34

__argbuf:
        ds      128

; __conout: output char in E to console with LF->CR/LF translation.
; Preserves all registers except F.
__conout:
        ld      a,e
        cp      0ah             ; LF?
        jr      nz,__conout_raw
        push    de
        ld      e,0dh           ; emit CR first
        ld      c,2
        call    5
        pop     de              ; restore original E (=0Ah)
__conout_raw:
        ld      c,2
        call    5
        ret

        public  __pchr
__pchr:
        push    ix
        ld      ix,0
        add     ix,sp
        ld      e,(ix+4)
        call    __conout
        ld      h,0
        ld      l,e
        pop     ix
        ret

        public  __fpc
__fpc:
        push    ix
        ld      ix,0
        add     ix,sp

        ; int fputc(int c, FILE *fp)
        ; fp values 0/1/2 are stdin/stdout/stderr pseudo FILEs in this RTL.
        ld      a,(ix+6)        ; low byte of fp/fd
        cp      1
        jr      z,fputc_con
        cp      2
        jr      z,fputc_con

        ; file path: store char in a one-byte buffer and call _write(fp,&ch,1)
        ld      a,(ix+4)
        ld      (___fpc_ch),a

        ld      hl,1
        push    hl              ; count
        ld      hl,___fpc_ch
        push    hl              ; buf
        ld      l,(ix+6)
        ld      h,(ix+7)
        push    hl              ; fp
        call    _write

        ; clean 3 args while preserving _write return in HL
        ex      de,hl
        ld      hl,6
        add     hl,sp
        ld      sp,hl
        ex      de,hl

        ; success iff _write returned 1 byte
        ld      a,h
        or      a
        jr      nz,fputc_bad
        ld      a,l
        cp      1
        jr      nz,fputc_bad

        ld      h,0
        ld      l,(ix+4)        ; return written character
        pop     ix
        ret

fputc_con:
        ld      e,(ix+4)
        call    __conout
        ld      h,0
        ld      l,(ix+4)
        pop     ix
        ret

fputc_bad:
        ld      hl,0ffffh       ; EOF
        pop     ix
        ret

___fpc_ch:
        db      0

        public  _clearerr
_clearerr:
        ; void clearerr(FILE *fp)
        ; Clear the EOF and error indicators for this stream's slot.  fd 0/1/2
        ; are console pseudo-streams with no slot, so they are left alone.
        push    ix
        ld      ix,0
        add     ix,sp
        ld      a,(ix+4)
        sub     FIRSTFD
        jr      c,clrerr_done
        cp      NFILES
        jr      nc,clrerr_done
        ld      h,0
        ld      l,a
        ld      de,__fdeof
        add     hl,de
        ld      (hl),0                  ; clear EOF flag
        ld      h,0
        ld      l,a
        ld      de,__fderr
        add     hl,de
        ld      (hl),0                  ; clear error flag
clrerr_done:
        ld      hl,0
        pop     ix
        ret

        public  _setbuf
_setbuf:
        ; void setbuf(FILE *fp, char *buf)
        ; Unbuffered/stubbed: all current I/O goes through direct CP/M calls.
        ld      hl,0
        ret

        public  _strerror
_strerror:
        ; char *strerror(int errnum)
        ; Small errno message table for the errors this RTL commonly sets.
        push    ix
        ld      ix,0
        add     ix,sp
        ld      a,(ix+4)
        cp      ENOENT
        jr      z,__se02
        cp      EIO
        jr      z,__se05
        cp      EBADF
        jr      z,__se09
        cp      EINVAL
        jr      z,__se22
        cp      EMFILE
        jr      z,__se24
        cp      ENOSPC
        jr      z,__se28
        cp      33              ; EDOM
        jr      z,__se33
        cp      34              ; ERANGE
        jr      z,__se34
        ld      hl,__seuk
        pop     ix
        ret
__se02:
        ld      hl,__sem02
        pop     ix
        ret
__se05:
        ld      hl,__sem05
        pop     ix
        ret
__se09:
        ld      hl,__sem09
        pop     ix
        ret
__se22:
        ld      hl,__sem22
        pop     ix
        ret
__se24:
        ld      hl,__sem24
        pop     ix
        ret
__se28:
        ld      hl,__sem28
        pop     ix
        ret
__se33:
        ld      hl,__sem33
        pop     ix
        ret
__se34:
        ld      hl,__sem34
        pop     ix
        ret

__seuk:         db      'Error',0
__sem02:        db      'No such file',0
__sem05:        db      'I/O error',0
__sem09:        db      'Bad file descriptor',0
__sem22:        db      'Invalid argument',0
__sem24:        db      'Too many open files',0
__sem28:        db      'No space left on device',0
__sem33:        db      'Domain error',0
__sem34:        db      'Range error',0


        public  __putc
__putc:
        ; int putc(int c, FILE *fp) -- same calling convention as fputc
        jp      __fpc

        public  __getc
__getc:
        ; int getc(FILE *fp)
        push    ix
        ld      ix,0
        add     ix,sp

        ld      hl,1
        push    hl              ; count
        ld      hl,___getc_ch
        push    hl              ; buf
        ld      l,(ix+4)
        ld      h,(ix+5)
        push    hl              ; fp/fd
        call    _read
        ex      de,hl
        ld      hl,6
        add     hl,sp
        ld      sp,hl
        ex      de,hl

        ; success iff _read returned 1
        ld      a,h
        or      a
        jr      nz,getc_bad
        ld      a,l
        cp      1
        jr      nz,getc_bad

        ld      h,0
        ld      a,(___getc_ch)
        ld      l,a
        pop     ix
        ret

getc_bad:
        ld      hl,0ffffh       ; EOF
        pop     ix
        ret

___getc_ch:
        db      0

        public  _remove
_remove:
        ; int remove(const char *path)
        jp      _unlink

        public  ___gchr
___gchr:
        ld      c,1
        call    5
        ld      h,0
        ld      l,a
        ret



; bdos(fn, dearg)
; Call CP/M BDOS directly.
;
; C prototype:
;     extern int bdos(int fn, int dearg);
;
; Arguments:
;     fn    -> BDOS function number, placed in C
;     dearg -> 16-bit argument pointer/value, placed in DE
;
; Return:
;     low-byte BDOS result A, returned as int in HL.
;     This matches CP/M 2.2 BDOS functions that return a byte value.
;     Functions whose useful result is written through DE, such as FCB/DMA
;     operations, should read that memory after the call.
        public  _bdos
_bdos:
        push    ix
        ld      ix,0
        add     ix,sp
        ld      c,(ix+4)        ; function number
        ld      e,(ix+6)        ; DE argument
        ld      d,(ix+7)
        call    5
        ld      l,a
        ld      h,0
        pop     ix
        ret


        public  __slen
__slen:
        ; size_t strlen(const char *s)
        ; IX-free entry; use CPIR to scan for NUL.
        pop     bc              ; return address
        pop     hl              ; HL = s
        push    hl              ; restore caller argument for caller cleanup
        push    bc              ; restore return address
        ld      e,l
        ld      d,h             ; DE = original s
        ld      bc,0ffffh
        xor     a               ; search for NUL
        cpir                    ; HL = byte after NUL
        or      a
        sbc     hl,de           ; bytes scanned including NUL
        dec     hl              ; length excluding NUL
        ret


        public  __slf
__slf:
        ; fastcall size_t strlen(const char *s)
        ; Entry: HL = s.  Return: HL = length.
        ld      e,l
        ld      d,h             ; DE = original s
        ld      bc,0ffffh
        xor     a
        cpir
        or      a
        sbc     hl,de           ; bytes scanned including NUL
        dec     hl
        ret

        public  __scpy
__scpy:
        push    ix
        ld      ix,0
        add     ix,sp
        ld      e,(ix+4)
        ld      d,(ix+5)
        ld      l,(ix+6)
        ld      h,(ix+7)
        push    de
sc1:
        ld      a,(hl)
        ld      (de),a
        inc     hl
        inc     de
        or      a
        jr      nz,sc1
        pop     hl
        pop     ix
        ret

        public  __scmp
__scmp:
        push    ix
        ld      ix,0
        add     ix,sp
        ld      e,(ix+4)
        ld      d,(ix+5)
        ld      l,(ix+6)
        ld      h,(ix+7)
sp1:
        ld      a,(de)
        cp      (hl)
        jr      nz,sp2
        or      a
        jr      z,sp3
        inc     de
        inc     hl
        jr      sp1
sp2:
        ; A still holds *s1 after CP (HL), so compute *s1 - *s2 directly.
        sub     (hl)
        ld      l,a
        ld      h,0
        jr      nc,sp4
        ld      h,0ffh
sp4:
        pop     ix
        ret

sp3:
        ld      hl,0
        pop     ix
        ret

        public  __srch
__srch:
        ; char *strrchr(const char *s, int c)
        ; CPIR finds end of string, then CPDR scans backward for last match.
        ; 37T/byte combined vs 52T/byte forward scan (~30% faster on typical strings).
        pop     de              ; pop return address
        pop     hl              ; HL = s
        pop     bc              ; BC = c (C = char)
        push    bc              ; restore c for caller cleanup
        push    hl              ; restore s for caller cleanup
        push    de              ; restore return address
        ld      e,c             ; save target char in E (CPIR clobbers BC)
        xor     a               ; A = 0, search for NUL
        ld      c,a
        ld      b,a             ; BC = 0 = 65536 max CPIR iterations
        cpir                    ; scan forward to NUL: 21T/byte
        dec     hl              ; HL = NUL position
        ld      a,c             ; negate BC to get strlen+1
        cpl
        ld      c,a
        ld      a,b
        cpl
        ld      b,a
        inc     bc              ; BC = strlen+1
        ld      a,e             ; A = target char
        cpdr                    ; scan backward: 16T/byte
        jp      nz,srch_not_found
        inc     hl              ; CPDR leaves HL one before match
        ret
srch_not_found:
        ld      hl,0
        ret


        public  __chf
__chf:
        ; char *strchr_fastcall(const char *s, int c)
        ; Entry: HL = s, A = low byte of c.  Return HL = match or 0.
        ld      c,a
schrf_loop:
        ld      a,(hl)
        cp      c
        ret     z
        inc     hl
        or      a
        jr      z,schrf_not_found

        ld      a,(hl)
        cp      c
        ret     z
        inc     hl
        or      a
        jr      z,schrf_not_found

        ld      a,(hl)
        cp      c
        ret     z
        inc     hl
        or      a
        jr      z,schrf_not_found

        ld      a,(hl)
        cp      c
        ret     z
        inc     hl
        or      a
        jr      nz,schrf_loop
schrf_not_found:
        ld      hl,0
        ret

        public  __schr
__schr:
        ; char *strchr(const char *s, int c)
        ; Unrolled scalar scan.  CPIR is unsafe without first finding NUL,
        ; and a length-prefetch would scan long misses twice.  This keeps
        ; strchr(s,'$') long misses to one pass while reducing loop branches.
        pop     de              ; pop return address
        pop     hl              ; HL = s
        pop     bc              ; BC = c (C = char)
        push    bc              ; restore c for caller cleanup
        push    hl              ; restore s for caller cleanup
        push    de              ; restore return address
schr_loop:
        ld      a,(hl)
        cp      c
        ret     z
        inc     hl
        or      a
        jr      z,schr_not_found

        ld      a,(hl)
        cp      c
        ret     z
        inc     hl
        or      a
        jr      z,schr_not_found

        ld      a,(hl)
        cp      c
        ret     z
        inc     hl
        or      a
        jr      z,schr_not_found

        ld      a,(hl)
        cp      c
        ret     z
        inc     hl
        or      a
        jr      nz,schr_loop
schr_not_found:
        ld      hl,0
        ret

        public  __sstr
__sstr:
        ; char *strstr(const char *haystack, const char *needle)
        ; Length-bounded CPIR outer scan, with a quick second-character
        ; precheck before saving full retry state.  This is especially good
        ; for repeated misses like strstr(s,"gfe") against alphabetic data:
        ; many candidates match needle[0], almost all fail at needle[1].
        pop     bc              ; return address
        pop     de              ; DE = haystack
        pop     hl              ; HL = needle
        push    hl              ; restore caller arguments for caller cleanup
        push    de
        push    bc              ; restore return address
        ld      a,(hl)
        or      a
        jr      nz,sstr_ne2
        ex      de,hl           ; empty needle => return haystack
        ret
sstr_ne2:
        ; Compute remaining haystack span including the terminating NUL.
        push    hl              ; save needle
        push    de              ; save haystack/current pointer
        ex      de,hl           ; HL = haystack
        ld      bc,0ffffh
        xor     a
        cpir                    ; find NUL, BC has one's-complement count left
        ld      a,c
        cpl
        ld      c,a
        ld      a,b
        cpl
        ld      b,a             ; BC = strlen(haystack) + 1
        pop     de              ; DE = current haystack search pointer
        pop     hl              ; HL = needle
        ld      a,(hl)          ; A = needle[0]
sstr_cpir_scan:
        push    hl              ; save original needle pointer
        ld      h,d
        ld      l,e             ; HL = current haystack pointer
        cpir                    ; search A within remaining span
        jr      nz,sstr_cpir_not_found

        ; Found first char.  HL is one past candidate, BC is remaining after it.
        ; Fast path: check needle[1] before pushing full retry state.
        pop     de              ; DE = original needle pointer
        inc     de              ; DE = needle + 1
        ld      a,(de)
        or      a
        jr      z,sstr_cpir_onechar
        cp      (hl)            ; compare needle[1] with candidate[1]
        jr      nz,sstr_cpir_fast_fail

        ; First two characters matched.  Save retry/return state and compare
        ; the rest of the needle.
        push    bc              ; save remaining span after candidate first byte
        push    de              ; save needle+1
        push    hl              ; save candidate+1
sstr_cpir_cmp_rest:
        inc     de
        inc     hl
        ld      a,(de)
        or      a
        jr      z,sstr_cpir_found
        cp      (hl)
        jr      nz,sstr_cpir_fail
        jr      sstr_cpir_cmp_rest

sstr_cpir_fast_fail:
        ; DE = needle+1, HL = candidate+1, BC = remaining span.
        dec     de              ; DE = original needle
        ex      de,hl           ; HL = original needle, DE = next haystack
        ld      a,(hl)          ; A = needle[0] for CPIR
        jr      sstr_cpir_scan

sstr_cpir_fail:
        pop     hl              ; HL = candidate+1
        pop     de              ; DE = needle+1
        pop     bc              ; BC = remaining span after candidate first byte
        dec     de              ; DE = original needle
        ex      de,hl           ; HL = original needle, DE = next haystack
        ld      a,(hl)          ; A = needle[0] for CPIR
        jr      sstr_cpir_scan

sstr_cpir_found:
        pop     hl              ; HL = candidate+1
        pop     de              ; discard saved needle+1
        pop     bc              ; discard saved remaining span
sstr_cpir_onechar:
        dec     hl              ; return candidate start
        ret

sstr_cpir_not_found:
        pop     hl              ; discard saved needle pointer
        ld      hl,0
        ret

        public  __ncmp
__ncmp:
        ; int strncmp(const char *s1, const char *s2, size_t n)
        push    ix
        ld      ix,0
        add     ix,sp
        ld      e,(ix+4)
        ld      d,(ix+5)
        ld      l,(ix+6)
        ld      h,(ix+7)
        ld      c,(ix+8)
        ld      b,(ix+9)
sncmp_loop:
        ld      a,b
        or      c
        jr      z,sncmp_equal
        ld      a,(de)
        cp      (hl)
        jr      nz,sncmp_diff
        or      a
        jr      z,sncmp_equal
        inc     de
        inc     hl
        dec     bc
        jr      sncmp_loop
sncmp_diff:
        ; A still holds *s1 after CP (HL), so compute *s1 - *s2 directly.
        sub     (hl)
        ld      l,a
        ld      h,0
        jr      nc,sncmp_ret
        ld      h,0ffh
sncmp_ret:
        pop     ix
        ret
sncmp_equal:
        ld      hl,0
        pop     ix
        ret

        public  __mchr
__mchr:
        ; void *memchr(const void *s, int c, size_t n)
        push    ix
        ld      ix,0
        add     ix,sp
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      c,(ix+8)
        ld      b,(ix+9)
        ld      a,b
        or      c
        jr      z,mchr_none
        ld      a,(ix+6)
        cpir
        jr      nz,mchr_none
        dec     hl              ; CPIR leaves HL one byte past the match
mchr_found:
        pop     ix
        ret
mchr_none:
        ld      hl,0
        pop     ix
        ret

        public  __scat
__scat:
        ; char *strcat(char *dst, const char *src)
        push    ix
        ld      ix,0
        add     ix,sp
        ld      e,(ix+4)
        ld      d,(ix+5)
        ld      l,(ix+6)
        ld      h,(ix+7)
        push    de
scat_end:
        ld      a,(de)
        or      a
        jr      z,scat_copy
        inc     de
        jr      scat_end
scat_copy:
        ld      a,(hl)
        ld      (de),a
        inc     hl
        inc     de
        or      a
        jr      nz,scat_copy
        pop     hl
        pop     ix
        ret


        public  __scol
__scol:
        ; int strcoll(const char *s1, const char *s2)
        ; Current C locale: collation is bytewise strcmp.
        jp      __scmp

        public  __scsp
__scsp:
        ; size_t strcspn(const char *s, const char *reject)
        ; Result is the length of the initial reject-free run, which equals
        ; (current s - initial s); no running counter is needed.
        push    ix
        ld      ix,0
        add     ix,sp

        ld      l,(ix+4)
        ld      h,(ix+5)        ; HL = s

scsp_outer:
        ld      a,(hl)
        or      a
        jr      z,scsp_ret_count

        push    hl              ; save current s
        ld      e,(ix+6)
        ld      d,(ix+7)        ; DE = reject
scsp_inner:
        ld      a,(de)
        or      a
        jr      z,scsp_no_match
        ld      c,a
        ld      a,(hl)
        cp      c
        jr      z,scsp_match
        inc     de
        jr      scsp_inner

scsp_no_match:
        pop     hl
        inc     hl
        jr      scsp_outer

scsp_match:
        pop     hl
scsp_ret_count:
        ld      e,(ix+4)
        ld      d,(ix+5)        ; DE = initial s
        or      a
        sbc     hl,de           ; HL = current s - initial s = count
        pop     ix
        ret

        public  __spbr
__spbr:
        ; char *strpbrk(const char *s, const char *accept)
        push    ix
        ld      ix,0
        add     ix,sp

        ld      l,(ix+4)
        ld      h,(ix+5)        ; HL = s

spbr_outer:
        ld      a,(hl)
        or      a
        jr      z,spbr_none

        push    hl
        ld      e,(ix+6)
        ld      d,(ix+7)        ; DE = accept
spbr_inner:
        ld      a,(de)
        or      a
        jr      z,spbr_no_match
        ld      c,a
        ld      a,(hl)
        cp      c
        jr      z,spbr_found
        inc     de
        jr      spbr_inner

spbr_no_match:
        pop     hl
        inc     hl
        jr      spbr_outer

spbr_found:
        pop     hl              ; return current s pointer
        pop     ix
        ret

spbr_none:
        ld      hl,0
        pop     ix
        ret

        public  __sspn
__sspn:
        ; size_t strspn(const char *s, const char *accept)
        ; Result is the length of the initial accept-only run, which equals
        ; (current s - initial s); no running counter is needed.
        push    ix
        ld      ix,0
        add     ix,sp

        ld      l,(ix+4)
        ld      h,(ix+5)        ; HL = s

sspn_outer:
        ld      a,(hl)
        or      a
        jr      z,sspn_ret_count

        push    hl              ; save current s
        ld      e,(ix+6)
        ld      d,(ix+7)        ; DE = accept
sspn_inner:
        ld      a,(de)
        or      a
        jr      z,sspn_no_match
        ld      c,a
        ld      a,(hl)
        cp      c
        jr      z,sspn_match
        inc     de
        jr      sspn_inner

sspn_match:
        pop     hl
        inc     hl
        jr      sspn_outer

sspn_no_match:
        pop     hl
sspn_ret_count:
        ld      e,(ix+4)
        ld      d,(ix+5)        ; DE = initial s
        or      a
        sbc     hl,de           ; HL = current s - initial s = count
        pop     ix
        ret


        public  __sdup
__sdup:
        ; char *strdup(const char *s)
        push    ix
        ld      ix,0
        add     ix,sp

        ; Compute length including NUL.
        ld      l,(ix+4)
        ld      h,(ix+5)
        push    hl              ; save src
        call    __slen
        inc     hl
        ld      (__sdup_len),hl

        ; malloc(len)
        push    hl
        call    _malloc
        pop     de              ; clean malloc arg
        pop     de              ; DE = src

        ; If malloc failed, return NULL.
        ld      a,h
        or      l
        jr      z,sdup_ret

        ; Copy len bytes from DE=src to HL=dest.
        push    hl              ; save dest for return
        ex      de,hl           ; HL = src, DE = dest
        ld      bc,(__sdup_len)
        ldir
        pop     hl              ; return dest

sdup_ret:
        pop     ix
        ret

__sdup_len:
        dw      0

        public  __ncpy
__ncpy:
        ; char *strncpy(char *dst, const char *src, size_t n)
        ; Copy at most n bytes and, if src ends first, pad the rest with NUL.
        ; Keep private labels short/unique for M80/L80 symbol significance.
        push    ix
        ld      ix,0
        add     ix,sp
        ld      e,(ix+4)        ; DE = dst
        ld      d,(ix+5)
        ld      l,(ix+6)        ; HL = src
        ld      h,(ix+7)
        ld      c,(ix+8)        ; BC = n
        ld      b,(ix+9)
        push    de              ; return dst
nc1lp:
        ld      a,b
        or      c
        jr      z,nc1dn
        ld      a,(hl)
        inc     hl
        ld      (de),a
        inc     de
        dec     bc
        or      a
        jr      nz,nc1lp
        xor     a
nc1pd:
        ld      a,b
        or      c
        jr      z,nc1dn
        xor     a
        ld      (de),a
        inc     de
        dec     bc
        jr      nc1pd
nc1dn:
        pop     hl
        pop     ix
        ret

        public  __mcmp
__mcmp:
        ; int memcmp(const void *s1, const void *s2, size_t n)
        ; IX-free argument setup.  Final hot loop uses DE=s1, HL=s2, BC=n.
        ld      hl,2
        add     hl,sp
        ld      c,(hl)
        inc     hl
        ld      b,(hl)          ; BC = s1 temporary
        inc     hl
        ld      e,(hl)
        inc     hl
        ld      d,(hl)          ; DE = s2 temporary
        inc     hl
        ld      a,(hl)
        inc     hl
        ld      h,(hl)
        ld      l,a             ; HL = n temporary
        push    bc              ; save s1
        push    hl              ; save n
        ex      de,hl           ; HL = s2
        pop     bc              ; BC = n
        pop     de              ; DE = s1
        ld      a,b
        or      c
        jr      z,mc2eq         ; n == 0
        ld      a,b
        or      a
        jr      z,mc2tail       ; n < 256: no 256-byte chunks
        push    bc              ; save [n_high, n_low] across chunk loop
mc2chunk:
        ; Compare one full 256-byte chunk.  The common tstring path is
        ; equality over long buffers; unroll 4 bytes per DJNZ to reduce
        ; branch overhead without changing mismatch return semantics.
        ld      b,64
mc2clp:
        ld      a,(de)
        cp      (hl)
        jr      nz,mc2dkl
        inc     de
        inc     hl
        ld      a,(de)
        cp      (hl)
        jr      nz,mc2dkl
        inc     de
        inc     hl
        ld      a,(de)
        cp      (hl)
        jr      nz,mc2dkl
        inc     de
        inc     hl
        ld      a,(de)
        cp      (hl)
        jr      nz,mc2dkl
        inc     de
        inc     hl
        djnz    mc2clp
        pop     bc              ; restore [n_high, n_low]
        djnz    mc2more         ; dec n_high; more chunks if nonzero
        jr      mc2tail         ; all chunks done, handle tail
mc2more:
        push    bc
        jr      mc2chunk
mc2tail:
        ld      a,c             ; A = n_low (remaining bytes)
        or      a
        jr      z,mc2eq
        ld      b,a
mc2tlp:
        ld      a,(de)
        cp      (hl)
        jr      nz,mc2dtl
        inc     de
        inc     hl
        djnz    mc2tlp
mc2eq:
        ld      hl,0
        ret
mc2dkl:
        pop     bc              ; clean [n_high, n_low] off stack
mc2dtl:
        sub     (hl)            ; A = *s1 - *s2
        ld      l,a
        ld      h,0
        ret     nc
        ld      h,0ffh
        ret

        public  __mmov
__mmov:
        ; void *memmove(void *dst, const void *src, size_t n)
        push    ix
        ld      ix,0
        add     ix,sp

        ; if n == 0, done
        ld      c,(ix+8)
        ld      b,(ix+9)
        ld      a,b
        or      c
        jr      z,mmv_ret_dst

        ; if dst == src, done
        ld      a,(ix+4)
        cp      (ix+6)
        jr      nz,mmv_cmp
        ld      a,(ix+5)
        cp      (ix+7)
        jr      z,mmv_ret_dst

mmv_cmp:
        ; Compare dst - src unsigned. If dst < src, copy forward.
        ld      l,(ix+4)
        ld      h,(ix+5)        ; HL = dst
        ld      e,(ix+6)
        ld      d,(ix+7)        ; DE = src
        or      a
        sbc     hl,de
        jr      c,mmv_do_forward

        ; Backward copy: HL = src+n, DE = dst+n, BC = n.
        ld      l,(ix+6)
        ld      h,(ix+7)        ; HL = src
        ld      c,(ix+8)
        ld      b,(ix+9)
        add     hl,bc           ; HL = src+n
        ld      e,(ix+4)
        ld      d,(ix+5)        ; DE = dst
        ex      de,hl           ; HL = dst, DE = src+n
        add     hl,bc           ; HL = dst+n
        ex      de,hl           ; HL = src+n, DE = dst+n
        dec     hl              ; HL = last source byte (src+n-1)
        dec     de              ; DE = last dest byte (dst+n-1)
        lddr                    ; copy n bytes high->low (n != 0 guaranteed)
        jr      mmv_ret_dst

mmv_do_forward:
        ; Forward copy: HL = src, DE = dst, BC = n.
        ld      l,(ix+6)
        ld      h,(ix+7)
        ld      e,(ix+4)
        ld      d,(ix+5)
        ld      c,(ix+8)
        ld      b,(ix+9)
        ldir

mmv_ret_dst:
        ld      l,(ix+4)
        ld      h,(ix+5)
        pop     ix
        ret

        public  __ncat
__ncat:
        ; char *strncat(char *dst, const char *src, size_t n)
        push    ix
        ld      ix,0
        add     ix,sp
        ld      e,(ix+4)
        ld      d,(ix+5)        ; DE = dst
        ld      l,(ix+6)
        ld      h,(ix+7)        ; HL = src
        ld      c,(ix+8)
        ld      b,(ix+9)        ; BC = n
        push    de              ; return dst

        ; find terminating NUL in dst, leaving DE at append position
snc_find_end:
        ld      a,(de)
        or      a
        jr      z,snc_copy
        inc     de
        jr      snc_find_end

snc_copy:
        ld      a,b
        or      c
        jr      z,snc_term
        ld      a,(hl)
        or      a
        jr      z,snc_term
        ld      (de),a
        inc     hl
        inc     de
        dec     bc
        jr      snc_copy

snc_term:
        xor     a
        ld      (de),a
        pop     hl              ; return dst
        pop     ix
        ret

        public  __mcpy
__mcpy:
        ; void *memcpy(void *dst, const void *src, size_t n)
        ; IX-free argument setup.  C memcpy is undefined for overlap, so LDIR is OK.
        ld      hl,2
        add     hl,sp
        ld      c,(hl)
        inc     hl
        ld      b,(hl)          ; BC = dst temporary
        inc     hl
        ld      e,(hl)
        inc     hl
        ld      d,(hl)          ; DE = src temporary
        inc     hl
        ld      a,(hl)
        inc     hl
        ld      h,(hl)
        ld      l,a             ; HL = n temporary
        push    bc              ; save dst for return/setup
        push    hl              ; save n
        ex      de,hl           ; HL = src
        pop     bc              ; BC = n
        pop     de              ; DE = dst
        push    de              ; return dst
        ld      a,b
        or      c
        jr      z,mcpy_done
        ldir
mcpy_done:
        pop     hl
        ret

        public  __mset
__mset:
        ; void *memset(void *dest, int c, int count)
        ; IX-free setup plus Z80 LDIR block-fill.
        ld      hl,2
        add     hl,sp
        ld      e,(hl)
        inc     hl
        ld      d,(hl)          ; DE = dest temporary
        inc     hl
        ld      a,(hl)          ; A = fill byte
        push    af              ; save fill while loading count
        inc     hl              ; skip high byte of int c
        inc     hl
        ld      c,(hl)
        inc     hl
        ld      b,(hl)          ; BC = count
        ex      de,hl           ; HL = dest
        pop     af              ; A = fill byte
        push    hl              ; save dest for return value
        ld      e,a             ; E = fill byte across zero tests
        ld      a,b
        or      c
        jr      z,ms_done       ; count == 0, nothing to do
        ld      a,e
        ld      (hl),a          ; write first byte
        dec     bc
        ld      a,b
        or      c
        jr      z,ms_done       ; count was 1, done
        ld      d,h
        ld      e,l
        inc     de              ; DE = dest+1, HL = dest (contains fill byte)
        ldir                    ; copy (HL)->(DE) BC times, each step propagates fill
ms_done:
        pop     hl              ; HL = dest (return value)
        ret


; Indirect call helper.
; Indirect call helper.
; Input HL = target address. Returns whatever callee returns in HL.
        public  __call_hl
__call_hl:
        jp      (hl)

        public  __mulu
__mulu:
        push    bc
        push    af
        ; HL = multiplier, DE = multiplicand, product returned in HL.
        ; Multiplication is commutative and the result is taken mod 2^16, so
        ; pick an operand with a zero high byte as the multiplier and run only
        ; 8 iterations.  The multiplicand is shifted with sla e/rl d, which is
        ; cheaper than ex de,hl/add hl,hl/ex de,hl.
        ld      a,h
        or      a
        jr      z,mul8          ; HL fits in 8 bits -> use it as multiplier
        ld      a,d
        or      a
        jr      nz,mul16        ; neither operand fits in 8 bits -> full 16
        ex      de,hl           ; DE fits in 8 bits -> swap it into HL
mul8:
        ld      c,l             ; C = 8-bit multiplier
        ld      hl,0            ; HL = product
        ld      b,8
mul8l:
        srl     c
        jr      nc,mul8s
        add     hl,de
mul8s:
        sla     e
        rl      d
        djnz    mul8l
        pop     af
        pop     bc
        ret

mul16:
        ld      b,16
        ld      c,l
        ld      a,h
        ld      hl,0
mu1:
        srl     a
        rr      c
        jr      nc,mu2
        add     hl,de
mu2:
        sla     e
        rl      d
        djnz    mu1
        pop     af
        pop     bc
        ret

        public  __divu
        public  __modu
        public  __divs
        public  __mods
DRSU:
        ; Unsigned 16-bit divide, hybrid bounded.
        ; Input:  HL = dividend, DE = divisor
        ; Output: HL = quotient, DE = remainder
        ;
        ; Small quotients (the common case, e.g. e.c divides a variable n with
        ; a small carry) use repeated subtraction, which beats the fixed
        ; 16-step divider.  A djnz down-counter caps the loop: once the
        ; quotient reaches the cap the partially divided value is discarded
        ; and the bounded D16U divider finishes the job, so a large quotient
        ; can no longer cause an unbounded (up to 65535 iteration) stall.
        push    bc
        push    af
        ld      a,d
        or      e
        jr      nz,dms_rs0
        ld      d,h             ; divide by zero: quotient = 0xffff,
        ld      e,l             ; remainder = original dividend
        ld      hl,0ffffh
        jr      dms_rs_done

dms_rs0:
        push    hl              ; save dividend for the fallback path
        ld      b,40            ; B = remaining attempts (quotient cap)

dms_rs1:
        or      a
        sbc     hl,de
        jr      c,dms_rs2       ; underflow -> quotient = 40 - B
        djnz    dms_rs1         ; cap not reached -> keep subtracting

        ; cap reached: quotient >= 40, finish with the bounded divider.
        pop     hl              ; restore dividend (DE still = divisor)
        call    D16U            ; HL = quotient, DE = remainder
        jr      dms_rs_done

dms_rs2:
        add     hl,de           ; undo failed subtract; HL = remainder
        ex      de,hl           ; DE = remainder
        ld      a,40
        sub     b               ; A = quotient (cap - remaining)
        ld      h,0
        ld      l,a             ; HL = quotient
        pop     bc              ; discard saved dividend

dms_rs_done:
        pop     af
        pop     bc
        ret

__divu:
        ; Faster cache-aware unsigned divide.
        ; Input:  HL = dividend, DE = divisor
        ; Output: HL = quotient
        ;
        ; Fast hit path compares the live operands directly against the
        ; cached operands.  This avoids storing scratch operands on every
        ; div/mod pair hit.
        ld      a,(__dmval)
        or      a
        jr      z,du_miss_save

        push    hl              ; save dividend
        or      a
        ld      hl,(__dmc_rhs)
        sbc     hl,de
        jr      nz,du_rhs_bad

        pop     hl              ; restore dividend
        push    de              ; save divisor
        push    hl              ; save original dividend so miss has correct HL
        ld      de,(__dmc_lhs)
        or      a
        sbc     hl,de           ; compare only; result discarded on both paths
        pop     hl              ; restore original dividend (hit or miss)
        pop     de              ; restore divisor
        jr      nz,du_miss_save

        ld      hl,(__dmquot)
        ret

du_rhs_bad:
        pop     hl              ; restore dividend

du_miss_save:
        ld      (__dmc_lhs),hl
        ex      de,hl
        ld      (__dmc_rhs),hl
        ex      de,hl

        call    DRSU        ; HL = quotient, DE = remainder

        ld      (__dmquot),hl
        ex      de,hl
        ld      (__dmrem),hl
        ld      a,1
        ld      (__dmval),a
        ld      hl,(__dmquot)
        ret

__modu:
        ; Cache-aware unsigned modulo.  Same cache as __divu, so x%n then x/n
        ; (or x/n then x%n) with identical operands calls DRSU once.
        ; Input:  HL = dividend, DE = divisor
        ; Output: HL = remainder
        ld      a,(__dmval)
        or      a
        jr      z,dm_miss       ; cache empty
        push    de              ; [SP: divisor]
        push    hl              ; [SP: dividend, divisor]
        ; Check rhs (divisor)
        or      a
        ld      hl,(__dmc_rhs)
        sbc     hl,de
        jr      nz,dm_both_pop  ; rhs mismatch
        ; rhs matches  check lhs (dividend)
        pop     hl              ; restore dividend  [SP: divisor]
        push    hl              ; re-save           [SP: dividend, divisor]
        ld      de,(__dmc_lhs)
        or      a
        sbc     hl,de           ; HL = dividend - cached_lhs (HL corrupted)
        jr      nz,dm_both_pop  ; lhs mismatch
        ; cache hit
        pop     hl              ; discard saved dividend [SP: divisor]
        pop     de              ; restore divisor
        ld      hl,(__dmrem)
        ret
dm_both_pop:
        pop     hl              ; restore dividend
        pop     de              ; restore divisor
dm_miss:
        ld      (__dmc_lhs),hl
        ex      de,hl
        ld      (__dmc_rhs),hl
        ex      de,hl
        call    DRSU  ; HL = quotient, DE = remainder
        ld      (__dmquot),hl
        ex      de,hl
        ld      (__dmrem),hl    ; HL = remainder
        ld      a,1
        ld      (__dmval),a
        ret


; Signed 16-bit division/modulo wrappers.
; Input:  HL = signed dividend, DE = signed divisor
; Output: HL = quotient (__divs) or remainder (__mods)
; Semantics: quotient truncates toward zero; remainder has dividend sign.
__divs:
        ; Fast path: if both operands are non-negative, signed division is
        ; identical to unsigned division.  This avoids the sign-wrapper
        ; overhead in hot loops such as e.c where int values stay >= 0.
        ld      a,h
        or      d
        jp      p,__divu
        push    bc
        ld      b,0             ; bit0: quotient negative?
        ld      a,h
        or      a
        jp      p,__ds_lpos
        ld      a,b
        xor     1
        ld      b,a
        xor     a
        sub     l
        ld      l,a
        ld      a,0
        sbc     a,h
        ld      h,a
__ds_lpos:
        ld      a,d
        or      a
        jp      p,__ds_rpos
        ld      a,b
        xor     1
        ld      b,a
        ex      de,hl
        xor     a
        sub     l
        ld      l,a
        ld      a,0
        sbc     a,h
        ld      h,a
        ex      de,hl
__ds_rpos:
        call    __divu
        ld      a,b
        or      a
        jp      z,__ds_done
        xor     a
        sub     l
        ld      l,a
        ld      a,0
        sbc     a,h
        ld      h,a
__ds_done:
        pop     bc
        ret

__mods:
        ; Fast path: if both operands are non-negative, signed modulo is
        ; identical to unsigned modulo.  Jump directly so cache pairing with
        ; __divu/__modu still works.
        ld      a,h
        or      d
        jp      p,__modu
        push    bc
        ld      b,0             ; bit0: remainder negative? dividend sign only
        ld      a,h
        or      a
        jp      p,__ms_lpos
        ld      b,1
        xor     a
        sub     l
        ld      l,a
        ld      a,0
        sbc     a,h
        ld      h,a
__ms_lpos:
        ld      a,d
        or      a
        jp      p,__ms_rpos
        ex      de,hl
        xor     a
        sub     l
        ld      l,a
        ld      a,0
        sbc     a,h
        ld      h,a
        ex      de,hl
__ms_rpos:
        call    __modu
        ld      a,b
        or      a
        jp      z,__ms_done
        xor     a
        sub     l
        ld      l,a
        ld      a,0
        sbc     a,h
        ld      h,a
__ms_done:
        pop     bc
        ret

        public  _abs
_abs:
        ; int abs(int j)
        push    ix
        ld      ix,0
        add     ix,sp
        ld      l,(ix+4)
        ld      h,(ix+5)
        bit     7,h
        jr      z,abs_done
        xor     a
        sub     l
        ld      l,a
        ld      a,0
        sbc     a,h
        ld      h,a
abs_done:
        pop     ix
        ret

        public  _labs
_labs:
        ; long labs(long j)
        push    ix
        ld      ix,0
        add     ix,sp
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      e,(ix+6)
        ld      d,(ix+7)
        bit     7,d
        jr      z,labs_done
        ld      a,l
        cpl
        ld      l,a
        ld      a,h
        cpl
        ld      h,a
        ld      a,e
        cpl
        ld      e,a
        ld      a,d
        cpl
        ld      d,a
        inc     hl
        ld      a,h
        or      l
        jr      nz,labs_done
        inc     de
labs_done:
        pop     ix
        ret

        public  _div
_div:
        ; div_t div(int numer, int denom)
        ; Hidden struct return pointer is the first argument at IX+4.
        push    ix
        ld      ix,0
        add     ix,sp

        ld      l,(ix+6)
        ld      h,(ix+7)        ; HL = numer
        ld      e,(ix+8)
        ld      d,(ix+9)        ; DE = denom
        call    __divs          ; HL = quotient
        ld      c,(ix+4)
        ld      b,(ix+5)        ; BC = result pointer
        ld      a,l
        ld      (bc),a
        inc     bc
        ld      a,h
        ld      (bc),a

        ld      l,(ix+6)
        ld      h,(ix+7)        ; HL = numer
        ld      e,(ix+8)
        ld      d,(ix+9)        ; DE = denom
        call    __mods          ; HL = remainder
        ld      c,(ix+4)
        ld      b,(ix+5)
        inc     bc
        inc     bc              ; BC = &result->rem
        ld      a,l
        ld      (bc),a
        inc     bc
        ld      a,h
        ld      (bc),a
        ld      l,(ix+4)
        ld      h,(ix+5)
        pop     ix
        ret

        public  _ldiv
_ldiv:
        ; ldiv_t ldiv(long numer, long denom)
        ; Hidden struct return pointer is the first argument at IX+4.
        push    ix
        ld      ix,0
        add     ix,sp

        ld      l,(ix+8)
        ld      h,(ix+9)        ; numer high word
        push    hl
        ld      l,(ix+6)
        ld      h,(ix+7)        ; numer low word
        push    hl
        ld      l,(ix+12)
        ld      h,(ix+13)       ; denom high word
        push    hl
        ld      l,(ix+10)
        ld      h,(ix+11)       ; denom low word
        push    hl
        call    __lds           ; DE:HL = quotient
        pop     bc
        pop     bc
        pop     bc
        pop     bc
        ld      c,(ix+4)
        ld      b,(ix+5)        ; BC = result pointer
        ld      a,l
        ld      (bc),a
        inc     bc
        ld      a,h
        ld      (bc),a
        inc     bc
        ld      a,e
        ld      (bc),a
        inc     bc
        ld      a,d
        ld      (bc),a

        ld      l,(ix+8)
        ld      h,(ix+9)        ; numer high word
        push    hl
        ld      l,(ix+6)
        ld      h,(ix+7)        ; numer low word
        push    hl
        ld      l,(ix+12)
        ld      h,(ix+13)       ; denom high word
        push    hl
        ld      l,(ix+10)
        ld      h,(ix+11)       ; denom low word
        push    hl
        call    __lms           ; DE:HL = remainder
        pop     bc
        pop     bc
        pop     bc
        pop     bc
        ld      c,(ix+4)
        ld      b,(ix+5)
        inc     bc
        inc     bc
        inc     bc
        inc     bc              ; BC = &result->rem
        ld      a,l
        ld      (bc),a
        inc     bc
        ld      a,h
        ld      (bc),a
        inc     bc
        ld      a,e
        ld      (bc),a
        inc     bc
        ld      a,d
        ld      (bc),a
        ld      l,(ix+4)
        ld      h,(ix+5)
        pop     ix
        ret


        public  _bsearch
; const void *bsearch(const void *key, const void *base, size_t num,
;                     size_t size, int (*compare)(const void *, const void *))
; Classic size-decrementing binary search: no signed index arithmetic, so it
; is correct for the full unsigned size_t range.  Calls the comparator through
; __call_hl using the standard dcc convention (args pushed right-to-left,
; result in HL, caller cleans the stack).  State is held in static scratch
; because the comparator may clobber every register.  Returns the matching
; element pointer, or 0 if not found.
_bsearch:
        push    ix
        ld      ix,0
        add     ix,sp
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      (__bs_key),hl
        ld      l,(ix+6)
        ld      h,(ix+7)
        ld      (__bs_base),hl
        ld      l,(ix+8)
        ld      h,(ix+9)
        ld      (__bs_num),hl
        ld      l,(ix+10)
        ld      h,(ix+11)
        ld      (__bs_size),hl
        ld      l,(ix+12)
        ld      h,(ix+13)
        ld      (__bs_cmp),hl
bs_loop:
        ld      hl,(__bs_num)
        ld      a,h
        or      l
        jp      z,bs_nf                 ; num == 0 -> not found
        ; half = num >> 1
        srl     h
        rr      l
        ld      (__bs_half),hl
        ; here = base + half*size
        ld      de,(__bs_size)
        call    __mulu                  ; HL = half*size
        ld      de,(__bs_base)
        add     hl,de
        ld      (__bs_here),hl
        ; compare(key, here): push here (b), push key (a)
        push    hl
        ld      hl,(__bs_key)
        push    hl
        ld      hl,(__bs_cmp)
        call    __call_hl
        pop     bc
        pop     bc
        ld      a,h
        or      l
        jr      z,bs_found              ; equal
        bit     7,h
        jr      nz,bs_lt                ; result < 0 -> search lower half
        ; result > 0 -> search upper half: base = here+size; num = num-half-1
        ld      hl,(__bs_here)
        ld      de,(__bs_size)
        add     hl,de
        ld      (__bs_base),hl
        ld      hl,(__bs_num)
        ld      de,(__bs_half)
        or      a
        sbc     hl,de
        dec     hl
        ld      (__bs_num),hl
        jp      bs_loop
bs_lt:
        ld      hl,(__bs_half)
        ld      (__bs_num),hl
        jp      bs_loop
bs_found:
        ld      hl,(__bs_here)
        pop     ix
        ret
bs_nf:
        ld      hl,0
        pop     ix
        ret
__bs_key:       dw      0
__bs_base:      dw      0
__bs_num:       dw      0
__bs_size:      dw      0
__bs_cmp:       dw      0
__bs_half:      dw      0
__bs_here:      dw      0

        public  _qsort
; void qsort(void *base, size_t num, size_t size,
;            int (*compare)(const void *, const void *))
; In-place Shell sort: non-recursive (no C-stack growth on adversarial input,
; unlike a recursive quicksort) and needs no auxiliary memory, which suits the
; small CP/M TPA.  Element size is arbitrary; elements are exchanged with a
; byte-wise swap.  The comparator is called through __call_hl.  State is kept
; in static scratch (the comparator may clobber all registers), so qsort is not
; re-entrant from within its own comparator -- acceptable for this runtime.
_qsort:
        push    ix
        ld      ix,0
        add     ix,sp
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      (__qs_base),hl
        ld      l,(ix+6)
        ld      h,(ix+7)
        ld      (__qs_num),hl
        ld      l,(ix+8)
        ld      h,(ix+9)
        ld      (__qs_size),hl
        ld      l,(ix+10)
        ld      h,(ix+11)
        ld      (__qs_cmp),hl
        ; if num < 2 nothing to do
        ld      hl,(__qs_num)
        ld      de,2
        or      a
        sbc     hl,de
        jp      c,qs_ret
        ; gap = num >> 1
        ld      hl,(__qs_num)
        srl     h
        rr      l
        ld      (__qs_gap),hl
qs_gaploop:
        ; gapb = gap * size
        ld      hl,(__qs_gap)
        ld      de,(__qs_size)
        call    __mulu
        ld      (__qs_gapb),hl
        ; i = gap ; pi = base + gapb
        ld      hl,(__qs_base)
        ld      de,(__qs_gapb)
        add     hl,de
        ld      (__qs_pi),hl
        ld      hl,(__qs_gap)
        ld      (__qs_i),hl
qs_iloop:
        ld      hl,(__qs_i)
        ld      de,(__qs_num)
        or      a
        sbc     hl,de
        jp      nc,qs_gapnext           ; i >= num -> end of this gap pass
        ; pj = pi ; j = i
        ld      hl,(__qs_pi)
        ld      (__qs_pj),hl
        ld      hl,(__qs_i)
        ld      (__qs_j),hl
qs_inner:
        ; while j >= gap
        ld      hl,(__qs_j)
        ld      de,(__qs_gap)
        or      a
        sbc     hl,de
        jr      c,qs_idone              ; j < gap -> stop
        ; pprev = pj - gapb
        ld      hl,(__qs_pj)
        ld      de,(__qs_gapb)
        or      a
        sbc     hl,de
        ld      (__qs_pprev),hl
        ; compare(pprev, pj): push pj (b), push pprev (a)
        ld      hl,(__qs_pj)
        push    hl
        ld      hl,(__qs_pprev)
        push    hl
        ld      hl,(__qs_cmp)
        call    __call_hl
        pop     bc
        pop     bc
        ld      a,h
        or      l
        jr      z,qs_idone              ; cmp == 0 -> ordered, stop
        bit     7,h
        jr      nz,qs_idone             ; cmp < 0 -> ordered, stop
        ; cmp > 0 -> swap *pprev and *pj (size bytes), then step down by gap
        ld      hl,(__qs_pprev)
        ld      de,(__qs_pj)
        ld      bc,(__qs_size)
qs_swap:
        ld      a,(de)
        ex      af,af'
        ld      a,(hl)
        ld      (de),a
        ex      af,af'
        ld      (hl),a
        inc     hl
        inc     de
        dec     bc
        ld      a,b
        or      c
        jr      nz,qs_swap
        ld      hl,(__qs_pprev)
        ld      (__qs_pj),hl
        ld      hl,(__qs_j)
        ld      de,(__qs_gap)
        or      a
        sbc     hl,de
        ld      (__qs_j),hl
        jp      qs_inner
qs_idone:
        ; i++ ; pi += size
        ld      hl,(__qs_i)
        inc     hl
        ld      (__qs_i),hl
        ld      hl,(__qs_pi)
        ld      de,(__qs_size)
        add     hl,de
        ld      (__qs_pi),hl
        jp      qs_iloop
qs_gapnext:
        ; gap >>= 1 ; continue while gap > 0
        ld      hl,(__qs_gap)
        srl     h
        rr      l
        ld      (__qs_gap),hl
        ld      a,h
        or      l
        jp      nz,qs_gaploop
qs_ret:
        pop     ix
        ret
__qs_base:      dw      0
__qs_num:       dw      0
__qs_size:      dw      0
__qs_cmp:       dw      0
__qs_gap:       dw      0
__qs_gapb:      dw      0
__qs_i:         dw      0
__qs_pi:        dw      0
__qs_j:         dw      0
__qs_pj:        dw      0
__qs_pprev:     dw      0


        public  __r1u
; 16-bit unsigned dividend modulo 8-bit constant divisor.
; Input:  HL = dividend, E = divisor (1..255)
; Output: HL = remainder
; Used for unsigned x % C when C fits in one byte and is not a power of two.
__r1u:
        push    bc
        push    de              ; preserve caller DE (D reused as bit counter)
        push    af
        ld      a,e
        or      a
        jr      nz,R1U0
        ; Undefined in C, but keep a deterministic fallback for divisor 0.
        pop     af
        pop     de
        pop     bc
        ret
R1U0:
        ld      bc,0            ; BC = partial remainder, kept < divisor
        ld      d,16            ; D = bit counter (D is otherwise unused here)
R1U1:
        add     hl,hl           ; next dividend bit -> carry
        rl      c
        rl      b

        ; if BC >= E, subtract E.  Since E is 8-bit and BC is at most
        ; 9 bits here, this avoids the full 16-bit divisor compare path.
        ld      a,b
        or      a
        jr      nz,R1US
        ld      a,c
        cp      e
        jr      c,R1UN
R1US:
        ld      a,c
        sub     e
        ld      c,a
        ld      a,b
        sbc     a,0
        ld      b,a
R1UN:
        dec     d
        jr      nz,R1U1
        ld      h,0
        ld      l,c
        pop     af
        pop     de
        pop     bc
        ret


        public  __r1s
; 16-bit signed dividend modulo positive 8-bit constant divisor.
; Input:  HL = signed dividend, E = divisor (1..255)
; Output: HL = signed remainder, same sign convention as __mods/__r2s.
__r1s:
        ld      a,h
        or      a
        jp      p,__r1u
        push    bc
        xor     a
        sub     l
        ld      l,a
        ld      a,0
        sbc     a,h
        ld      h,a
        call    __r1u
        xor     a
        sub     l
        ld      l,a
        ld      a,0
        sbc     a,h
        ld      h,a
        pop     bc
        ret


        public  __q2u
        public  __r2u
        public  __q2s
        public  __r2s
; Fixed 16-iteration unsigned divider for constant divisors.
; dccpeep rewrites ld de,<const> / call __div*/__mod* to these short
; public names.  Names are 5 chars and unique under short external matching.
D16U:
        ; Input:  HL = dividend, DE = divisor
        ; Output: HL = quotient, DE = remainder
        ; Uses alternate AF as the 16-iteration counter.  The old version
        ; stored the counter in memory every bit, which is costly in hot
        ; constant-modulo code such as rand() % C.
        push    bc
        push    af
        ld      a,d
        or      e
        jr      nz,D16U0
        ld      d,h
        ld      e,l
        ld      hl,0ffffh
        jr      D16UD
D16U0:
        ld      bc,0            ; BC = partial remainder
        ex      af,af'
        ld      a,16            ; alternate A = loop counter
        ex      af,af'
D16U1:
        add     hl,hl           ; shift next dividend bit into carry;
        rl      c               ; BC = (BC << 1) | carry
        rl      b

        ; if BC >= DE, BC -= DE and set current quotient bit.
        ld      a,c
        sub     e
        ld      a,b
        sbc     a,d
        jr      c,D16U2

        ld      a,c
        sub     e
        ld      c,a
        ld      a,b
        sbc     a,d
        ld      b,a
        inc     l               ; low bit is known clear after add hl,hl
D16U2:
        ex      af,af'          ; decrement alternate counter
        dec     a
        jr      z,D16U3
        ex      af,af'
        jr      D16U1
D16U3:
        ex      af,af'          ; restore primary AF before returning
        ld      d,b             ; DE = remainder
        ld      e,c
D16UD:
        pop     af
        pop     bc
        ret

__q2u:
        call    D16U             ; fixed divider quotient
        ret

__r2u:
        call    D16U             ; fixed divider remainder
        ex      de,hl
        ret

__q2s:
        ; Signed fixed 16-step quotient.  Same semantics as __divs.
        ld      a,h
        or      d
        jp      p,__q2u
        push    bc
        ld      b,0
        ld      a,h
        or      a
        jp      p,Q2SLP
        ld      a,b
        xor     1
        ld      b,a
        xor     a
        sub     l
        ld      l,a
        ld      a,0
        sbc     a,h
        ld      h,a
Q2SLP:
        ld      a,d
        or      a
        jp      p,Q2SRP
        ld      a,b
        xor     1
        ld      b,a
        ex      de,hl
        xor     a
        sub     l
        ld      l,a
        ld      a,0
        sbc     a,h
        ld      h,a
        ex      de,hl
Q2SRP:
        call    __q2u
        ld      a,b
        or      a
        jp      z,Q2SDN
        xor     a
        sub     l
        ld      l,a
        ld      a,0
        sbc     a,h
        ld      h,a
Q2SDN:
        pop     bc
        ret

__r2s:
        ; Signed fixed 16-step remainder.  Same semantics as __mods.
        ld      a,h
        or      d
        jp      p,__r2u
        push    bc
        ld      b,0
        ld      a,h
        or      a
        jp      p,R2SLP
        ld      b,1
        xor     a
        sub     l
        ld      l,a
        ld      a,0
        sbc     a,h
        ld      h,a
R2SLP:
        ld      a,d
        or      a
        jp      p,R2SRP
        ex      de,hl
        xor     a
        sub     l
        ld      l,a
        ld      a,0
        sbc     a,h
        ld      h,a
        ex      de,hl
R2SRP:
        call    __r2u
        ld      a,b
        or      a
        jp      z,R2SDN
        xor     a
        sub     l
        ld      l,a
        ld      a,0
        sbc     a,h
        ld      h,a
R2SDN:
        pop     bc
        ret

; Shared function-frame entry/exit stubs used by the dccpeep pass_shared_frame_stubs
; optimisation.  Each is a separate public block so dccrtlstrip includes only what
; the application actually references.
;
; Names are <= 6 characters so they remain distinct in L80's 6-character
; symbol-table (L80 truncates longer names for matching purposes).
;
; __en0  frame setup with no local-variable allocation (8 inline bytes -> 3).
;   Caller emits:   call __en0
;   Stack on entry: [body_ret, ret_addr, params...]
;
        public  __en0
__en0:
        pop     de              ; DE = return-to-body address
        push    ix              ; save caller's frame pointer
        ld      ix,0
        add     ix,sp           ; IX = frame  (params at IX+4, IX+6, ...)
        ex      de,hl           ; HL = body address (DE = old HL, discarded)
        jp      (hl)

; __entr  frame setup WITH local-variable allocation (13 inline bytes -> 6).
;   Caller emits:   ld hl,-N  /  call __entr
;   Stack on entry: [body_ret, ret_addr, params...]  HL = -local_size
;
        public  __entr
__entr:
        pop     de              ; DE = return-to-body address
        push    ix              ; save caller's frame pointer
        ld      ix,0
        add     ix,sp           ; IX = frame pointer
        add     hl,sp           ; HL = SP - local_size
        ld      sp,hl           ; allocate locals
        ex      de,hl           ; HL = body address
        jp      (hl)

; __lve  shared epilogue for functions that have locals (5 inline bytes -> 3).
;   Caller emits:   jp __lve
;
        public  __lve
__lve:
        ld      sp,ix
        pop     ix
        ret

; __la1/__la2/__la3  load first/second/third word parameter into HL.
;   Replaces 6-byte inline: ld l,(ix+N) / ld h,(ix+N+1)
;   Caller emits:  call __la1  (or __la2, __la3)
;   Returns: HL = parameter value.  All other registers and flags unchanged.
;
        public  __la1
__la1:
        ld      l,(ix+4)
        ld      h,(ix+5)
        ret

        public  __la2
__la2:
        ld      l,(ix+6)
        ld      h,(ix+7)
        ret

        public  __la3
__la3:
        ld      l,(ix+8)
        ld      h,(ix+9)
        ret

; __phix  save HL on the stack, then copy IX into HL (4 inline bytes -> 3).
;   Replaces:  push hl / push ix / pop hl
;   Caller emits:  call __phix
;   Returns: HL = IX (frame pointer); old HL value pushed onto the stack.
;   All other registers and flags unchanged.
;
        public  __phix
__phix:
        ex      (sp),hl         ; HL = return addr, [SP] = old HL
        push    hl              ; push return addr (below old HL on stack)
        push    ix              ; push IX value
        pop     hl              ; HL = IX
        ret                     ; return; old HL now sits at top of stack

; __lv1-__lv8: load local variable word into HL.
; Analogous to __la1/__la2/__la3 for parameters but uses negative IX offsets.
; Each stub saves 3 bytes per replaced ld l,(ix-N) / ld h,(ix-N+1) pair.
        public  __lv1
__lv1:  ld      l,(ix-2)
        ld      h,(ix-1)
        ret

        public  __lv2
__lv2:  ld      l,(ix-4)
        ld      h,(ix-3)
        ret

        public  __lv3
__lv3:  ld      l,(ix-6)
        ld      h,(ix-5)
        ret

        public  __lv4
__lv4:  ld      l,(ix-8)
        ld      h,(ix-7)
        ret

        public  __lv5
__lv5:  ld      l,(ix-10)
        ld      h,(ix-9)
        ret

        public  __lv6
__lv6:  ld      l,(ix-12)
        ld      h,(ix-11)
        ret

        public  __lv7
__lv7:  ld      l,(ix-14)
        ld      h,(ix-13)
        ret

        public  __lv8
__lv8:  ld      l,(ix-16)
        ld      h,(ix-15)
        ret

; __sv1-__sv6: store HL to local variable word.
; Replaces ld (ix-N),l / ld (ix-N+1),h pairs; caller loads HL first.
        public  __sv1
__sv1:  ld      (ix-2),l
        ld      (ix-1),h
        ret

        public  __sv2
__sv2:  ld      (ix-4),l
        ld      (ix-3),h
        ret

        public  __sv3
__sv3:  ld      (ix-6),l
        ld      (ix-5),h
        ret

        public  __sv4
__sv4:  ld      (ix-8),l
        ld      (ix-7),h
        ret

        public  __sv5
__sv5:  ld      (ix-10),l
        ld      (ix-9),h
        ret

        public  __sv6
__sv6:  ld      (ix-12),l
        ld      (ix-11),h
        ret

; __ldwl  dereference 16-bit pointer in HL (4 inline bytes -> 3).
;   Replaces:  ld e,(hl) / inc hl / ld d,(hl) / ex de,hl
;   Input: HL = pointer.  Output: HL = *HL, DE trashed.  Flags unchanged.
        public  __ldwl
__ldwl: ld      e,(hl)
        inc     hl
        ld      d,(hl)
        ex      de,hl
        ret

; __wand  HL &= DE, 16-bit AND (6 inline bytes -> 3).
;   Replaces:  ld a,h / and d / ld h,a / ld a,l / and e / ld l,a
;   Input: HL, DE.  Output: HL = HL & DE.  Flags set by low-byte AND.
        public  __wand
__wand: ld      a,h
        and     d
        ld      h,a
        ld      a,l
        and     e
        ld      l,a
        ret

; __icmp  signed 16-bit compare, set flags for signed subtraction (8 inline bytes -> 3).
;   Replaces: ld a,h/xor 80h/ld h,a/ld a,d/xor 80h/ld d,a/or a/sbc hl,de
;   Input: HL, DE = signed 16-bit operands.
;   Output: flags set for signed HL-DE, HL and DE trashed.  ret preserves flags.
        public  __icmp
__icmp: ld      a,h
        xor     80h
        ld      h,a
        ld      a,d
        xor     80h
        ld      d,a
        or      a
        sbc     hl,de
        ret

; __sxde  sign-extend HL: produce DE = 0FFFFh if HL negative, 0 otherwise (5 bytes -> 3).
;   Replaces:  ld a,h / rlca / sbc a,a / ld d,a / ld e,a
;   Input: HL = signed 16-bit value.  Output: DE = sign-extension word, HL unchanged.
        public  __sxde
__sxde: ld      a,h
        rlca
        sbc     a,a
        ld      d,a
        ld      e,a
        ret

; __sxhl  sign-extend L into H: HL = (int16_t)(int8_t)L (4 inline bytes -> 3).
;   Replaces:  ld a,l / rlca / sbc a,a / ld h,a
;   Input: L = signed 8-bit value.  Output: H = sign of L, HL = 16-bit signed value.
        public  __sxhl
__sxhl: ld      a,l
        rlca
        sbc     a,a
        ld      h,a
        ret

        public  _printf
_printf:
        push    ix
        ld      ix,0
        add     ix,sp
        push    bc
        push    de
        ld      hl,0
        ld      (pf_sink),hl            ; console mode
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      de,6
        ld      bc,0
        call    __pf_run
        ld      h,b
        ld      l,c
        pop     de
        pop     bc
        pop     ix
        ret

; __pf_run: shared printf body.
; IN:  HL=fmt, DE=vararg offset from IX, BC=0, pf_sink set.
; IX must point to the caller's stack frame throughout.
; OUT: BC = character count.
__pf_run:
pf_loop:
        ld      a,(hl)
        or      a
        jp      z,pf_done
        inc     hl
        cp      '%'
        jp      z,pf_percent
        call    pf_emit_a
        jp      pf_loop

pf_percent:
        xor     a
        ld      (pf_width),a
        ld      (pf_prec),a
        ld      (pf_left),a

pf_pct_next:
        ld      a,(hl)
        or      a
        jp      z,pf_done
        inc     hl

        cp      '%'
        jp      z,pf_emit_and_loop

        cp      '-'
        jp      z,pf_pct_left

        cp      '.'
        jp      z,pf_pct_dot

        ; C99 size_t length modifier.  In dcc, size_t is 16-bit, so
        ; %zu/%zd/%zi/%zx/%zX use the ordinary 16-bit integer handlers.
        cp      'z'
        jp      z,pf_pct_z

        ; Decimal field width: %2d / %3u / %8s etc.
        cp      '0'
        jp      c,pf_pct_done_width
        cp      '9'+1
        jp      nc,pf_pct_done_width

        sub     '0'
        ld      (pf_digit),a
        push    de              ; DE is the vararg byte offset; preserve it.
        ld      a,(pf_width)
        add     a,a             ; 2*w
        ld      e,a
        add     a,a             ; 4*w
        add     a,a             ; 8*w
        add     a,e             ; 10*w
        ld      e,a
        ld      a,(pf_digit)
        add     a,e
        ld      (pf_width),a
        pop     de
        jp      pf_pct_next

pf_pct_left:
        ld      a,1
        ld      (pf_left),a
        jp      pf_pct_next

pf_pct_dot:
        ; Parse digits after '.' into pf_prec (e.g. %.4d  prec=4).
        ; '.' was already consumed by inc hl in pf_pct_next.
pf_pct_prec_loop:
        ld      a,(hl)
        or      a
        jp      z,pf_done
        cp      '0'
        jp      c,pf_pct_prec_done
        cp      '9'+1
        jp      nc,pf_pct_prec_done
        inc     hl
        sub     '0'
        ld      (pf_digit),a
        push    de
        ld      a,(pf_prec)
        add     a,a             ; 2*p
        ld      e,a
        add     a,a             ; 4*p
        add     a,a             ; 8*p
        add     a,e             ; 10*p
        ld      e,a
        ld      a,(pf_digit)
        add     a,e
        ld      (pf_prec),a
        pop     de
        jr      pf_pct_prec_loop
pf_pct_prec_done:
        ; A = format specifier char, HL points to it (not yet consumed)
        inc     hl
        jp      pf_pct_done_width

pf_pct_z:
        ld      a,(hl)
        or      a
        jp      z,pf_done
        inc     hl
        ; fall through into dispatch with A = conversion char after 'z'

pf_pct_done_width:
        cp      'c'
        jp      z,pf_c
        cp      's'
        jp      z,pf_s
        cp      'u'
        jp      z,pf_u
        cp      'd'
        jp      z,pf_d
        cp      'i'
        jp      z,pf_d
        cp      'x'
        jp      z,pf_x
        cp      'X'
        jp      z,pf_x
        cp      'l'
        jp      z,pf_l
        cp      'f'
        jr      nz,pf_emit_and_loop
        push    hl                      ; save fmt ptr before clobbering HL
        ld      hl,(pf_float_hook)
        jp      (hl)                    ; handler pops HL to restore fmt ptr

pf_emit_and_loop:
        call    pf_emit_a
        jp      pf_loop

pf_arg_hl:
        push    ix
        pop     hl
        add     hl,de
        ld      a,(hl)
        inc     hl
        ld      h,(hl)
        ld      l,a
        inc     de
        inc     de
        ret

; Emit (pf_width - A) spaces, if positive.  A is content length.
pf_pad_a:
        push    af
        ld      a,(pf_width)
        ld      e,a
        pop     af
        ld      d,a
        ld      a,e
        sub     d
        ret     c
        ret     z
        ld      d,a
pf_pad_loop:
        ld      a,' '
        call    pf_emit_a
        dec     d
        jr      nz,pf_pad_loop
        ret

pf_c:
        push    hl
        call    pf_arg_hl
        push    de
        ld      a,(pf_left)
        or      a
        jr      nz,pf_c_emit
        ld      a,1
        call    pf_pad_a
pf_c_emit:
        ld      a,l
        call    pf_emit_a
        ld      a,(pf_left)
        or      a
        jr      z,pf_c_done
        ld      a,1
        call    pf_pad_a
pf_c_done:
        pop     de
        pop     hl
        jp      pf_loop

pf_s:
        push    hl
        call    pf_arg_hl
        push    de
        push    hl
        call    pf__slen_hl       ; A = strlen(HL), HL preserved by stack below
        ld      (pf_digit),a
        ld      a,(pf_left)
        or      a
        jr      nz,pf_s_no_prepad
        ld      a,(pf_digit)
        call    pf_pad_a
pf_s_no_prepad:
        pop     hl
pf_s_loop:
        ld      a,(hl)
        or      a
        jr      z,pf_s_done
        inc     hl
        call    pf_emit_a
        jr      pf_s_loop
pf_s_done:
        ld      a,(pf_left)
        or      a
        jr      z,pf_s_no_postpad
        ld      a,(pf_digit)
        call    pf_pad_a
pf_s_no_postpad:
        pop     de
        pop     hl
        jp      pf_loop

pf_u:
        push    hl
        call    pf_arg_hl
        push    de
        call    pf_build_u      ; A = digit count, HL -> first digit (built once)
        push    hl
        call    pf_pad_a        ; emit (width - count) leading spaces
        pop     hl
        call    pf_emit_z       ; emit the prebuilt digits
        pop     de
        pop     hl
        jp      pf_loop

pf_d:
        push    hl
        call    pf_arg_hl
        push    de

        ; Build digits of |value| once, then pad/sign/zero-fill/emit using the
        ; known length.  Avoids the separate digit-counting divide pass.
        bit     7,h
        jr      z,pf_d_pos
        ; Negative: build digits of -value, remember sign.
        xor     a
        sub     l
        ld      l,a
        ld      a,0
        sbc     a,h
        ld      h,a
        call    pf_build_u
        ld      (pf_digit),a    ; save digit count of |value|
        push    hl              ; save pointer to first digit
        inc     a               ; width includes the '-'
        call    pf_pad_a
        ld      a,'-'
        call    pf_emit_a
        jr      pf_d_zfill
pf_d_pos:
        call    pf_build_u
        ld      (pf_digit),a    ; save digit count
        push    hl              ; save pointer to first digit
        call    pf_pad_a
pf_d_zfill:
        ; Zero-fill for precision: print (prec - digit_count) leading zeros
        ld      a,(pf_prec)
        or      a
        jr      z,pf_d_print    ; prec=0: no zero-fill
        ld      d,a             ; D = prec (DE preserved across pf_emit_a)
        ld      a,(pf_digit)
        sub     d               ; A = digit_count - prec
        jr      nc,pf_d_print   ; digit_count >= prec: no fill
        neg                     ; A = prec - digit_count (zeros needed)
        ld      d,a
pf_d_zero_loop:
        ld      a,'0'
        call    pf_emit_a       ; push de/pop de preserves D
        dec     d
        jr      nz,pf_d_zero_loop
pf_d_print:
        pop     hl              ; HL -> first digit
        call    pf_emit_z
        pop     de
        pop     hl
        jp      pf_loop

pf_x:
        push    hl
        call    pf_arg_hl
        push    de
        ld      a,4
        call    pf_pad_a
        call    pf_print_x
        pop     de
        pop     hl
        jp      pf_loop

pf_l:
        ; 'l' length modifier: read next char for ld/lu/lx/ls
        ld      a,(hl)
        inc     hl
        cp      'd'
        jp      z,pf_ld
        cp      'u'
        jp      z,pf_lu
        cp      'x'
        jp      z,pf_lx
        cp      's'
        jp      z,pf_ls
        call    pf_emit_a
        jp      pf_loop

pf_ls:
        ; wchar_t * string.  DCC wchar_t is 16-bit for L"..." literals.
        ; Print the low byte as ASCII and ignore the high byte.
        push    hl
        call    pf_arg_hl
        push    de
        push    hl
        call    pf_wstrlen_hl      ; A = wide string length, HL preserved by stack
        call    pf_pad_a
        pop     hl
pf_ls_loop:
        ld      a,(hl)
        inc     hl
        ld      e,a                ; save low byte
        ld      a,(hl)
        inc     hl                 ; skip high byte
        or      e
        jr      z,pf_ls_done
        ld      a,e
        call    pf_emit_a
        jr      pf_ls_loop
pf_ls_done:
        pop     de
        pop     hl
        jp      pf_loop

pf_wstrlen_hl:
        push    hl
        ld      c,0
pf_wstrlen_loop:
        ld      a,(hl)
        inc     hl
        ld      e,a
        ld      a,(hl)
        inc     hl
        or      e
        jr      z,pf_wstrlen_done
        inc     c
        jr      pf_wstrlen_loop
pf_wstrlen_done:
        ld      a,c
        pop     hl
        ret

pf_ld:
        ; Signed 32-bit decimal
        push    hl
        call    pf_arg_dehl     ; loads __pf32_l/__pf32_h, advances DE by 4
        push    de
        ld      hl,(__pf32_h)
        bit     7,h
        jr      z,pf_ld_pos
        ; Negative: negate, build digits once, then print with '-'
        call    pf_neg32
        call    pf_build_u32    ; A = count, HL -> first digit
        push    hl
        inc     a               ; +1 for '-'
        call    pf_pad_a
        ld      a,'-'
        call    pf_emit_a
        jr      pf_ld_emit
pf_ld_pos:
        call    pf_build_u32    ; A = count, HL -> first digit
        push    hl
        call    pf_pad_a
pf_ld_emit:
        pop     hl
        call    pf_emit_z
        pop     de
        pop     hl
        jp      pf_loop

pf_lu:
        ; Unsigned 32-bit decimal
        push    hl
        call    pf_arg_dehl
        push    de
        call    pf_build_u32    ; A = count, HL -> first digit
        push    hl
        call    pf_pad_a
        pop     hl
        call    pf_emit_z
        pop     de
        pop     hl
        jp      pf_loop

pf_lx:
        ; Unsigned 32-bit hex (%lx): 8 hex digits, high word first
        push    hl
        call    pf_arg_dehl     ; loads __pf32_l/__pf32_h, advances DE by 4
        push    de
        ld      hl,(__pf32_h)
        call    pf_print_x      ; high word (4 hex digits)
        ld      hl,(__pf32_l)
        call    pf_print_x      ; low word (4 hex digits)
        pop     de
        pop     hl
        jp      pf_loop

pf_done:
        ret                     ; count in BC; caller cleans up

pf_emit_a:
        push    hl
        push    de
        push    bc
        ld      e,a
        ld      hl,(pf_sink)
        ld      a,h
        or      l
        jr      z,pfe_con       ; pf_sink=0  console
pfe_buf:
        ld      hl,(pf_bufptr)
        ld      (hl),e
        inc     hl
        ld      (pf_bufptr),hl
        pop     bc
        pop     de
        pop     hl
        inc     bc
        ret
pfe_con:
        call    __conout
        pop     bc
        pop     de
        pop     hl
        inc     bc
        ret

pf__slen_hl:
        push    hl
        push    bc
        ld      bc,0
pfsl1:
        ld      a,(hl)
        or      a
        jr      z,pfsl2
        inc     hl
        inc     bc
        jr      pfsl1
pfsl2:
        ld      a,c              ; low byte is enough for current tests
        pop     bc
        pop     hl
        ret

; pf_div10: constant-time unsigned divide of HL by 10.
; In:  HL = dividend
; Out: HL = quotient, A = remainder (0..9)
; Preserves DE and IX.  BC is saved/restored.
;
; Fixed 16-step shift-subtract divider specialised for divisor 10.  Unlike
; DRSU (repeated subtraction, O(quotient)) this is bounded, so printing an
; N-digit number is O(N*16) instead of O(value) -- e.g. ~44x faster for
; values in the tens of thousands.
pf_div10:
        push    bc
        ld      bc,1000h        ; B = 16 (loop counter), C = 0 (remainder)
pf_d10_lp:
        add     hl,hl           ; HL <<= 1, MSB -> carry
        ld      a,c
        adc     a,a             ; A = (rem<<1) | bit, range 0..19
        cp      10
        jr      c,pf_d10_no
        sub     10
        inc     l               ; set quotient bit 0 (clear after add hl,hl)
pf_d10_no:
        ld      c,a             ; save remainder
        djnz    pf_d10_lp
        ld      a,c             ; A = remainder (0..9)
        pop     bc
        ret

; pf_build_u: convert HL (unsigned 16-bit) to decimal text in pf_decbuf.
; Digits are built once into the buffer (high end downward) so the caller can
; derive the field length without a separate counting divide pass.
; Out: A = digit count, HL -> first digit (buffer null-terminated at
;      pf_decbuf+6).  Preserves BC and DE.
; NB: BC carries printf's running character count, so it must not be touched;
;     the digit count is computed from the buffer pointer, not a register.
pf_build_u:
        push    ix
        push    de
        ld      ix,pf_decbuf+6
        ld      (ix+0),0        ; null terminator
pfbu1:
        dec     ix
        call    pf_div10        ; HL = quotient, A = remainder
        add     a,'0'
        ld      (ix+0),a
        ld      a,h
        or      l
        jr      nz,pfbu1
        push    ix
        pop     hl              ; HL -> first digit
        ld      de,pf_decbuf+6
        ex      de,hl           ; DE -> first digit, HL = buffer end
        or      a
        sbc     hl,de           ; HL = digit count (end - first)
        ld      a,l             ; A = digit count (<= 5)
        ex      de,hl           ; HL -> first digit
        pop     de
        pop     ix
        ret

; pf_emit_z: emit the null-terminated string at HL through pf_emit_a.
pf_emit_z:
        ld      a,(hl)
        or      a
        ret     z
        inc     hl
        call    pf_emit_a
        jr      pf_emit_z

pf_print_x:
        ld      a,h
        call    pf_hex_byte
        ld      a,l
        call    pf_hex_byte
        ret
pf_hex_byte:
        push    af
        rrca
        rrca
        rrca
        rrca
        call    pf_hex_nib
        pop     af
pf_hex_nib:
        and     0fh
        add     a,'0'
        cp      '9'+1
        jr      c,pfh1
        add     a,7
pfh1:
        call    pf_emit_a
        ret

pf_width:
        db      0
pf_digit:
        db      0
pf_prec:
        db      0
pf_left:
        db      0

pf_decbuf:
        ds      7

pf_decbuf32:
        ds      11

; pf_arg_dehl: read 4-byte vararg into __pf32_l/__pf32_h, advance DE by 4
pf_arg_dehl:
        push    de              ; save vararg offset
        push    ix
        pop     hl              ; HL = IX (frame base)
        add     hl,de           ; HL = IX + DE
        ld      a,(hl)
        inc     hl
        ld      b,(hl)          ; B:A = low word bytes (A=low, B=high)
        inc     hl
        ld      c,(hl)
        inc     hl
        ld      e,(hl)          ; E:C = high word bytes (C=low, E=high)
        ld      l,a
        ld      h,b
        ld      (__pf32_l),hl
        ld      l,c
        ld      h,e
        ld      (__pf32_h),hl
        pop     de              ; restore vararg offset
        inc     de
        inc     de
        inc     de
        inc     de
        ret

; pf_neg32: negate __pf32_l/__pf32_h (two's complement)
pf_neg32:
        ld      de,(__pf32_l)
        ld      hl,0
        or      a
        sbc     hl,de
        ld      (__pf32_l),hl
        ld      de,(__pf32_h)
        ld      hl,0
        sbc     hl,de
        ld      (__pf32_h),hl
        ret

; pf_divu32_10: divide __pf32_l/__pf32_h by 10
; Output: __pf32_l/__pf32_h = quotient, A = remainder (0-9)
; Register-based: holds the 32-bit value in DE:HL and uses the same in-place
; shift-subtract trick as pf_div10 (quotient fills in at bit 0 as the dividend
; shifts out at bit 31).  Avoids the old 64-bit memory-resident shift loop.
pf_divu32_10:
        push    bc
        push    de
        push    hl
        ld      de,(__pf32_h)   ; DE = high word
        ld      hl,(__pf32_l)   ; HL = low word
        ld      bc,2000h        ; B = 32 (counter), C = 0 (remainder)
pf32d_loop:
        add     hl,hl           ; DE:HL <<= 1, bit31 -> carry
        rl      e
        rl      d
        ld      a,c
        adc     a,a             ; A = (rem<<1) | bit, range 0..19
        cp      10
        jr      c,pf32d_no_sub
        sub     10
        inc     l               ; set quotient bit 0 (clear after add hl,hl)
pf32d_no_sub:
        ld      c,a             ; save remainder
        djnz    pf32d_loop
        ld      (__pf32_l),hl
        ex      de,hl
        ld      (__pf32_h),hl   ; store quotient high word
        ld      a,c             ; A = remainder (0..9)
        pop     hl
        pop     de
        pop     bc
        ret

; pf_build_u32: convert __pf32_l/__pf32_h (unsigned 32-bit) to decimal text in
; pf_decbuf32, built once (high end downward).  Out: A = digit count,
; HL -> first digit (null-terminated at pf_decbuf32+10).  Preserves BC and DE.
; Destroys __pf32_l/__pf32_h (consumed as the dividend).
pf_build_u32:
        push    ix
        push    de
        ld      ix,pf_decbuf32+10
        ld      (ix+0),0        ; null terminator
pfbu32_1:
        dec     ix
        call    pf_divu32_10    ; A = remainder digit, __pf32 = quotient
        add     a,'0'
        ld      (ix+0),a
        ld      hl,(__pf32_h)
        ld      a,h
        or      l
        ld      hl,(__pf32_l)
        or      h
        or      l
        jr      nz,pfbu32_1
        push    ix
        pop     hl              ; HL -> first digit
        ld      de,pf_decbuf32+10
        ex      de,hl           ; DE -> first digit, HL = buffer end
        or      a
        sbc     hl,de           ; HL = digit count
        ld      a,l             ; A = digit count (<= 10)
        ex      de,hl           ; HL -> first digit
        pop     de
        pop     ix
        ret

; pf_print_u32: print __pf32_l/__pf32_h as unsigned decimal (no field width).
; Used by the %f float formatter for the integer part.
pf_print_u32:
        call    pf_build_u32    ; A = count, HL -> first digit
        call    pf_emit_z
        ret

__pf32_l:       dw      0
__pf32_h:       dw      0

pf_float_stub:
        pop     hl                      ; restore fmt ptr pushed by dispatch
        ld      a,'f'
        call    pf_emit_a
        jp      pf_loop
pf_float_hook:
        dw      pf_float_stub

; printf/sprintf/fprintf shared sink and buffer (here so they stay in the
; _printf block; placing them elsewhere forces dccrtlstrip to keep that block)
pf_sink:        dw      0       ; 0=console, 0FFFFh=buffer
pf_bufptr:      dw      0       ; write pointer for sprintf/fprintf
__pf_cnt:       dw      0       ; char count saved by fprintf
__pf_fbuf:      ds      256     ; static buffer for fprintf


; ---- float-enabled printf (-ffloatio) ------------------------------
        public  _pffio
_pffio:
        push    ix
        ld      ix,0
        add     ix,sp
        push    bc
        push    de
        ld      hl,0
        ld      (pf_sink),hl            ; console mode
        ld      hl,pf_f                 ; install float handler
        ld      (pf_float_hook),hl
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      de,6
        ld      bc,0
        call    __pf_run
        ld      hl,pf_float_stub        ; restore default handler
        ld      (pf_float_hook),hl
        ld      h,b
        ld      l,c
        pop     de
        pop     bc
        pop     ix
        ret

; pf_f is the %f handler installed via pf_float_hook when _pffio is active.
; It lives in the _pffio block so dccrtlstrip omits it for non-float builds.
; Uses __pf32_l/__pf32_h (shared with pf_ld/pf_lu/pf_lx) and pf_prec/pf_emit_a
; from the _printf block.
pf_f:
        ; HL (fmt ptr) already pushed by the %f dispatch in pf_pct_done_width
        call    pf_arg_dehl     ; loads __pf32_l/__pf32_h with raw float bits, advances DE by 4
        push    de

        ld      hl,(__pf32_l)
        ld      (pf_fl),hl
        ld      hl,(__pf32_h)
        ld      (pf_fh),hl

        ; Sign and absolute value.
        bit     7,h
        jp      z,pf_f_absdone
        ld      a,'-'
        call    pf_emit_a
        ld      hl,(__pf32_h)
        res     7,h
        ld      (__pf32_h),hl
        ld      (pf_fh),hl
pf_f_absdone:
        ld      hl,(__pf32_l)
        ld      (pf_fl),hl

        ; Printed precision: pf_prec==0 means default of 6 decimal places.
        ld      a,(pf_prec)
        or      a
        jp      nz,pf_f_prec_known
        ld      a,6
pf_f_prec_known:
        ld      (pf_fcnt),a

        ; Round before splitting integer/fractional parts: add 0.5*10^-prec.
        cp      10
        jp      nc,pf_f_rounded     ; no table entry for larger precisions
        add     a,a                 ; offset = precision * 4
        add     a,a
        ld      e,a
        ld      d,0
        ld      hl,pf_rndtab
        add     hl,de
        ld      e,(hl)
        inc     hl
        ld      d,(hl)
        inc     hl
        ld      (pf_ftl),de
        ld      e,(hl)
        inc     hl
        ld      d,(hl)
        ld      (pf_fth),de

        ld      hl,(pf_fl)
        ld      de,(pf_fh)
        push    de
        push    hl
        ld      hl,(pf_ftl)
        ld      de,(pf_fth)
        push    de
        push    hl
        call    __fadd
        pop     bc
        pop     bc
        pop     bc
        pop     bc
        ld      (pf_fl),hl
        ld      (pf_fh),de
pf_f_rounded:

        ; Integer part = (unsigned long)abs(f).
        ld      hl,(pf_fl)
        ld      de,(pf_fh)
        call    __fful

        ; Save integer part in pf_ftl/pf_fth; load __pf32_l/__pf32_h for pf_print_u32.
        ld      (__pf32_l),hl
        ld      (__pf32_h),de
        ld      (pf_ftl),hl
        ld      (pf_fth),de

        call    pf_print_u32

        ld      a,'.'
        call    pf_emit_a

        ; pf_print_u32 destroys __pf32_l/__pf32_h; restore integer part from pf_ftl/pf_fth.
        ld      hl,(pf_ftl)
        ld      de,(pf_fth)
        call    __fulf
        ld      (pf_ftl),hl
        ld      (pf_fth),de
        ld      hl,(pf_fl)
        ld      de,(pf_fh)
        push    de
        push    hl
        ld      hl,(pf_ftl)
        ld      de,(pf_fth)
        push    de
        push    hl
        call    __fsub
        pop     bc
        pop     bc
        pop     bc
        pop     bc
        ld      (pf_fl),hl
        ld      (pf_fh),de

pf_f_digloop:
        ld      a,(pf_fcnt)
        or      a
        jp      z,pf_f_done

        ; frac *= 10.0f
        ld      hl,(pf_fl)
        ld      de,(pf_fh)
        push    de
        push    hl
        ld      hl,0
        ld      de,16672        ; 10.0f = 0x41200000
        push    de
        push    hl
        call    __fmul
        pop     bc
        pop     bc
        pop     bc
        pop     bc
        ld      (pf_fl),hl
        ld      (pf_fh),de

        ; digit = (int)frac
        call    __ffi
        ld      (pf_fiw),hl
        ld      a,l
        add     a,'0'
        call    pf_emit_a

        ; frac -= (float)digit
        ld      hl,(pf_fiw)
        call    __fif
        ld      (pf_ftl),hl
        ld      (pf_fth),de
        ld      hl,(pf_fl)
        ld      de,(pf_fh)
        push    de
        push    hl
        ld      hl,(pf_ftl)
        ld      de,(pf_fth)
        push    de
        push    hl
        call    __fsub
        pop     bc
        pop     bc
        pop     bc
        pop     bc
        ld      (pf_fl),hl
        ld      (pf_fh),de

        ld      a,(pf_fcnt)
        dec     a
        ld      (pf_fcnt),a
        jp      pf_f_digloop
pf_f_done:
        pop     de
        pop     hl
        jp      pf_loop

pf_fl:      dw 0
pf_fh:      dw 0
pf_ftl:     dw 0
pf_fth:     dw 0
pf_fiw:     dw 0
pf_fcnt:    db 0

pf_rndtab:
        dw      00000H,03F00H        ; 0.5e-0
        dw      0CCCDH,03D4CH        ; 0.5e-1
        dw      0D70AH,03BA3H        ; 0.5e-2
        dw      0126FH,03A03H        ; 0.5e-3
        dw      0B717H,03851H        ; 0.5e-4
        dw      0C5ACH,036A7H        ; 0.5e-5
        dw      037BDH,03506H        ; 0.5e-6
        dw      0BF95H,03356H        ; 0.5e-7
        dw      0CC77H,031ABH        ; 0.5e-8
        dw      0705FH,03009H        ; 0.5e-9

        public  _exit
_exit:
        push    ix
        ld      ix,0
        add     ix,sp
        ld      l,(ix+4)
        ld      h,(ix+5)
        pop     ix
        call    __cpm_set_retcode
        jp      0000h

; ------------------------------------------------------------
; CP/M 3 program return code support.
;
; CP/M 3 / CP/M Plus BDOS function 108 (P_CODE):
;     C  = 6Ch
;     DE = program return code to set
;     DE = FFFFh means get current code, so avoid using FFFFh as a
;          set value.  For exit(-1), use 00FFh, matching the common
;          8-bit process-status convention.
;
; CP/M 2.2 safely ignores unsupported BDOS functions, and emulators can
; intercept this call directly, so no version check is needed.
; ------------------------------------------------------------
__cpm_set_retcode:
        ; input: HL = C int status / main return value

        ; If status is FFFFh, remap to 00FFh.  DE=FFFFh is the
        ; P_CODE "get" sentinel, not a settable return code.
        ld      a,h
        and     l
        inc     a
        jr      nz,csr_not_minus1
        ld      hl,00ffh
csr_not_minus1:

        ex      de,hl           ; DE = status
        ld      c,6ch           ; P_CODE: get/set program return code
        call    5
        ret

        public  _atoi
_atoi:
        push    ix
        ld      ix,0
        add     ix,sp
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      de,0
        ld      b,0
at_ws:
        ld      a,(hl)
        cp      ' '
        jr      z,at_ws_inc
        cp      9
        jr      nz,at_sign
at_ws_inc:
        inc     hl
        jr      at_ws
at_sign:
        cp      '-'
        jr      nz,at_plus
        ld      b,1
        inc     hl
        jr      at_digits
at_plus:
        cp      '+'             ; C89 atoi == (int)strtol(s,0,10): accept '+'
        jr      nz,at_digits
        inc     hl
at_digits:
        ld      a,(hl)
        cp      '0'
        jr      c,at_done_abs
        cp      '9'+1
        jr      nc,at_done_abs
        sub     '0'             ; A = digit value
        push    hl              ; save string pointer
        ld      h,d
        ld      l,e             ; HL = accumulator
        add     hl,hl           ; x2
        ld      d,h
        ld      e,l             ; DE = x2
        add     hl,hl           ; x4
        add     hl,hl           ; x8
        add     hl,de           ; x8 + x2 = acc*10
        ld      e,a
        ld      d,0             ; DE = digit
        add     hl,de           ; HL = acc*10 + digit
        ex      de,hl           ; DE = new accumulator
        pop     hl              ; restore string pointer
        inc     hl
        jr      at_digits
at_done_abs:
        ex      de,hl
        ld      a,b
        or      a
        jr      z,at_done
        xor     a
        sub     l
        ld      l,a
        ld      a,0
        sbc     a,h
        ld      h,a
at_done:
        pop     ix
        ret

        public  _atol
; long atol(const char *nptr)
; Like atoi but builds a 32-bit accumulator.  Skips leading spaces/tabs,
; accepts an optional '+'/'-' sign, then consumes decimal digits.  Overflow
; wraps modulo 2^32 (same defined-behaviour stance as atoi's 2^16 wrap).
; Returns the signed long in DE:HL (DE = high word).
_atol:
        push    ix
        ld      ix,0
        add     ix,sp
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      (__atl_p),hl            ; string pointer
        ld      hl,0
        ld      (__atl_acc),hl
        ld      (__atl_acc+2),hl        ; acc = 0
        xor     a
        ld      (__atl_neg),a
        ld      hl,(__atl_p)
atl_ws:
        ld      a,(hl)
        cp      ' '
        jr      z,atl_ws_i
        cp      9
        jr      nz,atl_sign
atl_ws_i:
        inc     hl
        jr      atl_ws
atl_sign:
        cp      '-'
        jr      nz,atl_plus
        ld      a,1
        ld      (__atl_neg),a
        inc     hl
        jr      atl_pset
atl_plus:
        cp      '+'
        jr      nz,atl_pset
        inc     hl
atl_pset:
        ld      (__atl_p),hl
atl_dig:
        ld      hl,(__atl_p)
        ld      a,(hl)
        cp      '0'
        jr      c,atl_fin
        cp      '9'+1
        jr      nc,atl_fin
        sub     '0'
        ld      (__atl_d),a
        inc     hl
        ld      (__atl_p),hl
        ; acc = acc*10 + digit, computed as acc*8 + acc*2 + digit
        ld      hl,(__atl_acc)
        ld      de,(__atl_acc+2)        ; DE:HL = acc
        add     hl,hl
        rl      e
        rl      d                       ; DE:HL = acc*2
        ld      (__atl_x2),hl
        ld      a,e
        ld      (__atl_x2+2),a
        ld      a,d
        ld      (__atl_x2+3),a          ; save acc*2
        add     hl,hl
        rl      e
        rl      d                       ; acc*4
        add     hl,hl
        rl      e
        rl      d                       ; DE:HL = acc*8
        ld      bc,(__atl_x2)
        add     hl,bc
        ex      de,hl
        ld      bc,(__atl_x2+2)
        adc     hl,bc
        ex      de,hl                   ; DE:HL = acc*10
        ld      a,(__atl_d)
        ld      c,a
        ld      b,0
        add     hl,bc
        jr      nc,atl_nc
        inc     de
atl_nc:
        ld      (__atl_acc),hl
        ld      (__atl_acc+2),de
        jr      atl_dig
atl_fin:
        ld      hl,(__atl_acc)
        ld      de,(__atl_acc+2)        ; DE:HL = acc
        ld      a,(__atl_neg)
        or      a
        jr      z,atl_done
        ld      a,l
        cpl
        ld      l,a
        ld      a,h
        cpl
        ld      h,a
        ld      a,e
        cpl
        ld      e,a
        ld      a,d
        cpl
        ld      d,a
        inc     hl
        ld      a,h
        or      l
        jr      nz,atl_done
        inc     de
atl_done:
        pop     ix
        ret
__atl_p:        dw      0
__atl_acc:      ds      4
__atl_x2:       ds      4
__atl_neg:      db      0
__atl_d:        db      0

        public  _fflush
_fflush:
        ld      hl,0
        ret

        public  _stdout
_stdout:
        dw      1               ; fd 1 = console output



        public  _stderr
_stderr:
        dw      2               ; fd 2 = console output

        public  _stdin
_stdin:
        dw      0

        public  _errno
_errno:
        dw      0

        public  _open
        public  _read
        public  _write
        public  _close
        public  _unlink
        public  _lseek
        public  _fsync
        public  _fdatasync

FIRSTFD  equ     3
; NFILES is the number of concurrently open real files (fd FIRSTFD..MAXFD-1).
; C89 (7.9.3) requires FOPEN_MAX >= 8 streams open at once, including the three
; standard streams.  Here stdin/stdout/stderr are console pseudo-FILEs that do
; not consume a real-file slot, so 8 real-file slots comfortably satisfies the
; standard.  The per-slot cost is one FCB (FCBSIZE) plus 7 bytes of state; the
; 128-byte DMA buffer and the read sector cache stay single/shared.
NFILES   equ     8
MAXFD    equ     FIRSTFD+NFILES
FCBSIZE  equ     36


; ------------------------------------------------------------
; Minimal CP/M byte-stream file I/O.
;
; fd 0 = stdin, fd 1 = stdout, fd 2 = stderr.
; real files are fd 3..6.
;
; One shared 128-byte DMA buffer. 32-bit current offsets, but lseek returns low 16 bits.
; ------------------------------------------------------------

_open:
        push    ix
        ld      ix,0
        add     ix,sp

        ld      hl,__fduse
        ld      b,NFILES
        xor     a
opfind:
        ld      e,a
        ld      a,(hl)
        or      a
        jr      z,opslot
        inc     hl
        ld      a,e
        inc     a
        djnz    opfind
        call    __emfil
        ld      hl,0ffffh
        pop     ix
        ret

opslot:
        ld      a,e
        ld      (__slot),a
        ld      (hl),1
        ; A new file occupies this slot: any cached record for the slot number
        ; belonged to a previous file, so drop the read sector cache.
        xor     a
        ld      (__rdcv),a

        call    __offp
        xor     a
        ld      (hl),a
        inc     hl
        ld      (hl),a
        inc     hl
        ld      (hl),a
        inc     hl
        ld      (hl),a

        ld      a,(__slot)
        call    __fcbp
        push    hl
        ex      de,hl
        ld      b,FCBSIZE
        xor     a
opclr:
        ld      (de),a
        inc     de
        djnz    opclr

        pop     de
        push    de
        ld      l,(ix+4)
        ld      h,(ix+5)
        call    __mkfcb
        pop     de

        ; Create/truncate only if O_CREAT or O_TRUNC is set.
        ; Test uses:
        ;   O_CREAT = 0100 octal = 0040h
        ;   O_TRUNC = 01000 octal = 0200h
        ;   O_RDWR  = 2, which must NOT truncate.
        ld      a,(ix+6)
        and     40h             ; O_CREAT low byte
        jr      nz,opmake
        ld      a,(ix+7)
        and     2               ; O_TRUNC high byte
        jr      nz,opmake

        ld      c,15            ; open existing
        call    5
        cp      0ffh
        jr      z,opfail_noent
        jr      opok

opmake:
        push    de
        ld      c,19            ; delete old, ignore status
        call    5
        pop     de
        ld      c,22            ; make new
        call    5
        cp      0ffh
        jr      z,opfail_nospc

opok:
        ld      a,(__slot)
        add     a,FIRSTFD
        ld      h,0
        ld      l,a
        pop     ix
        ret

opfail_noent:
        call    __enoent
        jr      opfail_common
opfail_nospc:
        call    __nospc
opfail_common:
        ld      a,(__slot)
        call    __usep
        ld      (hl),0
        ld      hl,0ffffh
        pop     ix
        ret

_close:
        push    ix
        ld      ix,0
        add     ix,sp
        ld      a,(ix+4)
        cp      FIRSTFD
        jr      c,clok
        cp      MAXFD
        jr      nc,clbad
        sub     FIRSTFD
        ld      (__slot),a
        call    __fcbp
        ex      de,hl
        ld      c,16            ; close file
        call    5
        push    af
        ld      a,(__slot)
        call    __usep
        ld      (hl),0
        ; invalidate the read sector cache: this slot is closing
        xor     a
        ld      (__rdcv),a
        pop     af
        cp      0ffh
        jr      z,clio
clok:
        ld      hl,0
        pop     ix
        ret
clbad:
        call    __ebadf
        ld      hl,0ffffh
        pop     ix
        ret
clio:
        call    __ioerr
        ld      hl,0ffffh
        pop     ix
        ret

; ---- _unlink(path) -> 0 on success, -1 on failure ----
; Erases a CP/M file using BDOS fn 19.
; path @ IX+4/5.
_unlink:
        push    ix
        ld      ix,0
        add     ix,sp

        ; Zero the scratch FCB (drive + 8-char name + 3-char ext = 12 bytes)
        ld      hl,__ulfcb
        ld      b,12
        xor     a
ulclr:
        ld      (hl),a
        inc     hl
        djnz    ulclr

        ; Build FCB from path string
        ld      l,(ix+4)
        ld      h,(ix+5)        ; HL = path
        ld      de,__ulfcb      ; DE = scratch FCB
        call    __mkfcb

        ; BDOS fn 19: erase file (DE = FCB)
        ld      de,__ulfcb
        ld      c,19
        call    5

        ; A = 0ffh on failure, 0..3 (directory code) on success
        cp      0ffh
        jr      z,ul_fail
        ld      hl,0
        pop     ix
        ret
ul_fail:
        call    __enoent
        ld      hl,0ffffh
        pop     ix
        ret

_read:
        push    ix
        ld      ix,0
        add     ix,sp

        ld      a,(ix+4)
        or      a
        jr      nz,rdfile
        ; stdin: return one blocking char if count > 0.
        ld      a,(ix+8)
        or      (ix+9)
        jr      z,rdzero
        ld      c,6
        ld      e,0ffh
        call    5
        ld      l,(ix+6)
        ld      h,(ix+7)
        ld      (hl),a
        ld      hl,1
        pop     ix
        ret
rdzero:
        ld      hl,0
        pop     ix
        ret

rdfile:
        call    __chkfd
        jp      c,rdbad
        ld      l,(ix+6)
        ld      h,(ix+7)
        ld      (__rwbuf),hl
        ld      l,(ix+8)
        ld      h,(ix+9)
        ld      (__rwrem),hl
        ld      hl,0
        ld      (__rwcnt),hl

rdloop:
        ld      hl,(__rwrem)
        ld      a,h
        or      l
        jr      z,rddone
        call    __setrr
        call    __chunk

        ; Full aligned records can be read directly into the caller buffer.
        ld      a,(__remdr)
        or      a
        jr      nz,rd_dma
        ld      a,(__chnk)
        cp      128
        jr      nz,rd_dma
        ld      de,(__rwbuf)
        ld      c,26            ; set DMA to caller buffer
        call    5
        ld      a,(__slot)
        call    __fcbp
        ex      de,hl
        ld      c,33            ; random read
        call    5
        or      a
        jr      nz,rddone       ; EOF/error returns short count
        call    __advio
        jr      rdloop

rd_dma:
        call    __rdhit         ; is this record already resident in __dma?
        jr      z,rd_copy       ; cache hit: skip BDOS set-DMA + random read
        ; Miss: the random read below overwrites __dma even when it fails with
        ; EOF/error, so invalidate the cache now and only re-validate on a
        ; successful read.  Otherwise a later read of the previously cached
        ; record would falsely hit on the clobbered buffer.
        xor     a
        ld      (__rdcv),a
        ld      de,__dma
        ld      c,26            ; set DMA
        call    5
        ld      a,(__slot)
        call    __fcbp
        ex      de,hl
        ld      c,33            ; random read
        call    5
        or      a
        jr      nz,rddone       ; EOF/error returns short count
        call    __rdsto         ; __dma now caches this (slot, record)
        jr      rd_copy

rd_copy:
        ; copy __chunk bytes from __dma+remainder to user buffer
        ld      a,(__remdr)
        ld      h,0
        ld      l,a
        ld      de,__dma
        add     hl,de           ; HL = source
        ld      de,(__rwbuf)    ; DE = dest
        ld      a,(__chnk)
        ld      c,a
        ld      b,0
        ldir
        call    __advio
        jr      rdloop

rddone:
        ld      hl,(__rwcnt)
        pop     ix
        ret
rdbad:
        call    __ebadf
        ld      hl,0ffffh
        pop     ix
        ret

_write:
        push    ix
        ld      ix,0
        add     ix,sp

        ld      a,(ix+4)
        cp      1
        jp      z,wrcon
        cp      2
        jp      z,wrcon
        call    __chkfd
        jp      c,wrbadfd
        ; A write changes file data and reuses __dma as scratch, so the read
        ; sector cache is no longer guaranteed to reflect disk contents.
        xor     a
        ld      (__rdcv),a
        ld      l,(ix+6)
        ld      h,(ix+7)
        ld      (__rwbuf),hl
        ld      l,(ix+8)
        ld      h,(ix+9)
        ld      (__rwrem),hl
        ld      hl,0
        ld      (__rwcnt),hl

wrloop:
        ld      hl,(__rwrem)
        ld      a,h
        or      l
        jp      z,wrdone
        call    __setrr
        call    __chunk

        ; Full aligned records can be written directly from the caller buffer.
        ld      a,(__remdr)
        or      a
        jr      nz,wrrd
        ld      a,(__chnk)
        cp      128
        jr      nz,wrrd
        ld      de,(__rwbuf)
        ld      c,26            ; set DMA to caller buffer
        call    5
        ld      a,(__slot)
        call    __fcbp
        ex      de,hl
        ld      c,34            ; random write
        call    5
        or      a
        jp      nz,wrnospc
        call    __advio
        jr      wrloop

        ; For partial records, read old data first. If it fails,
        ; zero-fill the shared DMA buffer.
wrrd:
        ld      de,__dma
        ld      c,26
        call    5
        ld      a,(__slot)
        call    __fcbp
        ex      de,hl
        ld      c,33
        call    5
        or      a
        jr      z,wrcopy
        call    __zerdm

wrcopy:
        ; copy __chunk bytes from user buffer to __dma+remainder
        ld      hl,(__rwbuf)    ; source
        ld      a,(__remdr)
        ld      d,0
        ld      e,a
        push    hl
        ld      hl,__dma
        add     hl,de
        ex      de,hl           ; DE = dest
        pop     hl              ; HL = source
        ld      a,(__chnk)
        ld      c,a
        ld      b,0
        ldir

        ld      de,__dma
        ld      c,26
        call    5
        ld      a,(__slot)
        call    __fcbp
        ex      de,hl
        ld      c,34            ; random write
        call    5
        or      a
        jp      nz,wrnospc
        call    __advio
        jp      wrloop

wrdone:
        ld      hl,(__rwcnt)
        pop     ix
        ret

wrcon:
        ld      hl,(__rwcnt)
        ; initialize console write vars
        ld      l,(ix+6)
        ld      h,(ix+7)
        ld      (__rwbuf),hl
        ld      l,(ix+8)
        ld      h,(ix+9)
        ld      (__rwrem),hl
        ld      hl,0
        ld      (__rwcnt),hl
wcloop:
        ld      hl,(__rwrem)
        ld      a,h
        or      l
        jr      z,wrdone
        ld      hl,(__rwbuf)
        ld      e,(hl)
        call    __conout
        ; advance buf/cnt/rem by 1 without updating fdoff (no __offp call)
        ld      hl,(__rwbuf)
        inc     hl
        ld      (__rwbuf),hl
        ld      hl,(__rwcnt)
        inc     hl
        ld      (__rwcnt),hl
        ld      hl,(__rwrem)
        dec     hl
        ld      (__rwrem),hl
        jr      wcloop

wrbadfd:
        call    __ebadf
        ld      hl,0ffffh
        pop     ix
        ret
wrnospc:
        ; A real write error (disk full / record write rejected).  __slot is
        ; valid here (we passed __chkfd), so record a stream error for ferror().
        ld      a,(__slot)
        ld      h,0
        ld      l,a
        ld      de,__fderr
        add     hl,de
        ld      (hl),1
        call    __nospc
        ld      hl,0ffffh
        pop     ix
        ret

_lseek:
        push    ix
        ld      ix,0
        add     ix,sp
        call    __chkfd
        jp      c,lsbadfd

        ; long lseek(int fd, long offset, int whence)
        ; ix+4/5   fd
        ; ix+6..9  offset, low word then high word
        ; ix+10/11 whence
        ld      a,(ix+10)
        or      a
        jr      z,lsset
        cp      1
        jr      z,lscur
        cp      2
        jr      z,lsend
        jp      lsinval

lsset:
        ; Set current offset from full 32-bit argument.
        call    __offp
        ld      a,(ix+6)
        ld      (hl),a
        inc     hl
        ld      a,(ix+7)
        ld      (hl),a
        inc     hl
        ld      a,(ix+8)
        ld      (hl),a
        inc     hl
        ld      a,(ix+9)
        ld      (hl),a
        jr      lsret

lscur:
        ; Add full 32-bit delta to current offset.
        call    __offp
        ld      a,(hl)
        add     a,(ix+6)
        ld      (hl),a
        inc     hl
        ld      a,(hl)
        adc     a,(ix+7)
        ld      (hl),a
        inc     hl
        ld      a,(hl)
        adc     a,(ix+8)
        ld      (hl),a
        inc     hl
        ld      a,(hl)
        adc     a,(ix+9)
        ld      (hl),a
        jr      lsret

lsret:
        ; Return full 32-bit offset in DE:HL.
        call    __offp
        ld      e,(hl)          ; byte 0
        inc     hl
        ld      d,(hl)          ; byte 1
        inc     hl
        push    de              ; low word
        ld      e,(hl)          ; byte 2
        inc     hl
        ld      d,(hl)          ; byte 3
        pop     hl              ; HL = low word, DE = high word
        pop     ix
        ret

lsend:
        ; SEEK_END: use BDOS fn 35 to get size in 128-byte records,
        ; then convert to byte offset and add full 32-bit delta.
        ld      a,(__slot)
        call    __fcbp
        ex      de,hl
        ld      c,35
        call    5

        ld      a,(__slot)
        call    __fcbp
        ld      de,33
        add     hl,de
        ld      c,(hl)
        inc     hl
        ld      b,(hl)          ; BC = 16-bit record count

        ; BC * 128 -> A:HL, where A is byte 2 and byte 3 is zero.
        ld      l,c
        ld      h,b
        xor     a
        add     hl,hl
        rla
        add     hl,hl
        rla
        add     hl,hl
        rla
        add     hl,hl
        rla
        add     hl,hl
        rla
        add     hl,hl
        rla
        add     hl,hl
        rla

        ; Add offset low word.
        ld      e,(ix+6)
        ld      d,(ix+7)
        add     hl,de

        ; Add offset high bytes plus carry from low word.
        ld      e,a
        ld      a,e
        adc     a,(ix+8)
        ld      b,a             ; result byte 2

        ld      a,0
        adc     a,(ix+9)
        ld      c,a             ; result byte 3

        push    bc
        push    hl

        call    __offp

        pop     de              ; low word
        ld      (hl),e
        inc     hl
        ld      (hl),d
        inc     hl
        pop     bc
        ld      (hl),b
        inc     hl
        ld      (hl),c
        jr      lsret

lsbadfd:
        call    __ebadf
        jr      lsbadret
lsinval:
        call    __einval
lsbadret:
        ld      hl,0ffffh
        ld      de,0ffffh
        pop     ix
        ret


_fsync:
_fdatasync:
        ld      hl,0
        ret

; Validate fd in A or (ix+4). Sets __slot. Carry set on error.
__chkfd:
        ld      a,(ix+4)
        cp      FIRSTFD
        jr      c,cfbad
        cp      MAXFD
        jr      nc,cfbad
        sub     FIRSTFD
        ld      (__slot),a
        call    __usep
        ld      a,(hl)
        or      a
        jr      z,cfbad
        or      a               ; clear carry
        ret
cfbad:
        scf
        ret

; ---- Read sector cache helpers ----
; __rdhit: after __setrr has loaded the FCB random record for __slot, test
; whether the shared __dma buffer already holds that exact (slot, record).
; Returns Z=1 on hit, Z=0 on miss.  Corrupts AF, BC, DE, HL.
__rdhit:
        ld      a,(__rdcv)
        or      a
        jr      z,rdh_miss              ; cache empty
        ld      a,(__slot)
        ld      hl,__rdck
        cp      (hl)
        jr      nz,rdh_miss             ; different slot
        ld      a,(__slot)
        call    __fcbp
        ld      de,33
        add     hl,de                   ; HL -> FCB random-record bytes
        ld      de,__rdck+1
        ld      b,3
rdh_cmp:
        ld      a,(de)
        cp      (hl)
        jr      nz,rdh_miss
        inc     de
        inc     hl
        djnz    rdh_cmp
        xor     a                       ; Z=1: hit
        ret
rdh_miss:
        ld      a,1
        or      a                       ; Z=0: miss
        ret

; __rdsto: record that __dma now holds (slot, current FCB random record).
; Corrupts AF, BC, DE, HL.
__rdsto:
        ld      a,(__slot)
        ld      (__rdck),a
        call    __fcbp
        ld      de,33
        add     hl,de                   ; HL -> FCB random-record bytes
        ld      de,__rdck+1
        ld      b,3
rds_cpy:
        ld      a,(hl)
        ld      (de),a
        inc     hl
        inc     de
        djnz    rds_cpy
        ld      a,1
        ld      (__rdcv),a
        ret

; A = slot 0..3, returns HL = fd_used slot
__usep:
        ld      h,0
        ld      l,a
        ld      de,__fduse
        add     hl,de
        ret

; __slot -> HL = 32-bit offset dword
__offp:
        ld      a,(__slot)
        ld      h,0
        ld      l,a
        add     hl,hl
        add     hl,hl           ; *4 bytes per offset
        ld      de,__fdoff
        add     hl,de
        ret

; A = slot 0..3, returns HL = FCB
__fcbp:
        ld      h,0
        ld      l,a
        add     hl,hl           ; *2
        add     hl,hl           ; *4
        ld      d,h
        ld      e,l
        add     hl,hl           ; *8
        add     hl,hl           ; *16
        add     hl,hl           ; *32
        add     hl,de           ; *36
        ld      de,__fcbs
        add     hl,de
        ret

; Set FCB random record from 32-bit byte offset.
; record = offset >> 7. remainder = offset & 127.
__setrr:
        call    __offp
        ld      e,(hl)          ; offset byte 0
        inc     hl
        ld      d,(hl)          ; offset byte 1
        inc     hl
        ld      b,(hl)          ; offset byte 2
        inc     hl
        ld      c,(hl)          ; offset byte 3

        ld      a,e
        and     7fh
        ld      (__remdr),a

        ; r0 = (byte0 >> 7) | (byte1 << 1)
        ld      a,e
        rlca
        and     1
        ld      l,a
        ld      a,d
        add     a,a
        or      l
        ld      l,a             ; L = r0

        ; r1 = (byte1 >> 7) | (byte2 << 1)
        ld      a,d
        rlca
        and     1
        ld      h,a
        ld      a,b
        add     a,a
        or      h
        ld      h,a             ; H = r1

        ; r2 = (byte2 >> 7) | (byte3 << 1)
        ld      a,b
        rlca
        and     1
        ld      e,a
        ld      a,c
        add     a,a
        or      e
        ld      e,a             ; E = r2

        push    hl              ; save r0/r1
        push    de              ; save r2 in E
        ld      a,(__slot)
        call    __fcbp
        ld      de,33
        add     hl,de
        pop     de
        pop     bc              ; C = r0, B = r1
        ld      (hl),c
        inc     hl
        ld      (hl),b
        inc     hl
        ld      (hl),e
        ret
; Compute chunk = min(remaining, bytes-left-in-current-CP/M-record), stores __chnk.
; Each CP/M BDOS record is 128 bytes, so we cap at 128 bytes per call.
; The important rule is that when remaining is less than 128, __chnk must
; be remaining, even at a record boundary.
__chunk:
        ; e = min(remaining, 128)
        ld      hl,(__rwrem)
        ld      a,h
        or      a
        jr      nz,ch_more128
        ld      a,l
        cp      129
        jr      nc,ch_more128
        ld      e,a             ; remaining is 1..128
        jr      ch_have_count

ch_more128:
        ld      e,128

ch_have_count:
        ; room = 128 - remainder.  If remainder is 0, room is 128,
        ; so the 128-byte cap already fits.
        ld      a,(__remdr)
        or      a
        jr      z,ch_store
        ld      c,a
        ld      a,128
        sub     c               ; room is 1..127
        cp      e
        jr      nc,ch_store
        ld      e,a

ch_store:
        ld      a,e
        ld      (__chnk),a
        ret

__advio:
        ld      a,(__chnk)
        ld      e,a
        ld      d,0
        ld      hl,(__rwbuf)
        add     hl,de
        ld      (__rwbuf),hl
        ld      hl,(__rwcnt)
        add     hl,de
        ld      (__rwcnt),hl
        ld      hl,(__rwrem)
        or      a
        sbc     hl,de
        ld      (__rwrem),hl
        call    __offp
        ; __offp clobbers DE, so reload the chunk before updating offset.
        ld      a,(__chnk)
        ld      e,a
        ld      d,0
        ld      a,(hl)
        add     a,e
        ld      (hl),a
        inc     hl
        ld      a,(hl)
        adc     a,d
        ld      (hl),a
        inc     hl
        ld      a,(hl)
        adc     a,0
        ld      (hl),a
        inc     hl
        ld      a,(hl)
        adc     a,0
        ld      (hl),a
        ret

__zerdm:
        ld      hl,__dma
        ld      b,128
        ld      a,1ah           ; Ctrl-Z: CP/M text-file EOF sentinel
zdm1:
        ld      (hl),a
        inc     hl
        djnz    zdm1
        ret

; HL = filename string, DE = FCB address.
__mkfcb:
        ld      (__mffcb),de
        push    hl
        ex      de,hl
        xor     a
        ld      (hl),a          ; default drive
        inc     hl
        ld      b,11
mfspc:
        ld      (hl),' '
        inc     hl
        djnz    mfspc
        pop     hl

        ld      de,(__mffcb)
        inc     de              ; name field
        ld      b,8
mfnam:
        ld      a,(hl)
        or      a
        ret     z
        cp      '.'
        jr      z,mfdot
        call    __upa
        ld      (de),a
        inc     de
        inc     hl
        djnz    mfnam
mfskp:
        ld      a,(hl)
        or      a
        ret     z
        cp      '.'
        jr      z,mfdot
        inc     hl
        jr      mfskp
mfdot:
        inc     hl
        push    hl
        ld      hl,(__mffcb)
        ld      de,9
        add     hl,de
        ex      de,hl           ; DE = extension field
        pop     hl
        ld      b,3
mfext:
        ld      a,(hl)
        or      a
        ret     z
        call    __upa
        ld      (de),a
        inc     de
        inc     hl
        djnz    mfext
        ret

__upa:
        cp      'a'
        ret     c
        cp      'z'+1
        ret     nc
        sub     20h
        ret

__seter:
        ld      (_errno),hl
        ret
__enoent:
        ld      hl,ENOENT
        jr      __seter
__ioerr:
        ld      hl,EIO
        jr      __seter
__ebadf:
        ld      hl,EBADF
        jr      __seter
__einval:
        ld      hl,EINVAL
        jr      __seter
__emfil:
        ld      hl,EMFILE
        jr      __seter
__nospc:
        ld      hl,ENOSPC
        jr      __seter


__slot:
        db      0
__chnk:
        db      0
__remdr:
        db      0
__rwbuf:
        dw      0
__rwrem:
        dw      0
__rwcnt:
        dw      0
__mffcb:
        dw      0
__ulfcb:
        ds      12              ; scratch FCB for _unlink

__dmval:
        db      0
__dmc_lhs:
        dw      0
__dmc_rhs:
        dw      0
__dmquot:
        dw      0
__dmrem:
        dw      0
__dmcnt:
        db      0

; Read sector cache: records which 128-byte file record currently resides in
; the shared __dma buffer, so consecutive small reads of the same record
; (e.g. fgets reading one byte at a time) skip the BDOS random read entirely.
__rdcv:         db      0       ; 1 = __dma holds the record identified by __rdck
__rdck:         ds      4       ; key: slot, then FCB random-record bytes r0,r1,r2

__fdeof:        ds      NFILES  ; EOF flag per slot (index = fd - FIRSTFD)
__fderr:        ds      NFILES  ; error flag per slot
__fduse:
        ds      NFILES
__fdoff:
        ds      NFILES*4

        public  __fcbs
__fcbs:
        ds      NFILES*FCBSIZE

        public  __dma
__dma:
        ds      128


; _srand/_rand placed here so their blocks do not enclose the file I/O and
; divu/modu shared data above; those would force _rand into every build that
; uses file I/O or integer division.
; the assembly implementations match this C code:
;    static unsigned int s_rnd = 1;
;
;    void srand(unsigned int seed)
;    {
;        s_rnd = seed;
;    }
;
;    int rand(void)
;    {
;        /* 16-bit Xorshift (Parameters: 7, 9, 8) */
;        s_rnd ^= s_rnd << 7;
;        s_rnd ^= s_rnd >> 9;
;        s_rnd ^= s_rnd << 8;
;    
;        return (int)(s_rnd & 0x7FFF);
;    }

        public  _srand
_srand:
        pop     de          ; return address
        pop     hl          ; seed
        push    hl          ; preserve caller cleanup convention
        push    de
        ld      (__rand_state),hl
        ret

        public  _rand
_rand:
        ld      hl,(__rand_state)   ; Load the current 16-bit state

        ; --- Step 1: next ^= next << 7 ---
        ld      a,h
        rra
        ld      a,l
        rra
        xor     h
        ld      h,a

        ; --- Step 2: next ^= next >> 9 ---
        ld      a,l
        rra
        ld      a,h
        rra
        xor     l
        ld      l,a

        ; --- Step 3: next ^= next << 8 ---
        xor     h
        ld      h,a

        ; Save the updated full 16-bit state back to memory
        ld      (__rand_state),hl

        ; Clear bit 15 to stay compliant with standard C89 RAND_MAX (0-32767)
        res     7,h
        ret

__rand_state:
        dw      1


; ============================================================
; 32-bit long arithmetic runtime routines
; Calling convention: caller pushes LHS (push de; push hl),
;   then RHS (push de; push hl), then calls.  After push ix;
;   ld ix,0; add ix,sp: IX+4=RHS_L, IX+6=RHS_H,
;   IX+8=LHS_L, IX+10=LHS_H.  Returns DE:HL (DE=high,
;   HL=low).  Caller cleans 8 bytes of args after return.
; ============================================================

        public  __lmul
__lmul:
        ; long __lmul(long a, long b) -> a*b (mod 2^32) in DE:HL.
        ;
        ; 32x32 -> 32 via partial products.  With X = Xhi:Xlo and Y = Yhi:Ylo,
        ;   X*Y mod 2^32 = Xlo*Ylo + ((Xlo*Yhi + Xhi*Ylo) & 0xFFFF) << 16.
        ; The base term Xlo*Ylo is a register-only 16x16->32 (no per-iteration
        ; memory traffic, unlike the old shift/add-in-RAM loop); the two cross
        ; terms only need the low 16 bits, so they reuse the tuned 16x16->16
        ; __mulu.  Y = arg0 (ix+4/6), X = arg1 (ix+8/10).
        push    ix
        ld      ix,0
        add     ix,sp
        ld      l,(ix+8)
        ld      h,(ix+9)
        ld      (__lm_lhs_l),hl         ; Xlo
        ld      l,(ix+10)
        ld      h,(ix+11)
        ld      (__lm_lhs_h),hl         ; Xhi
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      (__lm_rhs_l),hl         ; Ylo
        ld      l,(ix+6)
        ld      h,(ix+7)
        ld      (__lm_rhs_h),hl         ; Yhi

        ; --- base = Xlo * Ylo, register-only 16x16 -> 32 -------------------
        ; HL:DE is the 32-bit accumulator (HL high, DE low).  DE starts as the
        ; multiplier Ylo and is consumed LSB-first; product bits shift down out
        ; of HL into DE.  BC = constant multiplicand Xlo.  16 fixed iterations.
        ld      de,(__lm_rhs_l)         ; DE = Ylo (multiplier / low accumulator)
        ld      bc,(__lm_lhs_l)         ; BC = Xlo (multiplicand, constant)
        ld      hl,0                    ; HL = high accumulator
        ld      a,16
lmul_b:
        bit     0,e                     ; multiplier LSB (bit preserves carry)
        jr      z,lmul_bn
        add     hl,bc                   ; HL += Xlo; CF = carry out of bit 15
        jr      lmul_bs
lmul_bn:
        or      a                       ; CF = 0 for a clean shift
lmul_bs:
        rr      h                       ; shift CF:HL:DE right by one (33-bit)
        rr      l
        rr      d
        rr      e
        dec     a
        jr      nz,lmul_b
        ld      (__lm_res_l),de         ; result low = base low (final)
        push    hl                      ; save base high

        ; --- result high = base_high + low16(Xlo*Yhi) + low16(Xhi*Ylo) ------
        ld      hl,(__lm_lhs_l)         ; Xlo
        ld      de,(__lm_rhs_h)         ; Yhi
        call    __mulu                  ; HL = low16(Xlo*Yhi), BC preserved
        pop     de                      ; DE = base high
        add     hl,de
        push    hl                      ; save partial high
        ld      hl,(__lm_lhs_h)         ; Xhi
        ld      de,(__lm_rhs_l)         ; Ylo
        call    __mulu                  ; HL = low16(Xhi*Ylo)
        pop     de                      ; DE = partial high
        add     hl,de                   ; HL = result high
        ex      de,hl                   ; DE = result high
        ld      hl,(__lm_res_l)         ; HL = result low
        ld      sp,ix
        pop     ix
        ret

; __ldivu: unsigned 32-bit divide.  Returns DE:HL = LHS / RHS.
        public  __ldu
__ldu:
        push    ix
        ld      ix,0
        add     ix,sp
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      (__ldv_dvs_l),hl
        ld      l,(ix+6)
        ld      h,(ix+7)
        ld      (__ldv_dvs_h),hl
        ld      l,(ix+8)
        ld      h,(ix+9)
        ld      (__ldv_dvd_l),hl
        ld      l,(ix+10)
        ld      h,(ix+11)
        ld      (__ldv_dvd_h),hl
        ld      hl,0
        ld      (__ldv_rem_l),hl
        ld      (__ldv_rem_h),hl
        ld      (__ldv_quo_l),hl
        ld      (__ldv_quo_h),hl
        ; Fast path: divisor fits in 16 bits.
        ld      hl,(__ldv_dvs_h)
        ld      a,h
        or      l
        jp      z,ldivu_dvs16
        ld      b,32
ldivu_loop:
        push    bc
        ; Shift {rem:dvd} left 1 (64-bit)
        ld      hl,(__ldv_dvd_l)
        or      a
        add     hl,hl
        ld      (__ldv_dvd_l),hl
        ld      hl,(__ldv_dvd_h)
        adc     hl,hl
        ld      (__ldv_dvd_h),hl
        ld      hl,(__ldv_rem_l)
        adc     hl,hl
        ld      (__ldv_rem_l),hl
        ld      hl,(__ldv_rem_h)
        adc     hl,hl
        ld      (__ldv_rem_h),hl
        ; Compare rem with dvs (32-bit)
        ld      hl,(__ldv_rem_l)
        ld      de,(__ldv_dvs_l)
        or      a
        sbc     hl,de
        ex      de,hl           ; DE = rem_l - dvs_l (tentative)
        ld      hl,(__ldv_rem_h)
        ld      bc,(__ldv_dvs_h)
        sbc     hl,bc           ; HL = rem_h - dvs_h - borrow
        jr      c,ldivu_no_sub
        ; rem >= dvs: store rem - dvs, set quotient bit
        ld      (__ldv_rem_h),hl
        ex      de,hl
        ld      (__ldv_rem_l),hl
        ld      hl,(__ldv_quo_l)
        or      a
        add     hl,hl
        inc     l
        ld      (__ldv_quo_l),hl
        ld      hl,(__ldv_quo_h)
        adc     hl,hl
        ld      (__ldv_quo_h),hl
        jr      ldivu_next
ldivu_no_sub:
        ld      hl,(__ldv_quo_l)
        or      a
        add     hl,hl
        ld      (__ldv_quo_l),hl
        ld      hl,(__ldv_quo_h)
        adc     hl,hl
        ld      (__ldv_quo_h),hl
ldivu_next:
        pop     bc
        djnz    ldivu_loop
        ld      hl,(__ldv_quo_l)
        ld      de,(__ldv_quo_h)
        ld      sp,ix
        pop     ix
        ret

ldivu_dvs16:
        ; 16-bit divisor fast path: 32-bit dividend / 16-bit divisor.
        ; Build the 32-bit quotient in place in the dividend bytes (MSB-first)
        ; and leave the 16-bit remainder in HL (unused for divide).
        ld      de,(__ldv_dvs_l)        ; DE = divisor
        ld      hl,0                    ; HL = partial remainder
        ld      a,(__ldv_dvd_h+1)       ; byte 3 (MSB)
        call    ldqr_byte
        ld      (__ldv_dvd_h+1),a       ; quotient byte 3
        ld      a,(__ldv_dvd_h)         ; byte 2
        call    ldqr_byte
        ld      (__ldv_dvd_h),a         ; quotient byte 2
        ld      a,(__ldv_dvd_l+1)       ; byte 1
        call    ldqr_byte
        ld      (__ldv_dvd_l+1),a       ; quotient byte 1
        ld      a,(__ldv_dvd_l)         ; byte 0 (LSB)
        call    ldqr_byte
        ld      (__ldv_dvd_l),a         ; quotient byte 0
        ld      hl,(__ldv_dvd_l)        ; HL = quotient low word
        ld      de,(__ldv_dvd_h)        ; DE = quotient high word
        ld      sp,ix
        pop     ix
        ret

; __lmodu: unsigned 32-bit modulo.  Returns DE:HL = LHS % RHS.
        public  __lmu
__lmu:
        push    ix
        ld      ix,0
        add     ix,sp
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      (__ldv_dvs_l),hl
        ld      l,(ix+6)
        ld      h,(ix+7)
        ld      (__ldv_dvs_h),hl
        ld      l,(ix+8)
        ld      h,(ix+9)
        ld      (__ldv_dvd_l),hl
        ld      l,(ix+10)
        ld      h,(ix+11)
        ld      (__ldv_dvd_h),hl
        ld      hl,0
        ld      (__ldv_rem_l),hl
        ld      (__ldv_rem_h),hl
        ; Fast path: divisor fits in 16 bits  use compact register-based algorithm.
        ; Keep DE = divisor and HL = 16-bit running remainder throughout.
        ; Process the 32-bit dividend MSB-first, 8 bits per call to lmodu_byte.
        ld      hl,(__ldv_dvs_h)
        ld      a,h
        or      l
        jp      z,lmodu_dvs16
        ld      b,32
lmodu_loop:
        push    bc
        ld      hl,(__ldv_dvd_l)
        or      a
        add     hl,hl
        ld      (__ldv_dvd_l),hl
        ld      hl,(__ldv_dvd_h)
        adc     hl,hl
        ld      (__ldv_dvd_h),hl
        ld      hl,(__ldv_rem_l)
        adc     hl,hl
        ld      (__ldv_rem_l),hl
        ld      hl,(__ldv_rem_h)
        adc     hl,hl
        ld      (__ldv_rem_h),hl
        ld      hl,(__ldv_rem_l)
        ld      de,(__ldv_dvs_l)
        or      a
        sbc     hl,de
        ex      de,hl
        ld      hl,(__ldv_rem_h)
        ld      bc,(__ldv_dvs_h)
        sbc     hl,bc
        jr      c,lmodu_no_sub
        ld      (__ldv_rem_h),hl
        ex      de,hl
        ld      (__ldv_rem_l),hl
lmodu_no_sub:
        pop     bc
        djnz    lmodu_loop
        ld      hl,(__ldv_rem_l)
        ld      de,(__ldv_rem_h)
        ld      sp,ix
        pop     ix
        ret

lmodu_dvs16:
        ; Divisor is 16-bit (in __ldv_dvs_l).  Process the 32-bit dividend
        ; byte-by-byte MSB-first, accumulating a 16-bit remainder in HL.
        ; All four bytes are processed: a zero byte that follows a nonzero one
        ; still shifts the remainder, so bytes must NOT be skipped.  The final
        ; remainder is < divisor, so its high word is zero.
        ld      de,(__ldv_dvs_l)        ; DE = divisor (stays in register)
        ld      hl,0                    ; HL = partial remainder
        ld      a,(__ldv_dvd_h+1)       ; byte 3 (MSB)
        call    ldqr_byte
        ld      a,(__ldv_dvd_h)         ; byte 2
        call    ldqr_byte
        ld      a,(__ldv_dvd_l+1)       ; byte 1
        call    ldqr_byte
        ld      a,(__ldv_dvd_l)         ; byte 0 (LSB)
        call    ldqr_byte
        ; HL = remainder; DE high word = 0 (remainder < 16-bit divisor)
        ld      de,0
        ld      sp,ix
        pop     ix
        ret

ldqr_byte:
        ; Shared one-byte step for 32-bit / 16-bit division and modulo.
        ; In:  A = next dividend byte (MSB-first), HL = remainder, DE = divisor.
        ; Out: A = quotient byte for this position, HL = updated remainder.
        ;      Clobbers B.  Modulo callers ignore A; divide callers store A
        ;      back to build the in-place quotient.
        ;
        ; sla a frees bit0 to receive this position's quotient bit and feeds
        ; the dividend MSB into carry for adc hl,hl.  When adc hl,hl overflows,
        ; the true shifted value exceeds 65535 >= divisor, so a subtract is
        ; mandatory and (HL_wrapped - divisor) is the correct remainder.
        ld      b,8
ldqr_bit:
        sla     a                       ; dividend bit7 -> carry; bit0 = 0 (quotient slot)
        adc     hl,hl                   ; HL = (HL<<1) | bit; carry = 16-bit overflow
        jr      c,ldqr_sub              ; overflow: must subtract, quotient bit = 1
        or      a                       ; clear carry (leaves A unchanged)
        sbc     hl,de                   ; trial HL -= divisor
        jr      nc,ldqr_one             ; HL >= divisor: keep, quotient bit = 1
        add     hl,de                   ; restore: HL < divisor, quotient bit = 0
        jr      ldqr_cont
ldqr_sub:
        or      a                       ; clear carry
        sbc     hl,de                   ; HL_wrapped - divisor = correct remainder
ldqr_one:
        inc     a                       ; set quotient bit (bit0)
ldqr_cont:
        djnz    ldqr_bit
        ret

; __ldivs: signed 32-bit divide.  Returns DE:HL = LHS / RHS.
        public  __lds
__lds:
        push    ix
        ld      ix,0
        add     ix,sp
        ; Load args and make positive, track sign
        ld      l,(ix+8)
        ld      h,(ix+9)
        ld      (__ldv_dvd_l),hl
        ld      l,(ix+10)
        ld      h,(ix+11)
        ld      (__ldv_dvd_h),hl
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      (__ldv_dvs_l),hl
        ld      l,(ix+6)
        ld      h,(ix+7)
        ld      (__ldv_dvs_h),hl
        ; sign = sign(dvd) XOR sign(dvs)
        ld      a,(ix+11)       ; high byte of LHS_H
        xor     (ix+7)          ; XOR with high byte of RHS_H
        ld      (__ldv_sign),a  ; bit7 = result sign
        ; If dvd negative: negate it
        ld      a,(ix+11)
        bit     7,a
        jr      z,ldivs_dvd_pos
        ld      de,(__ldv_dvd_l)
        ld      hl,0
        or      a
        sbc     hl,de
        ld      (__ldv_dvd_l),hl
        ld      de,(__ldv_dvd_h)
        ld      hl,0
        sbc     hl,de
        ld      (__ldv_dvd_h),hl
ldivs_dvd_pos:
        ; If dvs negative: negate it
        ld      a,(ix+7)
        bit     7,a
        jr      z,ldivs_dvs_pos
        ld      de,(__ldv_dvs_l)
        ld      hl,0
        or      a
        sbc     hl,de
        ld      (__ldv_dvs_l),hl
        ld      de,(__ldv_dvs_h)
        ld      hl,0
        sbc     hl,de
        ld      (__ldv_dvs_h),hl
ldivs_dvs_pos:
        ; Now do unsigned division using the scratch vars
        ld      hl,0
        ld      (__ldv_rem_l),hl
        ld      (__ldv_rem_h),hl
        ld      (__ldv_quo_l),hl
        ld      (__ldv_quo_h),hl
        ; Fast path: divisor magnitude fits in 16 bits.
        ld      hl,(__ldv_dvs_h)
        ld      a,h
        or      l
        jp      z,ldivs_dvs16
        ld      b,32
ldivs_loop:
        push    bc
        ld      hl,(__ldv_dvd_l)
        or      a
        add     hl,hl
        ld      (__ldv_dvd_l),hl
        ld      hl,(__ldv_dvd_h)
        adc     hl,hl
        ld      (__ldv_dvd_h),hl
        ld      hl,(__ldv_rem_l)
        adc     hl,hl
        ld      (__ldv_rem_l),hl
        ld      hl,(__ldv_rem_h)
        adc     hl,hl
        ld      (__ldv_rem_h),hl
        ld      hl,(__ldv_rem_l)
        ld      de,(__ldv_dvs_l)
        or      a
        sbc     hl,de
        ex      de,hl
        ld      hl,(__ldv_rem_h)
        ld      bc,(__ldv_dvs_h)
        sbc     hl,bc
        jr      c,ldivs_no_sub
        ld      (__ldv_rem_h),hl
        ex      de,hl
        ld      (__ldv_rem_l),hl
        ld      hl,(__ldv_quo_l)
        or      a
        add     hl,hl
        inc     l
        ld      (__ldv_quo_l),hl
        ld      hl,(__ldv_quo_h)
        adc     hl,hl
        ld      (__ldv_quo_h),hl
        jr      ldivs_next
ldivs_no_sub:
        ld      hl,(__ldv_quo_l)
        or      a
        add     hl,hl
        ld      (__ldv_quo_l),hl
        ld      hl,(__ldv_quo_h)
        adc     hl,hl
        ld      (__ldv_quo_h),hl
ldivs_next:
        pop     bc
        djnz    ldivs_loop
ldivs_apply_sign:
        ; Apply sign to quotient
        ld      a,(__ldv_sign)
        bit     7,a
        jr      z,ldivs_pos_result
        ld      de,(__ldv_quo_l)
        ld      hl,0
        or      a
        sbc     hl,de
        ld      (__ldv_quo_l),hl
        ld      de,(__ldv_quo_h)
        ld      hl,0
        sbc     hl,de
        ld      (__ldv_quo_h),hl
ldivs_pos_result:
        ld      hl,(__ldv_quo_l)
        ld      de,(__ldv_quo_h)
        ld      sp,ix
        pop     ix
        ret

ldivs_dvs16:
        ; 16-bit divisor magnitude fast path: build the 32-bit quotient of the
        ; (already non-negative) dividend MSB-first using the shared ldqr_byte
        ; step, then apply the result sign via the common tail.
        ld      de,(__ldv_dvs_l)        ; DE = divisor
        ld      hl,0                    ; HL = partial remainder
        ld      a,(__ldv_dvd_h+1)       ; byte 3 (MSB)
        call    ldqr_byte
        ld      (__ldv_quo_h+1),a       ; quotient byte 3
        ld      a,(__ldv_dvd_h)         ; byte 2
        call    ldqr_byte
        ld      (__ldv_quo_h),a         ; quotient byte 2
        ld      a,(__ldv_dvd_l+1)       ; byte 1
        call    ldqr_byte
        ld      (__ldv_quo_l+1),a       ; quotient byte 1
        ld      a,(__ldv_dvd_l)         ; byte 0 (LSB)
        call    ldqr_byte
        ld      (__ldv_quo_l),a         ; quotient byte 0
        jp      ldivs_apply_sign

; __lmods: signed 32-bit modulo.  Returns DE:HL = LHS % RHS.
        public  __lms
__lms:
        push    ix
        ld      ix,0
        add     ix,sp
        ld      l,(ix+8)
        ld      h,(ix+9)
        ld      (__ldv_dvd_l),hl
        ld      l,(ix+10)
        ld      h,(ix+11)
        ld      (__ldv_dvd_h),hl
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      (__ldv_dvs_l),hl
        ld      l,(ix+6)
        ld      h,(ix+7)
        ld      (__ldv_dvs_h),hl
        ; sign of result = sign of dividend
        ld      a,(ix+11)
        ld      (__ldv_sign),a
        ; If dvd negative: negate
        bit     7,a
        jr      z,lmods_dvd_pos
        ld      de,(__ldv_dvd_l)
        ld      hl,0
        or      a
        sbc     hl,de
        ld      (__ldv_dvd_l),hl
        ld      de,(__ldv_dvd_h)
        ld      hl,0
        sbc     hl,de
        ld      (__ldv_dvd_h),hl
lmods_dvd_pos:
        ; If dvs negative: negate
        ld      a,(ix+7)
        bit     7,a
        jr      z,lmods_dvs_pos
        ld      de,(__ldv_dvs_l)
        ld      hl,0
        or      a
        sbc     hl,de
        ld      (__ldv_dvs_l),hl
        ld      de,(__ldv_dvs_h)
        ld      hl,0
        sbc     hl,de
        ld      (__ldv_dvs_h),hl
lmods_dvs_pos:
        ld      hl,0
        ld      (__ldv_rem_l),hl
        ld      (__ldv_rem_h),hl
        ; Fast path: divisor magnitude fits in 16 bits.
        ld      hl,(__ldv_dvs_h)
        ld      a,h
        or      l
        jp      z,lmods_dvs16
        ld      b,32
lmods_loop:
        push    bc
        ld      hl,(__ldv_dvd_l)
        or      a
        add     hl,hl
        ld      (__ldv_dvd_l),hl
        ld      hl,(__ldv_dvd_h)
        adc     hl,hl
        ld      (__ldv_dvd_h),hl
        ld      hl,(__ldv_rem_l)
        adc     hl,hl
        ld      (__ldv_rem_l),hl
        ld      hl,(__ldv_rem_h)
        adc     hl,hl
        ld      (__ldv_rem_h),hl
        ld      hl,(__ldv_rem_l)
        ld      de,(__ldv_dvs_l)
        or      a
        sbc     hl,de
        ex      de,hl
        ld      hl,(__ldv_rem_h)
        ld      bc,(__ldv_dvs_h)
        sbc     hl,bc
        jr      c,lmods_no_sub
        ld      (__ldv_rem_h),hl
        ex      de,hl
        ld      (__ldv_rem_l),hl
lmods_no_sub:
        pop     bc
        djnz    lmods_loop
lmods_apply_sign:
        ; Apply sign to remainder
        ld      a,(__ldv_sign)
        bit     7,a
        jr      z,lmods_pos_result
        ld      de,(__ldv_rem_l)
        ld      hl,0
        or      a
        sbc     hl,de
        ld      (__ldv_rem_l),hl
        ld      de,(__ldv_rem_h)
        ld      hl,0
        sbc     hl,de
        ld      (__ldv_rem_h),hl
lmods_pos_result:
        ld      hl,(__ldv_rem_l)
        ld      de,(__ldv_rem_h)
        ld      sp,ix
        pop     ix
        ret

lmods_dvs16:
        ; 16-bit divisor magnitude fast path: compute the remainder of the
        ; (already non-negative) dividend MSB-first using the shared ldqr_byte
        ; step (quotient bytes in A are discarded), then apply the dividend
        ; sign via the common tail.  Remainder < divisor so its high word is 0.
        ld      de,(__ldv_dvs_l)        ; DE = divisor
        ld      hl,0                    ; HL = partial remainder
        ld      a,(__ldv_dvd_h+1)       ; byte 3 (MSB)
        call    ldqr_byte
        ld      a,(__ldv_dvd_h)         ; byte 2
        call    ldqr_byte
        ld      a,(__ldv_dvd_l+1)       ; byte 1
        call    ldqr_byte
        ld      a,(__ldv_dvd_l)         ; byte 0 (LSB)
        call    ldqr_byte
        ld      (__ldv_rem_l),hl        ; remainder low word
        ld      hl,0
        ld      (__ldv_rem_h),hl        ; remainder high word = 0
        jp      lmods_apply_sign

; ---- 32-bit comparison functions ----
; Each returns HL=1 (true) or HL=0 (false).
; Caller cleanup (HL only): ex de,hl; ld hl,8; add hl,sp; ld sp,hl; ex de,hl

; Macro-like helper: load LHS_L into HL, RHS_L into DE, then
; load LHS_H into HL, RHS_H into DE after sbc.
; LHS at IX+8/10, RHS at IX+4/6.

        public  __ltu
__ltu:
        push    ix
        ld      ix,0
        add     ix,sp
        ld      l,(ix+8)
        ld      h,(ix+9)
        ld      e,(ix+4)
        ld      d,(ix+5)
        or      a
        sbc     hl,de
        ld      l,(ix+10)
        ld      h,(ix+11)
        ld      e,(ix+6)
        ld      d,(ix+7)
        sbc     hl,de
        ld      hl,0
        jr      nc,ltu_done
        inc     l
ltu_done:
        pop     ix
        ret

        public  __leu
__leu:
        ; LHS <= RHS  <==>  NOT (LHS > RHS)  <==>  NOT (RHS < LHS)
        push    ix
        ld      ix,0
        add     ix,sp
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      e,(ix+8)
        ld      d,(ix+9)
        or      a
        sbc     hl,de
        ld      l,(ix+6)
        ld      h,(ix+7)
        ld      e,(ix+10)
        ld      d,(ix+11)
        sbc     hl,de
        ; carry set iff RHS < LHS, i.e. LHS > RHS
        ld      hl,1
        jr      nc,leu_done ; RHS >= LHS, so LHS <= RHS: return 1
        ld      l,0
leu_done:
        pop     ix
        ret

        public  __lgu
__lgu:
        ; LHS > RHS  <==>  RHS < LHS
        push    ix
        ld      ix,0
        add     ix,sp
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      e,(ix+8)
        ld      d,(ix+9)
        or      a
        sbc     hl,de
        ld      l,(ix+6)
        ld      h,(ix+7)
        ld      e,(ix+10)
        ld      d,(ix+11)
        sbc     hl,de
        ld      hl,0
        jr      nc,gtu_done
        inc     l
gtu_done:
        pop     ix
        ret

        public  __lku
__lku:
        ; LHS >= RHS  <==>  NOT (LHS < RHS)
        push    ix
        ld      ix,0
        add     ix,sp
        ld      l,(ix+8)
        ld      h,(ix+9)
        ld      e,(ix+4)
        ld      d,(ix+5)
        or      a
        sbc     hl,de
        ld      l,(ix+10)
        ld      h,(ix+11)
        ld      e,(ix+6)
        ld      d,(ix+7)
        sbc     hl,de
        ld      hl,1
        jr      nc,geu_done
        ld      l,0
geu_done:
        pop     ix
        ret

; Signed comparisons: same as unsigned but check sign bits differently.
; For signed 32-bit a < b:
;   if sign(a) != sign(b): a < b iff a is negative
;   else: a - b has borrow (same as unsigned)
; Implemented as: (a - b) has "signed overflow" indicated by
;   (result sign != expected sign), or equivalently check
;   carry XOR overflow. Simpler: use sbc and check signed flags.
; Actually on Z80 for signed compare: after sbc hl,de on high word,
;   the S and P/V flags together indicate signed overflow.
;   Signed less-than: S xor P/V (i.e. jp m after XOR check).
;   But after 32-bit subtraction we only have the high-word flags.
;   The flags from the high-word sbc are sufficient for signed compare.

        public  __lts
__lts:
        push    ix
        ld      ix,0
        add     ix,sp
        ld      l,(ix+8)
        ld      h,(ix+9)
        ld      e,(ix+4)
        ld      d,(ix+5)
        or      a
        sbc     hl,de
        ld      l,(ix+10)
        ld      h,(ix+11)
        ld      e,(ix+6)
        ld      d,(ix+7)
        sbc     hl,de
        ; Signed less-than: S xor P/V
        ; jp pe = jump if parity/overflow set; jp m = jump if sign (negative)
        ld      hl,0
        jp      pe,lts_ov  ; overflow set
        jp      m,lts_true ; no overflow, negative  LHS < RHS
        jr      lts_done
lts_ov:
        jp      p,lts_true ; overflow + positive  LHS < RHS
        jr      lts_done
lts_true:
        inc     l
lts_done:
        pop     ix
        ret

        public  __lks
__lks:
        ; LHS >= RHS: NOT (LHS < RHS)
        push    ix
        ld      ix,0
        add     ix,sp
        ld      l,(ix+8)
        ld      h,(ix+9)
        ld      e,(ix+4)
        ld      d,(ix+5)
        or      a
        sbc     hl,de
        ld      l,(ix+10)
        ld      h,(ix+11)
        ld      e,(ix+6)
        ld      d,(ix+7)
        sbc     hl,de
        ld      hl,1
        jp      pe,ges_ov
        jp      m,ges_false
        jr      ges_done
ges_ov:
        jp      p,ges_false
        jr      ges_done
ges_false:
        ld      l,0
ges_done:
        pop     ix
        ret

        public  __lgs
__lgs:
        ; LHS > RHS: RHS < LHS (swap operands, do signed-lt)
        push    ix
        ld      ix,0
        add     ix,sp
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      e,(ix+8)
        ld      d,(ix+9)
        or      a
        sbc     hl,de
        ld      l,(ix+6)
        ld      h,(ix+7)
        ld      e,(ix+10)
        ld      d,(ix+11)
        sbc     hl,de
        ld      hl,0
        jp      pe,gts_ov
        jp      m,gts_true
        jr      gts_done
gts_ov:
        jp      p,gts_true
        jr      gts_done
gts_true:
        inc     l
gts_done:
        pop     ix
        ret

        public  __les
__les:
        ; LHS <= RHS: NOT (RHS < LHS)
        push    ix
        ld      ix,0
        add     ix,sp
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      e,(ix+8)
        ld      d,(ix+9)
        or      a
        sbc     hl,de
        ld      l,(ix+6)
        ld      h,(ix+7)
        ld      e,(ix+10)
        ld      d,(ix+11)
        sbc     hl,de
        ld      hl,1
        jp      pe,les_ov
        jp      m,les_false
        jr      les_done
les_ov:
        jp      p,les_false
        jr      les_done
les_false:
        ld      l,0
les_done:
        pop     ix
        ret

; ============================================================
; Heap allocator: first-fit, 3-byte block headers.
;
; Header layout:
;   byte 0-1 = user data size in bytes, unsigned 16-bit
;   byte 2   = flags: bit 0 set means free, zero means in use
;
; Older DCCRTL stored the free flag in bit 15 of the size word.  That made
; malloc(32768) unrepresentable: freeing such a block looked like freeing a
; zero-sized block and corrupted the heap walk.  Keep the flag in a separate
; byte instead.  The one-byte header cost is worth allowing any allocation that
; fits in CP/M memory.
;
; __hbase / __brk / __hlimit are set by start:.
; ============================================================

        public  _malloc
_malloc:
        push    ix
        ld      ix,0
        add     ix,sp
        ld      l,(ix+4)
        ld      h,(ix+5)        ; HL = requested size
        call    __mlh
        pop     ix
        ret

        public  __ckmul
; Internal: HL = a, DE = b.  Returns HL = a*b (low 16 bits) and carry set
; when the true product exceeds 65535 (16-bit size_t overflow).  Reuses the
; tested __mulu/__divu helpers: multiply, then verify product/b == a.
; Corrupts AF, BC, DE.  Does not use IX.
__ckmul:
        ld      a,h
        or      l
        jr      z,ck_zero       ; a == 0 -> product 0, no overflow
        ld      a,d
        or      e
        jr      z,ck_zero       ; b == 0 -> product 0, no overflow
        ld      (__ck_a),hl     ; save a
        push    de              ; save b
        call    __mulu          ; HL = a*b (mod 65536)
        pop     de              ; DE = b
        push    hl              ; save product
        call    __divu          ; HL = product / b
        ld      de,(__ck_a)
        or      a
        sbc     hl,de           ; quotient - a
        pop     hl              ; HL = product (POP preserves flags)
        ret     z               ; quotient == a -> no overflow (carry clear)
        scf                     ; mismatch -> overflow
        ret
ck_zero:
        ld      hl,0
        or      a               ; clear carry
        ret
__ck_a:         dw      0

        public  _calloc
_calloc:
        push    ix
        ld      ix,0
        add     ix,sp
        ld      l,(ix+4)
        ld      h,(ix+5)        ; HL = nmemb
        ld      e,(ix+6)
        ld      d,(ix+7)        ; DE = size
        call    __ckmul         ; HL = nmemb*size; carry set on overflow
        jr      c,ca_ovf        ; overflow -> behave like allocation failure
        call    __mlh     ; HL = ptr or 0; __ml_need = total size
        push    hl              ; save ptr for return
        ld      a,h
        or      l
        jr      z,ca_done       ; NULL: skip zero fill
        ; Zero fill __ml_need bytes starting at HL
        ld      de,(__ml_need)
        ld      b,d
        ld      c,e             ; BC = count
        ld      a,b
        or      c
        jr      z,ca_done       ; nothing to zero
        xor     a
        ld      (hl),a          ; write first zero
        dec     bc
        ld      a,b
        or      c
        jr      z,ca_done       ; count was 1
        ld      d,h
        ld      e,l
        inc     de              ; DE = ptr+1
        ldir                    ; fill remaining bytes
ca_done:
        pop     hl              ; return ptr (or 0)
        pop     ix
        ret
ca_ovf:
        ld      hl,0
        pop     ix
        ret


        public  __real
__real:
        push    ix
        ld      ix,0
        add     ix,sp

        ; realloc(NULL, size) is malloc(size).
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      a,h
        or      l
        jr      nz,rl_have_ptr
        ld      l,(ix+6)
        ld      h,(ix+7)
        call    __mlh
        pop     ix
        ret

rl_have_ptr:
        ld      (__rl_old),hl
        ld      l,(ix+6)
        ld      h,(ix+7)
        ld      (__rl_size),hl

        ; realloc(ptr, 0): free ptr and return NULL.
        ld      a,h
        or      l
        jr      nz,rl_alloc
        ld      hl,(__rl_old)
        call    __frcoal        ; free + coalesce, like _free
        ld      hl,0
        pop     ix
        ret

rl_alloc:
        ; Read old block user size from header at ptr-HDRSIZE.
        ld      hl,(__rl_old)
        ld      de,0-HDRSIZE
        add     hl,de
        ld      e,(hl)
        inc     hl
        ld      d,(hl)
        ld      (__rl_cnt),de           ; __rl_cnt = old user size

        ; ---- In-place fast paths (avoid allocate + copy + free) ----
        ld      hl,(__rl_cnt)           ; old size
        ld      de,(__rl_size)          ; new size
        or      a
        sbc     hl,de
        jp      c,rl_try_grow           ; new > old -> try growing in place
        ; new <= old: shrink or same size, in place.  HL = old - new = slack.
        ld      a,h
        or      a
        jr      nz,rl_shrink_split      ; slack >= 256 -> always split a tail
        ld      a,l
        cp      HDRSIZE+1
        jr      c,rl_keep_whole         ; slack < HDRSIZE+1 -> too small to split
rl_shrink_split:
        ; Shrink the block to the new size and free the tail as its own block.
        ld      hl,(__rl_old)
        ld      de,0-HDRSIZE
        add     hl,de                   ; HL = header
        ld      de,(__rl_size)
        ld      (hl),e
        inc     hl
        ld      (hl),d                  ; header size = new size (flags untouched)
        ; tail user size = slack - HDRSIZE
        ld      hl,(__rl_cnt)
        ld      de,(__rl_size)
        or      a
        sbc     hl,de                   ; HL = slack
        ld      de,HDRSIZE
        or      a
        sbc     hl,de                   ; HL = tail user size
        push    hl                      ; save tail user size
        ld      hl,(__rl_old)
        ld      de,(__rl_size)
        add     hl,de                   ; HL = tail header = ptr + new size
        pop     de                      ; DE = tail user size
        ld      (hl),e
        inc     hl
        ld      (hl),d
        inc     hl
        ld      (hl),1                  ; flags = free
        ; Coalesce the freed tail forward (and trim __brk if it is the top).
        ld      hl,(__rl_old)
        ld      de,(__rl_size)
        add     hl,de
        ld      de,HDRSIZE
        add     hl,de                   ; HL = tail user pointer
        call    __frcoal
        ld      hl,(__rl_old)
        pop     ix
        ret
rl_keep_whole:
        ld      hl,(__rl_old)
        pop     ix
        ret

rl_try_grow:
        ; new > old.  Grow in place only when this is the top heap block, i.e.
        ; its end == __brk and the larger end still fits below __hlimit.
        ld      hl,(__rl_old)
        ld      de,(__rl_cnt)
        add     hl,de                   ; HL = block end = ptr + old size
        ld      de,(__brk)
        or      a
        sbc     hl,de
        jp      nz,rl_do_alloc          ; not the top block
        ld      hl,(__rl_old)
        ld      de,(__rl_size)
        add     hl,de                   ; HL = new block end
        jp      c,rl_do_alloc           ; address wrap -> cannot grow here
        push    hl
        ld      de,(__hlimit)
        or      a
        sbc     hl,de                   ; new_end - hlimit
        pop     hl                      ; HL = new_end
        jr      c,rl_grow_ok            ; new_end < hlimit
        jr      z,rl_grow_ok            ; new_end == hlimit
        jp      rl_do_alloc             ; would overflow the heap limit
rl_grow_ok:
        ld      (__brk),hl              ; extend heap to the new end
        ld      hl,(__rl_old)
        ld      de,0-HDRSIZE
        add     hl,de                   ; HL = header
        ld      de,(__rl_size)
        ld      (hl),e
        inc     hl
        ld      (hl),d                  ; header size = new size
        ld      hl,(__rl_old)
        pop     ix
        ret

rl_do_alloc:
        ; Allocate the new block.  On failure, leave old block unchanged.
        ld      hl,(__rl_size)
        call    __mlh
        ld      (__rl_new),hl
        ld      a,h
        or      l
        jr      nz,rl_copy
        pop     ix
        ret

rl_copy:
        ; Copy min(old_size, new_size) bytes.
        ld      hl,(__rl_cnt)
        ld      de,(__rl_size)
        or      a
        sbc     hl,de           ; old_size - new_size
        jr      c,rl_count_ok   ; old < new: keep old_size
        ld      (__rl_cnt),de   ; new <= old: use new_size
rl_count_ok:
        ld      bc,(__rl_cnt)
        ld      a,b
        or      c
        jr      z,rl_free_old
        ld      hl,(__rl_old)
        ld      de,(__rl_new)
        ldir

rl_free_old:
        ld      hl,(__rl_old)
        call    __frcoal        ; free + coalesce old block, like _free
        ld      hl,(__rl_new)
        pop     ix
        ret

__rl_old:       dw      0
__rl_new:       dw      0
__rl_size:      dw      0
__rl_cnt:       dw      0

        public  _free
_free:
        push    ix
        ld      ix,0
        add     ix,sp
        ld      l,(ix+4)
        ld      h,(ix+5)        ; HL = ptr
        call    __frcoal        ; mark free + coalesce neighbours (handles NULL)
        pop     ix
        ret

        public  __frcoal
; Internal: HL = user pointer (may be NULL).  Marks the block free and merges
; it with an immediately-preceding free block and any following free blocks.
; Shared by _free and realloc so every free path keeps the heap coalesced;
; malloc's first-fit walk does not itself merge adjacent free blocks.
; Corrupts AF, BC, DE, HL.  Does not use IX.
__frcoal:
        ld      a,h
        or      l
        ret     z               ; NULL: do nothing
        dec     hl              ; HL = &header[2] flags byte
        ld      (hl),1          ; mark free
        dec     hl
        dec     hl              ; HL = header
        ld      (__fr_hdr),hl

        ; If the immediately preceding block is also free, use that as the
        ; coalescing anchor so frees in either order merge adjacent blocks.
        ld      hl,(__hbase)
        ld      (__fr_scan),hl
fr_prev:
        ld      hl,(__fr_scan)
        ld      de,(__fr_hdr)
        or      a
        sbc     hl,de           ; scan - current header
        jr      z,fr_coal       ; scan reached current block
        jr      nc,fr_coal      ; defensive: scan passed current block
        ld      hl,(__fr_scan)
        ld      e,(hl)
        inc     hl
        ld      d,(hl)          ; DE = scan block user size
        ld      hl,(__fr_scan)
        ld      bc,HDRSIZE
        add     hl,bc
        add     hl,de           ; HL = block after scan
        push    hl
        ld      de,(__fr_hdr)
        or      a
        sbc     hl,de
        pop     hl              ; HL = block after scan
        jr      z,fr_prev_adj
        jr      nc,fr_coal      ; defensive: next passed current block
        ld      (__fr_scan),hl
        jr      fr_prev

fr_prev_adj:
        ld      hl,(__fr_scan)
        inc     hl
        inc     hl
        ld      a,(hl)          ; previous flags
        or      a
        jr      z,fr_coal       ; previous block is used
        ld      hl,(__fr_scan)
        ld      (__fr_hdr),hl   ; previous free block becomes the anchor

fr_coal:
        ; Merge any immediately following free blocks.  Never read a next
        ; header unless next < __brk; next == __brk means this is the tail.
        ld      hl,(__fr_hdr)
        ld      e,(hl)
        inc     hl
        ld      d,(hl)          ; DE = current user size
        ld      hl,(__fr_hdr)
        ld      bc,HDRSIZE
        add     hl,bc
        add     hl,de           ; HL = next block header
        push    hl
        ld      de,(__brk)
        or      a
        sbc     hl,de           ; carry iff next < __brk
        pop     hl              ; HL = next block header
        jr      nc,fr_done      ; next >= __brk: no following block

        push    hl
        inc     hl
        inc     hl
        ld      a,(hl)          ; next flags
        pop     hl              ; HL = next block header
        or      a
        jr      z,fr_done       ; next block is used

        ld      e,(hl)
        inc     hl
        ld      d,(hl)          ; DE = next user size
        ld      hl,(__fr_hdr)
        ld      c,(hl)
        inc     hl
        ld      b,(hl)          ; BC = current user size
        ld      hl,HDRSIZE
        add     hl,de
        add     hl,bc           ; HL = merged user size
        ex      de,hl
        ld      hl,(__fr_hdr)
        ld      (hl),e
        inc     hl
        ld      (hl),d
        jr      fr_coal
fr_done:
        ; Heap trim: if the (coalesced) free block ends exactly at __brk it is
        ; the top block, so lower __brk to its header.  This returns the space
        ; to the heap/stack gap instead of leaving a stranded top free block,
        ; so the heap high-water mark falls when the top block is released.
        ld      hl,(__fr_hdr)
        ld      e,(hl)
        inc     hl
        ld      d,(hl)                  ; DE = anchor user size
        ld      hl,(__fr_hdr)
        ld      bc,HDRSIZE
        add     hl,bc
        add     hl,de                   ; HL = anchor block end
        ld      de,(__brk)
        or      a
        sbc     hl,de                   ; anchor_end - __brk
        ret     nz                      ; not the top block: keep as free block
        ld      hl,(__fr_hdr)
        ld      (__brk),hl              ; drop the heap high-water mark
        ret

__fr_hdr:       dw      0
__fr_scan:      dw      0

        public  __mlh
; Internal: HL = requested size (0 treated as 1). Returns HL = ptr or 0.
; Corrupts AF, BC, DE, HL. Does not use/save IX.
; Separate public block: _malloc/_calloc reference this helper, but _free and
; programs that only need heap-limit startup state do not pull it in.
__mlh:
        ld      a,h
        or      l
        jr      nz,mh_sz_ok
        ld      l,1             ; size 0 -> 1
mh_sz_ok:
        ld      (__ml_need),hl

        ; Walk free list from __hbase to __brk
        ld      hl,(__hbase)
        ld      (__ml_p),hl

mh_walk:
        ; Stop if walk pointer has reached (or passed) __brk
        ld      hl,(__brk)
        ld      de,(__ml_p)
        or      a
        sbc     hl,de           ; HL = brk - p; carry if p > brk
        jp      z,mh_extend
        jp      c,mh_extend

        ; Read 3-byte header at __ml_p: DE = user size, A = flags
        ld      hl,(__ml_p)
        ld      e,(hl)
        inc     hl
        ld      d,(hl)
        inc     hl
        ld      a,(hl)

        ; Dispatch on free flag (bit 0; nonzero is treated as free)
        or      a
        jr      z,mh_used

        ; --- Free block ---
        ld      (__ml_usiz),de  ; save in case block is too small

        ; Compare user_size (DE) >= need (HL = __ml_need)
        ld      hl,(__ml_need)
        ex      de,hl           ; HL = user_size, DE = need
        or      a
        sbc     hl,de           ; HL = user_size - need; carry if too small
        jr      c,mh_skip_free

        ; Block fits. HL = remainder = user_size - need, DE = need.
        ; Split if remainder >= HDRSIZE+1 (= 4)
        ld      a,h
        or      a
        jr      nz,mh_split     ; high byte != 0 -> remainder >= 256 -> always split
        ld      a,l
        cp      HDRSIZE+1
        jr      nc,mh_split

        ; No split: use whole block. Restore user_size = need + remainder.
        ex      de,hl           ; HL = need, DE = remainder
        add     hl,de           ; HL = user_size
        ; Write used header at __ml_p
        ld      de,(__ml_p)
        ld      a,l
        ld      (de),a
        inc     de
        ld      a,h
        ld      (de),a
        inc     de
        xor     a               ; flags = used
        ld      (de),a
        ; Return __ml_p + HDRSIZE
        ld      hl,(__ml_p)
        ld      de,HDRSIZE
        add     hl,de
        ret

mh_split:
        ; HL = remainder, DE = need.
        ; Write used header at __ml_p: size=need, flags=0
        ld      bc,(__ml_p)
        ld      a,e
        ld      (bc),a          ; header low = need_lo
        inc     bc
        ld      a,d
        ld      (bc),a          ; header high = need_hi
        inc     bc
        xor     a
        ld      (bc),a          ; flags = used
        ; Compute new free block address = __ml_p + HDRSIZE + need
        push    hl              ; save remainder
        ld      hl,(__ml_p)
        ld      de,HDRSIZE
        add     hl,de
        ld      de,(__ml_need)
        add     hl,de           ; HL = new free block address
        pop     de              ; DE = remainder
        ; New block user_size = remainder - HDRSIZE
        ld      a,e
        sub     HDRSIZE
        ld      e,a
        ld      a,d
        sbc     a,0
        ld      d,a             ; DE = new_user_size
        ; Write free header at HL
        ld      (hl),e
        inc     hl
        ld      (hl),d
        inc     hl
        ld      (hl),1          ; flags = free
        ; Return __ml_p + HDRSIZE
        ld      hl,(__ml_p)
        ld      de,HDRSIZE
        add     hl,de
        ret

mh_skip_free:
        ; Free but too small: advance by HDRSIZE + user_size
        ld      hl,(__ml_p)
        ld      de,(__ml_usiz)
        ld      bc,HDRSIZE
        add     hl,bc
        add     hl,de
        ld      (__ml_p),hl
        jp      mh_walk

mh_used:
        ; Used block. DE = user_size from header.
        ld      hl,(__ml_p)
        ld      bc,HDRSIZE
        add     hl,bc
        add     hl,de
        ld      (__ml_p),hl
        jp      mh_walk

mh_extend:
        ; No free block found. Extend heap upward.
        ; Check: brk + HDRSIZE + need <= heap_limit
        ld      hl,(__brk)
        ld      (__ml_p),hl     ; save old brk (reuse __ml_p)
        ld      de,(__ml_need)
        add     hl,de
        jp      c,mh_oom        ; 16-bit wrap means the block cannot fit
        ld      de,HDRSIZE
        add     hl,de           ; HL = brk + need + HDRSIZE
        jp      c,mh_oom        ; header addition wrapped past 0ffffh
        ; Require new_brk <= __hlimit.  HL is the exclusive end of
        ; the allocation (old brk + header + user size).
        ; This comparison deliberately avoids computing hlimit+1, which
        ; itself can wrap when the CP/M stack starts near FFFFh.
        ld      de,(__hlimit)
        or      a
        sbc     hl,de           ; carry if end < limit, z if end == limit
        jr      c,mh_extend_ok
        jr      z,mh_extend_ok
        jr      mh_oom

mh_extend_ok:

        ; Write used header at old brk
        ld      hl,(__ml_p)     ; HL = old brk
        ld      de,(__ml_need)
        ld      (hl),e
        inc     hl
        ld      (hl),d
        inc     hl
        ld      (hl),0          ; flags = used
        ; Advance brk: new_brk = old_brk + HDRSIZE + need
        ld      hl,(__ml_p)
        ld      de,HDRSIZE
        add     hl,de
        ld      de,(__ml_need)
        add     hl,de
        ld      (__brk),hl
        ; Return old_brk + HDRSIZE
        ld      hl,(__ml_p)
        ld      de,HDRSIZE
        add     hl,de
        ret

mh_oom:
        ld      hl,0
        ret

; Allocator temporaries
__ml_need:      dw      0
__ml_p:         dw      0
__ml_usiz:      dw      0

        public  __lmd
__lmd:
; ---- scratch data for long arithmetic ----
__lm_lhs_l:     dw      0
__lm_lhs_h:     dw      0
__lm_rhs_l:     dw      0
__lm_rhs_h:     dw      0
__lm_res_l:     dw      0
__lm_res_h:     dw      0

__ldv_dvs_l:    dw      0
__ldv_dvs_h:    dw      0
__ldv_dvd_l:    dw      0
__ldv_dvd_h:    dw      0
__ldv_rem_l:    dw      0
__ldv_rem_h:    dw      0
__ldv_quo_l:    dw      0
__ldv_quo_h:    dw      0
__ldv_sign:     db      0

; ============================================================
; Character classification and conversion
; ============================================================

; ---- _toupper(int c) ----
; Returns c converted to upper-case if 'a'<=c<='z', else c unchanged.
; Arg: c @ IX+4/5.  Return: HL = result.
        public  __ctu
__ctu:
        ld      hl,2
        add     hl,sp
        ld      a,(hl)          ; A = c low byte
        inc     hl
        ld      h,(hl)          ; H = c high byte
        ld      l,a             ; HL = c (full int)
        cp      'a'             ; c < 'a' -> leave as-is
        jr      c,toup_done
        cp      'z'+1           ; c > 'z' -> leave as-is
        jr      nc,toup_done
        sub     20h             ; lowercase -> uppercase
        ld      l,a
        ld      h,0
toup_done:
        ret

; ---- _isspace(int c) ----
; Returns HL=1 if c is a whitespace character, HL=0 otherwise.
; Recognises: SP HT LF VT FF CR.
        public  __csp
__csp:
        ld      hl,2
        add     hl,sp
        ld      a,(hl)
        cp      ' '
        jr      z,issp_yes
        cp      09h             ; HT
        jr      z,issp_yes
        cp      0ah             ; LF
        jr      z,issp_yes
        cp      0bh             ; VT
        jr      z,issp_yes
        cp      0ch             ; FF
        jr      z,issp_yes
        cp      0dh             ; CR
        jr      z,issp_yes
        ld      hl,0
        ret
issp_yes:
        ld      hl,1
        ret

; ---- _isdigit(int c) ----
; Returns HL=1 if '0'<=c<='9', HL=0 otherwise.
        public  __cdg
__cdg:
        ld      hl,2
        add     hl,sp
        ld      a,(hl)
        cp      '0'
        jr      c,isdig_no
        cp      '9'+1
        jr      nc,isdig_no
        ld      hl,1
        ret
isdig_no:
        ld      hl,0
        ret

; ---- ctype helpers with short external names for M80/L80 ----
; All take int c at IX+4/5 and return HL=1/0 except __ctl.

        public  __caa
__caa:
        ld      hl,2
        add     hl,sp
        ld      a,(hl)
        cp      'A'
        jr      c,ialp_no
        cp      'Z'+1
        jr      c,ialp_yes
        cp      'a'
        jr      c,ialp_no
        cp      'z'+1
        jr      c,ialp_yes
ialp_no:
        ld      hl,0
        ret
ialp_yes:
        ld      hl,1
        ret

        public  __can
__can:
        ld      hl,2
        add     hl,sp
        ld      a,(hl)
        cp      '0'
        jr      c,ialn_alpha
        cp      '9'+1
        jr      c,ialn_yes
ialn_alpha:
        cp      'A'
        jr      c,ialn_no
        cp      'Z'+1
        jr      c,ialn_yes
        cp      'a'
        jr      c,ialn_no
        cp      'z'+1
        jr      c,ialn_yes
ialn_no:
        ld      hl,0
        ret
ialn_yes:
        ld      hl,1
        ret

        public  __cup
__cup:
        ld      hl,2
        add     hl,sp
        ld      a,(hl)
        cp      'A'
        jr      c,isup_no
        cp      'Z'+1
        jr      nc,isup_no
        ld      hl,1
        ret
isup_no:
        ld      hl,0
        ret

        public  __clo
__clo:
        ld      hl,2
        add     hl,sp
        ld      a,(hl)
        cp      'a'
        jr      c,islo_no
        cp      'z'+1
        jr      nc,islo_no
        ld      hl,1
        ret
islo_no:
        ld      hl,0
        ret

        public  __cxd
__cxd:
        ld      hl,2
        add     hl,sp
        ld      a,(hl)
        cp      '0'
        jr      c,ixdg_alpha
        cp      '9'+1
        jr      c,ixdg_yes
ixdg_alpha:
        cp      'A'
        jr      c,ixdg_lower
        cp      'F'+1
        jr      c,ixdg_yes
ixdg_lower:
        cp      'a'
        jr      c,ixdg_no
        cp      'f'+1
        jr      c,ixdg_yes
ixdg_no:
        ld      hl,0
        ret
ixdg_yes:
        ld      hl,1
        ret

        public  __cpr
__cpr:
        ld      hl,2
        add     hl,sp
        ld      a,(hl)
        cp      20h
        jr      c,iprt_no
        cp      7fh
        jr      nc,iprt_no
        ld      hl,1
        ret
iprt_no:
        ld      hl,0
        ret

        public  __cct
__cct:
        ld      hl,2
        add     hl,sp
        ld      a,(hl)
        cp      20h
        jr      c,icnt_yes
        cp      7fh
        jr      z,icnt_yes
        ld      hl,0
        ret
icnt_yes:
        ld      hl,1
        ret

        public  __cpu
__cpu:
        ld      hl,2
        add     hl,sp
        ld      a,(hl)
        ; printable, not space, and not alnum
        cp      21h
        jr      c,ipnc_no
        cp      7fh
        jr      nc,ipnc_no
        cp      '0'
        jr      c,ipnc_yes
        cp      '9'+1
        jr      c,ipnc_no
        cp      'A'
        jr      c,ipnc_yes
        cp      'Z'+1
        jr      c,ipnc_no
        cp      'a'
        jr      c,ipnc_yes
        cp      'z'+1
        jr      c,ipnc_no
ipnc_yes:
        ld      hl,1
        ret
ipnc_no:
        ld      hl,0
        ret

        public  __ctl
__ctl:
        ld      hl,2
        add     hl,sp
        ld      a,(hl)          ; A = c low byte
        inc     hl
        ld      h,(hl)          ; H = c high byte
        ld      l,a             ; HL = c (full int)
        cp      'A'
        jr      c,tolo_done
        cp      'Z'+1
        jr      nc,tolo_done
        add     a,20h
        ld      l,a
        ld      h,0
tolo_done:
        ret

; ---- _fgets(char *buf, int size, FILE *fp) ----
; fp < 3 (stdin/stdout/stderr)  read from console via BDOS fn 1.
; fp >= 3 (real file)  read char-by-char using _read.
; Returns HL = buf on success, HL = 0 at EOF or if size <= 0.
; Args: buf @ IX+4/5,  size @ IX+6/7,  fp @ IX+8/9.
        public  _fgets
_fgets:
        push    ix
        ld      ix,0
        add     ix,sp

        ; if size <= 0 return NULL immediately
        ld      l,(ix+6)
        ld      h,(ix+7)
        ld      a,h
        or      l
        jp      z,fgets_null

        ; dispatch on fp: < 3  console, >= 3  file
        ld      a,(ix+8)
        cp      FIRSTFD
        jp      c,fgets_con

        ; ---- File path ----
        ; Check EOF flag for this slot
        sub     FIRSTFD                 ; A = slot
        ld      h,0
        ld      l,a
        ld      de,__fdeof
        add     hl,de
        ld      a,(hl)
        or      a
        jp      nz,fgets_null           ; already at EOF

        ; Set up: rem = size-1, ptr = buf, start = buf
        ld      l,(ix+6)
        ld      h,(ix+7)
        dec     hl
        ld      (__fgets_rem),hl
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      (__fgets_ptr),hl
        ld      (__fgets_start),hl

fgf_loop:
        ld      hl,(__fgets_rem)
        ld      a,h
        or      l
        jp      z,fgets_term            ; buffer full

        ; _read(fp, &__fgets_ch, 1)
        ld      hl,1
        push    hl                      ; count=1
        ld      hl,__fgets_ch
        push    hl                      ; buf
        ld      l,(ix+8)
        ld      h,(ix+9)
        push    hl                      ; fp
        call    _read
        ex      de,hl                   ; DE = bytes read
        ld      hl,6
        add     hl,sp
        ld      sp,hl                   ; clean 3 args
        ex      de,hl                   ; HL = bytes read

        ld      a,h
        or      l
        jr      z,fgf_eof               ; read 0 bytes  EOF

        ld      a,(__fgets_ch)
        cp      1ah                     ; Ctrl-Z = CP/M EOF marker
        jr      z,fgf_eof

        ; store char
        ld      hl,(__fgets_ptr)
        ld      (hl),a
        inc     hl
        ld      (__fgets_ptr),hl
        ld      hl,(__fgets_rem)
        dec     hl
        ld      (__fgets_rem),hl
        cp      0ah                     ; LF  end of line
        jr      z,fgets_term
        jr      fgf_loop

fgf_eof:
        ; set EOF flag for this slot
        ld      a,(ix+8)
        sub     FIRSTFD
        ld      h,0
        ld      l,a
        ld      de,__fdeof
        add     hl,de
        ld      (hl),1
        ; if no chars were stored  return NULL
        ld      hl,(__fgets_ptr)
        ld      de,(__fgets_start)
        or      a
        sbc     hl,de
        jp      z,fgets_null            ; ptr == start  nothing read
        ; else: NUL-terminate and return buf
        jr      fgets_term

        ; ---- Console path ----
fgets_con:
        ; HL still = size (loaded at top); compute rem = size-1
        ld      l,(ix+6)
        ld      h,(ix+7)
        dec     hl
        ld      (__fgets_rem),hl
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      (__fgets_ptr),hl

fgets_loop:
        ld      hl,(__fgets_rem)
        ld      a,h
        or      l
        jr      z,fgets_term

        ld      c,1
        call    5                       ; BDOS fn 1: console input  A

        cp      1ah                     ; Ctrl-Z  EOF
        jr      z,fgets_term

        cp      0dh                     ; CR  translate to LF, end line
        jr      nz,fgets_store
        ld      e,0ah
        ld      c,2
        call    5                       ; echo LF
        ld      a,0ah

fgets_store:
        ld      b,a
        ld      hl,(__fgets_ptr)
        ld      (hl),b
        inc     hl
        ld      (__fgets_ptr),hl
        ld      hl,(__fgets_rem)
        dec     hl
        ld      (__fgets_rem),hl
        ld      a,b
        cp      0ah
        jr      z,fgets_term
        jr      fgets_loop

fgets_term:
        ld      hl,(__fgets_ptr)
        ld      (hl),0
        ld      l,(ix+4)
        ld      h,(ix+5)
        pop     ix
        ret

fgets_null:
        ld      hl,0
        pop     ix
        ret

__fgets_ptr:    dw      0
__fgets_rem:    dw      0
__fgets_ch:     db      0
__fgets_start:  dw      0

; ============================================================
; _sprintf(buf, fmt, ...)
; IX+4=buf, IX+6=fmt, IX+8=first vararg
; ============================================================
        public  _sprintf
_sprintf:
        push    ix
        ld      ix,0
        add     ix,sp
        push    bc
        push    de
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      (pf_bufptr),hl          ; pf_bufptr = buf
        ld      hl,0FFFFh
        ld      (pf_sink),hl            ; buffer mode
        ld      l,(ix+6)
        ld      h,(ix+7)                ; HL = fmt (second arg)
        ld      de,8                    ; first vararg at IX+8
        ld      bc,0
        call    __pf_run                ; IX = _sprintf's frame; varargs at IX+8+
        ld      hl,(pf_bufptr)
        ld      (hl),0                  ; NUL-terminate
        ld      h,b
        ld      l,c                     ; return count
        pop     de
        pop     bc
        pop     ix
        ret

; ============================================================
; _fprintf(fp, fmt, ...)
; IX+4=fp, IX+6=fmt, IX+8=first vararg
; Formats into __pf_fbuf, then writes to fp via _write.
; ============================================================
        public  _fprintf
_fprintf:
        push    ix
        ld      ix,0
        add     ix,sp
        push    bc
        push    de

        ; For stdout/stderr, stream directly to the console.  The old path
        ; formatted into the fixed 256-byte __pf_fbuf and then called _write;
        ; that was fragile for status/progress output and any longer fprintf.
        ld      a,(ix+4)
        cp      1
        jr      z,fpcn
        cp      2
        jr      z,fpcn

        ld      hl,__pf_fbuf
        ld      (pf_bufptr),hl          ; output to static buffer
        ld      hl,0FFFFh
        ld      (pf_sink),hl            ; buffer mode
        ld      l,(ix+6)
        ld      h,(ix+7)                ; HL = fmt
        ld      de,8                    ; first vararg at IX+8
        ld      bc,0
        call    __pf_run                ; IX = _fprintf's frame
        ld      h,b
        ld      l,c
        ld      (__pf_cnt),hl           ; save count
        ld      hl,(pf_bufptr)
        ld      (hl),0                  ; NUL-terminate
        ; _write(fp, __pf_fbuf, count)
        ld      hl,(__pf_cnt)
        push    hl                      ; count
        ld      hl,__pf_fbuf
        push    hl                      ; buf
        ld      l,(ix+4)
        ld      h,(ix+5)
        push    hl                      ; fp
        call    _write
        ex      de,hl
        ld      hl,6
        add     hl,sp
        ld      sp,hl                   ; clean 3 args
        ld      hl,(__pf_cnt)           ; return char count
        pop     de
        pop     bc
        pop     ix
        ret

fpcn:
        ld      hl,0
        ld      (pf_sink),hl            ; direct console mode
        ld      l,(ix+6)
        ld      h,(ix+7)                ; HL = fmt
        ld      de,8
        ld      bc,0
        call    __pf_run
        ld      h,b
        ld      l,c
        pop     de
        pop     bc
        pop     ix
        ret

; ============================================================
; _puts(str)    write str + '\n' to stdout.
; ============================================================
        public  _puts
_puts:
        push    ix
        ld      ix,0
        add     ix,sp
        ld      l,(ix+4)
        ld      h,(ix+5)                ; str
puts_loop:
        ld      a,(hl)
        or      a
        jr      z,puts_nl
        ld      e,a
        call    __conout
        inc     hl
        jr      puts_loop
puts_nl:
        ld      e,0ah
        call    __conout                ; '\n' (with CR+LF translation)
        ld      hl,0
        pop     ix
        ret

; ============================================================
; _fopen(path, mode)
; path @ IX+4/5, mode @ IX+6/7
; Returns HL = FILE* (fd 3..6) or HL = 0 on failure.
; ============================================================
        public  _fopen
_fopen:
        push    ix
        ld      ix,0
        add     ix,sp
        ld      l,(ix+6)
        ld      h,(ix+7)
        ld      a,(hl)                  ; first char of mode
        ld      hl,0
        cp      'r'
        jr      z,fo_doit               ; flags=0: open existing
        ld      hl,0240h
        cp      'w'
        jr      z,fo_doit               ; flags=O_CREAT|O_TRUNC
        ld      hl,0040h                ; "a" or other: O_CREAT only
fo_doit:
        push    hl                      ; flags (second arg to _open)
        ld      l,(ix+4)
        ld      h,(ix+5)
        push    hl                      ; path (first arg)
        call    _open
        pop     de
        pop     de                      ; clean 4 bytes
        ld      a,h
        cp      0FFh
        jr      z,fo_fail               ; _open returned -1
        ; Clear EOF and error flags for the new slot
        push    hl                      ; save fd
        ld      a,l
        sub     FIRSTFD
        ld      e,a
        ld      d,0
        ld      hl,__fdeof
        add     hl,de
        xor     a
        ld      (hl),a
        ld      hl,__fderr
        add     hl,de
        ld      (hl),a
        ; Initialize file position to zero for this slot
        ld      hl,__fdoff
        add     hl,de           ; HL = __fdoff + slot
        add     hl,de           ; HL = __fdoff + slot*2
        add     hl,de           ; HL = __fdoff + slot*3
        add     hl,de           ; HL = __fdoff + slot*4
        xor     a               ; A already 0 but be explicit
        ld      (hl),a
        inc     hl
        ld      (hl),a
        inc     hl
        ld      (hl),a
        inc     hl
        ld      (hl),a
        pop     hl                      ; restore fd = FILE*
        pop     ix
        ret
fo_fail:
        ld      hl,0
        pop     ix
        ret

; ============================================================
; _fclose(fp)
; ============================================================
        public  _fclose
_fclose:
        push    ix
        ld      ix,0
        add     ix,sp
        ld      l,(ix+4)
        ld      h,(ix+5)
        push    hl                      ; fp
        call    _close
        pop     de                      ; clean 2 bytes
        pop     ix
        ret                             ; HL = 0 (ok) or -1 (error)

; ============================================================
; __fps(str, fp)
; fp < 3  console output;  fp >= 3  _write to file.
; ============================================================
        public  __fps
__fps:
        push    ix
        ld      ix,0
        add     ix,sp
        ld      a,(ix+6)                ; fp (low byte)
        cp      FIRSTFD
        jr      nc,fputs_file
        ; console path
        ld      l,(ix+4)
        ld      h,(ix+5)
fputs_con:
        ld      a,(hl)
        or      a
        jr      z,fputs_con_done
        ld      e,a
        call    __conout
        inc     hl
        jr      fputs_con
fputs_con_done:
        ld      hl,0
        pop     ix
        ret
fputs_file:
        ; compute strlen(str)
        ld      l,(ix+4)
        ld      h,(ix+5)
        push    hl
        ld      bc,0
fputs_sl:
        ld      a,(hl)
        or      a
        jr      z,fputs_sl_done
        inc     hl
        inc     bc
        jr      fputs_sl
fputs_sl_done:
        pop     hl                      ; str
        ; _write(fp, str, len)
        push    bc                      ; len
        push    hl                      ; str
        ld      l,(ix+6)
        ld      h,(ix+7)
        push    hl                      ; fp
        call    _write
        ex      de,hl
        ld      hl,6
        add     hl,sp
        ld      sp,hl
        ex      de,hl                   ; HL = _write return value
        pop     ix
        ret

; ============================================================
; _fread(buf, size, count, fp)
; IX+4=buf, IX+6=size, IX+8=count, IX+10=fp
; Returns HL = number of items read.
; ============================================================
        public  _fread
_fread:
        push    ix
        ld      ix,0
        add     ix,sp
        ; size == 0 -> 0 items (also avoids divide-by-zero in the item count)
        ld      l,(ix+6)
        ld      h,(ix+7)                ; HL = size
        ld      a,h
        or      l
        jr      z,frd_zero
        ; nbytes = size * count, rejecting 16-bit overflow
        ld      e,(ix+8)
        ld      d,(ix+9)                ; DE = count
        call    __ckmul                 ; HL = size*count; carry set on overflow
        jr      c,frd_zero              ; overflow -> read nothing
        ld      (__frw_nb),hl
        ; _read(fp, buf, nbytes)
        push    hl                      ; nbytes
        ld      l,(ix+4)
        ld      h,(ix+5)
        push    hl                      ; buf
        ld      l,(ix+10)
        ld      h,(ix+11)
        push    hl                      ; fp
        call    _read
        ex      de,hl
        ld      hl,6
        add     hl,sp
        ld      sp,hl
        ex      de,hl                   ; HL = bytes_read
        ; if bytes_read < nbytes  set EOF
        push    hl
        ld      de,(__frw_nb)
        or      a
        sbc     hl,de
        jr      nc,frd_neof
        ld      a,(ix+10)
        sub     FIRSTFD
        jr      c,frd_neof
        ld      h,0
        ld      l,a
        ld      de,__fdeof
        add     hl,de
        ld      (hl),1
frd_neof:
        pop     hl                      ; bytes_read
        ; return bytes_read / size
        ld      e,(ix+6)
        ld      d,(ix+7)
        call    __divu                  ; HL = items read
        pop     ix
        ret
frd_zero:
        ld      hl,0
        pop     ix
        ret

__frw_nb:       dw      0

; ============================================================
; _fwrite(buf, size, count, fp)
; IX+4=buf, IX+6=size, IX+8=count, IX+10=fp
; Returns HL = number of items written.
; ============================================================
        public  _fwrite
_fwrite:
        push    ix
        ld      ix,0
        add     ix,sp
        ; size == 0 -> 0 items (also avoids divide-by-zero in the item count)
        ld      l,(ix+6)
        ld      h,(ix+7)
        ld      a,h
        or      l
        jr      z,fwr_zero
        ; nbytes = size * count, rejecting 16-bit overflow
        ld      e,(ix+8)
        ld      d,(ix+9)
        call    __ckmul                 ; HL = size*count; carry set on overflow
        jr      c,fwr_zero              ; overflow -> write nothing
        ; _write(fp, buf, nbytes)
        push    hl                      ; nbytes
        ld      l,(ix+4)
        ld      h,(ix+5)
        push    hl                      ; buf
        ld      l,(ix+10)
        ld      h,(ix+11)
        push    hl                      ; fp
        call    _write
        ex      de,hl
        ld      hl,6
        add     hl,sp
        ld      sp,hl
        ex      de,hl                   ; HL = bytes_written
        ; return bytes_written / size
        ld      e,(ix+6)
        ld      d,(ix+7)
        call    __divu
        pop     ix
        ret
fwr_zero:
        ld      hl,0
        pop     ix
        ret

; ============================================================
; _fseek(fp, offset, whence)    delegates to _lseek; clears EOF.
; ============================================================
        public  _fseek
_fseek:
        push    ix
        ld      ix,0
        add     ix,sp

        ; int fseek(FILE *fp, long offset, int whence)
        ; ix+4/5   fp/fd
        ; ix+6..9  offset, low word then high word
        ; ix+10/11 whence
        ;
        ; Call long lseek(int fd, long offset, int whence).
        ld      l,(ix+10)
        ld      h,(ix+11)
        push    hl                      ; whence

        ld      l,(ix+8)
        ld      h,(ix+9)
        push    hl                      ; offset high word

        ld      l,(ix+6)
        ld      h,(ix+7)
        push    hl                      ; offset low word

        ld      l,(ix+4)
        ld      h,(ix+5)
        push    hl                      ; fp/fd

        call    _lseek

        ; Pop 8 bytes of arguments.
        push    de
        push    hl
        ld      hl,8
        add     hl,sp
        ld      sp,hl
        pop     hl
        pop     de

        ; lseek failure is -1L == DE:HL all ones.
        ld      a,h
        cp      0ffh
        jr      nz,fseek_ok_clear
        ld      a,l
        cp      0ffh
        jr      nz,fseek_ok_clear
        ld      a,d
        cp      0ffh
        jr      nz,fseek_ok_clear
        ld      a,e
        cp      0ffh
        jr      nz,fseek_ok_clear
        jr      fseek_bad

fseek_ok_clear:
        ; clear EOF flag
        ld      a,(ix+4)
        sub     FIRSTFD
        jr      c,fseek_ok
        ld      h,0
        ld      l,a
        ld      de,__fdeof
        add     hl,de
        ld      (hl),0
fseek_ok:
        ld      hl,0
        pop     ix
        ret
fseek_bad:
        ld      hl,0FFFFh
        pop     ix
        ret


; ============================================================
; _ftell(fp)    returns current file position (low 16 bits).
; ============================================================
        public  _ftell
_ftell:
        push    ix
        ld      ix,0
        add     ix,sp
        ld      a,(ix+4)
        sub     FIRSTFD
        jr      c,ftell_bad
        cp      NFILES
        jr      nc,ftell_bad
        ld      (__slot),a
        call    __offp                  ; HL  32-bit offset table entry
        ld      e,(hl)
        inc     hl
        ld      d,(hl)                  ; DE = low 16 bits of file position
        inc     hl
        ld      a,(hl)
        inc     hl
        ld      h,(hl)
        ld      l,a                     ; HL = high 16 bits of file position
        ex      de,hl                   ; HL = low 16 bits, DE = high 16 bits
        pop     ix
        ret
ftell_bad:
        ld      hl,0FFFFh
        ld      de,0FFFFh
        pop     ix
        ret

; ============================================================
; _rewind(fp)    seek to 0, clear EOF.
; ============================================================
        public  _rewind
_rewind:
        push    ix
        ld      ix,0
        add     ix,sp
        ; rewind(fp) == (void)lseek(fd, 0L, SEEK_SET).  offset is a 32-bit long,
        ; so it must be pushed as two words; pushing a single word (as an
        ; earlier version did) misaligned the frame so _lseek read a garbage
        ; whence, fell through to EINVAL, and never moved the file position.
        ld      hl,0
        push    hl                      ; whence = 0 (SEEK_SET)
        push    hl                      ; offset high word = 0
        push    hl                      ; offset low word = 0
        ld      l,(ix+4)
        ld      h,(ix+5)
        push    hl                      ; fp
        call    _lseek
        ; Pop 8 bytes of arguments (return value unused: rewind is void).
        ld      hl,8
        add     hl,sp
        ld      sp,hl
        ; clear EOF flag
        ld      a,(ix+4)
        sub     FIRSTFD
        jr      c,rewind_ret
        ld      h,0
        ld      l,a
        ld      de,__fdeof
        add     hl,de
        ld      (hl),0
rewind_ret:
        ld      hl,0
        pop     ix
        ret

; ============================================================
; _feof(fp)    returns HL=1 if EOF, HL=0 otherwise.
; ============================================================
        public  _feof
_feof:
        push    ix
        ld      ix,0
        add     ix,sp
        ld      a,(ix+4)
        sub     FIRSTFD
        jr      c,feof_no
        cp      NFILES
        jr      nc,feof_no
        ld      h,0
        ld      l,a
        ld      de,__fdeof
        add     hl,de
        ld      a,(hl)
        ld      l,a
        ld      h,0
        pop     ix
        ret
feof_no:
        ld      hl,0
        pop     ix
        ret

; ============================================================
; _ferror(fp)    returns HL=1 if error, HL=0 otherwise.
; ============================================================
        public  _ferror
_ferror:
        push    ix
        ld      ix,0
        add     ix,sp
        ld      a,(ix+4)
        sub     FIRSTFD
        jr      c,ferr_no
        cp      NFILES
        jr      nc,ferr_no
        ld      h,0
        ld      l,a
        ld      de,__fderr
        add     hl,de
        ld      a,(hl)
        ld      l,a
        ld      h,0
        pop     ix
        ret
ferr_no:
        ld      hl,0
        pop     ix
        ret

; ============================================================
; scanf family  (small non-floating C89 subset)
;
; Supports: whitespace/literal matching, %%, assignment suppression '*',
; field widths, h/l length modifiers, and conversions:
;   %d %i %u %x %X %o %c %s
;
; Deliberately not implemented here: floating input, scansets, %n, %p.
; All three public entry points share __scan_run.  IX stays bound to the
; public caller's frame so varargs can be read by byte offset, just like
; the printf engine above.
; ============================================================
        public  _scanf
_scanf:
        push    ix
        ld      ix,0
        add     ix,sp
        xor     a
        inc     a
        ld      (sc_kind),a             ; 1 = FILE/console source
        ld      hl,0
        ld      (sc_fp),hl              ; stdin fd
        ld      l,(ix+4)
        ld      h,(ix+5)                ; format
        ld      de,6                    ; first vararg offset
        call    __scan_run
        pop     ix
        ret

        public  _sscanf
_sscanf:
        push    ix
        ld      ix,0
        add     ix,sp
        xor     a
        ld      (sc_kind),a             ; 0 = string source
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      (sc_src),hl
        ld      l,(ix+6)
        ld      h,(ix+7)                ; format
        ld      de,8                    ; first vararg offset
        call    __scan_run
        pop     ix
        ret

        public  _fscanf
_fscanf:
        push    ix
        ld      ix,0
        add     ix,sp
        xor     a
        inc     a
        ld      (sc_kind),a             ; 1 = FILE/console source
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      (sc_fp),hl
        ld      l,(ix+6)
        ld      h,(ix+7)                ; format
        ld      de,8                    ; first vararg offset
        call    __scan_run
        pop     ix
        ret

__scan_run:
        ld      (sc_fmt),hl
        ld      (sc_argoff),de
        ld      hl,0
        ld      (sc_count),hl
        ld      a,(sc_kind)
        or      a
        jr      nz,sc_init_file_pushback
        xor     a
        ld      (sc_ungot),a
        jr      sc_init_done
sc_init_file_pushback:
        ld      a,(sc_ungot)
        or      a
        jr      z,sc_init_done
        ld      a,(sc_ukind)
        cp      1
        jr      nz,sc_init_clear_pushback
        ld      hl,(sc_ufp)
        ld      de,(sc_fp)
        or      a
        sbc     hl,de
        ld      a,h
        or      l
        jr      z,sc_init_done
sc_init_clear_pushback:
        xor     a
        ld      (sc_ungot),a
sc_init_done:

sc_loop:
        ld      hl,(sc_fmt)
        ld      a,(hl)
        or      a
        jp      z,sc_done
        inc     hl
        ld      (sc_fmt),hl

        call    sc_is_space
        jp      c,sc_fmt_space

        cp      '%'
        jp      z,sc_percent

        ld      b,a
        call    sc_get
        jp      c,sc_input_fail
        cp      b
        jp      z,sc_loop
        call    sc_unget
        jp      sc_match_fail

sc_fmt_space:
        ld      hl,(sc_fmt)
sc_fmt_space_loop:
        ld      a,(hl)
        call    sc_is_space
        jr      nc,sc_fmt_space_done
        inc     hl
        jr      sc_fmt_space_loop
sc_fmt_space_done:
        ld      (sc_fmt),hl
        call    sc_skip_input_space
        jp      sc_loop

sc_percent:
        ld      a,1
        ld      (sc_assign),a
        xor     a
        ld      (sc_long),a
        ld      hl,0ffffh
        ld      (sc_width),hl

        call    sc_fmt_get
        or      a
        jp      z,sc_done

        cp      '%'
        jp      z,sc_match_percent

        cp      '*'
        jr      nz,sc_width_start
        xor     a
        ld      (sc_assign),a
        call    sc_fmt_get
        or      a
        jp      z,sc_done

sc_width_start:
        cp      '0'
        jr      c,sc_length_start
        cp      '9'+1
        jr      nc,sc_length_start
        ld      hl,0
        ld      (sc_width),hl
sc_width_loop:
        sub     '0'
        ld      (sc_digit),a
        ld      hl,(sc_width)
        add     hl,hl                   ; 2*w
        ld      d,h
        ld      e,l
        add     hl,hl                   ; 4*w
        add     hl,hl                   ; 8*w
        add     hl,de                   ; 10*w
        ld      a,(sc_digit)
        ld      e,a
        ld      d,0
        add     hl,de
        ld      (sc_width),hl
        call    sc_fmt_get
        cp      '0'
        jr      c,sc_length_start
        cp      '9'+1
        jr      c,sc_width_loop

sc_length_start:
        cp      'h'
        jr      nz,sc_check_long
        call    sc_fmt_get              ; short == int on dcc
        jr      sc_dispatch
sc_check_long:
        cp      'l'
        jr      nz,sc_dispatch
        ld      a,1
        ld      (sc_long),a
        call    sc_fmt_get

sc_dispatch:
        cp      'd'
        jp      z,sc_conv_d
        cp      'i'
        jp      z,sc_conv_i
        cp      'u'
        jp      z,sc_conv_u
        cp      'x'
        jp      z,sc_conv_x
        cp      'X'
        jp      z,sc_conv_x
        cp      'o'
        jp      z,sc_conv_o
        cp      'c'
        jp      z,sc_conv_c
        cp      's'
        jp      z,sc_conv_s
        jp      sc_match_fail

sc_match_percent:
        call    sc_get
        jp      c,sc_input_fail
        cp      '%'
        jp      z,sc_loop
        call    sc_unget
        jp      sc_match_fail

sc_conv_d:
        ld      a,10
        ld      (sc_base),a
        xor     a
        ld      (sc_auto),a
        jp      sc_scan_number
sc_conv_u:
        ld      a,10
        ld      (sc_base),a
        xor     a
        ld      (sc_auto),a
        jp      sc_scan_number
sc_conv_o:
        ld      a,8
        ld      (sc_base),a
        xor     a
        ld      (sc_auto),a
        jp      sc_scan_number
sc_conv_x:
        ld      a,16
        ld      (sc_base),a
        xor     a
        ld      (sc_auto),a
        jp      sc_scan_number
sc_conv_i:
        ld      a,10
        ld      (sc_base),a
        ld      a,1
        ld      (sc_auto),a
        jp      sc_scan_number

sc_conv_s:
        call    sc_skip_input_space
        jp      c,sc_input_fail
        xor     a
        ld      (sc_ndig),a
        ld      a,(sc_assign)
        or      a
        jr      z,sc_s_loop
        call    sc_next_arg
        ld      (sc_dest),hl
sc_s_loop:
        call    sc_get_w
        jr      c,sc_s_end_check
        ld      (sc_ch),a
        call    sc_is_space
        jr      nc,sc_s_store
        ld      a,(sc_ch)
        call    sc_unget
        jr      sc_s_end_check
sc_s_store:
        ld      a,(sc_assign)
        or      a
        jr      z,sc_s_count
        ld      a,(sc_ch)
        call    sc_store_char
sc_s_count:
        ld      a,(sc_ndig)
        inc     a
        ld      (sc_ndig),a
        ld      hl,(sc_width)
        ld      a,h
        or      l
        jr      nz,sc_s_loop
sc_s_end_check:
        ld      a,(sc_ndig)
        or      a
        jp      z,sc_input_fail
        ld      a,(sc_assign)
        or      a
        jp      z,sc_loop
        xor     a
        call    sc_store_char
        call    sc_inc_count
        jp      sc_loop

sc_conv_c:
        ld      hl,(sc_width)
        ld      a,h
        cp      0ffh
        jr      nz,sc_c_width_known
        ld      a,l
        cp      0ffh
        jr      nz,sc_c_width_known
        ld      hl,1
        ld      (sc_width),hl
sc_c_width_known:
        xor     a
        ld      (sc_ndig),a
        ld      a,(sc_assign)
        or      a
        jr      z,sc_c_loop
        call    sc_next_arg
        ld      (sc_dest),hl
sc_c_loop:
        ld      hl,(sc_width)
        ld      a,h
        or      l
        jr      z,sc_c_done
        call    sc_get_w
        jp      c,sc_input_fail
        ld      (sc_ch),a
        ld      a,(sc_assign)
        or      a
        jr      z,sc_c_count
        ld      a,(sc_ch)
        call    sc_store_char
sc_c_count:
        ld      a,(sc_ndig)
        inc     a
        ld      (sc_ndig),a
        jr      sc_c_loop
sc_c_done:
        ld      a,(sc_assign)
        or      a
        jp      z,sc_loop
        call    sc_inc_count
        jp      sc_loop

sc_scan_number:
        call    sc_skip_input_space
        jp      c,sc_input_fail
        ld      hl,0
        ld      (sc_val_l),hl
        ld      (sc_val_h),hl
        xor     a
        ld      (sc_sign),a
        ld      (sc_ndig),a

        call    sc_get_w
        jp      c,sc_input_fail
        cp      '-'
        jr      nz,sc_num_plus
        ld      a,1
        ld      (sc_sign),a
        call    sc_get_w
        jp      c,sc_match_fail
        jr      sc_num_after_sign
sc_num_plus:
        cp      '+'
        jr      nz,sc_num_after_sign
        call    sc_get_w
        jp      c,sc_match_fail

sc_num_after_sign:
        ld      b,a                     ; first candidate char
        ld      a,(sc_auto)
        or      a
        jr      z,sc_num_not_auto
        ld      a,b
        cp      '0'
        jr      nz,sc_num_auto_decimal
        ld      a,8
        ld      (sc_base),a
        ld      hl,(sc_width)
        ld      a,h
        or      l
        jr      z,sc_num_process_zero
        call    sc_get_w
        jr      c,sc_num_process_zero
        cp      'x'
        jr      z,sc_num_prefix_hex
        cp      'X'
        jr      z,sc_num_prefix_hex
        call    sc_unget
sc_num_process_zero:
        ld      a,'0'
        jr      sc_num_have_char
sc_num_auto_decimal:
        ld      a,10
        ld      (sc_base),a
        ld      a,b
        jr      sc_num_have_char

sc_num_not_auto:
        ld      a,(sc_base)
        cp      16
        jr      nz,sc_num_use_b
        ld      a,b
        cp      '0'
        jr      nz,sc_num_use_b
        ld      hl,(sc_width)
        ld      a,h
        or      l
        jr      z,sc_num_process_zero
        call    sc_get_w
        jr      c,sc_num_process_zero
        cp      'x'
        jr      z,sc_num_prefix_hex
        cp      'X'
        jr      z,sc_num_prefix_hex
        call    sc_unget
        ld      a,'0'
        jr      sc_num_have_char
sc_num_use_b:
        ld      a,b
        jr      sc_num_have_char

sc_num_prefix_hex:
        ld      a,16
        ld      (sc_base),a
        call    sc_get_w
        jp      c,sc_match_fail

sc_num_have_char:
        ld      (sc_ch),a
        call    sc_digit_value
        jr      nc,sc_num_digit_ok
        ld      a,(sc_ch)
        call    sc_unget
        jr      sc_num_end_check
sc_num_digit_ok:
        ld      (sc_digit),a
        call    sc_muladd_digit
        ld      a,(sc_ndig)
        inc     a
        ld      (sc_ndig),a
        ld      hl,(sc_width)
        ld      a,h
        or      l
        jr      z,sc_num_end_check
        call    sc_get_w
        jr      nc,sc_num_have_char

sc_num_end_check:
        ld      a,(sc_ndig)
        or      a
        jp      z,sc_match_fail
        ld      a,(sc_sign)
        or      a
        call    nz,sc_neg_val
        ld      a,(sc_assign)
        or      a
        jp      z,sc_loop
        call    sc_next_arg
        ld      (sc_dest),hl
        ld      a,(sc_long)
        or      a
        jr      z,sc_store_num16
        ld      hl,(sc_dest)
        ld      de,(sc_val_l)
        ld      (hl),e
        inc     hl
        ld      (hl),d
        inc     hl
        ld      de,(sc_val_h)
        ld      (hl),e
        inc     hl
        ld      (hl),d
        call    sc_inc_count
        jp      sc_loop
sc_store_num16:
        ld      hl,(sc_dest)
        ld      de,(sc_val_l)
        ld      (hl),e
        inc     hl
        ld      (hl),d
        call    sc_inc_count
        jp      sc_loop

sc_done:
        ld      hl,(sc_count)
        ret
sc_match_fail:
        ld      hl,(sc_count)
        ret
sc_input_fail:
        ld      hl,(sc_count)
        ld      a,h
        or      l
        ret     nz
        ld      hl,0ffffh
        ret

sc_fmt_get:
        ld      hl,(sc_fmt)
        ld      a,(hl)
        inc     hl
        ld      (sc_fmt),hl
        ret

sc_get_w:
        ld      hl,(sc_width)
        ld      a,h
        or      l
        jr      z,sc_get_w_fail
        dec     hl
        ld      (sc_width),hl
        call    sc_get
        ret
sc_get_w_fail:
        scf
        ret

sc_get:
        ld      a,(sc_ungot)
        or      a
        jr      z,sc_get_source
        xor     a
        ld      (sc_ungot),a
        ld      a,(sc_unch)
        or      a
        ret
sc_get_source:
        ld      a,(sc_kind)
        or      a
        jr      nz,sc_get_file
        ld      hl,(sc_src)
        ld      a,(hl)
        or      a
        jr      z,sc_get_eof
        inc     hl
        ld      (sc_src),hl
        or      a
        ret
sc_get_file:
        ld      hl,(sc_fp)
        push    hl
        call    __getc
        pop     bc
        ld      a,h
        cp      0ffh
        jr      nz,sc_get_file_ok
        ld      a,l
        cp      0ffh
        jr      z,sc_get_eof
sc_get_file_ok:
        ld      a,l
        or      a
        ret
sc_get_eof:
        scf
        ret

sc_unget:
        ld      (sc_unch),a
        ld      a,(sc_kind)
        ld      (sc_ukind),a
        or      a
        jr      z,sc_unget_set
        ld      hl,(sc_fp)
        ld      (sc_ufp),hl
sc_unget_set:
        ld      a,1
        ld      (sc_ungot),a
        ret

sc_skip_input_space:
        call    sc_get
        ret     c
        call    sc_is_space
        jr      c,sc_skip_input_space
        call    sc_unget
        or      a
        ret

sc_is_space:
        cp      ' '
        jr      z,sc_space_yes
        cp      9
        jr      z,sc_space_yes
        cp      10
        jr      z,sc_space_yes
        cp      11
        jr      z,sc_space_yes
        cp      12
        jr      z,sc_space_yes
        cp      13
        jr      z,sc_space_yes
        or      a
        ret
sc_space_yes:
        scf
        ret

sc_digit_value:
        cp      '0'
        jr      c,sc_digit_bad
        cp      '9'+1
        jr      c,sc_digit_dec
        cp      'A'
        jr      c,sc_digit_lower
        cp      'F'+1
        jr      c,sc_digit_upper
sc_digit_lower:
        cp      'a'
        jr      c,sc_digit_bad
        cp      'f'+1
        jr      nc,sc_digit_bad
        sub     'a'-10
        jr      sc_digit_check_base
sc_digit_upper:
        sub     'A'-10
        jr      sc_digit_check_base
sc_digit_dec:
        sub     '0'
sc_digit_check_base:
        ld      c,a
        ld      a,(sc_base)
        cp      c
        jr      z,sc_digit_bad
        jr      c,sc_digit_bad
        ld      a,c
        or      a
        ret
sc_digit_bad:
        scf
        ret

sc_muladd_digit:
        ld      hl,0
        ld      (sc_tmp_l),hl
        ld      (sc_tmp_h),hl
        ld      a,(sc_base)
        ld      b,a
sc_muladd_loop:
        ld      hl,(sc_tmp_l)
        ld      de,(sc_val_l)
        add     hl,de
        ld      (sc_tmp_l),hl
        ld      hl,(sc_tmp_h)
        ld      de,(sc_val_h)
        adc     hl,de
        ld      (sc_tmp_h),hl
        djnz    sc_muladd_loop
        ld      hl,(sc_tmp_l)
        ld      (sc_val_l),hl
        ld      hl,(sc_tmp_h)
        ld      (sc_val_h),hl
        ld      hl,(sc_val_l)
        ld      a,(sc_digit)
        ld      e,a
        ld      d,0
        add     hl,de
        ld      (sc_val_l),hl
        ld      hl,(sc_val_h)
        ld      de,0
        adc     hl,de
        ld      (sc_val_h),hl
        ret

sc_neg_val:
        ld      de,(sc_val_l)
        ld      hl,0
        or      a
        sbc     hl,de
        ld      (sc_val_l),hl
        ld      de,(sc_val_h)
        ld      hl,0
        sbc     hl,de
        ld      (sc_val_h),hl
        ret

sc_next_arg:
        ld      hl,(sc_argoff)
        ld      e,l
        ld      d,h
        push    ix
        pop     hl
        add     hl,de
        ld      e,(hl)
        inc     hl
        ld      d,(hl)
        ld      hl,(sc_argoff)
        inc     hl
        inc     hl
        ld      (sc_argoff),hl
        ex      de,hl
        ret

sc_store_char:
        ld      hl,(sc_dest)
        ld      (hl),a
        inc     hl
        ld      (sc_dest),hl
        ret

sc_inc_count:
        ld      hl,(sc_count)
        inc     hl
        ld      (sc_count),hl
        ret

sc_kind:        db      0
sc_ungot:       db      0
sc_unch:        db      0
sc_ukind:       db      0
sc_assign:      db      0
sc_long:        db      0
sc_base:        db      10
sc_auto:        db      0
sc_sign:        db      0
sc_ndig:        db      0
sc_digit:       db      0
sc_ch:          db      0
sc_src:         dw      0
sc_fp:          dw      0
sc_ufp:         dw      0
sc_fmt:         dw      0
sc_argoff:      dw      0
sc_count:       dw      0
sc_width:       dw      0
sc_dest:        dw      0
sc_val_l:       dw      0
sc_val_h:       dw      0
sc_tmp_l:       dw      0
sc_tmp_h:       dw      0

; ============================================================
; setjmp / longjmp  (C89)
;
; jmp_buf layout (stored at the address passed as first arg):
;   [0,1] = saved return address (where setjmp "returns" to)
;   [2,3] = saved SP  (= IX+4 at time of setjmp call, i.e. the SP
;            after ret from setjmp, pointing at the env argument)
;   [4,5] = saved IX  (caller's frame pointer)
;   [6,7] = padding
;
; Z80/dcc calling convention at entry to _setjmp:
;   (IX+0,1) = old IX pushed by prologue
;   (IX+2,3) = return address
;   (IX+4,5) = env pointer (first argument = &jmp_buf)
; ============================================================

        public  _setjmp
_setjmp:
        push    ix
        ld      ix,0
        add     ix,sp
        ; HL = env pointer (jmp_buf address)
        ld      l,(ix+4)
        ld      h,(ix+5)

        ; env[0,1] = return address
        ld      a,(ix+2)
        ld      (hl),a
        inc     hl
        ld      a,(ix+3)
        ld      (hl),a
        inc     hl

        ; env[2,3] = saved SP = IX + 4
        ;   (after ret from _setjmp, SP will point to env arg slot = IX+4)
        push    ix
        pop     de              ; DE = current IX value
        ld      a,e
        add     a,4
        ld      (hl),a
        inc     hl
        ld      a,d
        adc     a,0
        ld      (hl),a
        inc     hl

        ; env[4,5] = saved IX (caller's frame pointer = old IX at (IX+0,1))
        ld      a,(ix+0)
        ld      (hl),a
        inc     hl
        ld      a,(ix+1)
        ld      (hl),a

        ; return 0
        ld      hl,0
        ld      sp,ix
        pop     ix
        ret

; ============================================================
        public  _longjmp
_longjmp:
        push    ix
        ld      ix,0
        add     ix,sp
        ; (IX+4,5) = env pointer
        ; (IX+6,7) = val (must not be 0; if 0 return 1 per C standard)

        ; Get return value, ensure != 0
        ld      l,(ix+6)
        ld      h,(ix+7)
        ld      a,h
        or      l
        jr      nz,lj_nonzero
        ld      hl,1
lj_nonzero:
        ld      (lj_val),hl

        ; Load env pointer
        ld      l,(ix+4)
        ld      h,(ix+5)

        ; Read env[0,1] = saved return address
        ld      a,(hl)
        ld      (lj_retaddr),a
        inc     hl
        ld      a,(hl)
        ld      (lj_retaddr+1),a
        inc     hl

        ; Read env[2,3] = saved SP
        ld      a,(hl)
        ld      (lj_sp),a
        inc     hl
        ld      a,(hl)
        ld      (lj_sp+1),a
        inc     hl

        ; Read env[4,5] = saved IX
        ld      a,(hl)
        ld      (lj_ix),a
        inc     hl
        ld      a,(hl)
        ld      (lj_ix+1),a

        ; Restore SP (points to env arg slot in original setjmp call frame)
        ld      hl,(lj_sp)
        ld      sp,hl

        ; Restore IX (caller's frame pointer)
        ld      hl,(lj_ix)
        push    hl
        pop     ix

        ; Push return address so RET jumps to setjmp call site
        ld      hl,(lj_retaddr)
        push    hl

        ; Load return value into HL
        ld      hl,(lj_val)

        ; Jump to setjmp call site  HL is the return value
        ret

lj_val:         dw      0
lj_retaddr:     dw      0
lj_sp:          dw      0
lj_ix:          dw      0



; ============================================================
; Minimal CP/M dirent API
;
; Supports:
;   DIR *opendir(const char *path);     ; macro -> dopn
;   struct dirent *readdir(DIR *dirp);  ; macro -> drd
;   int closedir(DIR *dirp);         ; macro -> dcls
;   void perror(const char *s);
;
; This is intentionally small and CP/M-2.2-oriented.  opendir("."),
; opendir("*.*"), and opendir("A:") enumerate all files on the selected
; drive.  Other path strings are accepted but treated as wildcard scans;
; CP/M has no hierarchical directories.
; ============================================================
        public  _dopn
_dopn:
        push    ix
        ld      ix,0
        add     ix,sp

        ; Clear FCB.
        ld      hl,__drfcb
        ld      de,__drfcb+1
        ld      bc,35
        ld      (hl),0
        ldir

        ; Optional drive letter: "A:" -> 1, "B:" -> 2, ...
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      a,(hl)
        or      a
        jr      z,__drod0
        inc     hl
        ld      b,(hl)
        dec     hl
        ld      a,b
        cp      ':'
        jr      nz,__drod0
        ld      a,(hl)
        cp      'a'
        jr      c,__drod1
        cp      'z'+1
        jr      nc,__drod1
        sub     20h
__drod1:
        cp      'A'
        jr      c,__drod0
        cp      'Z'+1
        jr      nc,__drod0
        sub     'A'-1
        ld      (__drfcb),a
__drod0:

        ; Wildcard name/ext: ???????????
        ld      hl,__drfcb+1
        ld      b,11
__drofq:
        ld      (hl),'?'
        inc     hl
        djnz    __drofq

        ; Set DMA buffer.
        ld      c,26
        ld      de,__drdma
        call    5

        ; Find first.
        ld      c,17
        ld      de,__drfcb
        call    5
        cp      0ffh
        jr      nz,__droky
        ld      hl,0
        pop     ix
        ret

__droky:
        ld      (__dridx),a
        xor     a
        ld      (__drdn),a
        inc     a
        ld      (__drhav),a
        ld      hl,__dirob
        pop     ix
        ret

        public  _drd
_drd:
        push    ix
        ld      ix,0
        add     ix,sp

        ; NULL DIR* or done -> NULL.
        ld      a,(ix+4)
        or      (ix+5)
        jr      z,__drnul
        ld      a,(__drdn)
        or      a
        jr      nz,__drnul

        ; If opendir already has a current result, consume it; otherwise
        ; ask BDOS for the next result.
        ld      a,(__drhav)
        or      a
        jr      nz,__drcur

        ; A read()/write() since opendir may have repointed the BDOS DMA at a
        ; caller buffer (the direct-DMA file I/O path does this), so search-next
        ; would fill that buffer instead of __drdma.  Restore our directory DMA.
        ld      c,26
        ld      de,__drdma
        call    5

        ld      c,18
        ld      de,__drfcb
        call    5
        cp      0ffh
        jr      nz,__drnxt
        ld      (__drdn),a
__drnul:
        ld      hl,0
        pop     ix
        ret

__drnxt:
        ld      (__dridx),a
__drcur:
        xor     a
        ld      (__drhav),a

        ; HL = __drdma + result_index * 32
        ld      a,(__dridx)
        add     a,a
        add     a,a
        add     a,a
        add     a,a
        add     a,a
        ld      e,a
        ld      d,0
        ld      hl,__drdma
        add     hl,de
        inc     hl              ; skip user byte; now at 8-byte name
        ld      de,__drent

        ; Copy base name, trimming spaces/high attribute bits.
        ld      b,8
__drnam:
        ld      a,(hl)
        and     7fh
        cp      ' '
        jr      z,__drnsp
        ld      (de),a
        inc     de
__drnsp:
        inc     hl
        djnz    __drnam

        ; Extension: if first ext char is non-space, add '.' and copy the
        ; non-space extension chars.
        ld      a,(hl)
        and     7fh
        cp      ' '
        jr      z,__drter
        ld      a,'.'
        ld      (de),a
        inc     de
        ld      b,3
__drext:
        ld      a,(hl)
        and     7fh
        cp      ' '
        jr      z,__dresp
        ld      (de),a
        inc     de
__dresp:
        inc     hl
        djnz    __drext

__drter:
        xor     a
        ld      (de),a
        ld      hl,__drent
        pop     ix
        ret

        public  _dcls
_dcls:
        ld      a,1
        ld      (__drdn),a
        ld      hl,0
        ret

        public  _perror
_perror:
        push    ix
        ld      ix,0
        add     ix,sp
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      a,h
        or      l
        jr      z,__prmsg
__prlp:
        ld      a,(hl)
        or      a
        jr      z,__prcol
        ld      e,a
        call    __conout
        inc     hl
        jr      __prlp
__prcol:
        ld      e,':'
        call    __conout
        ld      e,' '
        call    __conout
__prmsg:
        ld      hl,(_errno)
        push    hl
        call    _strerror
        pop     de
__prlp2:
        ld      a,(hl)
        or      a
        jr      z,__prend
        ld      e,a
        call    __conout
        inc     hl
        jr      __prlp2
__prend:
        ld      e,0ah
        call    __conout
        ld      hl,0
        pop     ix
        ret


; Opaque DIR object, FCB, DMA buffer, and one static dirent.  This API is
; deliberately non-reentrant, matching the tiny CP/M runtime style.
__dirob:        db      0
__dridx:        db      0
__drhav:        db      0
__drdn:         db      1
__drfcb:        ds      36
__drdma:        ds      128
__drent:        ds      13



; ---------------------------------------------------------------------------
; IEEE-754 single precision float core, phase 1.
;
; ABI convention for opaque float values matches dcc's existing 32-bit value
; convention: DE:HL holds the raw IEEE bits, with HL = low word and DE = high
; word.  In memory this is little-endian: byte0, byte1, byte2, byte3.
;
; These helpers intentionally do not implement arithmetic yet.  They provide
; classification/sign primitives and real IEEE-aware equality/inequality that
; later arithmetic/conversion routines can build on.  Kept as separate PUBLIC
; blocks so dccrtlstrip can remove them when no float operation references them.
; ---------------------------------------------------------------------------

        public  __fzro
__fzro:
        ; input DE:HL raw float. return HL=1 if +/-0.0, else 0.
        ld      a,d
        and     7fh
        or      e
        or      h
        or      l
        jp      z,__fzr1
        ld      hl,0
        ret
__fzr1:
        ld      hl,1
        ret

        public  __fnan
__fnan:
        ; input DE:HL raw float. return HL=1 if NaN, else 0.
        ld      a,d
        and     7fh
        cp      7fh
        jp      nz,__fnn0
        ld      a,e
        and     80h
        jp      z,__fnn0
        ld      a,e
        and     7fh
        or      h
        or      l
        jp      z,__fnn0
        ld      hl,1
        ret
__fnn0:
        ld      hl,0
        ret

        public  __finf
__finf:
        ; input DE:HL raw float. return HL=1 if +/-Inf, else 0.
        ld      a,d
        and     7fh
        cp      7fh
        jp      nz,__fif0
        ld      a,e
        and     80h
        jp      z,__fif0
        ld      a,e
        and     7fh
        or      h
        or      l
        jp      nz,__fif0
        ld      hl,1
        ret
__fif0:
        ld      hl,0
        ret

        public  __fabs
__fabs:
        ; input/output DE:HL raw float. clear sign bit.
        ld      a,d
        and     7fh
        ld      d,a
        ret

        public  __fchs
__fchs:
        ; input/output DE:HL raw float. toggle sign bit.
        ld      a,d
        xor     80h
        ld      d,a
        ret

        public  __fsgn
__fsgn:
        ; input DE:HL raw float. return HL=1 if sign bit set, else 0.
        bit     7,d
        jp      nz,__fsg1
        ld      hl,0
        ret
__fsg1:
        ld      hl,1
        ret

        public  __feq
__feq:
        ; int __feq(float a, float b)
        ; IEEE-aware equality for phase 1: NaN compares false, +0 == -0.
        push    ix
        ld      ix,0
        add     ix,sp

        ; if a is NaN, false
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      e,(ix+6)
        ld      d,(ix+7)
        call    __fnan
        ld      a,h
        or      l
        jp      nz,__feq0

        ; if b is NaN, false
        ld      l,(ix+8)
        ld      h,(ix+9)
        ld      e,(ix+10)
        ld      d,(ix+11)
        call    __fnan
        ld      a,h
        or      l
        jp      nz,__feq0

        ; if a is zero, true only when b is also zero
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      e,(ix+6)
        ld      d,(ix+7)
        call    __fzro
        ld      a,h
        or      l
        jp      z,__feq_cmp
        ld      l,(ix+8)
        ld      h,(ix+9)
        ld      e,(ix+10)
        ld      d,(ix+11)
        call    __fzro
        ld      a,h
        or      l
        jp      nz,__feq1
        jp      __feq0

__feq_cmp:
        ; raw bit compare for all non-zero, non-NaN values
        ld      a,(ix+4)
        cp      (ix+8)
        jp      nz,__feq0
        ld      a,(ix+5)
        cp      (ix+9)
        jp      nz,__feq0
        ld      a,(ix+6)
        cp      (ix+10)
        jp      nz,__feq0
        ld      a,(ix+7)
        cp      (ix+11)
        jp      nz,__feq0
__feq1:
        ld      hl,1
        ld      sp,ix
        pop     ix
        ret
__feq0:
        ld      hl,0
        ld      sp,ix
        pop     ix
        ret

        public  __fneq
__fneq:
        ; int __fneq(float a, float b) -- logical inverse of __feq.
        push    ix
        ld      ix,0
        add     ix,sp

        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      e,(ix+6)
        ld      d,(ix+7)
        call    __fnan
        ld      a,h
        or      l
        jp      nz,__fnq1

        ld      l,(ix+8)
        ld      h,(ix+9)
        ld      e,(ix+10)
        ld      d,(ix+11)
        call    __fnan
        ld      a,h
        or      l
        jp      nz,__fnq1

        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      e,(ix+6)
        ld      d,(ix+7)
        call    __fzro
        ld      a,h
        or      l
        jp      z,__fnq_cmp
        ld      l,(ix+8)
        ld      h,(ix+9)
        ld      e,(ix+10)
        ld      d,(ix+11)
        call    __fzro
        ld      a,h
        or      l
        jp      nz,__fnq0
        jp      __fnq1

__fnq_cmp:
        ld      a,(ix+4)
        cp      (ix+8)
        jp      nz,__fnq1
        ld      a,(ix+5)
        cp      (ix+9)
        jp      nz,__fnq1
        ld      a,(ix+6)
        cp      (ix+10)
        jp      nz,__fnq1
        ld      a,(ix+7)
        cp      (ix+11)
        jp      nz,__fnq1
__fnq0:
        ld      hl,0
        ld      sp,ix
        pop     ix
        ret
__fnq1:
        ld      hl,1
        ld      sp,ix
        pop     ix
        ret


; ---------------------------------------------------------------------------
; IEEE-754 single precision ordered comparisons, phase 2.
;
; C-style ordered comparisons return false when either operand is NaN.
; +0.0 and -0.0 compare equal.  For all other values, comparison is done by
; sign first, then raw IEEE magnitude ordering.  This is enough for correct
; < <= > >= without doing any arithmetic.
;
; Calling convention: first arg at IX+4..IX+7, second arg at IX+8..IX+11.
; Return HL=1 for true, HL=0 for false.
; ---------------------------------------------------------------------------

        public  __flt
__flt:
        ; int __flt(float a, float b) -- a < b
        push    ix
        ld      ix,0
        add     ix,sp

        ; Fast path: both positive non-NaN. For positive IEEE singles (sign=0,
        ; exp<255), raw byte ordering matches numeric ordering, so skip NaN/zero
        ; checks and compare directly.
        ld      a,(ix+7)
        ld      b,a
        ld      a,(ix+11)
        or      b               ; both sign bits must be 0
        and     80h
        jp      nz,__flt_slow
        ld      a,(ix+7)
        and     7fh
        cp      7fh
        jp      z,__flt_slow    ; a: D&7F==7F => might be NaN/Inf
        ld      a,(ix+11)
        and     7fh
        cp      7fh
        jp      z,__flt_slow    ; b: D&7F==7F => might be NaN/Inf
        ld      a,(ix+7)
        cp      (ix+11)
        jp      c,__flt1
        jp      nz,__flt0
        ld      a,(ix+6)
        cp      (ix+10)
        jp      c,__flt1
        jp      nz,__flt0
        ld      a,(ix+5)
        cp      (ix+9)
        jp      c,__flt1
        jp      nz,__flt0
        ld      a,(ix+4)
        cp      (ix+8)
        jp      c,__flt1
        jp      __flt0

__flt_slow:
        ; cold path: classify once with the shared ordered comparator.
        ; __fcmps returns A = 0 unordered, 1 a<b, 2 a==b, 3 a>b.
        call    __fcmps
        cp      1
        jp      z,__flt1        ; a < b
        jp      __flt0
__flt1:
        ld      hl,1
        ld      sp,ix
        pop     ix
        ret
__flt0:
        ld      hl,0
        ld      sp,ix
        pop     ix
        ret

        public  __fgt
__fgt:
        ; int __fgt(float a, float b) -- a > b == b < a
        push    ix
        ld      ix,0
        add     ix,sp

        ; Fast path: both positive non-NaN -- a > b iff b_raw < a_raw.
        ld      a,(ix+7)
        ld      b,a
        ld      a,(ix+11)
        or      b
        and     80h
        jp      nz,__fgt_slow
        ld      a,(ix+7)
        and     7fh
        cp      7fh
        jp      z,__fgt_slow
        ld      a,(ix+11)
        and     7fh
        cp      7fh
        jp      z,__fgt_slow
        ld      a,(ix+11)       ; compare b vs a (b < a means a > b)
        cp      (ix+7)
        jp      c,__fgt1
        jp      nz,__fgt0
        ld      a,(ix+10)
        cp      (ix+6)
        jp      c,__fgt1
        jp      nz,__fgt0
        ld      a,(ix+9)
        cp      (ix+5)
        jp      c,__fgt1
        jp      nz,__fgt0
        ld      a,(ix+8)
        cp      (ix+4)
        jp      c,__fgt1
        jp      __fgt0

__fgt_slow:
        ; cold path: a > b is true only for the greater classification.
        call    __fcmps
        cp      3
        jp      z,__fgt1        ; a > b
        jp      __fgt0
__fgt1:
        ld      hl,1
        ld      sp,ix
        pop     ix
        ret
__fgt0:
        ld      hl,0
        ld      sp,ix
        pop     ix
        ret

        public  __fle
__fle:
        ; int __fle(float a, float b) -- a <= b, false if unordered.
        push    ix
        ld      ix,0
        add     ix,sp

        ; Fast path: both positive non-NaN -- a <= b iff a_raw <= b_raw.
        ld      a,(ix+7)
        ld      b,a
        ld      a,(ix+11)
        or      b
        and     80h
        jp      nz,__fle_slow
        ld      a,(ix+7)
        and     7fh
        cp      7fh
        jp      z,__fle_slow
        ld      a,(ix+11)
        and     7fh
        cp      7fh
        jp      z,__fle_slow
        ld      a,(ix+7)
        cp      (ix+11)
        jp      c,__fle1
        jp      nz,__fle0
        ld      a,(ix+6)
        cp      (ix+10)
        jp      c,__fle1
        jp      nz,__fle0
        ld      a,(ix+5)
        cp      (ix+9)
        jp      c,__fle1
        jp      nz,__fle0
        ld      a,(ix+4)
        cp      (ix+8)
        jp      c,__fle1
        jp      nz,__fle0
        jp      __fle1          ; equal => a <= b

__fle_slow:
        ; cold path: a <= b is true for less or equal, false if unordered.
        call    __fcmps
        or      a
        jp      z,__fle0        ; unordered
        cp      3
        jp      z,__fle0        ; greater
        jp      __fle1          ; less or equal
__fle1:
        ld      hl,1
        ld      sp,ix
        pop     ix
        ret
__fle0:
        ld      hl,0
        ld      sp,ix
        pop     ix
        ret

        public  __fge
__fge:
        ; int __fge(float a, float b) -- a >= b, false if unordered.
        push    ix
        ld      ix,0
        add     ix,sp

        ; Fast path: both positive non-NaN -- a >= b iff a_raw >= b_raw.
        ld      a,(ix+7)
        ld      b,a
        ld      a,(ix+11)
        or      b
        and     80h
        jp      nz,__fge_slow
        ld      a,(ix+7)
        and     7fh
        cp      7fh
        jp      z,__fge_slow
        ld      a,(ix+11)
        and     7fh
        cp      7fh
        jp      z,__fge_slow
        ld      a,(ix+7)
        cp      (ix+11)
        jp      c,__fge0        ; a_byte < b_byte => a < b
        jp      nz,__fge1       ; a_byte > b_byte => a > b
        ld      a,(ix+6)
        cp      (ix+10)
        jp      c,__fge0
        jp      nz,__fge1
        ld      a,(ix+5)
        cp      (ix+9)
        jp      c,__fge0
        jp      nz,__fge1
        ld      a,(ix+4)
        cp      (ix+8)
        jp      c,__fge0
        jp      __fge1          ; equal or a_byte >= b_byte => a >= b

__fge_slow:
        ; cold path: a >= b is true for greater or equal, false if unordered.
        call    __fcmps
        cp      2
        jp      nc,__fge1       ; equal or greater
        jp      __fge0          ; unordered or less
__fge1:
        ld      hl,1
        ld      sp,ix
        pop     ix
        ret
__fge0:
        ld      hl,0
        ld      sp,ix
        pop     ix
        ret

; ---------------------------------------------------------------------------
; Shared ordered float comparator.  Classifies a@IX+4 vs b@IX+8 once; the
; individual __flt/__fgt/__fle/__fge cold paths map the result to a boolean.
; Returns A = 0 unordered (either NaN), 1 a<b, 2 a==b (incl +0==-0), 3 a>b.
; Assumes the caller's IX frame is live; preserves IX.
; ---------------------------------------------------------------------------
__fcmps:
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      e,(ix+6)
        ld      d,(ix+7)
        call    __fnan
        ld      a,h
        or      l
        jp      nz,__fcun       ; a is NaN -> unordered
        ld      l,(ix+8)
        ld      h,(ix+9)
        ld      e,(ix+10)
        ld      d,(ix+11)
        call    __fnan
        ld      a,h
        or      l
        jp      nz,__fcun       ; b is NaN -> unordered
        ; zero handling: +0 and -0 are equal to each other
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      e,(ix+6)
        ld      d,(ix+7)
        call    __fzro
        push    hl
        ld      l,(ix+8)
        ld      h,(ix+9)
        ld      e,(ix+10)
        ld      d,(ix+11)
        call    __fzro          ; HL = (b == 0)
        pop     de              ; DE = (a == 0)
        ld      a,d
        or      e
        jp      z,__fcsg        ; a != 0 -> compare by sign/magnitude
        ld      a,h
        or      l
        jp      nz,__fceq       ; a == 0 and b == 0 -> equal
        ; a == 0, b != 0: fall through to sign/magnitude compare
__fcsg:
        ld      a,(ix+7)
        xor     (ix+11)
        and     80h
        jp      z,__fcsm        ; same sign
        ; different signs: the negative operand is the smaller
        ld      a,(ix+7)
        bit     7,a
        jp      nz,__fclt       ; a negative -> a < b
        jp      __fcgt          ; a positive, b negative -> a > b
__fcsm:
        ld      a,(ix+7)
        bit     7,a
        jp      nz,__fcsn
        ; both positive: raw magnitude order matches numeric order
        jp      __frcmp         ; tail: A = 1/2/3 maps to less/equal/greater
__fcsn:
        ; both negative: raw magnitude order is reversed
        call    __frcmp
        cp      1
        jp      z,__fcgt        ; a_raw < b_raw -> a > b
        cp      3
        jp      z,__fclt        ; a_raw > b_raw -> a < b
        ret                     ; equal stays equal (A = 2)
__fcun:
        xor     a               ; 0 = unordered
        ret
__fclt:
        ld      a,1
        ret
__fceq:
        ld      a,2
        ret
__fcgt:
        ld      a,3
        ret

; Raw unsigned 3-way magnitude compare of a@IX+4 vs b@IX+8.
; Returns A = 1 (a_raw < b_raw), 2 (a_raw == b_raw), 3 (a_raw > b_raw).
__frcmp:
        ld      a,(ix+7)
        cp      (ix+11)
        jp      c,__frcl
        jp      nz,__frcg
        ld      a,(ix+6)
        cp      (ix+10)
        jp      c,__frcl
        jp      nz,__frcg
        ld      a,(ix+5)
        cp      (ix+9)
        jp      c,__frcl
        jp      nz,__frcg
        ld      a,(ix+4)
        cp      (ix+8)
        jp      c,__frcl
        jp      nz,__frcg
        ld      a,2
        ret
__frcl:
        ld      a,1
        ret
__frcg:
        ld      a,3
        ret


; ---- IEEE single / integer conversion helpers ---------------------------
; Calling convention: float values are returned/passed in DE:HL, with HL
; holding the low 16 bits and DE holding the high 16 bits of the IEEE word.
;
; __fuf: unsigned 16-bit HL -> float DE:HL
; __fif: signed   16-bit HL -> float DE:HL
; __ffu: float DE:HL -> unsigned 16-bit HL, trunc toward zero
; __ffi: float DE:HL -> signed   16-bit HL, trunc toward zero

        public  __fuf
__fuf:
        ld      a,h
        or      l
        jp      nz,FUFNZ
        ld      de,0
        ret
FUFNZ:
        ld      b,142          ; exponent for bit 15
FUFN1:
        bit     7,h
        jp      nz,FUFND
        add     hl,hl
        dec     b
        jp      FUFN1
FUFND:
        ld      c,h            ; C = normalized high byte
        ld      a,l
        ld      h,a            ; HL low word = (norm_low << 8)
        ld      l,0
        ld      a,b
        ld      d,a
        srl     d              ; D = exponent >> 1
        and     1
        rrca                    ; A = exponent low bit in bit 7
        and     80h
        ld      e,a
        ld      a,c
        and     7fh            ; mantissa bits 22..16
        or      e
        ld      e,a
        ret

        public  __fif
__fif:
        bit     7,h
        jp      nz,FIFNG
        jp      __fuf
FIFNG:
        ld      a,h
        cpl
        ld      h,a
        ld      a,l
        cpl
        ld      l,a
        inc     hl
        call    __fuf
        ld      a,d
        or      80h
        ld      d,a
        ret

        public  __ffu
__ffu:
        ; Get unbiased exponent from high word DE.  Sign is ignored here.
        ld      a,d
        and     7fh
        add     a,a
        ld      c,a
        ld      a,e
        rlca
        and     1
        or      c              ; A = exponent
        cp      127
        jp      nc,FFU_GE1
        ld      hl,0
        ret
FFU_GE1:
        cp      143
        jp      c,FFU_OK
        ld      hl,0ffffh      ; saturate overflow/inf/nan-ish cases
        ret
FFU_OK:
        ld      c,a
        ld      a,142
        sub     c
        ld      b,a            ; B = right shift count
        ld      c,h            ; save mantissa bits 15..8 source
        ld      a,e
        and     7fh
        or      80h
        ld      h,a
        ld      l,c            ; HL = normalized 1.x as 16-bit
        inc     b
FFUS1:
        dec     b
        jp      z,FFUDN
        srl     h
        rr      l
        jp      FFUS1
FFUDN:
        ret

        public  __ffi
__ffi:
        ld      a,d
        and     80h
        push    af
        res     7,d
        call    __ffu
        pop     af
        or      a
        ret     z
        ld      a,h
        cpl
        ld      h,a
        ld      a,l
        cpl
        ld      l,a
        inc     hl
        ret



; ---- IEEE single add/sub helpers ----------------------------------------
; Calling convention: caller pushes left float then right float as
;   push de / push hl for each.  At entry:
;     IX+4..7   = right operand low..high
;     IX+8..11  = left  operand low..high
; Return DE:HL = left +/- right.  This is a compact phase-1 IEEE add/sub:
; normalized finite numbers and signed zero are handled; NaN/Inf handling is
; conservative and returns the left operand for those uncommon bootstrap cases.

        public  __fadd
__fadd:
        push    ix
        ld      ix,0
        add     ix,sp
        xor     a
        ld      (FSUB),a
        jp      FADD0

        public  __fsub
__fsub:
        push    ix
        ld      ix,0
        add     ix,sp
        ld      a,1
        ld      (FSUB),a
FADD0:
        ; unpack left operand into A* scratch
        ld      l,(ix+8)
        ld      h,(ix+9)
        ld      e,(ix+10)
        ld      d,(ix+11)
        call    FUNA
        ; unpack right operand into B* scratch
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      e,(ix+6)
        ld      d,(ix+7)
        call    FUNB
        ld      a,(FSUB)
        or      a
        jp      z,FANOS
        ld      a,(BSGN)
        xor     80h             ; flip IEEE sign bit, not bit 0
        ld      (BSGN),a
FANOS:
        ; zero shortcuts
        ld      a,(AEXP)
        or      a
        jp      nz,FABNZ
        ld      a,(AM2)
        or      a
        jp      nz,FABNZ
        ld      a,(AM1)
        or      a
        jp      nz,FABNZ
        ld      a,(AM0)
        or      a
        jp      nz,FABNZ
        call    FPB
        jp      FARET
FABNZ:
        ld      a,(BEXP)
        or      a
        jp      nz,FALGN
        ld      a,(BM2)
        or      a
        jp      nz,FALGN
        ld      a,(BM1)
        or      a
        jp      nz,FALGN
        ld      a,(BM0)
        or      a
        jp      nz,FALGN
        call    FPA
        jp      FARET

FALGN:
        ; align exponents: compute diff once, shift in a djnz loop, early-exit if diff>=24.
        ld      a,(AEXP)
        ld      b,a             ; B = AEXP
        ld      a,(BEXP)        ; A = BEXP
        sub     b               ; A = BEXP - AEXP (signed)
        jp      z,FASGN         ; equal exponents: nothing to align
        jp      c,FALGN_AGT     ; carry: BEXP < AEXP, A has larger exponent

        ; BEXP > AEXP: shift A mantissa right by (BEXP-AEXP), then set AEXP=BEXP
        cp      24
        jp      nc,FALGN_AABS   ; diff >= 24: A's contribution rounds to zero
        ld      b,a             ; B = shift count (1..23)
FALGN_AB8:
        ; FSRA is a truncating right shift, so 8 of them == moving each
        ; mantissa byte down one position with a zero fill at the top.
        ld      a,b
        cp      8
        jp      c,FALGN_ABIT    ; <8 remaining: bit-shift the rest
        ld      a,(AM1)
        ld      (AM0),a
        ld      a,(AM2)
        ld      (AM1),a
        xor     a
        ld      (AM2),a
        ld      a,b
        sub     8
        ld      b,a
        jp      FALGN_AB8
FALGN_ABIT:
        ld      a,b
        or      a
        jp      z,FALGN_ADONE   ; whole number of bytes: no residual bits
FALGN_ASHR:
        call    FSRA
        djnz    FALGN_ASHR
FALGN_ADONE:
        ld      a,(BEXP)
        ld      (AEXP),a        ; align AEXP up to BEXP
        jp      FASGN

FALGN_AGT:
        ; AEXP > BEXP: A = BEXP-AEXP is negative, negate to get AEXP-BEXP
        neg                     ; A = AEXP - BEXP (positive)
        cp      24
        jp      nc,FALGN_BABS   ; diff >= 24: B's contribution rounds to zero
        ld      b,a             ; B = shift count (1..23)
FALGN_BB8:
        ; same truncating byte-shift shortcut for the B mantissa.
        ld      a,b
        cp      8
        jp      c,FALGN_BBIT    ; <8 remaining: bit-shift the rest
        ld      a,(BM1)
        ld      (BM0),a
        ld      a,(BM2)
        ld      (BM1),a
        xor     a
        ld      (BM2),a
        ld      a,b
        sub     8
        ld      b,a
        jp      FALGN_BB8
FALGN_BBIT:
        ld      a,b
        or      a
        jp      z,FASGN         ; whole number of bytes: no residual bits
FALGN_BSHR:
        call    FSRB
        djnz    FALGN_BSHR
        jp      FASGN

FALGN_AABS:
        ; A is negligible relative to B: zero A's mantissa, set AEXP=BEXP
        xor     a
        ld      (AM0),a
        ld      (AM1),a
        ld      (AM2),a
        ld      a,(BEXP)
        ld      (AEXP),a
        jp      FASGN

FALGN_BABS:
        ; B is negligible relative to A: zero B's mantissa
        xor     a
        ld      (BM0),a
        ld      (BM1),a
        ld      (BM2),a
        jp      FASGN

FASGN:
        ld      a,(ASGN)
        ld      b,a
        ld      a,(BSGN)
        cp      b
        jp      nz,FSUBM
        ; same sign: mantissa A += B
        ld      a,(AM0)
        ld      b,a
        ld      a,(BM0)
        add     a,b
        ld      (AM0),a
        ld      a,(AM1)
        ld      b,a
        ld      a,(BM1)
        adc     a,b
        ld      (AM1),a
        ld      a,(AM2)
        ld      b,a
        ld      a,(BM2)
        adc     a,b
        ld      (AM2),a
        jp      nc,FNORM
        ; carry out of bit 23: shift right and set hidden bit
        call    FSRA
        ld      a,(AM2)
        or      80h
        ld      (AM2),a
        ld      a,(AEXP)
        inc     a
        ld      (AEXP),a
        jp      FPACK

FSUBM:
        ; different signs: subtract smaller magnitude from larger.
        call    FCMPM
        jp      z,FZERO
        jp      nc,FASUB          ; A >= B
        ; B > A: A = B - A, sign = B sign
        ld      a,(BM0)
        ld      b,a
        ld      a,(AM0)
        ld      c,a
        ld      a,b
        sub     c
        ld      (AM0),a
        ld      a,(BM1)
        ld      b,a
        ld      a,(AM1)
        ld      c,a
        ld      a,b
        sbc     a,c
        ld      (AM1),a
        ld      a,(BM2)
        ld      b,a
        ld      a,(AM2)
        ld      c,a
        ld      a,b
        sbc     a,c
        ld      (AM2),a
        ld      a,(BSGN)
        ld      (ASGN),a
        jp      FNORM
FASUB:
        ld      a,(AM0)
        ld      b,a
        ld      a,(BM0)
        ld      c,a
        ld      a,b
        sub     c
        ld      (AM0),a
        ld      a,(AM1)
        ld      b,a
        ld      a,(BM1)
        ld      c,a
        ld      a,b
        sbc     a,c
        ld      (AM1),a
        ld      a,(AM2)
        ld      b,a
        ld      a,(BM2)
        ld      c,a
        ld      a,b
        sbc     a,c
        ld      (AM2),a

FNORM:
        ; if mantissa became zero, return +0.
        ld      a,(AM2)
        or      a
        jp      nz,FNL1
        ld      a,(AM1)
        or      a
        jp      nz,FNL0
        ld      a,(AM0)
        or      a
        jp      z,FZERO
FNL0:
        ; shift left until high byte non-zero or exponent reaches zero
        call    FSLA
        ld      a,(AEXP)
        dec     a
        ld      (AEXP),a
        jp      z,FPACK
        jp      FNORM
FNL1:
        ; Reload AM2 on each pass.  After decrementing AEXP, A no longer
        ; contains the mantissa high byte.
        ld      a,(AM2)
        bit     7,a
        jp      nz,FPACK
        call    FSLA
        ld      a,(AEXP)
        dec     a
        ld      (AEXP),a
        jp      nz,FNL1

FPACK:
        call    FPA
FARET:
        ld      sp,ix
        pop     ix
        ret
FZERO:
        ld      hl,0
        ld      de,0
        jp      FARET

; unpack DE:HL to A scratch
FUNA:
        ld      a,d
        and     80h
        ld      (ASGN),a
        ld      a,d
        and     7fh
        add     a,a
        ld      b,a
        ld      a,e
        rlca
        and     1
        or      b
        ld      (AEXP),a
        ld      a,e
        and     7fh
        ld      b,a
        ld      a,(AEXP)
        or      a
        jp      z,FUNAZ
        ld      a,b
        or      80h
        ld      b,a
FUNAZ:
        ld      a,b
        ld      (AM2),a
        ld      a,h
        ld      (AM1),a
        ld      a,l
        ld      (AM0),a
        ret
; unpack DE:HL to B scratch
FUNB:
        ld      a,d
        and     80h
        ld      (BSGN),a
        ld      a,d
        and     7fh
        add     a,a
        ld      b,a
        ld      a,e
        rlca
        and     1
        or      b
        ld      (BEXP),a
        ld      a,e
        and     7fh
        ld      b,a
        ld      a,(BEXP)
        or      a
        jp      z,FUNBZ
        ld      a,b
        or      80h
        ld      b,a
FUNBZ:
        ld      a,b
        ld      (BM2),a
        ld      a,h
        ld      (BM1),a
        ld      a,l
        ld      (BM0),a
        ret

; pack A scratch to DE:HL
FPA:
        ld      a,(AEXP)
        or      a
        jp      z,FPAZ
        ld      b,a
        srl     a
        ld      d,a
        ld      a,(ASGN)
        or      d
        ld      d,a
        ld      a,b
        and     1
        rrca
        and     80h
        ld      b,a
        ld      a,(AM2)
        and     7fh
        or      b
        ld      e,a
        ld      a,(AM1)
        ld      h,a
        ld      a,(AM0)
        ld      l,a
        ret
FPAZ:
        ld      hl,0
        ld      de,0
        ret
FPB:
        ld      a,(BEXP)
        ld      (AEXP),a
        ld      a,(BSGN)
        ld      (ASGN),a
        ld      a,(BM2)
        ld      (AM2),a
        ld      a,(BM1)
        ld      (AM1),a
        ld      a,(BM0)
        ld      (AM0),a
        jp      FPA

FSRA:
        ld      a,(AM2)
        srl     a
        ld      (AM2),a
        ld      a,(AM1)
        rr      a
        ld      (AM1),a
        ld      a,(AM0)
        rr      a
        ld      (AM0),a
        ret
FSRB:
        ld      a,(BM2)
        srl     a
        ld      (BM2),a
        ld      a,(BM1)
        rr      a
        ld      (BM1),a
        ld      a,(BM0)
        rr      a
        ld      (BM0),a
        ret
FSLA:
        ld      a,(AM0)
        add     a,a
        ld      (AM0),a
        ld      a,(AM1)
        rla
        ld      (AM1),a
        ld      a,(AM2)
        rla
        ld      (AM2),a
        ret

; compare A mantissa with B mantissa. Carry set if A < B, Z if equal.
FCMPM:
        ld      a,(AM2)
        ld      b,a
        ld      a,(BM2)
        cp      b
        jp      c,FCAGT
        jp      nz,FCALT
        ld      a,(AM1)
        ld      b,a
        ld      a,(BM1)
        cp      b
        jp      c,FCAGT
        jp      nz,FCALT
        ld      a,(AM0)
        ld      b,a
        ld      a,(BM0)
        cp      b
        jp      c,FCAGT
        jp      nz,FCALT
        xor     a              ; A == B: clear carry, set Z
        ret
FCAGT:
        or      1              ; A > B: clear carry, force Z clear
        ret
FCALT:
        or      1              ; A < B: force Z clear before setting carry
        scf
        ret



        public  __fmul
__fmul:
        push    ix
        ld      ix,0
        add     ix,sp

        ; unpack left operand into A scratch
        ld      l,(ix+8)
        ld      h,(ix+9)
        ld      e,(ix+10)
        ld      d,(ix+11)
        call    FUNA
        ; unpack right operand into B scratch
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      e,(ix+6)
        ld      d,(ix+7)
        call    FUNB

        ; zero/subnormal shortcut: this phase treats exponent-zero values as 0.
        ld      a,(AEXP)
        or      a
        jp      z,FMZERO
        ld      a,(BEXP)
        or      a
        jp      z,FMZERO

        ; sign = ASGN xor BSGN
        ld      a,(ASGN)
        ld      b,a
        ld      a,(BSGN)
        xor     b
        and     80h
        ld      (ASGN),a

        ; exponent = AEXP + BEXP - 127
        ld      a,(AEXP)
        ld      l,a
        ld      h,0
        ld      a,(BEXP)
        ld      e,a
        ld      d,0
        add     hl,de
        ld      de,127
        or      a
        sbc     hl,de
        bit     7,h
        jp      nz,FMZERO
        ld      a,h
        or      a
        jp      nz,FMINF
        ld      a,l
        cp      255
        jp      nc,FMINF
        ld      (AEXP),a

        ; P = 0.
        xor     a
        ld      (FP0),a
        ld      (FP1),a
        ld      (FP2),a
        ld      (FP3),a
        ld      (FP4),a
        ld      (FP5),a

        ; Choose the multiplier Q to avoid guaranteed zero low-byte
        ; iterations.  Product is commutative, so this is exact.
        ;
        ; Prefer a 16-bit byte skip if either mantissa has two zero low bytes;
        ; otherwise use an 8-bit byte skip if either mantissa has one zero low
        ; byte.  This keeps full 24-bit mantissas and only avoids iterations
        ; where Q's low byte would force no add.
        ld      a,(AM0)
        or      a
        jp      nz,FMCHECK_B
        ld      a,(AM1)
        or      a
        jp      z,FMSET_BA_8    ; A has 16 low zero bits
        jp      FMCHECK_B2_FOR_8

FMCHECK_B:
        ld      a,(BM0)
        or      a
        jp      nz,FMSET_AB_24
        ld      a,(BM1)
        or      a
        jp      z,FMSET_AB_8    ; B has 16 low zero bits
        jp      FMSET_AB_16     ; B has 8 low zero bits

FMCHECK_B2_FOR_8:
        ; A has 8 low zero bits.  If B has 16, prefer that; otherwise use A.
        ld      a,(BM0)
        or      a
        jp      nz,FMSET_BA_16
        ld      a,(BM1)
        or      a
        jp      z,FMSET_AB_8
        jp      FMSET_BA_16

FMSET_BA_16:
        ; A has 8 low zero bits: M = B mantissa << 8, Q = A >> 8.
        xor     a
        ld      (FM0),a
        ld      a,(BM0)
        ld      (FM1),a
        ld      a,(BM1)
        ld      (FM2),a
        ld      a,(BM2)
        ld      (FM3),a
        xor     a
        ld      (FM4),a
        ld      (FM5),a
        ld      h,0
        ld      a,(AM2)
        ld      l,a
        ld      a,(AM1)
        ld      e,a
        ld      b,16
        jp      FMLP

FMSET_BA_8:
        ; A has 16 low zero bits: M = B mantissa << 16, Q = A >> 16.
        xor     a
        ld      (FM0),a
        ld      (FM1),a
        ld      a,(BM0)
        ld      (FM2),a
        ld      a,(BM1)
        ld      (FM3),a
        ld      a,(BM2)
        ld      (FM4),a
        xor     a
        ld      (FM5),a
        ld      h,0
        ld      l,0
        ld      a,(AM2)
        ld      e,a
        ld      b,8
        jp      FMLP

FMSET_AB_16:
        ; B has 8 low zero bits: M = A mantissa << 8, Q = B >> 8.
        xor     a
        ld      (FM0),a
        ld      a,(AM0)
        ld      (FM1),a
        ld      a,(AM1)
        ld      (FM2),a
        ld      a,(AM2)
        ld      (FM3),a
        xor     a
        ld      (FM4),a
        ld      (FM5),a
        ld      h,0
        ld      a,(BM2)
        ld      l,a
        ld      a,(BM1)
        ld      e,a
        ld      b,16
        jp      FMLP

FMSET_AB_8:
        ; B has 16 low zero bits: M = A mantissa << 16, Q = B >> 16.
        xor     a
        ld      (FM0),a
        ld      (FM1),a
        ld      a,(AM0)
        ld      (FM2),a
        ld      a,(AM1)
        ld      (FM3),a
        ld      a,(AM2)
        ld      (FM4),a
        xor     a
        ld      (FM5),a
        ld      h,0
        ld      l,0
        ld      a,(BM2)
        ld      e,a
        ld      b,8
        jp      FMLP

FMSET_AB_24:
        ; General path: M = A mantissa, Q = B mantissa.
        ld      a,(AM0)
        ld      (FM0),a
        ld      a,(AM1)
        ld      (FM1),a
        ld      a,(AM2)
        ld      (FM2),a
        xor     a
        ld      (FM3),a
        ld      (FM4),a
        ld      (FM5),a
        ld      a,(BM2)
        ld      h,a
        ld      a,(BM1)
        ld      l,a
        ld      a,(BM0)
        ld      e,a
        ld      b,24

FMLP:
        ld      a,e             ; FQ0 in register E
        and     1
        jp      z,FMNA
        ; P += M
        ld      a,(FP0)
        ld      c,a
        ld      a,(FM0)
        add     a,c
        ld      (FP0),a
        ld      a,(FP1)
        ld      c,a
        ld      a,(FM1)
        adc     a,c
        ld      (FP1),a
        ld      a,(FP2)
        ld      c,a
        ld      a,(FM2)
        adc     a,c
        ld      (FP2),a
        ld      a,(FP3)
        ld      c,a
        ld      a,(FM3)
        adc     a,c
        ld      (FP3),a
        ld      a,(FP4)
        ld      c,a
        ld      a,(FM4)
        adc     a,c
        ld      (FP4),a
        ld      a,(FP5)
        ld      c,a
        ld      a,(FM5)
        adc     a,c
        ld      (FP5),a
FMNA:
        ; M <<= 1
        ld      a,(FM0)
        add     a,a
        ld      (FM0),a
        ld      a,(FM1)
        rla
        ld      (FM1),a
        ld      a,(FM2)
        rla
        ld      (FM2),a
        ld      a,(FM3)
        rla
        ld      (FM3),a
        ld      a,(FM4)
        rla
        ld      (FM4),a
        ld      a,(FM5)
        rla
        ld      (FM5),a
        ; Q >>= 1 (registers only: H=FQ2, L=FQ1, E=FQ0)
        srl     h
        rr      l
        rr      e
        dec     b
        jp      nz,FMLP

        ; If product bit 47 is set, mantissa = product >> 24 and exponent++.
        ld      a,(FP5)
        bit     7,a
        jp      z,FMNOC
        ld      a,(AEXP)
        inc     a
        cp      255
        jp      nc,FMINF
        ld      (AEXP),a
        ld      a,(FP3)
        ld      (AM0),a
        ld      a,(FP4)
        ld      (AM1),a
        ld      a,(FP5)
        ld      (AM2),a
        jp      FMPAK

FMNOC:
        ; Mantissa = product >> 23.  Shift P5:P4:P3:P2 right by 7.
        ld      b,7
FMSR7:
        ld      a,(FP5)
        srl     a
        ld      (FP5),a
        ld      a,(FP4)
        rr      a
        ld      (FP4),a
        ld      a,(FP3)
        rr      a
        ld      (FP3),a
        ld      a,(FP2)
        rr      a
        ld      (FP2),a
        djnz    FMSR7
        ld      a,(FP2)
        ld      (AM0),a
        ld      a,(FP3)
        ld      (AM1),a
        ld      a,(FP4)
        ld      (AM2),a

FMPAK:
        call    FPA
        ld      sp,ix
        pop     ix
        ret
FMZERO:
        ld      hl,0
        ld      de,0
        ld      sp,ix
        pop     ix
        ret
FMINF:
        ld      hl,0
        ld      de,7f80h
        ld      a,(ASGN)
        or      d
        ld      d,a
        ld      sp,ix
        pop     ix
        ret


        public  __fdiv
__fdiv:
        push    ix
        ld      ix,0
        add     ix,sp

        ; unpack left operand into A scratch
        ld      l,(ix+8)
        ld      h,(ix+9)
        ld      e,(ix+10)
        ld      d,(ix+11)
        call    FUNA
        ; unpack right operand into B scratch
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      e,(ix+6)
        ld      d,(ix+7)
        call    FUNB

        ; sign = ASGN xor BSGN
        ld      a,(ASGN)
        ld      c,a
        ld      a,(BSGN)
        xor     c
        and     80h
        ld      (ASGN),a

        ; 0 / anything = 0.  This phase treats subnormals as zero.
        ld      a,(AEXP)
        or      a
        jp      z,FDZRO

        ; divide by zero => signed infinity
        ld      a,(BEXP)
        or      a
        jp      z,FDINF

        ; exponent = AEXP - BEXP + 127
        ld      a,(AEXP)
        ld      l,a
        ld      h,0
        ld      a,(BEXP)
        ld      e,a
        ld      d,0
        or      a
        sbc     hl,de
        ld      de,127
        add     hl,de
        bit     7,h
        jp      nz,FDZRO
        ld      a,h
        or      a
        jp      nz,FDINF
        ld      a,l
        or      a
        jp      z,FDZRO
        cp      255
        jp      nc,FDINF
        ld      (AEXP),a

        ; R = A mantissa, Q = 0.  Compute 24-bit Q ~= A/B scaled by 2^23.
        ld      a,(AM0)
        ld      (FP0),a
        ld      a,(AM1)
        ld      (FP1),a
        ld      a,(AM2)
        ld      (FP2),a
        xor     a
        ld      (FP3),a
        ld      (FQ0),a
        ld      (FQ1),a
        ld      (FQ2),a

        ; Load divisor mantissa into registers for the 24-iteration loop.
        ; H=BM2, L=BM1, D=BM0 are constant throughout; C=0 for FP3 borrow.
        ; B=BM2 survives from FUNB; BM0/BM1 must reload from memory because
        ; the exponent computation above clobbers H, L, D, and E.
        ld      h,b             ; H = BM2  (B preserved through exponent computation)
        ld      a,(BM1)
        ld      l,a             ; L = BM1
        ld      a,(BM0)
        ld      d,a             ; D = BM0
        ld      c,0

        ld      b,24
FDLUP:
        ; Q <<= 1
        ld      a,(FQ0)
        add     a,a
        ld      (FQ0),a
        ld      a,(FQ1)
        rla
        ld      (FQ1),a
        ld      a,(FQ2)
        rla
        ld      (FQ2),a

        ; if R >= B then R -= B and set low bit of Q.
        ; R is kept as a 25-bit value in FP3:FP2:FP1:FP0.
        ; BM (divisor mantissa) is in H:L:D; C=0 supplies the zero borrow operand.
        ld      a,(FP3)
        or      a
        jp      nz,FDSUB        ; FP3 != 0: R > B (B has no byte here)
        ld      a,(FP2)
        cp      h               ; FP2 - BM2; carry if FP2 < BM2
        jp      c,FDNSB         ; R < B
        jp      nz,FDSUB        ; R > B
        ld      a,(FP1)
        cp      l               ; FP1 - BM1
        jp      c,FDNSB
        jp      nz,FDSUB
        ld      a,(FP0)
        cp      d               ; FP0 - BM0; carry if FP0 < BM0
        jp      c,FDNSB         ; R < B; fall through if R >= B
FDSUB:
        ld      a,(FP0)
        sub     d               ; FP0 - BM0 (no borrow input)
        ld      (FP0),a
        ld      a,(FP1)
        sbc     a,l             ; FP1 - BM1 - borrow
        ld      (FP1),a
        ld      a,(FP2)
        sbc     a,h             ; FP2 - BM2 - borrow
        ld      (FP2),a
        ld      a,(FP3)
        sbc     a,c             ; FP3 - 0 - borrow (C=0)
        ld      (FP3),a
        ld      a,(FQ0)
        or      1
        ld      (FQ0),a
FDNSB:
        ; R <<= 1
        ld      a,(FP0)
        add     a,a
        ld      (FP0),a
        ld      a,(FP1)
        rla
        ld      (FP1),a
        ld      a,(FP2)
        rla
        ld      (FP2),a
        ld      a,(FP3)
        rla
        ld      (FP3),a

        dec     b
        jp      nz,FDLUP

        ; Round division result.  At this point FP3:FP2:FP1:FP0 holds
        ; 2*remainder from the final quotient step.  If that value is at
        ; least the divisor mantissa, round the 24-bit quotient up.  This is
        ; round-half-up rather than full round-to-nearest-even, but it fixes
        ; the dominant truncation error without changing the ABI or helper
        ; calling convention.
        ld      a,(FP3)
        or      a
        jp      nz,FDRUP
        ld      a,(FP2)
        ld      c,a
        ld      a,(BM2)
        cp      c
        jp      c,FDRUP
        jp      nz,FDRNO
        ld      a,(FP1)
        ld      c,a
        ld      a,(BM1)
        cp      c
        jp      c,FDRUP
        jp      nz,FDRNO
        ld      a,(FP0)
        ld      c,a
        ld      a,(BM0)
        cp      c
        jp      c,FDRUP
        jp      nz,FDRNO
FDRUP:
        ld      a,(FQ0)
        inc     a
        ld      (FQ0),a
        jp      nz,FDRNO
        ld      a,(FQ1)
        inc     a
        ld      (FQ1),a
        jp      nz,FDRNO
        ld      a,(FQ2)
        inc     a
        ld      (FQ2),a
        jp      nz,FDRNO
        ; Quotient overflowed from 0ffffffh to 1000000h.  Renormalize to
        ; 800000h and bump exponent.
        ld      a,80h
        ld      (FQ2),a
        xor     a
        ld      (FQ1),a
        ld      (FQ0),a
        ld      a,(AEXP)
        inc     a
        cp      255
        jp      nc,FDINF
        ld      (AEXP),a
FDRNO:

        ; Q is the mantissa candidate. Normalize left if the hidden bit is clear.
        ld      a,(FQ0)
        ld      (AM0),a
        ld      a,(FQ1)
        ld      (AM1),a
        ld      a,(FQ2)
        ld      (AM2),a
FDNOR:
        ld      a,(AM2)
        bit     7,a
        jp      nz,FDPAK
        call    FSLA
        ld      a,(AEXP)
        dec     a
        ld      (AEXP),a
        jp      z,FDZRO
        jp      FDNOR

FDPAK:
        call    FPA
        ld      sp,ix
        pop     ix
        ret
FDZRO:
        ld      hl,0
        ld      de,0
        ld      sp,ix
        pop     ix
        ret
FDINF:
        ld      hl,0
        ld      de,7f80h
        ld      a,(ASGN)
        or      d
        ld      d,a
        ld      sp,ix
        pop     ix
        ret

FSUB:   db      0
ASGN:   db      0
AEXP:   db      0
AM0:    db      0
AM1:    db      0
AM2:    db      0
BSGN:   db      0
BEXP:   db      0
BM0:    db      0
BM1:    db      0
BM2:    db      0
FP0:    db      0
FP1:    db      0
FP2:    db      0
FP3:    db      0
FP4:    db      0
FP5:    db      0
FM0:    db      0
FM1:    db      0
FM2:    db      0
FM3:    db      0
FM4:    db      0
FM5:    db      0
FQ0:    db      0
FQ1:    db      0
FQ2:    db      0


; ---------------------------------------------------------------------------
; C89-ish single-precision math helpers.  These are intentionally separate
; PUBLIC blocks so dccrtlstrip can remove them unless the app references them.
;
; ABI: float arguments are 4 bytes on stack, low word then high word.
;      return float in DE:HL.
; These helpers reuse the existing IEEE single core/arithmetic helpers.

        public  _fabsf
_fabsf:
        push    ix
        ld      ix,0
        add     ix,sp
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      e,(ix+6)
        ld      d,(ix+7)
        call    __fabs
        ld      sp,ix
        pop     ix
        ret

        public  _floorf
_floorf:
        push    ix
        ld      ix,0
        add     ix,sp
        ld      hl,-8
        add     hl,sp
        ld      sp,hl

        ; l = (long)x
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      e,(ix+6)
        ld      d,(ix+7)
        call    __ffl
        ld      (ix-4),l
        ld      (ix-3),h
        ld      (ix-2),e
        ld      (ix-1),d

        ; y = (float)l
        ld      l,(ix-4)
        ld      h,(ix-3)
        ld      e,(ix-2)
        ld      d,(ix-1)
        call    __flf
        ld      (ix-8),l
        ld      (ix-7),h
        ld      (ix-6),e
        ld      (ix-5),d

        ; if (x < y) l--, y = (float)l.
        ; Do the adjustment in integer space.  This avoids depending on
        ; opposite-sign __fsub edge cases while preserving floor semantics
        ; for negative non-integral values.
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      e,(ix+6)
        ld      d,(ix+7)
        push    de
        push    hl
        ld      l,(ix-8)
        ld      h,(ix-7)
        ld      e,(ix-6)
        ld      d,(ix-5)
        push    de
        push    hl
        call    __fgt             ; y > x
        pop     bc
        pop     bc
        pop     bc
        pop     bc
        ld      a,h
        or      l
        jp      z,FMFRET

        ld      l,(ix-4)
        ld      h,(ix-3)
        ld      e,(ix-2)
        ld      d,(ix-1)
        dec     hl
        ld      a,l
        cp      0ffh
        jp      nz,FMFDEC
        ld      a,h
        cp      0ffh
        jp      nz,FMFDEC
        dec     de
FMFDEC:
        call    __flf
        ld      (ix-8),l
        ld      (ix-7),h
        ld      (ix-6),e
        ld      (ix-5),d
FMFRET:
        ld      l,(ix-8)
        ld      h,(ix-7)
        ld      e,(ix-6)
        ld      d,(ix-5)
        ld      sp,ix
        pop     ix
        ret

        public  _ceilf
_ceilf:
        push    ix
        ld      ix,0
        add     ix,sp
        ld      hl,-8
        add     hl,sp
        ld      sp,hl

        ; l = (long)x
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      e,(ix+6)
        ld      d,(ix+7)
        call    __ffl
        ld      (ix-4),l
        ld      (ix-3),h
        ld      (ix-2),e
        ld      (ix-1),d

        ; y = (float)l
        ld      l,(ix-4)
        ld      h,(ix-3)
        ld      e,(ix-2)
        ld      d,(ix-1)
        call    __flf
        ld      (ix-8),l
        ld      (ix-7),h
        ld      (ix-6),e
        ld      (ix-5),d

        ; if (x > y) l++, y = (float)l.
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      e,(ix+6)
        ld      d,(ix+7)
        push    de
        push    hl
        ld      l,(ix-8)
        ld      h,(ix-7)
        ld      e,(ix-6)
        ld      d,(ix-5)
        push    de
        push    hl
        call    __flt             ; y < x
        pop     bc
        pop     bc
        pop     bc
        pop     bc
        ld      a,h
        or      l
        jp      z,FMCRET

        ld      l,(ix-4)
        ld      h,(ix-3)
        ld      e,(ix-2)
        ld      d,(ix-1)
        inc     hl
        ld      a,h
        or      l
        jp      nz,FMCCNV
        inc     de
FMCCNV:
        call    __flf
        ld      (ix-8),l
        ld      (ix-7),h
        ld      (ix-6),e
        ld      (ix-5),d
FMCRET:
        ld      l,(ix-8)
        ld      h,(ix-7)
        ld      e,(ix-6)
        ld      d,(ix-5)
        ld      sp,ix
        pop     ix
        ret

        public  _fmodf
_fmodf:
        push    ix
        ld      ix,0
        add     ix,sp
        ld      hl,-12
        add     hl,sp
        ld      sp,hl

        ; if (y == 0.0f) return quiet NaN (0x7fc00000).
        ; Treat both +0 and -0 as zero.
        ld      a,(ix+11)
        and     7fh
        ld      b,a
        ld      a,(ix+10)
        or      b
        ld      b,a
        ld      a,(ix+9)
        or      b
        ld      b,a
        ld      a,(ix+8)
        or      b
        jp      nz,FMDNZ
        ld      hl,0
        ld      de,7fc0h
        jp      FMDRET

FMDNZ:
        ; q = x / y
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      e,(ix+6)
        ld      d,(ix+7)
        push    de              ; left operand x
        push    hl
        ld      l,(ix+8)
        ld      h,(ix+9)
        ld      e,(ix+10)
        ld      d,(ix+11)
        push    de              ; right operand y
        push    hl
        call    __fdiv
        pop     bc
        pop     bc
        pop     bc
        pop     bc

        ; iq = (long)q, truncating toward zero.
        call    __ffl

        ; tq = (float)iq
        call    __flf
        ld      (ix-4),l
        ld      (ix-3),h
        ld      (ix-2),e
        ld      (ix-1),d

        ; prod = tq * y
        ld      l,(ix-4)
        ld      h,(ix-3)
        ld      e,(ix-2)
        ld      d,(ix-1)
        push    de              ; left operand tq
        push    hl
        ld      l,(ix+8)
        ld      h,(ix+9)
        ld      e,(ix+10)
        ld      d,(ix+11)
        push    de              ; right operand y
        push    hl
        call    __fmul
        pop     bc
        pop     bc
        pop     bc
        pop     bc
        ld      (ix-8),l
        ld      (ix-7),h
        ld      (ix-6),e
        ld      (ix-5),d

        ; return x - prod
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      e,(ix+6)
        ld      d,(ix+7)
        push    de              ; left operand x
        push    hl
        ld      l,(ix-8)
        ld      h,(ix-7)
        ld      e,(ix-6)
        ld      d,(ix-5)
        push    de              ; right operand prod
        push    hl
        call    __fsub
        pop     bc
        pop     bc
        pop     bc
        pop     bc

FMDRET:
        ld      sp,ix
        pop     ix
        ret

        public  _sqrtf
_sqrtf:
        push    ix
        ld      ix,0
        add     ix,sp
        ld      hl,-10
        add     hl,sp
        ld      sp,hl

        ; if (x <= 0.0f) return 0.0f;
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      e,(ix+6)
        ld      d,(ix+7)
        push    de
        push    hl
        ld      hl,0
        ld      de,0
        push    de
        push    hl
        call    __fge             ; generated convention for x <= 0.0f
        pop     bc
        pop     bc
        pop     bc
        pop     bc
        ld      a,h
        or      l
        jp      z,FMSPOS
        ld      hl,0
        ld      de,0
        jp      FMSRET

FMSPOS:
        ; g = x
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      e,(ix+6)
        ld      d,(ix+7)
        ld      (ix-4),l
        ld      (ix-3),h
        ld      (ix-2),e
        ld      (ix-1),d
        ld      hl,0              ; i = 0
        ld      (ix-6),l
        ld      (ix-5),h
FMSLP:
        ld      l,(ix-6)
        ld      h,(ix-5)
        push    hl
        ld      hl,8
        ex      de,hl
        pop     hl
        ld      a,h
        xor     80h
        ld      h,a
        ld      a,d
        xor     80h
        ld      d,a
        or      a
        sbc     hl,de
        jp      nc,FMSDONE

        ; g = (g + x / g) * 0.5f
        ld      l,(ix-4)
        ld      h,(ix-3)
        ld      e,(ix-2)
        ld      d,(ix-1)
        push    de
        push    hl
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      e,(ix+6)
        ld      d,(ix+7)
        push    de
        push    hl
        ld      l,(ix-4)
        ld      h,(ix-3)
        ld      e,(ix-2)
        ld      d,(ix-1)
        push    de
        push    hl
        call    __fdiv
        pop     bc
        pop     bc
        pop     bc
        pop     bc
        push    de
        push    hl
        call    __fadd
        pop     bc
        pop     bc
        pop     bc
        pop     bc
        ld      b,0ffh            ; exact * 2^-1, replacing full multiply by 0.5f
        call    __fscale_pow2
        ; If the new iterate equals the previous g bit-for-bit, Newton's
        ; method has reached a fixed point and every remaining iteration would
        ; reproduce it, so stop early.  g is a positive finite float here
        ; (never NaN), so a byte compare is a true value compare and the early
        ; exit is bit-identical to running the full iteration count.
        ld      a,l
        cp      (ix-4)
        jr      nz,FMSUPD
        ld      a,h
        cp      (ix-3)
        jr      nz,FMSUPD
        ld      a,e
        cp      (ix-2)
        jr      nz,FMSUPD
        ld      a,d
        cp      (ix-1)
        jp      z,FMSDONE       ; converged: stored g already equals new g
FMSUPD:
        ld      (ix-4),l
        ld      (ix-3),h
        ld      (ix-2),e
        ld      (ix-1),d

        inc     (ix-6)
        jp      nz,FMSLP
        inc     (ix-5)
        jp      FMSLP

FMSDONE:
        ; One final correction: the simple division/multiply helpers truncate,
        ; so Newton iteration can settle one representable value below the
        ; correctly rounded answer for perfect squares such as 9.0f.  If
        ; g*g < x, advance positive g by one IEEE single-precision bit.
        ld      l,(ix-4)
        ld      h,(ix-3)
        ld      e,(ix-2)
        ld      d,(ix-1)
        push    de
        push    hl
        push    de
        push    hl
        call    __fmul
        pop     bc
        pop     bc
        pop     bc
        pop     bc
        ; Save product, then call __flt(product, x).  The C calling
        ; convention pushes arguments right-to-left, so push x first.
        ld      (ix-10),l
        ld      (ix-9),h
        ld      (ix-8),e
        ld      (ix-7),d
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      e,(ix+6)
        ld      d,(ix+7)
        push    de
        push    hl
        ld      l,(ix-10)
        ld      h,(ix-9)
        ld      e,(ix-8)
        ld      d,(ix-7)
        push    de
        push    hl
        call    __flt             ; g*g < x ?
        pop     bc
        pop     bc
        pop     bc
        pop     bc
        ld      a,h
        or      l
        jp      z,FMSLD
        ld      l,(ix-4)
        ld      h,(ix-3)
        ld      e,(ix-2)
        ld      d,(ix-1)
        inc     hl
        ld      a,h
        or      l
        jp      nz,FMSST
        inc     de
FMSST:
        ld      (ix-4),l
        ld      (ix-3),h
        ld      (ix-2),e
        ld      (ix-1),d
FMSLD:
        ld      l,(ix-4)
        ld      h,(ix-3)
        ld      e,(ix-2)
        ld      d,(ix-1)
FMSRET:
        ld      sp,ix
        pop     ix
        ret

; ---- IEEE single <-> 32-bit long conversion helpers ---------------------
; Float calling convention: DE:HL holds the 32-bit IEEE single value.
; Long calling convention:  DE:HL holds a 32-bit integer value.
;
; __flf   signed   long  DE:HL -> float DE:HL
; __fulf  unsigned long  DE:HL -> float DE:HL
; __ffl   float DE:HL -> signed   long DE:HL, trunc toward zero
; __fful  float DE:HL -> unsigned long DE:HL, trunc toward zero


        public  __fscale_pow2
__fscale_pow2:
        ; Scale float DE:HL by 2^B.
        ; Input:  DE:HL = IEEE single raw bits, B = signed exponent delta.
        ; Output: DE:HL = scaled float.
        ;
        ; Fast/correct for normalized finite values.  Preserves NaN/Inf and
        ; signed zero.  Overflow becomes signed infinity.  Underflow becomes
        ; signed zero, matching the compact RTL's existing subnormal policy.
        ;
        ; Important: the original D/E bytes contain sign, exponent, and the
        ; high mantissa bits.  Do not use D/E as scratch until after they have
        ; been saved; otherwise scaling 2.0f by 2 could preserve the scratch
        ; byte as a mantissa bit and produce 4.03125 instead of 4.0.

        ; exp = ((D & 7f) << 1) | (E >> 7)
        ld      a,d
        and     7fh
        add     a,a
        ld      c,a
        ld      a,e
        rlca
        and     1
        or      c              ; A = biased exponent

        ; zero/subnormal: preserve signed zero / treat subnormal as zero.
        or      a
        jp      z,FSCL_RET

        ; NaN/Inf: preserve input.
        cp      255
        jp      z,FSCL_RET

        ; Preserve original float bits before using DE/HL as integer scratch.
        push    de
        push    hl

        ; A = exponent, B = signed delta.  Compute signed 16-bit A+B in HL.
        ld      l,a
        ld      h,0
        bit     7,b
        jp      z,FSCL_POS
        ld      a,b
        ld      e,a
        ld      d,0ffh
        jp      FSCL_ADD
FSCL_POS:
        ld      e,b
        ld      d,0
FSCL_ADD:
        add     hl,de

        ; new exponent <= 0 => signed zero.
        bit     7,h
        jp      nz,FSCL_ZERO
        ld      a,h
        or      a
        jp      nz,FSCL_INF
        ld      a,l
        or      a
        jp      z,FSCL_ZERO

        ; new exponent >= 255 => signed infinity.
        cp      255
        jp      nc,FSCL_INF

        ; Install new biased exponent A into original D/E, preserving sign and
        ; mantissa.  Restore original raw bits first.
        ld      c,a            ; C = new exponent
        pop     hl
        pop     de
        srl     a              ; A = exp >> 1
        ld      b,a
        ld      a,d
        and     80h            ; sign bit
        or      b
        ld      d,a
        ld      a,c
        and     1
        rrca                   ; exp low bit -> bit 7
        ld      b,a
        ld      a,e
        and     7fh            ; preserve mantissa high 7 bits
        or      b
        ld      e,a
        ret

FSCL_ZERO:
        pop     hl
        pop     de
        ld      a,d
        and     80h
        ld      d,a
        ld      e,0
        ld      h,0
        ld      l,0
        ret

FSCL_INF:
        pop     hl
        pop     de
        ld      a,d
        and     80h
        or      7fh
        ld      d,a
        ld      e,80h
        ld      h,0
        ld      l,0
FSCL_RET:
        ret


        public  __fulf
__fulf:
        ld      a,d
        or      e
        or      h
        or      l
        jp      nz,FUL1
        ld      de,0
        ret
FUL1:
        ld      b,158          ; exponent for bit 31
FUL2:
        bit     7,d
        jp      nz,FUL3
        add     hl,hl
        rl      e
        rl      d
        dec     b
        jp      FUL2
FUL3:
        ld      a,e
        ld      (FULM),a       ; mantissa bits 23..16
        ld      a,h
        ld      (FULL),a       ; mantissa bits 15..8
        ld      c,d            ; normalized top byte, bit 7 hidden
        ld      a,b
        ld      d,a
        srl     d              ; D = exponent >> 1, sign clear
        and     1
        rrca
        and     80h
        ld      e,a
        ld      a,c
        and     7fh            ; mantissa bits 22..16
        or      e
        ld      e,a
        ld      a,(FULM)
        ld      h,a
        ld      a,(FULL)
        ld      l,a
        ret
FULM:   db      0
FULL:   db      0

        public  __flf
__flf:
        bit     7,d
        jp      nz,FLFN
        jp      __fulf
FLFN:
        ld      a,l
        cpl
        ld      l,a
        ld      a,h
        cpl
        ld      h,a
        ld      a,e
        cpl
        ld      e,a
        ld      a,d
        cpl
        ld      d,a
        inc     l
        jp      nz,FLF1
        inc     h
        jp      nz,FLF1
        inc     e
        jp      nz,FLF1
        inc     d
FLF1:
        call    __fulf
        ld      a,d
        or      80h
        ld      d,a
        ret

        public  __fful
__fful:
        ld      a,d
        and     7fh
        add     a,a
        ld      b,a
        ld      a,e
        rlca
        and     1
        or      b              ; A = biased exponent
        cp      127
        jp      nc,FFUL1
        ld      de,0
        ld      hl,0
        ret
FFUL1:
        cp      159
        jp      c,FFUL2
        ld      de,0ffffh
        ld      hl,0ffffh
        ret
FFUL2:
        ld      c,a            ; C = exponent
        ld      a,e
        and     7fh
        or      80h
        ld      e,a            ; DEHL = 00:mantissa24
        ld      d,0
        ; H and L are already mantissa low bytes from input float.
        ld      a,c
        cp      150
        jp      z,FFULD
        jp      c,FFURS
        sub     150
        ld      b,a
FFULS:
        add     hl,hl
        rl      e
        rl      d
        dec     b
        jp      nz,FFULS
        jp      FFULD
FFURS:
        ld      a,150
        sub     c
        ld      b,a
FFUR1:
        srl     d
        rr      e
        rr      h
        rr      l
        dec     b
        jp      nz,FFUR1
FFULD:
        ret

        public  __ffl
__ffl:
        ld      a,d
        and     80h
        push    af
        res     7,d
        call    __fful
        pop     af
        or      a
        ret     z
        ld      a,l
        cpl
        ld      l,a
        ld      a,h
        cpl
        ld      h,a
        ld      a,e
        cpl
        ld      e,a
        ld      a,d
        cpl
        ld      d,a
        inc     l
        ret     nz
        inc     h
        ret     nz
        inc     e
        ret     nz
        inc     d
        ret


; ---------------------------------------------------------------------------
; nextafter / nextafterf -- single-precision implementation for dcc.
;
; dcc currently has only 32-bit float arithmetic, so both nextafter and
; nextafterf use float ABI: nextafter(float x, float y) returns the adjacent
; IEEE-754 single value after x in the direction of y.
;
; Args: x at IX+4..IX+7, y at IX+8..IX+11. Return DE:HL.
; ---------------------------------------------------------------------------

        public  _nextafterf
_nextafterf:
        push    ix
        ld      ix,0
        add     ix,sp

        ; Fast path for nextafterf(x, FLT_MAX).  eps() uses exactly this form:
        ;     nextafterf(f, FLT_MAX) - f
        ; For finite/non-NaN x, moving toward +FLT_MAX is just an IEEE raw
        ; bit step: positive values increment, negative values decrement,
        ; zero returns the smallest positive subnormal.  Fall back to the
        ; general path for every other 'toward' value.
        ld      l,(ix+8)
        ld      h,(ix+9)
        ld      e,(ix+10)
        ld      d,(ix+11)
        ld      a,l
        cp      0ffh
        jp      nz,NXGEN
        ld      a,h
        cp      0ffh
        jp      nz,NXGEN
        ld      a,e
        cp      07fh
        jp      nz,NXGEN
        ld      a,d
        cp      07fh
        jp      nz,NXGEN

        ; x is NaN => return x
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      e,(ix+6)
        ld      d,(ix+7)
        call    __fnan
        ld      a,h
        or      l
        jp      nz,NXRET_X

        ; x == FLT_MAX => return y/x unchanged
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      e,(ix+6)
        ld      d,(ix+7)
        ld      a,l
        cp      0ffh
        jp      nz,NXFMAX_NE
        ld      a,h
        cp      0ffh
        jp      nz,NXFMAX_NE
        ld      a,e
        cp      07fh
        jp      nz,NXFMAX_NE
        ld      a,d
        cp      07fh
        jp      z,NXRET
NXFMAX_NE:

        ; x == +/-0 => smallest positive subnormal
        ld      a,d
        and     7fh
        or      e
        or      h
        or      l
        jp      nz,NXFMAX_NZ
        ld      hl,1
        ld      de,0
        jp      NXRET
NXFMAX_NZ:
        ; For negative x, move toward +FLT_MAX by decrementing raw bits.
        bit     7,d
        jp      nz,NXDEC
        jp      NXINC

NXGEN:
        ; if x is NaN, return x
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      e,(ix+6)
        ld      d,(ix+7)
        call    __fnan
        ld      a,h
        or      l
        jp      nz,NXRET_X

        ; if y is NaN, return y
        ld      l,(ix+8)
        ld      h,(ix+9)
        ld      e,(ix+10)
        ld      d,(ix+11)
        call    __fnan
        ld      a,h
        or      l
        jp      nz,NXRET_Y

        ; if x == y, return y
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      e,(ix+6)
        ld      d,(ix+7)
        push    de
        push    hl
        ld      l,(ix+8)
        ld      h,(ix+9)
        ld      e,(ix+10)
        ld      d,(ix+11)
        push    de
        push    hl
        call    __feq
        pop     bc
        pop     bc
        pop     bc
        pop     bc
        ld      a,h
        or      l
        jp      nz,NXRET_Y

        ; if x == 0, return the smallest subnormal with y's sign
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      e,(ix+6)
        ld      d,(ix+7)
        call    __fzro
        ld      a,h
        or      l
        jp      nz,NXZERO

        ; lt = x < y
        ; __flt follows the normal dcc call ABI: the first argument must be
        ; the last value pushed, so push y first, then x.
        ld      l,(ix+8)
        ld      h,(ix+9)
        ld      e,(ix+10)
        ld      d,(ix+11)
        push    de
        push    hl
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      e,(ix+6)
        ld      d,(ix+7)
        push    de
        push    hl
        call    __flt
        pop     bc
        pop     bc
        pop     bc
        pop     bc
        ld      a,h
        or      l
        ld      (NXLT),a

        ; Load raw x.
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      e,(ix+6)
        ld      d,(ix+7)

        ; For positive x, x<y means increment raw bits; otherwise decrement.
        ; For negative x, x<y means decrement raw bits; otherwise increment.
        ld      a,d
        and     80h
        jp      nz,NXNEG
NXPOS:
        ld      a,(NXLT)
        or      a
        jp      nz,NXINC
        jp      NXDEC
NXNEG:
        ld      a,(NXLT)
        or      a
        jp      nz,NXDEC
        jp      NXINC

NXZERO:
        ld      hl,1
        ld      de,0
        ld      a,(ix+11)
        and     80h
        jp      z,NXRET
        ld      d,80h
        jp      NXRET

NXRET_X:
        ld      l,(ix+4)
        ld      h,(ix+5)
        ld      e,(ix+6)
        ld      d,(ix+7)
        jp      NXRET
NXRET_Y:
        ld      l,(ix+8)
        ld      h,(ix+9)
        ld      e,(ix+10)
        ld      d,(ix+11)
        jp      NXRET

NXINC:
        inc     l
        jp      nz,NXRET
        inc     h
        jp      nz,NXRET
        inc     e
        jp      nz,NXRET
        inc     d
        jp      NXRET

NXDEC:
        ld      a,l
        or      a
        jp      nz,NXDL
        ld      l,0ffh
        ld      a,h
        or      a
        jp      nz,NXDH
        ld      h,0ffh
        ld      a,e
        or      a
        jp      nz,NXDE
        ld      e,0ffh
        dec     d
        jp      NXRET
NXDE:
        dec     e
        jp      NXRET
NXDH:
        dec     h
        jp      NXRET
NXDL:
        dec     l

NXRET:
        ld      sp,ix
        pop     ix
        ret

NXLT:   db      0

        end     start
